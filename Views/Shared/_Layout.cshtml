<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR University - @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Kantumruy+Pro:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --sidebar-width: 260px;
            --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
            --accent-color: #5e5ce6;
            /* Light Mode Colors */
            --body-bg: #f4f7fe;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --text-main: #333333;
            --text-muted: #6c757d;
            --border-color: rgba(0,0,0,0.05);
            --nav-hover: #f0f3ff;
        }

        /* Dark Mode Colors Definitions */
        [data-bs-theme="dark"] {
            --body-bg: #0b0e14;
            --sidebar-bg: #151921;
            --card-bg: #151921;
            --text-main: #e1e1e1;
            --text-muted: #a0aec0;
            --border-color: rgba(255,255,255,0.1);
            --nav-hover: #1c222d;
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Inter', 'Kantumruy Pro', sans-serif;
            margin: 0;
            overflow-x: hidden;
            color: var(--text-main);
            transition: background-color 0.3s ease;
        }

        /* --- Sidebar Style --- */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .sidebar-header {
            padding: 20px 15px;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
        }

            .sidebar-header img {
                width: 50px;
                height: auto;
                margin-bottom: 8px;
            }

            .sidebar-header h5 {
                font-size: 15px;
                color: #0d6efd;
                font-weight: 800;
                margin: 0;
                letter-spacing: 0.5px;
            }

        .sidebar-scroll-area {
            flex: 1;
            overflow-y: auto;
            padding-top: 10px;
            scrollbar-width: thin;
        }

        .sidebar .nav-link {
            color: var(--text-muted);
            padding: 10px 20px;
            border-radius: 12px;
            margin: 4px 15px;
            transition: all 0.25s ease;
            text-decoration: none;
            display: flex;
            align-items: center;
            font-size: 13.5px;
            font-weight: 500;
            position: relative;
        }

            .sidebar .nav-link:hover {
                background-color: var(--nav-hover);
                color: var(--accent-color);
                transform: translateX(5px);
            }

            .sidebar .nav-link.active {
                background-color: var(--nav-hover);
                color: var(--accent-color);
                font-weight: 700;
            }

        .arrow-icon {
            margin-left: auto;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 0.8rem;
            display: inline-block;
        }

        .nav-link:not(.collapsed) .arrow-icon {
            transform: rotate(90deg);
            color: var(--accent-color);
        }

        .submenu {
            list-style: none;
            padding-left: 0;
            margin: 5px 15px 10px 40px;
            border-left: 1px dashed var(--border-color);
        }

            .submenu .nav-link {
                padding: 7px 15px;
                font-size: 12.5px;
                margin: 2px 0;
            }

        /* --- Main Wrapper & Navbar --- */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .top-navbar {
            height: 70px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 40px;
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1010;
            gap: 15px;
        }

        /* Dark Mode Toggle Style */
        .dark-mode-toggle {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: white;
            backdrop-filter: blur(10px);
            transition: 0.3s;
        }

            .dark-mode-toggle:hover {
                background: rgba(255, 255, 255, 0.25);
            }

        .search-box {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 14px;
            padding: 8px 18px;
            display: flex;
            align-items: center;
            width: 280px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s;
        }

            .search-box:focus-within {
                background: rgba(255, 255, 255, 0.25);
                width: 320px;
            }

            .search-box input {
                background: transparent;
                border: none;
                color: white;
                margin-left: 10px;
                outline: none;
                width: 100%;
                font-size: 13.5px;
            }

                .search-box input::placeholder {
                    color: rgba(255, 255, 255, 0.8);
                }

        .header-gradient {
            background: var(--primary-gradient);
            height: 220px;
            padding: 85px 40px 0;
            color: white;
            width: 100%;
        }

        .content-body {
            margin-top: -70px;
            padding: 0 40px 40px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        #display-area {
            background: var(--card-bg);
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.06);
            padding: 35px;
            min-height: calc(100vh - 260px);
            width: 100%;
            transition: background 0.3s ease;
        }

        .login-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
            text-decoration: none;
        }

            .login-profile img {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                border: 2px solid rgba(255,255,255,0.6);
                object-fit: cover;
                box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            }

        /* Modal Dark Theme Support */
        [data-bs-theme="dark"] .modal-content {
            background-color: var(--sidebar-bg);
            color: var(--text-main);
            border: 1px solid var(--border-color);
        }

        [data-bs-theme="dark"] .dropdown-menu {
            background-color: var(--sidebar-bg);
            border: 1px solid var(--border-color);
        }

        [data-bs-theme="dark"] .dropdown-item {
            color: var(--text-main);
        }

            [data-bs-theme="dark"] .dropdown-item:hover {
                background-color: var(--nav-hover);
            }
    </style>
</head>
<body data-bs-theme="light">

    <div class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo.png" alt="Logo" />
            <h5>HRU UNIVERSITY</h5>
        </div>

        <div class="sidebar-scroll-area">
            <nav class="nav flex-column mt-2">
                <a class="nav-link ajax-link active" data-url="/Home/Index">
                    <i class="bi bi-house-door-fill me-3"></i> HOME
                </a>
            </nav>

            <nav class="nav flex-column">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#securityMenu">
                    <i class="bi bi-shield-lock-fill me-3"></i> User Management
                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>
                <div class="collapse" id="securityMenu">
                    <ul class="submenu nav flex-column">
                        <li>
                            <a class="nav-link ajax-link" data-url="/User/Create">1.1. Create User</a>
                        </li>
                        <li>
                        <a class="nav-link ajax-link" data-url="/User/Roles">1.2. Role & Right</a>
                        <li>
                        <a class="nav-link ajax-link" data-url="/User/Index">1.3. User List</a>
                        </li>
                        <li>
                        <a class="nav-link ajax-link" data-url="/User/ResetPassword">1.4. Reset Password</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <nav class="nav flex-column">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#studentMenu">
                    <i class="bi bi-people-fill me-3"></i> Students
                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>
                <div class="collapse" id="studentMenu">
                    <ul class="submenu nav flex-column">
                        <li>
                        <a class="nav-link ajax-link" data-url="/Student/Create">Create Student</a>
                        </li>
                        <li>
                        <a class="nav-link ajax-link" data-url="/Student/StudentCenter">Student Center</a>
                        </li>
                        <li>
                        <a class="nav-link ajax-link" data-url="/Student/Payment">Payment</a>
                        </li>
                        <li>
                        <a class="nav-link ajax-link" data-url="/Student/Reports">Reports</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <nav class="nav flex-column">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#attendantMenu" role="button" aria-expanded="false">
                    <i class="bi bi-calendar2-check-fill me-3"></i> Attendance
                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>
                <div class="collapse" id="attendantMenu">
                    <ul class="submenu nav flex-column">
                        <li>
                        <a class="nav-link ajax-link" data-url="/Student/CheckAttendance">3.1. Check Attendance</a>
                        </li>
                        <li>
                        <a class="nav-link ajax-link" data-url="/Student/AttendanceList">3.2. Attendance List</a>
                        </li>
                    </ul>
                </div>
            </nav>

            <nav class="nav flex-column">
                <a class="nav-link ajax-link" data-url="/SystemSettings/Index"><i class="bi bi-gear-fill me-3"></i> System Settings</a>
                <a class="nav-link ajax-link" data-url="/SystemSettings/ActivityLogs"><i class="bi bi-file-earmark-text-fill me-3"></i> Activity Logs</a>
            </nav>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="top-navbar">
            <div class="search-box">
                <i class="bi bi-search text-white"></i>
                <input type="text" placeholder="ស្វែងរកអ្វីមួយនៅទីនេះ..." />
            </div>

            <div class="dark-mode-toggle" id="btnThemeToggle" title="Toggle Dark/Light Mode">
                <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
            </div>

            <div class="dropdown">
                <a href="#" class="login-profile dropdown-toggle" data-bs-toggle="dropdown">
                    <img id="navbarProfileImg" src="" alt="User">
                    <span class="fw-bold" id="navUsername" style="font-size: 14px;">Account</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-3 p-2">
                    <li><a class="dropdown-item py-2 rounded-3" href="#" data-bs-toggle="modal" data-bs-target="#profileModal"><i class="bi bi-camera me-2"></i> Change Photo</a></li>
                    <li><a class="dropdown-item py-2 rounded-3" href="#" data-bs-toggle="modal" data-bs-target="#myProfileModal"><i class="bi bi-person me-2"></i> My Profile</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item py-2 rounded-3 text-danger" href="javascript:void(0)" id="btnLogout"><i class="bi bi-power me-2"></i> Logout</a></li>
                </ul>
            </div>
        </div>

        <div class="header-gradient">
            <h2 class="fw-bold m-0" id="page-title">Home Overview</h2>
            <p class="opacity-75 small">Welcome to HR University Management System</p>
        </div>

        <div class="content-body">
            <div id="display-area">
                @RenderBody()
            </div>
        </div>
    </div>

    <div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">Update Profile Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <img id="previewImg" src="" class="rounded-circle mb-3 border" style="width: 130px; height: 130px; object-fit: cover;">
                    <input type="file" id="uploadInput" class="form-control" accept="image/*">
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="button" id="btnSavePhoto" class="btn btn-primary px-4 rounded-3">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="myProfileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom px-4 pt-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-circle me-2"></i> Profile Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="text-center mb-4">
                        <img id="profileInfoImg" src="" class="rounded-circle border" style="width: 100px; height: 100px; object-fit: cover;">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted fw-bold">Full Name</label>
                        <input type="text" id="inputFullName" class="form-control rounded-3">
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="btnSaveProfileInfo" class="btn btn-primary px-4 rounded-3">Update Profile</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // --- Theme Management ---
            function initTheme() {
                const savedTheme = localStorage.getItem('theme') || 'light';
                applyTheme(savedTheme);
            }

            function applyTheme(theme) {
                $('body').attr('data-bs-theme', theme);
                localStorage.setItem('theme', theme);
                if (theme === 'dark') {
                    $('#themeIcon').removeClass('bi-moon-stars-fill').addClass('bi-sun-fill');
                } else {
                    $('#themeIcon').removeClass('bi-sun-fill').addClass('bi-moon-stars-fill');
                }
            }

            $('#btnThemeToggle').click(function() {
                const currentTheme = $('body').attr('data-bs-theme');
                applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
            });

            initTheme();

            // --- User Data Management ---
            function loadUserData() {
                const savedName = localStorage.getItem('userFullName') || 'Admin User';
                const savedPhoto = localStorage.getItem('userProfilePic');
                $('#navUsername, #welcomeName').text(savedName);
                $('#inputFullName').val(savedName);
                const avatar = savedPhoto || `https://ui-avatars.com/api/?name=${encodeURIComponent(savedName)}&background=random&color=fff`;
                $('#navbarProfileImg, #previewImg, #profileInfoImg').attr('src', avatar);
            }
            loadUserData();

            // --- Ajax Navigation ---
            $(document).on("click", ".ajax-link", function (e) {
                e.preventDefault();
                var url = $(this).attr("data-url");
                var title = $(this).text().trim();

                $(".ajax-link").removeClass("active");
                $(this).addClass("active");
                $("#page-title").text(title);

                $("#display-area").html('<div class="text-center p-5"><div class="spinner-grow text-primary"></div><p class="mt-2 text-muted">ទាញយកទិន្នន័យ...</p></div>');

                $.ajax({
                    url: url,
                    type: 'GET',
                    cache: false,
                    success: function (res) {
                        $("#display-area").html(res).hide().fadeIn(400);
                        window.history.pushState(null, '', url);
                    },
                    error: function() {
                        $("#display-area").html('<div class="alert alert-danger rounded-4">Error: មិនអាចទាញយកទិន្នន័យបានទេ។</div>');
                    }
                });
            });

            // --- Profile Logic ---
            $('#btnSaveProfileInfo').click(function() {
                const newName = $('#inputFullName').val();
                if(newName.trim() !== "") {
                    localStorage.setItem('userFullName', newName);
                    loadUserData();
                    $('#myProfileModal').modal('hide');
                    Swal.fire({ icon: 'success', title: 'ជោគជ័យ', text: 'ព័ត៌មានត្រូវបានកែប្រែ', confirmButtonColor: '#5e5ce6' });
                }
            });

            $(document).on('change', '#uploadInput', function() {
                var file = this.files[0];
                if (file) {
                    var reader = new FileReader();
                    reader.onload = function(e) { $('#previewImg').attr('src', e.target.result); }
                    reader.readAsDataURL(file);
                }
            });

            $('#btnSavePhoto').click(function() {
                var newImg = $('#previewImg').attr('src');
                localStorage.setItem('userProfilePic', newImg);
                loadUserData();
                bootstrap.Modal.getInstance(document.getElementById('profileModal')).hide();
                Swal.fire({ icon: 'success', title: 'ជោគជ័យ', text: 'រូបភាពត្រូវបានផ្លាស់ប្ដូរ', confirmButtonColor: '#5e5ce6' });
            });

            $('#btnLogout').click(function() {
                Swal.fire({
                    title: 'ចាកចេញ?',
                    text: "តើបងពិតជាចង់ចាកចេញមែនទេ?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#5e5ce6',
                    confirmButtonText: 'បាទ/ចាស',
                    cancelButtonText: 'ទេ'
                }).then((result) => {
                    if (result.isConfirmed) window.location.href = '/Account/Login';
                });
            });
        });
    </script>
</body>
</html>