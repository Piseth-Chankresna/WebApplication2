
@using System.Security.Claims

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>HR University - @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Kantumruy+Pro:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --sidebar-width: 260px;
            --primary: #6b7280;
            --primary-dark: #4a5568;
            --primary-light: #9ca3af;
            --primary-gradient: linear-gradient(135deg, #6b7280 0%, #9ca3af 50%, #6b7280 100%);
            --primary-gradient-subtle: linear-gradient(135deg, rgba(107,114,128,0.1) 0%, rgba(156,163,175,0.06) 100%);
            --accent-color: #9ca3af;
            --accent-hover: #6b7280;
            --body-bg: #f5f5f4;
            --sidebar-bg: #ffffff;
            --card-bg: #ffffff;
            --text-main: #374151;
            --text-secondary: #6b7280;
            --text-muted: #9ca3af;
            --border-color: #e5e7eb;
            --nav-hover: rgba(107,114,128,0.08);
            --input-bg: #ffffff;
            --input-border: #d1d5db;
            --input-text: #374151;
            --btn-primary-text: #ffffff;
            --btn-secondary-bg: #f8fafc;
            --btn-secondary-text: #6b7280;
            --table-header-bg: #f8fafc;
            --table-row-hover: #f1f5f9;
            --card-shadow: 0 1px 3px rgba(0,0,0,0.05);
            --card-shadow-lg: 0 10px 25px -5px rgba(0,0,0,0.07);
        }

        [data-bs-theme="dark"] {
            --primary: #818cf8;
            --primary-dark: #6366f1;
            --primary-light: #a5b4fc;
            --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #6366f1 50%, #818cf8 100%);
            --primary-gradient-subtle: linear-gradient(135deg, rgba(99,102,241,0.2) 0%, rgba(129,140,248,0.1) 100%);
            --accent-color: #a5b4fc;
            --accent-hover: #818cf8;
            --body-bg: #0c1222;
            --sidebar-bg: #1a2234;
            --card-bg: #1e293b;
            --text-main: #f8fafc;
            --text-secondary: #e2e8f0;
            --text-muted: #94a3b8;
            --border-color: #334155;
            --nav-hover: rgba(129,140,248,0.15);
            --input-bg: #0f172a;
            --input-border: #475569;
            --input-text: #f8fafc;
            --btn-primary-text: #ffffff;
            --btn-secondary-bg: #334155;
            --btn-secondary-text: #e2e8f0;
            --table-header-bg: #0f172a;
            --table-row-hover: #334155;
            --card-shadow: 0 1px 3px rgba(0,0,0,0.3);
            --card-shadow-lg: 0 10px 25px -5px rgba(0,0,0,0.4);
        }

        body {
            background-color: var(--body-bg);
            font-family: 'Inter', 'Kantumruy Pro', sans-serif;
            margin: 0;
            overflow-x: hidden;
            color: var(--text-main);
            transition: background-color 0.25s ease, color 0.25s ease;
        }

        #display-area,
        .sidebar,
        .card {
            transition: background-color 0.25s ease, border-color 0.25s ease, color 0.2s ease;
        }

        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-color);
            z-index: 1050;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s ease;
        }

        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.4);
            z-index: 1040;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .sidebar-overlay.show {
            opacity: 1;
        }

        .sidebar-toggle {
            display: none;
            position: fixed;
            top: 18px;
            left: 20px;
            z-index: 1060;
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(255,255,255,0.2);
            border: 1px solid rgba(255,255,255,0.3);
            color: white;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            backdrop-filter: blur(10px);
            transition: 0.3s;
        }

        .sidebar-toggle:hover {
            background: rgba(255,255,255,0.3);
        }

        @@media (max-width: 991.98px) {
            .sidebar {
                transform: translateX(-100%);
                box-shadow: none;
            }

            .sidebar.show {
                transform: translateX(0);
                box-shadow: 8px 0 24px rgba(0,0,0,0.15);
            }

            .sidebar-overlay {
                display: block;
            }

            .sidebar-overlay.show {
                display: block;
            }

            .sidebar-toggle {
                display: flex;
            }

            .main-wrapper {
                margin-left: 0;
            }

            .top-navbar {
                padding-left: 70px;
                padding-right: 16px;
                flex-wrap: nowrap;
                gap: 8px;
            }

            .top-navbar .navbar-left {
                flex: 0 1 auto;
            }

            .page-title-inline {
                font-size: 1rem !important;
                max-width: 120px;
            }

            .search-box {
                width: 140px;
                flex-shrink: 0;
            }

            .search-box:focus-within {
                width: 180px;
            }

            .content-body {
                padding: 0 16px 24px;
            }

            #display-area {
                padding: 20px;
                min-height: calc(100vh - 160px);
                border-radius: 16px;
            }

            .login-profile span {
                max-width: 100px;
                overflow: hidden;
                text-overflow: ellipsis;
            }
        }

        @@media (max-width: 575.98px) {
            .sidebar {
                width: 100%;
                max-width: 280px;
            }

            .top-navbar {
                padding-left: 60px;
            }

            .page-title-inline {
                font-size: 1rem !important;
            }
        }

        .sidebar-header {
            padding: 20px 15px;
            text-align: center;
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-header-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-decoration: none;
            color: inherit;
            padding: 8px;
            margin: -8px;
            border-radius: 14px;
            transition: all 0.25s ease;
        }

        .sidebar-header-link:hover {
            background: var(--primary-gradient-subtle);
            transform: scale(1.02);
        }

        .sidebar-header-link:active {
            transform: scale(0.98);
        }

        .sidebar-header-link img {
            width: 52px;
            height: 52px;
            object-fit: contain;
            margin-bottom: 10px;
            transition: transform 0.25s ease;
        }

        .sidebar-header-link:hover img {
            transform: scale(1.05);
        }

        .sidebar-header-link h5 {
            font-size: 14px;
            font-weight: 800;
            margin: 0;
            letter-spacing: 0.8px;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        [data-bs-theme="dark"] .sidebar-header-link h5 {
            background: linear-gradient(135deg, #a5b4fc 0%, #818cf8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .sidebar-header-link .home-hint {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 4px;
            font-weight: 500;
        }

        .sidebar-scroll-area {
            flex: 1;
            overflow-y: auto;
            padding-top: 10px;
            scrollbar-width: thin;
        }

            .sidebar-scroll-area::-webkit-scrollbar {
                width: 4px;
            }

            .sidebar-scroll-area::-webkit-scrollbar-thumb {
                background: var(--border-color);
                border-radius: 4px;
            }

        .sidebar .nav-link {
            color: var(--text-muted);
            padding: 10px 20px;
            border-radius: 12px;
            margin: 4px 15px;
            transition: all 0.25s ease;
            text-decoration: none;
            display: flex;
            align-items: center;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            position: relative;
        }

            .sidebar .nav-link:hover {
                background-color: var(--nav-hover);
                color: var(--accent-color);
                transform: translateX(4px);
            }

            .sidebar .nav-link.active {
                background: var(--primary-gradient-subtle);
                color: var(--accent-color);
                font-weight: 700;
                border-left: 3px solid var(--accent-color);
            }

        .arrow-icon {
            margin-left: auto;
            transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            font-size: 0.8rem;
            display: inline-block;
        }

        .nav-link:not(.collapsed) .arrow-icon {
            transform: rotate(90deg);
            color: var(--accent-color);
        }

        .submenu {
            list-style: none;
            padding-left: 0;
            margin: 5px 15px 10px 40px;
            border-left: 1px dashed var(--border-color);
        }

            .submenu .nav-link {
                padding: 7px 15px;
                font-size: 12.5px;
                margin: 2px 0;
            }

        .main-wrapper {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .top-navbar {
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 24px 0 28px;
            background: var(--primary-gradient);
            gap: 16px;
        }

        .top-navbar .navbar-left {
            display: flex;
            align-items: center;
            flex: 1;
            min-width: 0;
        }

        .top-navbar .navbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .dark-mode-toggle {
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.2);
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: white;
            backdrop-filter: blur(10px);
            transition: 0.3s;
        }

            .dark-mode-toggle:hover {
                background: rgba(255, 255, 255, 0.25);
            }

        .search-box {
            background: rgba(255, 255, 255, 0.15);
            border-radius: 14px;
            padding: 8px 18px;
            display: flex;
            align-items: center;
            width: 280px;
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            transition: all 0.3s;
        }

            .search-box:focus-within {
                background: rgba(255, 255, 255, 0.25);
                width: 320px;
            }

            .search-box input {
                background: transparent;
                border: none;
                color: white;
                margin-left: 10px;
                outline: none;
                width: 100%;
                font-size: 13.5px;
            }

                .search-box input::placeholder {
                    color: rgba(255, 255, 255, 0.8);
                }

        .page-title-inline {
            font-size: 1.15rem;
            font-weight: 700;
            color: white;
            margin: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            text-shadow: 0 1px 2px rgba(0,0,0,0.15);
        }

        .content-body {
            padding: 24px 40px 40px;
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        #display-area {
            background: var(--card-bg);
            border-radius: 20px;
            box-shadow: var(--card-shadow-lg);
            border: 1px solid var(--border-color);
            padding: 28px;
            min-height: calc(100vh - 180px);
            width: 100%;
            transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        }

        .login-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            color: white;
            text-decoration: none;
            padding: 6px 12px;
            border-radius: 12px;
            transition: background 0.25s ease;
        }

        .login-profile:hover {
            background: rgba(255,255,255,0.15);
        }

            .login-profile img {
                width: 38px;
                height: 38px;
                border-radius: 50%;
                border: 2px solid rgba(255,255,255,0.5);
                object-fit: cover;
                box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            }

        [data-bs-theme="dark"] .modal-content {
            background-color: var(--sidebar-bg);
            color: var(--text-main);
            border: 1px solid var(--border-color);
        }

        [data-bs-theme="dark"] .dropdown-menu {
            background-color: var(--sidebar-bg);
            border: 1px solid var(--border-color);
        }

        [data-bs-theme="dark"] .dropdown-item {
            color: var(--text-main);
        }

            [data-bs-theme="dark"] .dropdown-item:hover {
                background-color: var(--nav-hover);
            }

        /* Animations */
        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        #display-area {
            animation: fadeIn 0.3s ease;
        }
    </style>
</head>
<body data-bs-theme="light" data-user-name="@(User.Identity?.IsAuthenticated == true ? (User.Identity.Name ?? "") : "")" data-user-photo="@(User.FindFirst("ProfileImage")?.Value ?? "")">
    <!-- Sidebar Overlay (Mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay" aria-hidden="true"></div>

    <!-- Mobile Menu Toggle -->
    <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="បើកម៉ឺនុយ">
        <i class="bi bi-list" style="font-size: 1.4rem;"></i>
    </button>

    <!-- Sidebar -->
    <div class="sidebar" id="mainSidebar">
        <div class="sidebar-header">
            <a href="/Home/Index" class="sidebar-header-link ajax-link" data-url="/Home/Index" data-title="Home Overview" title="ទៅទំព័រដើម">
                <img src="/images/logo.png" alt="HRU Logo" />
                <h5>HRU UNIVERSITY</h5>
            </a>
        </div>

        <div class="sidebar-scroll-area">

            <nav class="nav flex-column">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#studentMenu">
                    <i class="bi bi-people-fill me-3"></i> Students
                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>
                <div class="collapse show" id="studentMenu">
                    <ul class="submenu nav flex-column">
                        <li><a class="nav-link ajax-link" data-url="/Student/Create">&#128221; Add Student</a></li>
                        <li><a class="nav-link ajax-link" data-url="/Student/Index">&#128196; Student List</a></li>
                        <li><a class="nav-link ajax-link" data-url="/Student/Classes">&#127968; Classes</a></li>
                        <li><a class="nav-link ajax-link" data-url="/Student/Grades">&#128202; Grades</a></li>
                    </ul>
                </div>
            </nav>

            <nav class="nav flex-column">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#userMenu">
                    <i class="bi bi-shield-lock-fill me-3"></i> User Management
                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>
                <div class="collapse" id="userMenu">
                    <ul class="submenu nav flex-column">
                        <li><a class="nav-link ajax-link" data-url="/User/Create">1.1. Create User</a></li>
                        <li><a class="nav-link ajax-link" data-url="/User/Roles">1.2. Role & Right</a></li>
                        <li><a class="nav-link ajax-link" data-url="/User/Index">1.3. User List</a></li>
                        <li><a class="nav-link ajax-link" data-url="/User/ResetPassword/1">1.4. Reset Password</a></li>
                    </ul>
                </div>
            </nav>


            <nav class="nav flex-column">
                <a class="nav-link collapsed" data-bs-toggle="collapse" href="#attendantMenu">
                    <i class="bi bi-calendar2-check-fill me-3"></i> Attendance
                    <i class="bi bi-chevron-right arrow-icon"></i>
                </a>
                <div class="collapse" id="attendantMenu">
                    <ul class="submenu nav flex-column">
                        <li><a class="nav-link ajax-link" data-url="/Student/CheckAttendance">3.1. Check Attendance</a></li>
                        <li><a class="nav-link ajax-link" data-url="/Student/AttendanceList">3.2. Attendance List</a></li>
                    </ul>
                </div>
            </nav>

            <nav class="nav flex-column">
                <a class="nav-link ajax-link" data-url="/Student/Payment"><i class="bi bi-credit-card-fill me-3"></i> Payments</a>
                <a class="nav-link ajax-link" data-url="/Student/Scholarship"><i class="bi bi-gift-fill me-3"></i> Scholarships</a>
                <a class="nav-link ajax-link" data-url="/Student/StudentCenter"><i class="bi bi-layout-text-window me-3"></i> Student Center</a>
                <a class="nav-link ajax-link" data-url="/Report/Index"><i class="bi bi-file-earmark-text-fill me-3"></i> Reports</a>
            </nav>

        </div>
    </div>

    <!-- Main Wrapper -->
    <div class="main-wrapper">
        <!-- Top Navbar (single bar: title left, search/theme/profile right) -->
        <div class="top-navbar">
            <div class="navbar-left">
                <h2 class="page-title-inline" id="page-title">Home Overview</h2>
            </div>
            <div class="navbar-right">
            <div class="search-box">
                <i class="bi bi-search text-white"></i>
                <input type="text" placeholder="ស្វែងរក..." />
            </div>

            <div class="dark-mode-toggle" id="btnThemeToggle">
                <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
            </div>

            <div class="dropdown">
                <a href="#" class="login-profile dropdown-toggle" data-bs-toggle="dropdown">
                    <img id="navbarProfileImg" src="@(User.FindFirst("ProfileImage")?.Value ?? $"https://ui-avatars.com/api/?name={User.Identity?.Name ?? "User"}&background=random")" alt="User">
                    <span class="fw-bold" id="navUsername" 
                      data-id="@(User.FindFirst("UserId")?.Value ?? "1")" 
                      data-email="@(User.FindFirst(ClaimTypes.Email)?.Value ?? "user@example.com")">@(User.Identity?.Name ?? "User")</span>
                </a>
                <!-- រកមើលប៊ូតុង Logout នៅក្នុង Dropdown Menu -->
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-4 mt-3 p-2">
                    <li><a class="dropdown-item py-2 rounded-3 ajax-link" href="/Home/Index" data-url="/Home/Index" data-title="Home Overview"><i class="bi bi-house-door me-2"></i>ទំព័រដើម</a></li>
                    <li><a class="dropdown-item py-2 rounded-3" href="#" id="changePhotoBtn"><i class="bi bi-camera me-2"></i> Change Photo</a></li>
                    <li><a class="dropdown-item py-2 rounded-3" href="#" id="myProfileBtn"><i class="bi bi-person me-2"></i> My Profile</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <!-- កែប្រែប៊ូតុង Logout នេះ -->
                    <li>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item py-2 rounded-3 text-danger" style="border: none; background: none; width: 100%; text-align: left;">
                                <i class="bi bi-power me-2"></i> Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
            </div>
        </div>

        <!-- Content Body -->
        <div class="content-body">
            <div id="display-area">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Modals -->
    <div class="modal fade" id="profileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold">Update Profile Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-4">
                    <img id="previewImg" src="" class="rounded-circle mb-3 border" style="width: 130px; height: 130px; object-fit: cover;" alt="Profile Preview">
                    <label for="uploadInput" class="form-label">Choose Profile Picture</label>
                    <input type="file" id="uploadInput" name="profilePicture" class="form-control" accept="image/*">
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Close</button>
                    <button type="button" id="btnSavePhoto" class="btn btn-primary px-4 rounded-3">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="myProfileModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom px-4 pt-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-circle me-2"></i> Profile Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="text-center mb-4">
                        <img id="profileInfoImg" src="" class="rounded-circle border" style="width: 100px; height: 100px; object-fit: cover;">
                    </div>
                    <div class="mb-3">
                        <label for="inputFullName" class="form-label small text-muted fw-bold">Full Name</label>
                        <input type="text" id="inputFullName" name="fullName" class="form-control rounded-3">
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" id="btnSaveProfileInfo" class="btn btn-primary px-4 rounded-3">Update Profile</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            // Theme Management
            function initTheme() {
                const savedTheme = localStorage.getItem('theme') || 'light';
                applyTheme(savedTheme);
            }

            function applyTheme(theme) {
                $('body').attr('data-bs-theme', theme);
                localStorage.setItem('theme', theme);
                if (theme === 'dark') {
                    $('#themeIcon').removeClass('bi-moon-stars-fill').addClass('bi-sun-fill');
                } else {
                    $('#themeIcon').removeClass('bi-sun-fill').addClass('bi-moon-stars-fill');
                }
            }

            $('#btnThemeToggle').click(function() {
                const currentTheme = $('body').attr('data-bs-theme');
                applyTheme(currentTheme === 'dark' ? 'light' : 'dark');
            });

            initTheme();

            // Mobile Sidebar Toggle
            function toggleSidebar() {
                $('#mainSidebar').toggleClass('show');
                $('#sidebarOverlay').toggleClass('show');
                $('body').toggleClass('sidebar-open');
                document.body.style.overflow = $('#mainSidebar').hasClass('show') ? 'hidden' : '';
            }

            $('#sidebarToggle').on('click', toggleSidebar);
            $('#sidebarOverlay').on('click', function() {
                if ($('#mainSidebar').hasClass('show')) toggleSidebar();
            });

            // Close sidebar when clicking a nav link on mobile
            $(document).on('click', '.sidebar .ajax-link', function() {
                if (window.innerWidth < 992 && $('#mainSidebar').hasClass('show')) {
                    toggleSidebar();
                }
            });

            // User Data Management
            let profileLoaded = false; // Prevent multiple loads
            function loadUserData() {
                if (profileLoaded) return; // Prevent multiple calls
                
                const currentName = $('#navUsername').text().trim();
                const currentPhoto = $('#navbarProfileImg').attr('src') || '';
                
                $('#navUsername, #welcomeName').text(currentName);
                $('#inputFullName').val(currentName);
                
                const defaultAvatar = `https://ui-avatars.com/api/?name=${encodeURIComponent(currentName)}&background=4361ee&color=fff&size=150`;
                const finalPhoto = (currentPhoto && !currentPhoto.includes('ui-avatars.com')) ? currentPhoto : defaultAvatar;
                
                $('#navbarProfileImg, #previewImg, #profileInfoImg').attr('src', finalPhoto);
                
                profileLoaded = true; // Mark as loaded
                console.log('Profile loaded:', { name: currentName, photo: finalPhoto });
            }
            loadUserData();

            // Profile button click handlers
            $('#changePhotoBtn').click(function(e) {
                e.preventDefault();
                profileLoaded = false; // Allow refresh
                loadUserData(); // Refresh current data
                // Clear file input
                $('#uploadInput').val('');
                // Set preview image to current profile
                const currentPhoto = $('#navbarProfileImg').attr('src') || '';
                $('#previewImg').attr('src', currentPhoto);
                // Open modal
                $('#profileModal').modal('show');
            });

            $('#myProfileBtn').click(function(e) {
                e.preventDefault();
                profileLoaded = false; // Allow refresh
                loadUserData(); // Refresh current data
                // Open modal
                $('#myProfileModal').modal('show');
            });

            // Functions to open modals with current user data
            function openProfileModal() {
                loadUserData(); // Refresh current data
                // Clear file input
                $('#uploadInput').val('');
                // Set preview image to current profile
                const currentPhoto = $('#navbarProfileImg').attr('src') || '';
                $('#previewImg').attr('src', currentPhoto);
            }

            function openMyProfileModal() {
                loadUserData(); // Refresh current data
            }

            // Load initial page based on current URL
            function loadInitialPage() {
                var path = window.location.pathname;
                var menuItem = $('.ajax-link[data-url="' + path + '"]');

                if (path !== '/' && path !== '/Home/Index' && menuItem.length > 0) {
                    var title = menuItem.text().trim();
                    menuItem.addClass('active');
                    $("#page-title").text(title);

                    $.ajax({
                        url: path,
                        type: 'GET',
                        cache: false,
                        headers: {
                            'Cache-Control': 'no-cache'
                        },
                        success: function (res) {
                            $("#display-area").html(res);
                        },
                        error: function() {
                            window.location.href = path; // Fallback to normal navigation
                        }
                    });
                }
            }

            loadInitialPage();

            // AJAX Navigation
            $(document).on("click", ".ajax-link", function (e) {
                e.preventDefault();
                var $link = $(this);
                var url = $link.attr("data-url");
                var title = $link.attr("data-title") || $link.text().trim();
                var ddToggle = $link.closest('.dropdown').find('[data-bs-toggle="dropdown"]')[0];
                if (ddToggle) try { bootstrap.Dropdown.getInstance(ddToggle)?.hide(); } catch (_) {}

                // Update browser history
                window.history.pushState({ url: url, title: title }, '', url);

                $(".ajax-link").removeClass("active");
                $(this).addClass("active");
                $("#page-title").text(title);

                $("#display-area").html(`
                    <div class="text-center p-5">
                        <div class="spinner-grow text-primary" role="status"></div>
                        <p class="mt-2 text-muted">កំពុងទាញយកទិន្នន័យ...</p>
                    </div>
                `);

                // Add timestamp to prevent caching
                var timestamp = new Date().getTime();
                if (url.indexOf('?') === -1) {
                    url = url + '?_=' + timestamp;
                } else {
                    url = url + '&_=' + timestamp;
                }

                $.ajax({
                    url: url,
                    type: 'GET',
                    cache: false,
                    headers: {
                        'Cache-Control': 'no-cache, no-store, must-revalidate',
                        'Pragma': 'no-cache',
                        'Expires': '0'
                    },
                    success: function (res) {
                        $("#display-area").html(res).hide().fadeIn(400);
                    },
                    error: function(xhr, status, error) {
                        console.error("AJAX Error:", error);
                        $("#display-area").html(`
                            <div class="alert alert-danger rounded-4">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                Error: មិនអាចទាញយកទិន្នន័យបានទេ។
                                <br><small>${xhr.status} - ${error}</small>
                            </div>
                        `);
                    }
                });
            });

            // Handle browser back/forward buttons
            window.addEventListener('popstate', function(event) {
                if (event.state) {
                    var url = event.state.url.split('?')[0];
                    var title = event.state.title;

                    $(".ajax-link").removeClass("active");
                    $('.ajax-link[data-url="' + url + '"]').addClass("active");
                    $("#page-title").text(title);

                    $.ajax({
                        url: url,
                        type: 'GET',
                        cache: false,
                        success: function (res) {
                            $("#display-area").html(res);
                        }
                    });
                }
            });

            // Profile Update Logic
            $('#btnSaveProfileInfo').click(function() {
                const fullName = $('#inputFullName').val().trim();
                if(fullName === "") {
                    Swal.fire({ icon: 'warning', title: 'ព្រមាន', text: 'សូមបញ្ចូលឈ្មោះពេញ' });
                    return;
                }

                // Create form data with proper ProfileUpdateModel structure
                var formData = new FormData();
                formData.append('Id', $('#navUsername').data('id') || '1');
                formData.append('FullName', fullName);
                // Get email from user data or use a default
                var userEmail = $('#navUsername').data('email') || 'user@example.com';
                formData.append('Email', userEmail);
                
                // Get anti-forgery token
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (!token) {
                    // Try to get from form
                    token = $('form input[name="__RequestVerificationToken"]').val();
                }
                
                console.log('Updating profile with data:', {
                    fullName: fullName,
                    email: $('#navUsername').data('email') || '',
                    token: token ? 'exists' : 'missing'
                });
                
                $.ajax({
                    url: '/User/UpdateCurrentUserProfile',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        console.log('Profile update response:', response);
                        if (response.success) {
                            // Update UI
                            $('#navUsername').text(response.fullName);
                            $('#inputFullName').val(response.fullName);
                            localStorage.setItem('userFullName', response.fullName);
                            
                            // Show success message
                            Swal.fire({ 
                                icon: 'success', 
                                title: 'ជោគជ័យ', 
                                text: response.message, 
                                timer: 2000,
                                showConfirmButton: false 
                            }).then(() => {
                                // Reload page to reflect changes
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({ icon: 'error', title: 'កំហុស', text: response.message });
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Profile update error:', xhr.responseText);
                        Swal.fire({ 
                            icon: 'error', 
                            title: 'កំហុស', 
                            text: 'មានបញ្ហាក្នុងការភ្ជាប់ទៅម៉ាស៊ីនមេ: ' + error 
                        });
                    }
                });
            });

            // Profile Picture Upload
            $(document).on('change', '#uploadInput', function() {
                var file = this.files[0];
                if (file) {
                    // Check file type
                    if (!file.type.startsWith('image/')) {
                        Swal.fire({ icon: 'warning', title: 'ព្រមាន', text: 'សូមជ្រើសរើសឯកសាររូបភាពតែប៉ុណ្ណោះ' });
                        return;
                    }
                    
                    // Check file size (max 5MB)
                    if (file.size > 5 * 1024 * 1024) {
                        Swal.fire({ icon: 'warning', title: 'ព្រមាន', text: 'ទំហំរូបភាពមិនត្រូវលើស 5MB' });
                        return;
                    }

                    var reader = new FileReader();
                    reader.onload = function(e) { 
                        $('#previewImg').attr('src', e.target.result); 
                    }
                    reader.readAsDataURL(file);
                }
            });

            $('#btnSavePhoto').click(function() {
                var fileInput = document.getElementById('uploadInput');
                var file = fileInput.files[0];
                
                if (!file) {
                    Swal.fire({ icon: 'warning', title: 'ព្រមាន', text: 'សូមជ្រើសរើសរូបភាពជាមុន' });
                    return;
                }

                console.log('Uploading profile picture:', file.name, file.size, file.type);

                var formData = new FormData();
                formData.append('ProfileImage', file);
                formData.append('Id', $('#navUsername').data('id') || '1');
                formData.append('FullName', $('#navUsername').text());
                // Get email from user data or use a default
                var userEmail = $('#navUsername').data('email') || 'user@example.com';
                formData.append('Email', userEmail);
                
                // Get anti-forgery token
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (!token) {
                    token = $('form input[name="__RequestVerificationToken"]').val();
                }
                
                console.log('Uploading with token:', token ? 'exists' : 'missing');
                
                $.ajax({
                    url: '/User/UpdateCurrentUserProfile',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        console.log('Profile picture upload response:', response);
                        if (response.success) {
                            // Update all profile images
                            if (response.profileImage) {
                                $('#navbarProfileImg, #previewImg, #profileInfoImg').attr('src', response.profileImage);
                                localStorage.setItem('userProfilePic', response.profileImage);
                                
                                // Also update server-side rendered image
                                $('#navbarProfileImg').attr('src', response.profileImage + '?t=' + new Date().getTime());
                            }
                            
                            Swal.fire({ 
                                icon: 'success', 
                                title: 'ជោគជ័យ', 
                                text: response.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                // Reload page to reflect changes
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({ icon: 'error', title: 'កំហុស', text: response.message });
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Profile picture upload error:', xhr.responseText);
                        Swal.fire({ 
                            icon: 'error', 
                            title: 'កំហុស', 
                            text: 'មានបញ្ហាក្នុងការភ្ជាប់ទៅម៉ាស៊ីនមេ: ' + error 
                        });
                    }
                });
            });

            $('#btnLogout').click(function() {
                Swal.fire({
                    title: 'ចាកចេញ?',
                    text: "តើបងពិតជាចង់ចាកចេញមែនទេ?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#5e5ce6',
                    confirmButtonText: 'បាទ/ចាស',
                    cancelButtonText: 'ទេ'
                }).then((result) => {
                    if (result.isConfirmed) window.location.href = '/Account/Login';
                });
            });
        });
    </script>
</body>
</html>