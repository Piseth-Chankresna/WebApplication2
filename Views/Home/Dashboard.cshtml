@using WebApplication2.Controllers
@model DashboardViewModel
@{
    ViewData["Title"] = "ផ្ទាំងគ្រប់គ្រង";
}

<style>
    .dashboard-container {
        padding: 20px 0;
    }

    .welcome-card {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: white;
        border-radius: 30px;
        padding: 30px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
    }

        .welcome-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .welcome-card::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

    .welcome-content {
        position: relative;
        z-index: 2;
    }

        .welcome-content h3 {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .welcome-content p {
            font-size: 1rem;
            opacity: 0.9;
            margin: 0;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(99,102,241,0.1);
    }

    .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #6366f1;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .chart-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        height: 100%;
    }

    [data-theme="dark"] .chart-card {
        background: #1e293b;
        border-color: #334155;
    }

    .chart-card h5 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    [data-theme="dark"] .chart-card h5 {
        color: white;
    }

    .chart-card h5 i {
        color: #6366f1;
    }

    .event-item {
        background: white;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 12px;
        border-left: 4px solid;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    [data-theme="dark"] .event-item {
        background: #1e293b;
    }

    .event-item:hover {
        transform: translateX(5px);
        box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
    }

    .event-warning {
        border-left-color: #f59e0b;
    }

    .event-important {
        border-left-color: #ef4444;
    }

    .event-info {
        border-left-color: #3b82f6;
    }

    .event-holiday {
        border-left-color: #8b5cf6;
    }

    .event-success {
        border-left-color: #10b981;
    }

    .event-date {
        font-size: 0.85rem;
        color: #64748b;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .event-title {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .event-title {
        color: white;
    }

    .event-description {
        font-size: 0.85rem;
        color: #64748b;
    }

    .event-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .student-avatar-sm {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        overflow: hidden;
        flex-shrink: 0;
    }

        .student-avatar-sm img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .activity-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border-bottom: 1px solid #e2e8f0;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .activity-item {
        border-bottom-color: #334155;
    }

    .activity-item:hover {
        background: #f8fafc;
    }

    [data-theme="dark"] .activity-item:hover {
        background: #0f172a;
    }

    .activity-icon {
        width: 40px;
        height: 40px;
        background: #e0e7ff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6366f1;
        flex-shrink: 0;
    }

    .activity-content {
        flex: 1;
    }

    .activity-title {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 2px;
    }

    [data-theme="dark"] .activity-title {
        color: white;
    }

    .activity-time {
        font-size: 0.8rem;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .student-rank {
        width: 28px;
        height: 28px;
        background: #f1f5f9;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #64748b;
        flex-shrink: 0;
    }

    .rank-1 {
        background: #fbbf24;
        color: white;
    }

    .rank-2 {
        background: #94a3b8;
        color: white;
    }

    .rank-3 {
        background: #b45309;
        color: white;
    }

    .view-all-link {
        color: #6366f1;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

        .view-all-link:hover {
            color: #4f46e5;
        }

    .text-success {
        color: #10b981 !important;
    }

    .text-danger {
        color: #ef4444 !important;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .welcome-content h3 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="dashboard-container">
    <!-- Welcome Card -->
    <div class="welcome-card">
        <div class="welcome-content">
            <h3>សួស្តី, អ្នកគ្រប់គ្រង!</h3>
            <p>ស្វាគមន៍មកកាន់ប្រព័ន្ធគ្រប់គ្រងសាកលវិទ្យាល័យ HRU</p>
            <p class="mt-2">ថ្ងៃនេះជាថ្ងៃ @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("km-KH"))</p>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <i class="bi bi-people-fill stat-icon"></i>
            <div class="stat-value">@Model.TotalStudents</div>
            <div class="stat-label">សិស្សសរុប</div>
        </div>
        <div class="stat-card">
            <i class="bi bi-person-badge-fill stat-icon"></i>
            <div class="stat-value">@Model.TotalTeachers</div>
            <div class="stat-label">គ្រូបង្រៀន</div>
        </div>
        <div class="stat-card">
            <i class="bi bi-door-open-fill stat-icon"></i>
            <div class="stat-value">@Model.TotalClasses</div>
            <div class="stat-label">ថ្នាក់សរុប</div>
        </div>
        <div class="stat-card">
            <i class="bi bi-cash-stack stat-icon"></i>
            <div class="stat-value">$@Model.TotalPayments.ToString("N0")</div>
            <div class="stat-label">បង់ប្រាក់សរុប</div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="chart-card">
                <h5><i class="bi bi-bar-chart-line"></i> វត្តមានប្រចាំសប្តាហ៍</h5>
                <canvas id="weeklyAttendanceChart" style="height: 300px;"></canvas>
            </div>
        </div>
        <div class="col-md-4">
            <div class="chart-card">
                <h5><i class="bi bi-pie-chart"></i> វត្តមានថ្ងៃនេះ</h5>
                <canvas id="todayAttendanceChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Second Row -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="chart-card">
                <h5><i class="bi bi-trophy-fill" style="color: #fbbf24;"></i> សិស្សពូកែ (Top 5)</h5>
                <div class="student-rank-list">
                    @if (Model.TopStudents.Any())
                    {
                        @for (int i = 0; i < Model.TopStudents.Count; i++)
                        {
                            var student = Model.TopStudents[i];
                            var rankClass = i == 0 ? "rank-1" : i == 1 ? "rank-2" : i == 2 ? "rank-3" : "";
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="student-rank @rankClass">@(i + 1)</div>
                                <div class="student-avatar-sm">
                                    @if (!string.IsNullOrEmpty(student.Photo))
                                    {
                                        <img src="@student.Photo" alt="@student.Name">
                                    }
                                    else
                                    {
                                        <span>@(student.Name?.Length > 0 ? student.Name.Substring(0, 1).ToUpper() : "?")</span>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@student.Name</div>
                                    <div class="small text-muted">@student.Major</div>
                                </div>
                                <div class="fw-bold text-success">@student.AverageGrade.ToString("F1")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">មិនទាន់មានទិន្នន័យ</p>
                    }
                </div>
                <div class="text-end mt-2">
                    <a href="/Student/Grades" class="view-all-link">
                        មើលទាំងអស់ <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="chart-card">
                <h5><i class="bi bi-exclamation-triangle-fill" style="color: #ef4444;"></i> ត្រូវការជំនួយ</h5>
                <div class="student-rank-list">
                    @if (Model.StrugglingStudents.Any())
                    {
                        @foreach (var student in Model.StrugglingStudents)
                        {
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="student-avatar-sm">
                                    @if (!string.IsNullOrEmpty(student.Photo))
                                    {
                                        <img src="@student.Photo" alt="@student.Name">
                                    }
                                    else
                                    {
                                        <span>@(student.Name?.Length > 0 ? student.Name.Substring(0, 1).ToUpper() : "?")</span>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold">@student.Name</div>
                                    <div class="small text-muted">@student.Major</div>
                                </div>
                                <div class="fw-bold text-danger">@student.AverageGrade.ToString("F1")</div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">មិនទាន់មានទិន្នន័យ</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="chart-card">
                <h5><i class="bi bi-cash-stack" style="color: #10b981;"></i> បង់ប្រាក់ប្រចាំខែ</h5>
                <canvas id="monthlyPaymentChart" style="height: 200px;"></canvas>
                <div class="mt-3 text-center">
                    <div class="fw-bold fs-4 text-success">$@Model.MonthlyPayment.ToString("N0")</div>
                    <div class="small text-muted">ប្រចាំខែនេះ</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Third Row -->
    <div class="row">
        <div class="col-md-6">
            <div class="chart-card">
                <h5><i class="bi bi-clock-history"></i> សកម្មភាពថ្មីៗ</h5>
                <div class="activity-list" style="max-height: 300px; overflow-y: auto;">
                    @if (Model.RecentActivities.Any())
                    {
                        @foreach (var activity in Model.RecentActivities)
                        {
                            <div class="activity-item">
                                <div class="activity-icon">
                                    <i class="bi bi-circle-fill"></i>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-title">@activity.Action</div>
                                    <div class="activity-time">
                                        <i class="bi bi-clock"></i>
                                        @GetTimeAgo(activity.Timestamp)
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">មិនទាន់មានសកម្មភាព</p>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="chart-card">
                <h5><i class="bi bi-calendar-event"></i> ព្រឹត្តិការណ៍ខាងមុខ</h5>
                <div class="event-list">
                    @foreach (var ev in Model.UpcomingEvents)
                    {
                        <div class="event-item event-@ev.Type">
                            <div class="event-date">
                                <i class="bi bi-calendar3"></i>
                                @ev.Date.ToString("dd MMM yyyy")
                                <span class="event-badge bg-@(ev.Type) ms-auto">
                                    @(ev.Type == "warning" ? "ជិតដល់" :
                                                                    ev.Type == "important" ? "សំខាន់" :
                                                                    ev.Type == "holiday" ? "ថ្ងៃឈប់សម្រាក" :
                                                                    ev.Type == "success" ? "រីករាយ" : "ព័ត៌មាន")
                            </span>
                        </div>
                        <div class="event-title">@ev.Title</div>
                        <div class="event-description">@ev.Description</div>
                    </div>
                                        }
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    $(document).ready(function() {
        // ក្រាហ្វវត្តមានថ្ងៃនេះ
        var todayCtx = document.getElementById('todayAttendanceChart').getContext('2d');
        new Chart(todayCtx, {
            type: 'doughnut',
            data: {
                labels: ['វត្តមាន', 'មកយឺត', 'អវត្តមាន'],
                datasets: [{
                    data: [
                        @(Model.TodayAttendance?.ContainsKey("P") == true ? Model.TodayAttendance["P"] : 0),
                        @(Model.TodayAttendance?.ContainsKey("L") == true ? Model.TodayAttendance["L"] : 0),
                        @(Model.TodayAttendance?.ContainsKey("A") == true ? Model.TodayAttendance["A"] : 0)
                    ],
                    backgroundColor: ['#10b981', '#f59e0b', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // ក្រាហ្វវត្តមានប្រចាំសប្តាហ៍
        var weeklyCtx = document.getElementById('weeklyAttendanceChart').getContext('2d');
        var weeklyData = @Html.Raw(Json.Serialize(Model.WeeklyAttendance));

        new Chart(weeklyCtx, {
            type: 'line',
            data: {
                labels: weeklyData.map(d => new Date(d.date).toLocaleDateString('km-KH', { weekday: 'short', day: 'numeric' })),
                datasets: [{
                    label: 'វត្តមាន',
                    data: weeklyData.map(d => d.present),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.1)',
                    tension: 0.4,
                    fill: true
                }, {
                    label: 'មកយឺត',
                    data: weeklyData.map(d => d.late),
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245,158,11,0.1)',
                    tension: 0.4,
                    fill: true
                }, {
                    label: 'អវត្តមាន',
                    data: weeklyData.map(d => d.absent),
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239,68,68,0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

        // ក្រាហ្វបង់ប្រាក់ប្រចាំខែ
        var paymentCtx = document.getElementById('monthlyPaymentChart').getContext('2d');
        var paymentData = @Html.Raw(Json.Serialize(Model.MonthlyPayments));
        var months = ['មករា', 'កុម្ភៈ', 'មីនា', 'មេសា', 'ឧសភា', 'មិថុនា',
                      'កក្កដា', 'សីហា', 'កញ្ញា', 'តុលា', 'វិច្ឆិកា', 'ធ្នូ'];

        new Chart(paymentCtx, {
            type: 'bar',
            data: {
                labels: paymentData.map(d => months[d.month - 1]),
                datasets: [{
                    label: 'ទឹកប្រាក់ ($)',
                    data: paymentData.map(d => d.total),
                    backgroundColor: '#10b981',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return '$' + value;
                            }
                        }
                    }
                }
            }
        });
    });

    @functions {
            public string GetTimeAgo(DateTime timestamp)
            {
                    var timeSpan = DateTime.Now - timestamp;

                    if (timeSpan.TotalMinutes < 1)
                            return "ទើបតែប៉ុន្មានវិនាទីមុន";
                    if (timeSpan.TotalMinutes < 60)
                            return $"{(int)timeSpan.TotalMinutes} នាទីមុន";
                    if (timeSpan.TotalHours < 24)
                            return $"{(int)timeSpan.TotalHours} ម៉ោងមុន";
                    if (timeSpan.TotalDays < 7)
                            return $"{(int)timeSpan.TotalDays} ថ្ងៃមុន";
                    if (timeSpan.TotalDays < 30)
                            return $"{(int)(timeSpan.TotalDays / 7)} សប្តាហ៍មុន";
                    if (timeSpan.TotalDays < 365)
                            return $"{(int)(timeSpan.TotalDays / 30)} ខែមុន";
                    return $"{(int)(timeSpan.TotalDays / 365)} ឆ្នាំមុន";
            }
    }
</script>