@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>មិនអនុញ្ញាតចូល - HR University</title>
    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        * { box-sizing: border-box; }
        html { height: 100%; }
        body {
            background: linear-gradient(135deg, #ef4444 0%, #dc2626 50%, #b91c1c 100%);
            font-family: 'Kantumruy Pro', sans-serif;
            min-height: 100vh;
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
            -webkit-tap-highlight-color: transparent;
        }

        .error-card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            width: 100%;
            max-width: 480px;
            padding: 40px 36px;
            text-align: center;
        }

        .error-icon {
            font-size: 4rem;
            color: #dc2626;
            margin-bottom: 24px;
        }

        .error-title {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 12px;
        }

        .error-message {
            font-size: 1rem;
            color: #475569;
            margin-bottom: 32px;
            line-height: 1.6;
        }

        .btn-primary {
            width: 100%;
            height: 48px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            border: none;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #fff;
            transition: transform 0.2s, box-shadow 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 25px -5px rgba(99,102,241,0.4);
            color: #fff;
        }

        .btn-secondary {
            width: 100%;
            height: 48px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            border: 2px solid #e2e8f0;
            background: #fff;
            color: #475569;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 12px;
        }

        .btn-secondary:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
            color: #334155;
        }

        .user-info {
            background: #f1f5f9;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
            font-size: 0.9rem;
            color: #475569;
        }

        .user-info strong {
            color: #1e293b;
        }

        @@media (max-width: 575.98px) {
            body { padding: 16px; }
            .error-card { padding: 28px 24px; border-radius: 20px; }
            .error-icon { font-size: 3rem; }
            .error-title { font-size: 1.4rem; }
        }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-shield-exclamation"></i>
        </div>
        
        <h1 class="error-title">មិនអនុញ្ញាតចូល</h1>
        
        <p class="error-message">
            អ្នកមិនមានសិទ្ធិគ្រប់គ្រងដើម្បីចូលទៅកាន់ទំព័រនេះទេ។ 
            សូមទាក់ទងអ្នកគ្រប់គ្រងប្រព័ន្ធ ប្រសិនបើអ្នកជឿថានេះជាកំហុស។
        </p>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="user-info">
                <div><strong>អ្នកប្រើប្រាស់:</strong> @User.Identity.Name</div>
                <div><strong>តួនាទី:</strong> @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
            </div>
            
            <div style="display: flex; gap: 12px; flex-direction: column;">
                <a href="/Home/Index" class="btn-primary">
                    <i class="bi bi-house"></i>
                    ត្រឡប់ទៅទំព័រដើម
                </a>
                
                <a href="/Account/RoleSelection" class="btn-secondary" style="margin-top: 0;">
                    <i class="bi bi-arrow-left-right"></i>
                    ជ្រើសរើសតួនាទីឡើងវិញ
                </a>
            </div>
            
            <div style="margin-top: 12px;">
                <form asp-action="Logout" asp-controller="Account" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-secondary" style="width: 100%;">
                        <i class="bi bi-box-arrow-right"></i>
                        ចាកចេញពីប្រព័ន្ធ
                    </button>
                </form>
            </div>
        }
        else
        {
            <a href="/Account/RoleSelection" class="btn-primary">
                <i class="bi bi-house"></i>
                ជ្រើសរើសតួនាទី
            </a>
        }
    </div>
</body>
</html>
