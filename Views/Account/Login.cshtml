@model WebApplication2.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>ចូលប្រើប្រាស់ - HR University</title>
    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        * { box-sizing: border-box; }
        html { height: 100%; }
        body {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #a855f7 100%);
            font-family: 'Kantumruy Pro', sans-serif;
            min-height: 100vh;
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
            -webkit-tap-highlight-color: transparent;
        }

        .auth-card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            width: 100%;
            max-width: 420px;
            padding: 40px 36px;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 32px;
        }
        .auth-header img {
            height: 64px;
            margin-bottom: 16px;
        }
        .auth-header h1 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 4px;
        }
        .auth-header .role-badge {
            display: inline-block;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            color: white;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 16px;
        }
        .auth-header .role-badge.user {
            background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
        }
        .auth-header h1 {
            color: #1e293b;
            margin-bottom: 4px;
        }
        .auth-header p {
            font-size: 0.9rem;
            color: #475569;
        }

        .input-wrap {
            position: relative;
        }
        .input-wrap .form-control {
            padding-left: 44px;
            padding-right: 48px;
            height: 48px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .input-wrap .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        }
        .input-wrap .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
            pointer-events: none;
        }
        .input-wrap .btn-toggle-pwd {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            padding: 8px;
            cursor: pointer;
            border-radius: 8px;
            transition: color 0.2s;
        }
        .input-wrap .btn-toggle-pwd:hover {
            color: #6366f1;
        }

        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .alert-msg {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 16px 20px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-size: 0.95rem;
            line-height: 1.5;
            font-weight: 500;
        }
        .alert-msg.error {
            background: #fef2f2;
            color: #b91c1c;
            border: 2px solid #fecaca;
        }
        .alert-msg.error .alert-icon { flex-shrink: 0; font-size: 1.25rem; }
        .alert-msg.error ul {
            margin: 0;
            padding-left: 1.1rem;
        }
        .alert-msg.error li {
            margin-bottom: 4px;
        }
        .alert-msg.success {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .field-error {
            display: block;
            font-size: 0.9rem;
            font-weight: 500;
            color: #dc2626;
            margin-top: 6px;
            line-height: 1.4;
        }

        .validation-summary-errors {
            color: inherit !important;
        }
        .validation-summary-errors ul { list-style: disc; }

        .form-check-input:checked { background-color: #6366f1; border-color: #6366f1; }
        .form-check-label { font-size: 0.9rem; color: #475569; }

        .btn-submit {
            width: 100%;
            height: 48px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            border: none;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #fff;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 25px -5px rgba(99,102,241,0.4);
            color: #fff;
        }

        .auth-footer {
            text-align: center;
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }
        .auth-footer a {
            color: #6366f1;
            text-decoration: none;
            font-weight: 600;
        }
        .auth-footer a:hover { color: #4f46e5; }
        .auth-footer { font-size: 0.95rem; color: #475569; }

        @@media (max-width: 575.98px) {
            body { padding: 16px; }
            .auth-card { padding: 28px 24px; border-radius: 20px; }
            .auth-header img { height: 52px; }
            .auth-header h1 { font-size: 1.25rem; }
        }

        @@media (min-width: 576px) and (min-height: 700px) {
            .auth-card { padding: 48px 40px; }
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-header">
            <img src="/images/log.jpg.png" alt="HRU Logo" onerror="this.style.display='none'">
            <h1>
                ចូលប្រើប្រាស់ប្រព័ន្ធ
                @if (ViewBag.Role == "Admin")
                {
                    <span class="role-badge">អ្នកគ្រប់គ្រងប្រព័ន្ធ</span>
                }
                else if (ViewBag.Role == "User")
                {
                    <span class="role-badge user">អ្នកប្រើប្រាស់</span>
                }
            </h1>
            <p>HR University Management System</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-msg success">
                <i class="bi bi-check-circle-fill mt-1"></i>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert-msg error">
                <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                <div class="alert-text">
                    <strong>សូមកែប្រែ:</strong>
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label" asp-for="Email">អ៊ីមែល</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" class="form-control" type="email" placeholder="example@hru.edu.kh" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Password">លេខសម្ងាត់</label>
                <div class="input-wrap">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" id="loginPassword" class="form-control" type="password" placeholder="បញ្ចូលលេខសម្ងាត់" autocomplete="current-password" />
                    <button type="button" class="btn-toggle-pwd" onclick="togglePwd('loginPassword', this)" aria-label="បង្ហាញ/លាក់លេខសម្ងាត់">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label class="form-check-label" asp-for="RememberMe">ចងចាំខ្ញុំ</label>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-box-arrow-in-right me-2"></i>ចូលប្រើប្រាស់
            </button>
        </form>

        <div class="auth-footer">
            មិនទាន់មានគណនី? <a href="/Account/Register">ចុះឈ្មោះនៅទីនេះ</a>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePwd(id, btn) {
            var inp = document.getElementById(id);
            var icon = btn.querySelector('i');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                inp.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
</body>
</html>
