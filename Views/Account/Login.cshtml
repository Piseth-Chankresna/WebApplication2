@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - HR University</title>
    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />

    <style>
        body {
            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
            font-family: 'Kantumruy Pro', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-card {
            background: white;
            /* ដក Padding ខាងលើចេញ ដើម្បីឱ្យរូបភាពនៅជាប់គែមលើបង្អស់ */
            padding: 0 40px 40px 40px;
            border-radius: 25px;
            box-shadow: 0 20px 45px rgba(0,0,0,0.25);
            width: 100%;
            max-width: 420px;
            text-align: center;
            position: relative;
            overflow: hidden; /* ដើម្បីឱ្យរូបភាពមិនលយចេញក្រៅរង្វង់កាត */
        }

        /* រចនា Logo ឱ្យពេញទទឹងផ្នែកខាងលើ */
        .logo-header-full {
            margin: 0 -40px 25px -40px; /* រុញឱ្យចេញផុត Padding របស់ Card */
            display: block;
        }

            .logo-header-full img {
                width: 100%; /* ពង្រីកពេញផ្ទៃ */
                height: auto;
                display: block;
                /* ប្រសិនបើអ្នកចង់ឱ្យរូបភាពមានរាងមូលតាមកាតផ្នែកខាងលើ */
                border-top-left-radius: 25px;
                border-top-right-radius: 25px;
            }

        .form-control {
            border-radius: 12px;
            padding: 12px 15px;
            margin-bottom: 15px;
            border: 1px solid #e0e0e0;
            background-color: #f9f9f9;
        }

            .form-control:focus {
                background-color: #fff;
                border-color: #5e5ce6;
                box-shadow: 0 0 0 0.2rem rgba(94, 92, 230, 0.15);
            }

        .btn-login {
            background: #5e5ce6;
            color: white;
            border: none;
            padding: 13px;
            border-radius: 12px;
            width: 100%;
            font-weight: 600;
            transition: 0.3s;
            font-size: 1.1rem;
            margin-top: 10px;
        }

            .btn-login:hover {
                background: #4a48c9;
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(94, 92, 230, 0.3);
            }

        .error-msg {
            font-size: 0.85rem;
            color: #dc3545;
            background: #f8d7da;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 20px;
            border: 1px solid #f5c6cb;
            margin-top: 10px;
        }

        .register-link {
            margin-top: 25px;
            font-size: 0.95rem;
        }

            .register-link a {
                color: #5e5ce6;
                text-decoration: none;
                font-weight: 600;
            }

        .input-icon-group {
            position: relative;
            margin-bottom: 15px;
        }

            .input-icon-group i {
                position: absolute;
                right: 15px;
                bottom: 14px;
                color: #adb5bd;
                font-size: 1.1rem;
            }

            .input-icon-group label {
                margin-bottom: 5px;
                display: block;
            }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="logo-header-full">
            <img src="/images/log.jpg.png" alt="HRU Logo">
        </div>

        <h4 class="fw-bold mb-1">ចូលប្រើប្រាស់ប្រព័ន្ធ</h4>
        <p class="text-muted mb-4 small">HR University Management System</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg text-start">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
            </div>
        }

        <form id="loginForm" action="/Account/ProcessLogin" method="post">
            <div class="text-start input-icon-group">
                <label class="form-label small fw-bold">ឈ្មោះអ្នកប្រើប្រាស់</label>
                <input type="text" name="username" class="form-control mb-0" placeholder="បញ្ចូល Username" required>
                <i class="bi bi-person"></i>
            </div>

            <div class="text-start input-icon-group">
                <label class="form-label small fw-bold">លេខសម្ងាត់</label>
                <input type="password" name="password" class="form-control mb-0" placeholder="បញ្ចូល Password" required>
                <i class="bi bi-lock"></i>
            </div>

            <button type="submit" class="btn-login">ចូលក្នុងប្រព័ន្ធ</button>
        </form>

        <div class="register-link">
            មិនទាន់មានគណនី? <a href="/Account/Register">ចុះឈ្មោះនៅទីនេះ</a>
        </div>

        <div class="mt-4 small text-muted pt-3 border-top">
            &copy; 2026 HR University. All rights reserved.
        </div>
    </div>

    <script>
        document.getElementById('loginForm').onsubmit = function() {
            const username = document.getElementsByName('username')[0].value;
            localStorage.setItem('userFullName', username);
        };
    </script>

</body>
</html>