@{
    ViewData["Title"] = "ជ្រើសរើសតួនាទី";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="role-selection-container">
    <div class="role-header">
        <img src="/images/log.jpg.png" alt="HRU Logo" onerror="this.style.display='none'">
        <h1>ជ្រើសរើសតួនាទី</h1>
        <p>សូមជ្រើសរើសតួនាទីរបស់អ្នក</p>
    </div>

    <div class="role-options">
        <a href="/Account/AdminLogin" class="role-option">
            <div class="role-icon">
                <i class="bi bi-shield-check"></i>
            </div>
            <div class="role-title">អ្នកគ្រប់គ្រងប្រព័ន្ធ-Admin</div>
            <div class="role-description">
                មានសិទ្ធិគ្រប់គ្រងទាំងអស់នៅក្នុងប្រព័ន្ធ និងគ្រប់គ្រងទាំងអស់នៅក្នុងប្រព័ន្ធ
            </div>
        </a>

        <a href="/Account/UserLogin" class="role-option">
            <div class="role-icon">
                <i class="bi bi-person-circle"></i>
            </div>
            <div class="role-title">អ្នកប្រើប្រាស់-User</div>
            <div class="role-description">
                សម្រាប់ក្នុងការចូលប្រើប្រាស់និងគ្រប់គ្រងព័ត៌មានផ្ទាល់ខ្លួន និងមើលទិន្នន័យសិស្ស
            </div>
        </a>
    </div>

    <div class="mt-4">
        <button class="back-btn" onclick="goBack()">
            <i class="bi bi-arrow-left me-2"></i>
            ត្រឡប់ទៅក្រោយ
        </button>
    </div>
</div>

<style>
    .role-selection-container {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
        width: 100%;
        max-width: 520px;
        padding: 40px;
        text-align: center;
        margin: 50px auto;
    }

    .role-header {
        margin-bottom: 40px;
    }
    .role-header img {
        height: 80px;
        margin-bottom: 16px;
    }
    .role-header h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 8px;
    }
    .role-header p {
        font-size: 1rem;
        color: #475569;
        font-weight: 500;
    }

    .role-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 40px;
    }

    .role-option {
        background: #fff;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 30px 20px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        text-decoration: none;
        color: inherit;
    }

    .role-option:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px -12px rgba(0,0,0,0.15);
        border-color: #6366f1;
    }

    .role-icon {
        font-size: 3rem;
        margin-bottom: 16px;
        color: #6366f1;
    }

    .role-title {
        font-size: 1.3rem;
        font-weight: 700;
        margin-bottom: 8px;
        color: #1e293b;
    }

    .role-description {
        font-size: 0.9rem;
        color: #64748b;
        line-height: 1.5;
    }

    .back-btn {
        background: none;
        border: none;
        color: #64748b;
        font-weight: 500;
        font-size: 0.95rem;
        cursor: pointer;
        transition: color 0.2s;
    }

    .back-btn:hover {
        color: #1e293b;
    }

    @@media (max-width: 575.98px) {
        .role-selection-container { 
            padding: 30px 24px; 
            border-radius: 20px; 
            margin: 20px;
        }
        .role-header img { height: 60px; }
        .role-header h1 { font-size: 1.5rem; }
        .role-options { grid-template-columns: 1fr; gap: 16px; }
        .role-option { padding: 24px 20px; }
    }
</style>

<script>
    function goBack() {
        window.location.href = '/';
    }

    // Add hover effects
    document.querySelectorAll('.role-option').forEach(option => {
        option.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-4px) scale(1.02)';
        });
        
        option.addEventListener('mouseleave', function() {
            this.style.transform = '';
        });
    });
</script>
