@model WebApplication2.Models.UserAccount
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>ចុះឈ្មោះ - HR University</title>
    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
        * { box-sizing: border-box; }
        html { height: 100%; }
        body {
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #a855f7 100%);
            font-family: 'Kantumruy Pro', sans-serif;
            min-height: 100vh;
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 20px;
            -webkit-tap-highlight-color: transparent;
        }

        .auth-card {
            background: #fff;
            border-radius: 24px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            width: 100%;
            max-width: 480px;
            padding: 36px 32px;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 28px;
        }
        .auth-header img {
            height: 60px;
            margin-bottom: 12px;
        }
        .auth-header h1 {
            font-size: 1.4rem;
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 4px;
        }
        .auth-header p {
            font-size: 0.9rem;
            color: #475569;
        }

        .input-wrap {
            position: relative;
        }
        .input-wrap .form-control {
            padding-left: 44px;
            padding-right: 48px;
            height: 48px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .input-wrap .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
        }
        .input-wrap .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
            pointer-events: none;
        }
        .input-wrap .btn-toggle-pwd {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #94a3b8;
            padding: 8px;
            cursor: pointer;
            border-radius: 8px;
            transition: color 0.2s;
        }
        .input-wrap .btn-toggle-pwd:hover {
            color: #6366f1;
        }

        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        .alert-msg {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 16px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 0.95rem;
            line-height: 1.5;
            font-weight: 500;
        }
        .alert-msg.error {
            background: #fef2f2;
            color: #b91c1c;
            border: 2px solid #fecaca;
        }
        .alert-msg.error .alert-icon { flex-shrink: 0; font-size: 1.25rem; }
        .alert-msg.error ul { margin: 0; padding-left: 1.1rem; }
        .alert-msg.error li { margin-bottom: 4px; }
        .alert-msg.success {
            background: #f0fdf4;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .field-error {
            display: block;
            font-size: 0.9rem;
            font-weight: 500;
            color: #dc2626;
            margin-top: 6px;
            line-height: 1.4;
        }

        .validation-summary-errors { color: inherit !important; }
        .validation-summary-errors ul { list-style: disc; }

        .btn-submit {
            width: 100%;
            height: 48px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            border: none;
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
            color: #fff;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-submit:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 25px -5px rgba(99,102,241,0.4);
            color: #fff;
        }

        .auth-footer {
            text-align: center;
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }
        .auth-footer a {
            color: #6366f1;
            text-decoration: none;
            font-weight: 600;
        }
        .auth-footer a:hover { color: #4f46e5; }
        .auth-footer { font-size: 0.95rem; color: #475569; }

        .password-hint {
            font-size: 0.875rem;
            color: #475569;
            margin-top: 6px;
            line-height: 1.4;
            font-weight: 500;
        }

        @@media (max-width: 575.98px) {
            body { padding: 16px; }
            .auth-card { padding: 24px 20px; border-radius: 20px; }
            .auth-header img { height: 50px; }
            .auth-header h1 { font-size: 1.2rem; }
            .input-wrap .form-control { height: 46px; padding-left: 40px; }
            .btn-submit { height: 46px; }
        }

        @@media (min-width: 576px) and (min-height: 800px) {
            .auth-card { padding: 40px 36px; }
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-header">
            <img src="/images/log.jpg.png" alt="HRU Logo" onerror="this.style.display='none'">
            <h1>បង្កើតគណនីថ្មី</h1>
            <p>សូមបំពេញព័ត៌មានខាងក្រោម</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-msg success">
                <i class="bi bi-check-circle-fill mt-1"></i>
                <span>@TempData["SuccessMessage"]</span>
            </div>
        }

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert-msg error">
                <i class="bi bi-exclamation-triangle-fill alert-icon"></i>
                <div class="alert-text">
                    <strong>សូមកែប្រែ:</strong>
                    @Html.ValidationSummary(false, "", new { @class = "mb-0" })
                </div>
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label" asp-for="FullName">ឈ្មោះពេញ</label>
                <div class="input-wrap">
                    <i class="bi bi-person input-icon"></i>
                    <input asp-for="FullName" class="form-control" placeholder="សូមបញ្ចូលឈ្មោះពេញ" autocomplete="name" style="padding-right: 16px;" />
                </div>
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Email">អ៊ីមែល</label>
                <div class="input-wrap">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" class="form-control" type="email" placeholder="example@hru.edu.kh" autocomplete="email" style="padding-right: 16px;" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Role">តួនាទី</label>
                <div class="input-wrap">
                    <i class="bi bi-shield input-icon"></i>
                    <select asp-for="Role" class="form-control" style="padding-right: 16px;">
                        <option value="">ជ្រើសរើសតួនាទី</option>
                        <option value="User">អ្នកប្រើប្រាស់-User</option>
                        <option value="Admin">អ្នកគ្រប់គ្រងប្រព័ន្ធ-Admin</option>
                    </select>
                </div>
                <span asp-validation-for="Role" class="field-error"></span>
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>
                    <span id="roleDescription">សូមជ្រើសរើសតួនាទីដើម្បីកំណត់សិទ្ធិរបស់អ្នក</span>
                </small>
            </div>

            <div class="mb-3">
                <label class="form-label" asp-for="Password">លេខសម្ងាត់</label>
                <div class="input-wrap">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" id="regPassword" class="form-control" type="password" placeholder="យ៉ាងតិច 8 តួ, មានអក្សរធំ តូច និងលេខ" autocomplete="new-password" />
                    <button type="button" class="btn-toggle-pwd" onclick="togglePwd('regPassword', this)" aria-label="បង្ហាញ/លាក់លេខសម្ងាត់">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
                <p class="password-hint">ត្រូវមានយ៉ាងតិច 8 តួ រួមទាំងអក្សរធំ អក្សរតូច និងលេខ</p>
            </div>

            <div class="mb-4">
                <label class="form-label" asp-for="ConfirmPassword">បញ្ជាក់លេខសម្ងាត់</label>
                <div class="input-wrap">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <input asp-for="ConfirmPassword" id="regConfirmPassword" class="form-control" type="password" placeholder="បញ្ចូលលេខសម្ងាត់ម្តងទៀត" autocomplete="new-password" />
                    <button type="button" class="btn-toggle-pwd" onclick="togglePwd('regConfirmPassword', this)" aria-label="បង្ហាញ/លាក់លេខសម្ងាត់">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="btn-submit">
                <i class="bi bi-person-plus-fill me-2"></i>ចុះឈ្មោះ
            </button>
        </form>

        <div class="auth-footer">
            មានគណនីរួចហើយ? <a href="/Account/Login">ចូលប្រើប្រាស់</a>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script>
        function togglePwd(id, btn) {
            var inp = document.getElementById(id);
            var icon = btn.querySelector('i');
            if (inp.type === 'password') {
                inp.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                inp.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }

        // Role description updates
        document.addEventListener('DOMContentLoaded', function() {
            const roleSelect = document.querySelector('select[name="Role"]');
            const roleDescription = document.getElementById('roleDescription');
            
            const roleDescriptions = {
                '': 'សូមជ្រើសរើសតួនាទីដើម្បីកំណត់សិទ្ធិរបស់អ្នក',
                'User': 'អ្នកប្រើប្រាស់ - អាចមើលនិងគ្រប់គ្រងព័ត៌មានផ្ទាល់ខ្លួន និងមើលទិន្នន័យសិស្ស',
                'Admin': 'អ្នកគ្រប់គ្រងប្រព័ន្ធ - មានសិទ្ធិគ្រប់គ្រងទាំងអស់នៅក្នុងប្រព័ន្ធ'
            };
            
            roleSelect.addEventListener('change', function() {
                roleDescription.textContent = roleDescriptions[this.value] || roleDescriptions[''];
            });
        });
    </script>
</body>
</html>
