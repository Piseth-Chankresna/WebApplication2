@model IEnumerable<WebApplication2.Models.ActivityLog>
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Activity Logs";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #4361ee, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }

    .log-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .log-container {
        background: #1e293b;
        border-color: #334155;
    }

    .log-table {
        width: 100%;
        border-collapse: collapse;
    }

        .log-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
        }

    [data-theme="dark"] .log-table th {
        border-bottom-color: #334155;
    }

    .log-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .log-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .log-table tbody tr:hover {
        background: #f8fafc;
    }

    [data-theme="dark"] .log-table tbody tr:hover {
        background: #0f172a;
    }

    .badge-success {
        background: #d1fae5;
        color: #10b981;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.85rem;
    }

    .badge-danger {
        background: #fee2e2;
        color: #ef4444;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.85rem;
    }

    .btn-clear {
        background: #ef4444;
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-clear:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(239,68,68,0.3);
        }

    .search-box {
        position: relative;
        width: 300px;
    }

        .search-box i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

        .search-box input {
            width: 100%;
            padding: 12px 16px 12px 44px;
            border: 2px solid #e2e8f0;
            border-radius: 40px;
            background: white;
            color: #1e293b;
        }

    [data-theme="dark"] .search-box input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .search-box input:focus {
        outline: none;
        border-color: #4361ee;
        box-shadow: 0 0 0 4px #e0e7ff;
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-journal-text me-2"></i>Activity Logs</h2>
    <p class="text-muted">កត់ត្រាសកម្មភាពទាំងអស់ក្នុងប្រព័ន្ធ</p>
</div>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="search-box">
        <i class="bi bi-search"></i>
        <input type="text" id="searchLog" placeholder="ស្វែងរក...">
    </div>
    <button class="btn-clear" onclick="clearLogs()">
        <i class="bi bi-trash me-2"></i>សម្អាតទាំងអស់
    </button>
</div>

<div class="log-container">
    <div class="table-responsive">
        <table class="log-table">
            <thead>
                <tr>
                    <th>អ្នកប្រើប្រាស់</th>
                    <th>សកម្មភាព</th>
                    <th>ការពិពណ៌នា</th>
                    <th>IP Address</th>
                    <th>ស្ថានភាព</th>
                    <th>ពេលវេលា</th>
                </tr>
            </thead>
            <tbody id="logTableBody">
                @foreach (var log in Model)
                {
                    <tr>
                        <td>
                            <strong>@log.UserName</strong>
                            <div><small class="text-muted">ID: @log.UserId</small></div>
                        </td>
                        <td>@log.Action</td>
                        <td>@log.Description</td>
                        <td>@log.IpAddress</td>
                        <td>
                            <span class="@(log.Status == "ជោគជ័យ" ? "badge-success" : "badge-danger")">
                                @log.Status
                            </span>
                        </td>
                        <td>@log.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-journal-x" style="font-size: 4rem; color: #cbd5e1;"></i>
                <h5 class="mt-3 text-muted">មិនទាន់មានកំណត់ត្រានៅឡើយទេ</h5>
            </div>
        }
    </div>
</div>

<script>
    // ស្វែងរកក្នុងតារាង
    $('#searchLog').on('keyup', function() {
        var value = $(this).val().toLowerCase();
        $('#logTableBody tr').filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
        });
    });

    // សម្អាតកំណត់ត្រាទាំងអស់
    function clearLogs() {
        Swal.fire({
            title: 'សម្អាតកំណត់ត្រាទាំងអស់?',
            text: 'សកម្មភាពនេះមិនអាចត្រឡប់វិញបានទេ!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'បាទ/ចាស សម្អាត',
            cancelButtonText: 'បោះបង់'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '/ActivityLog/ClearLogs',
                    type: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function() {
                        Swal.fire({
                            icon: 'success',
                            title: 'ជោគជ័យ!',
                            text: 'បានសម្អាតកំណត់ត្រាទាំងអស់',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            location.reload();
                        });
                    }
                });
            }
        });
    }
</script>