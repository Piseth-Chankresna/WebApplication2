@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "បញ្ជីសិស្ស";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #10b981;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #10b981, #059669);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-bs-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #10b981;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-bs-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .action-bar {
        background: white;
        border-radius: 60px;
        padding: 6px 6px 6px 24px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .action-bar {
        background: #1e293b;
        border-color: #334155;
    }

    .search-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .search-wrapper i {
            color: #94a3b8;
        }

        .search-wrapper input {
            border: none;
            background: transparent;
            padding: 12px 0;
            width: 100%;
            outline: none;
            color: #1e293b;
        }

    [data-bs-theme="dark"] .search-wrapper input {
        color: white;
    }

    .btn-create, .btn-excel {
        padding: 12px 28px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        border: none;
    }

    .btn-create {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
    }

    .btn-excel {
        background: #10b981;
        color: white;
        margin-right: 10px;
    }

        .btn-create:hover, .btn-excel:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .filter-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .filter-card {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-card h5 {
        color: #1e293b;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    [data-bs-theme="dark"] .filter-card h5 {
        color: white;
    }

    .filter-card h5 i {
        color: #10b981;
    }

    .filter-card .form-label {
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-bs-theme="dark"] .filter-card .form-label {
        color: #cbd5e1;
    }

    .filter-card .form-select,
    .filter-card .form-control {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px;
        width: 100%;
    }

    [data-bs-theme="dark"] .filter-card .form-select,
    [data-bs-theme="dark"] .filter-card .form-control {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .student-table {
        width: 100%;
        border-collapse: collapse;
    }

        .student-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-bs-theme="dark"] .student-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .student-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .student-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .student-table tbody tr {
        transition: all 0.2s ease;
        cursor: pointer;
    }

        .student-table tbody tr:hover {
            background: #f8fafc;
        }

    [data-bs-theme="dark"] .student-table tbody tr:hover {
        background: #0f172a;
    }

    .student-avatar {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1.2rem;
        overflow: hidden;
        flex-shrink: 0;
    }

        .student-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .status-badge {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-active {
        background: #d1fae5;
        color: #10b981;
    }

    .status-inactive {
        background: #fee2e2;
        color: #ef4444;
    }

    .status-warning {
        background: #fef3c7;
        color: #f59e0b;
    }

    .action-group {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
        text-decoration: none;
    }

    [data-bs-theme="dark"] .btn-icon {
        background: #0f172a;
        border-color: #334155;
        color: #cbd5e1;
    }

    .btn-icon:hover {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        transform: translateY(-2px);
    }

    .filtered-count {
        background: #10b981;
        color: white;
        padding: 4px 12px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .action-bar {
            flex-direction: column;
            border-radius: 20px;
            padding: 16px;
        }

        .search-wrapper {
            width: 100%;
        }

        .btn-create, .btn-excel {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<!-- AntiForgeryToken -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-people-fill me-2"></i>បញ្ជីសិស្ស</h2>
    <p class="text-muted">គ្រប់គ្រងព័ត៌មានសិស្សទាំងអស់ក្នុងប្រព័ន្ធ</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid" id="statsGrid">
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-gender-male stat-icon"></i>
        <div class="stat-value" id="maleStudents">0</div>
        <div class="stat-label">ប្រុស</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-gender-female stat-icon"></i>
        <div class="stat-value" id="femaleStudents">0</div>
        <div class="stat-label">ស្រី</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-check-circle-fill stat-icon"></i>
        <div class="stat-value" id="activeStudents">0</div>
        <div class="stat-label">កំពុងសិក្សា</div>
    </div>
</div>

<!-- Action Bar -->
<div class="action-bar">
    <div class="search-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" placeholder="ស្វែងរកតាមឈ្មោះ លេខសម្គាល់...">
    </div>
    <div class="d-flex gap-2">
        <a href="/Student/ExportStudents" class="btn-excel">
            <i class="bi bi-file-earmark-excel"></i>
            <span class="d-none d-md-inline">Excel</span>
        </a>
        <a href="/Student/Create" class="btn-create ajax-link" data-url="/Student/Create">
            <i class="bi bi-plus-lg"></i>
            <span class="d-none d-md-inline">បន្ថែមថ្មី</span>
        </a>
    </div>
</div>

<!-- Advanced Filter -->
<div class="filter-card">
    <h5><i class="bi bi-sliders2"></i> តម្រងកម្រិតខ្ពស់</h5>

    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label fw-bold">ជំនាញ</label>
            <select id="filterMajor" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">ឆ្នាំសិក្សា</label>
            <select id="filterYear" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="1">ឆ្នាំទី១</option>
                <option value="2">ឆ្នាំទី២</option>
                <option value="3">ឆ្នាំទី៣</option>
                <option value="4">ឆ្នាំទី៤</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">វេនសិក្សា</label>
            <select id="filterShift" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="ព្រឹក">ព្រឹក</option>
                <option value="រសៀល">រសៀល</option>
                <option value="យប់">យប់</option>
                <option value="សៅរ៍-អាទិត្យ">សៅរ៍-អាទិត្យ</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-bold">ស្ថានភាព</label>
            <select id="filterStatus" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="កំពុងសិក្សា">កំពុងសិក្សា</option>
                <option value="ឈប់សម្រាក">ឈប់សម្រាក</option>
                <option value="បញ្ចប់ការសិក្សា">បញ្ចប់</option>
            </select>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-success" onclick="applyFilter()" style="border-radius: 40px; padding: 10px 24px;">
            <i class="bi bi-search me-2"></i>ស្វែងរក
        </button>
        <button class="btn btn-outline-secondary" onclick="resetFilter()" style="border-radius: 40px; padding: 10px 24px;">
            <i class="bi bi-arrow-counterclockwise me-2"></i>កំណត់ឡើងវិញ
        </button>
    </div>
</div>

<!-- Filtered Count -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="filtered-count" id="filteredCount">0 / 0</span>
</div>

<!-- Student Table -->
<div class="table-container">
    <div class="table-responsive">
        <table class="student-table">
            <thead>
                <tr>
                    <th>សិស្ស</th>
                    <th>ជំនាញ</th>
                    <th>ឆ្នាំ</th>
                    <th>វេន/បន្ទប់</th>
                    <th>ស្ថានភាព</th>
                    <th class="text-end">សកម្មភាព</th>
                </tr>
            </thead>
            <tbody id="studentTableBody">
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let students = [];
    let isLoading = false;

    $(document).ready(function() {
        loadStudents();
        loadStats();
    });

    function loadStudents() {
        if (isLoading) return;
        isLoading = true;

        $('#studentTableBody').html(`
            <tr>
                <td colspan="6" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        `);

        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            cache: false,
            success: function(response) {
                isLoading = false;

                if (response && response.success) {
                    students = response.data || [];
                } else if (Array.isArray(response)) {
                    students = response;
                } else {
                    students = [];
                }

                displayStudents(students);
                updateFilteredCount(students.length);
            },
            error: function(xhr, status, error) {
                isLoading = false;
                console.error("Error loading students:", error);
                showError('មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ');
            }
        });
    }

    function loadStats() {
        $.ajax({
            url: '/Student/GetStudentStats',
            type: 'GET',
            cache: false,
            success: function(response) {
                if (response) {
                    $('#totalStudents').text(response.total || 0);
                    $('#maleStudents').text(response.male || 0);
                    $('#femaleStudents').text(response.female || 0);
                    $('#activeStudents').text(response.active || 0);
                }
            },
            error: function(xhr, status, error) {
                console.error("Error loading stats:", error);
            }
        });
    }

    function displayStudents(data) {
        var tbody = $('#studentTableBody');
        tbody.empty();

        if (!data || data.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="bi bi-people" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានទិន្នន័យសិស្សនៅឡើយទេ</h5>
                        <a href="/Student/Create" class="btn btn-success mt-3 ajax-link" data-url="/Student/Create">
                            <i class="bi bi-plus-lg me-2"></i>បន្ថែមសិស្សដំបូង
                        </a>
                    </td>
                </tr>
            `);
            return;
        }

        data.forEach(s => {
            var statusClass = s.status === 'កំពុងសិក្សា' ? 'status-active' :
                             s.status === 'ឈប់សម្រាក' ? 'status-warning' : 'status-inactive';

            var avatarHtml = s.photo ?
                `<img src="${s.photo}" alt="${s.name}">` :
                (s.name ? s.name.charAt(0).toUpperCase() : '?');

            var row = `
                <tr onclick="viewStudent('${s.id}')">
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div class="student-avatar">
                                ${avatarHtml}
                            </div>
                            <div>
                                <div class="fw-bold">${s.name || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">ID: ${s.id}</small>
                            </div>
                        </div>
                    </td>
                    <td>${s.major || 'មិនមាន'}</td>
                    <td>ឆ្នាំទី${s.year || '?'}</td>
                    <td>
                        <div>${s.shift || 'មិនមាន'}</div>
                        <small class="text-muted">${s.room || ''}</small>
                    </td>
                    <td>
                        <span class="status-badge ${statusClass}">${s.status || 'កំពុងសិក្សា'}</span>
                    </td>
                    <td class="text-end">
                        <div class="action-group" onclick="event.stopPropagation()">
                            <a href="/Student/Edit/${s.id}" class="btn-icon ajax-link" data-url="/Student/Edit/${s.id}" title="កែប្រែ">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="/Student/Details/${s.id}" class="btn-icon ajax-link" data-url="/Student/Details/${s.id}" title="មើលលម្អិត">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="/Student/CheckAttendance?studentId=${s.id}" class="btn-icon ajax-link" data-url="/Student/CheckAttendance?studentId=${s.id}" title="វត្តមាន">
                                <i class="bi bi-calendar-check"></i>
                            </a>
                            <button class="btn-icon" onclick="deleteStudent('${s.id}', '${s.name}')" title="លុប">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });
    }

    function applyFilter() {
        var searchText = $('#searchInput').val().toLowerCase();
        var major = $('#filterMajor').val();
        var year = $('#filterYear').val();
        var shift = $('#filterShift').val();
        var status = $('#filterStatus').val();

        var filtered = students.filter(s => {
            var matchSearch = !searchText ||
                (s.name && s.name.toLowerCase().includes(searchText)) ||
                (s.id && s.id.toLowerCase().includes(searchText));
            var matchMajor = !major || s.major === major;
            var matchYear = !year || s.year === year;
            var matchShift = !shift || s.shift === shift;
            var matchStatus = !status || s.status === status;

            return matchSearch && matchMajor && matchYear && matchShift && matchStatus;
        });

        displayStudents(filtered);
        updateFilteredCount(filtered.length);
    }

    function resetFilter() {
        $('#searchInput').val('');
        $('#filterMajor').val('');
        $('#filterYear').val('');
        $('#filterShift').val('');
        $('#filterStatus').val('');
        displayStudents(students);
        updateFilteredCount(students.length);
    }

    function updateFilteredCount(count) {
        $('#filteredCount').text(count + ' / ' + students.length);
    }

    function viewStudent(id) {
        window.location.href = '/Student/Details/' + id;
    }

    function deleteStudent(id, name) {
        Swal.fire({
            title: 'លុបសិស្ស?',
            text: `តើអ្នកពិតជាចង់លុប ${name} មែនទេ?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'បាទ/ចាស លុប',
            cancelButtonText: 'បោះបង់'
        }).then((result) => {
            if (result.isConfirmed) {
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Student/Delete',
                    type: 'POST',
                    data: { id: id },
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'ជោគជ័យ!',
                                text: response.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                loadStudents();
                                loadStats();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'កំហុស',
                                text: response.message
                            });
                        }
                    },
                    error: function(xhr, status, error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'កំហុស',
                            text: 'មានបញ្ហាបច្ចេកទេស'
                        });
                    }
                });
            }
        });
    }

    function showError(message) {
        $('#studentTableBody').html(`
            <tr>
                <td colspan="6" class="text-center py-5">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-danger">${message}</h5>
                    <button class="btn btn-primary mt-3" onclick="loadStudents()">
                        <i class="bi bi-arrow-clockwise me-2"></i>ព្យាយាមម្តងទៀត
                    </button>
                </td>
            </tr>
        `);
    }

    // Search on keyup
    $('#searchInput').on('keyup', function() {
        applyFilter();
    });
</script>