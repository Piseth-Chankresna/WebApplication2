<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HRU Dashboard - Professional Sync</title>

    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
                :root {
                        --hru-blue: #2b59ff;
                        --main-font: 'Kantumruy Pro', sans-serif;
                        --bg-light: #f4f7fe;

        }

                body {
                        font-family: var(--main-font);
                        background-color: var(--bg-light);
                        color: #334155;
                        margin: 0;
                        padding: 20px;

        }

                .report-card {
                        background: white;
                        border: none;
                        border-radius: 20px;
                        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
                        padding: 25px;
                        margin-bottom: 25px;

        }

                .header-section {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        margin-bottom: 30px;

        }

                    .header-section h2 {
                            font-weight: 700;
                            color: #1e293b;
                            font-size: 1.5rem;
                            margin: 0;

        }

                .stat-box {
                        border-radius: 20px;
                        padding: 22px;
                        color: white;
                        position: relative;
                        overflow: hidden;
                        transition: transform 0.3s ease;
                        min-height: 130px;
                        display: flex;
                        flex-direction: column;
                        justify-content: center;
                        box-shadow: 0 8px 20px rgba(0,0,0,0.08);

        }

                    .stat-box:hover {
                            transform: translateY(-5px);

        }

                .bg-gradient-blue {
                        background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);

        }

                .bg-gradient-purple {
                        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

        }

                .bg-gradient-emerald {
                        background: linear-gradient(135deg, #059669 0%, #34d399 100%);

        }

                .bg-gradient-rose {
                        background: linear-gradient(135deg, #e11d48 0%, #fb7185 100%);

        }

                .stat-box i {
                        position: absolute;
                        right: -10px;
                        bottom: -10px;
                        font-size: 4.5rem;
                        opacity: 0.25;

        }

                .stat-box h6 {
                        font-size: 0.9rem;
                        margin-bottom: 8px;
                        opacity: 0.9;
                        font-weight: 400;

        }

                .stat-box h2 {
                        font-size: 1.8rem;
                        margin: 0;
                        font-weight: 700;

        }

                .table-header-custom {
                        background: #fff;
                        border-radius: 15px 15px 0 0;
                        padding: 20px;
                        border-bottom: 2px solid #f1f5f9;
                        display: flex;
                        justify-content: space-between;
                        align-items: center;

        }

                .table-title {
                        color: #ef4444;
                        font-weight: 700;
                        margin: 0;

        }

                .debt-badge-info {
                        background: rgba(239, 68, 68, 0.1);
                        color: #ef4444;
                        padding: 6px 16px;
                        border-radius: 12px;
                        font-weight: 600;
                        font-size: 0.9rem;
                        border: 1px solid rgba(239, 68, 68, 0.2);

        }

                .custom-table {
                        background: white;
                        border-radius: 0 0 15px 15px;
                        overflow: hidden;

        }

                .table thead th {
                        background: #f8fafc;
                        text-transform: uppercase;
                        font-size: 0.75rem;
                        color: #64748b;
                        padding: 15px;
                        border: none;

        }

                .btn-action {
                        border-radius: 10px;
                        padding: 8px 16px;
                        font-weight: 600;
                        transition: 0.2s;

        }

                .btn-sync {
                        background: var(--hru-blue);
                        color: white;
                        border: none;

        }

                .btn-excel {
                        background: #10b981;
                        color: white;
                        border: none;
                        margin-right: 8px;

        }


    </style>
</head>
<body>

    <div class="container-fluid">
        <div class="header-section">
            <div>
                <h2><i class="fa-solid fa-chart-pie me-2 text-primary"></i>របាយការណ៍សង្ខេប</h2>
                <p class="text-muted small mb-0">អាប់ដេតចុងក្រោយ៖ <span id="lastUpdate">--/--/--</span></p>
            </div>
            <div>
                <button class="btn btn-excel btn-action" onclick="exportToExcel()">
                    <i class="fa-solid fa-file-excel me-1"></i> នាំចេញ Excel
                </button>
                <button class="btn btn-sync btn-action" onclick="refreshAllData()">
                    <i class="fa-solid fa-rotate me-1"></i> អាប់ដេតទិន្នន័យ
                </button>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="stat-box bg-gradient-blue shadow-sm">
                    <h6>ចំនួនសិស្សសរុប</h6>
                    <h2 id="txtTotalStudents">0</h2>
                    <i class="fa-solid fa-users"></i>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-box bg-gradient-purple shadow-sm">
                    <h6>អវត្តមានសរុប</h6>
                    <h2 id="txtAbsent">0</h2>
                    <i class="fa-solid fa-user-xmark"></i>
                    <div class="mt-2"><button class="btn btn-sm text-white p-0 small opacity-75" onclick="editManualValue('absent')">កែសម្រួល</button></div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-box bg-gradient-emerald shadow-sm">
                    <h6>បង់ប្រាក់រួច (%)</h6>
                    <h2 id="txtPaidPerc">0%</h2>
                    <i class="fa-solid fa-money-bill-check"></i>
                    <div class="mt-2"><button class="btn btn-sm text-white p-0 small opacity-75" onclick="editManualValue('paid')">Manual %</button></div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat-box bg-gradient-rose shadow-sm">
                    <h6>ជំពាក់ប្រាក់ (%)</h6>
                    <h2 id="txtDebtPerc">0%</h2>
                    <i class="fa-solid fa-file-invoice-dollar"></i>
                    <div class="mt-2"><button class="btn btn-sm text-white p-0 small opacity-75" onclick="editManualValue('debt')">Manual %</button></div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                <div class="report-card">
                    <h6 class="fw-bold mb-4">ស្ថិតិសិស្ស (Bar Chart)</h6>
                    <div style="height: 300px;"><canvas id="summaryChart"></canvas></div>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="report-card">
                    <h6 class="fw-bold mb-4">កម្រិតសិក្សា (Degree)</h6>
                    <div style="height: 300px;"><canvas id="degreeChart"></canvas></div>
                </div>
            </div>
        </div>

        <div class="mt-4 shadow-sm border-0">
            <div class="table-header-custom">
                <h5 class="table-title"><i class="fa-solid fa-circle-exclamation me-2"></i>បញ្ជីសិស្សមិនទាន់បង់ប្រាក់</h5>
                <div class="d-flex gap-2">
                    <div class="debt-badge-info" id="debtCountBadge">សិស្សជំពាក់៖ 0 នាក់</div>
                    <div class="debt-badge-info" id="debtPercentBadge">ស្មើនឹង៖ 0%</div>
                </div>
            </div>
            <div class="custom-table table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>ID / ឈ្មោះសិស្ស</th>
                            <th>ភេទ</th>
                            <th>ជំនាញ/ថ្នាក់</th>
                            <th>កម្រិតសិក្សា</th>
                            <th>លេខទូរស័ព្ទ</th>
                            <th>ស្ថានភាព</th>
                        </tr>
                    </thead>
                    <tbody id="debtTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        const refreshAllData = () => {
            const students = JSON.parse(localStorage.getItem('students')) || [];
            const payments = JSON.parse(localStorage.getItem('payment_history')) || [];
            const manualStats = JSON.parse(localStorage.getItem('dashboard_manual_stats')) || null;

            const paidIdsSet = new Set(payments.map(p => (p.studentId || p.id || "").toString().trim()));
            const paidNamesSet = new Set(payments.map(p => (p.name || p.fullName || "").trim().toLowerCase()));

            const debtStudents = students.filter(s => {
                const sId = (s.studentId || s.id || "").toString().trim();
                const sName = (s.name || s.fullName || "").trim().toLowerCase();
                const isPaidById = sId !== "" && paidIdsSet.has(sId);
                const isPaidByName = sName !== "" && paidNamesSet.has(sName);
                return !(isPaidById || isPaidByName);
            });

            document.getElementById('lastUpdate').innerText = new Date().toLocaleString('km-KH');

            const totalS = students.length;
            const countDebt = debtStudents.length;
            const countPaid = totalS - countDebt;

            let paidPerc = totalS > 0 ? Math.round((countPaid / totalS) * 100) : 0;
            let debtPerc = totalS > 0 ? Math.round((countDebt / totalS) * 100) : 0;

            if (manualStats) {
                if (manualStats.paid !== undefined) paidPerc = manualStats.paid;
                if (manualStats.debt !== undefined) debtPerc = manualStats.debt;
            }

            document.getElementById('txtTotalStudents').innerText = totalS;
            document.getElementById('txtAbsent').innerText = (manualStats && manualStats.absent !== undefined) ? manualStats.absent : 0;
            document.getElementById('txtPaidPerc').innerText = paidPerc + '%';
            document.getElementById('txtDebtPerc').innerText = debtPerc + '%';

            document.getElementById('debtCountBadge').innerText = `សិស្សជំពាក់៖ ${countDebt} នាក់`;
            document.getElementById('debtPercentBadge').innerText = `ស្មើនឹង៖ ${totalS > 0 ? Math.round((countDebt / totalS) * 100) : 0}%`;

            updateCharts(students);
            renderDebtTable(debtStudents);
        };

        function renderDebtTable(debtStudents) {
            const tbody = document.getElementById('debtTableBody');
            tbody.innerHTML = '';
            if (debtStudents.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted">មិនមានសិស្សជំពាក់ប្រាក់ឡើយ 🎉</td></tr>`;
                return;
            }
            debtStudents.forEach((s, index) => {
                tbody.innerHTML += `
                    <tr>
                        <td class="text-muted small">${index + 1}</td>
                        <td class="fw-bold" style="color: #1e293b;">
                            ${s.name || s.fullName || '---'}
                            <div class="small text-muted fw-normal">ID: ${s.studentId || s.id || 'N/A'}</div>
                        </td>
                        <td>${s.gender || '---'}</td>
                        <td><span class="badge bg-light text-dark border">${s.major || s.class || '---'}</span></td>
                        <td>${s.degree || '---'}</td>
                        <td>${s.phone || s.phoneNumber || '---'}</td>
                        <td><span class="badge bg-danger rounded-pill px-3">មិនទាន់បង់</span></td>
                    </tr>`;
            });
        }

        function updateCharts(students) {
            // 1. Bar Chart
            const barCtx = document.getElementById('summaryChart').getContext('2d');
            if (window.myBarChart) window.myBarChart.destroy();
            window.myBarChart = new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: ['សរុប', 'ស្រី', 'ប្រុស', 'សិស្សថ្មី'],
                    datasets: [{
                        data: [
                            students.length,
                            students.filter(s => s.gender === 'ស្រី' || s.gender === 'Female').length,
                            students.filter(s => s.gender === 'ប្រុស' || s.gender === 'Male').length,
                            students.filter(s => s.status === 'សិស្សថ្មី' || s.isNew === true).length
                        ],
                        backgroundColor: ['#2b59ff', '#f472b6', '#60a5fa', '#fbbf24'],
                        borderRadius: 8
                    }]
                },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
            });

            // 2. Degree Chart (Fixed & Improved)
            const degCtx = document.getElementById('degreeChart').getContext('2d');
            const counts = { 'បរិញ្ញាបត្ររង': 0, 'បរិញ្ញាបត្រ': 0, 'បរិញ្ញាបត្រជាន់ខ្ពស់': 0 };

            students.forEach(s => {
                const d = (s.degree || "").toString();
                if (d.includes('Bachelor') || d.includes('បរិញ្ញាបត្រ')) {
                    counts['បរិញ្ញាបត្រ']++;
                } else if (d.includes('Associate') || d.includes('បរិញ្ញាបត្ររង')) {
                    counts['បរិញ្ញាបត្ររង']++;
                } else if (d.includes('Master') || d.includes('បរិញ្ញាបត្រជាន់ខ្ពស់')) {
                    counts['បរិញ្ញាបត្រជាន់ខ្ពស់']++;
                }
            });

            if (window.myDoughnutChart) window.myDoughnutChart.destroy();
            window.myDoughnutChart = new Chart(degCtx, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(counts),
                    datasets: [{
                        data: Object.values(counts),
                        backgroundColor: ['#4facfe', '#667eea', '#f093fb']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { family: 'Kantumruy Pro' } } }
                    }
                }
            });
        }

        async function editManualValue(type) {
            const { value: newVal } = await Swal.fire({
                title: `កែសម្រួលទិន្នន័យ ${type}`,
                input: 'number',
                inputLabel: 'បញ្ចូលតួលេខថ្មី',
                confirmButtonText: 'យល់ព្រម',
                showCancelButton: true
            });
            if (newVal !== null && newVal !== "") {
                let stats = JSON.parse(localStorage.getItem('dashboard_manual_stats')) || {};
                stats[type] = Number(newVal);
                localStorage.setItem('dashboard_manual_stats', JSON.stringify(stats));
                refreshAllData();
            }
        }

        function exportToExcel() {
            const students = JSON.parse(localStorage.getItem('students')) || [];
            if(students.length === 0) return Swal.fire('គ្មានទិន្នន័យ', 'មិនមានទិន្នន័យសិស្សសម្រាប់ទាញចេញទេ', 'warning');
            const ws = XLSX.utils.json_to_sheet(students);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Student_Report");
            XLSX.writeFile(wb, "HRU_System_Report.xlsx");
        }

        document.addEventListener('DOMContentLoaded', refreshAllData);
    </script>
</body>
</html>