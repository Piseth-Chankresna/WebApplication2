@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "របាយការណ៍";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

    .date-filter {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

    [data-theme="dark"] .date-filter {
        background: #1e293b;
        border-color: #334155;
    }

    .date-range {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .date-input {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .date-input label {
            font-weight: 600;
            color: #475569;
        }

    [data-theme="dark"] .date-input label {
        color: #cbd5e1;
    }

    .date-input input {
        padding: 8px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .date-input input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-generate {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-generate:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(139,92,246,0.3);
        }

    .btn-export {
        background: #10b981;
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-export:hover {
            background: #059669;
            transform: translateY(-2px);
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #8b5cf6;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .charts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 24px;
        margin-bottom: 30px;
    }

    .chart-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .chart-card {
        background: #1e293b;
        border-color: #334155;
    }

    .chart-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

        .chart-header h5 {
            font-weight: 700;
            color: #1e293b;
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    [data-theme="dark"] .chart-header h5 {
        color: white;
    }

    .chart-header i {
        color: #8b5cf6;
        font-size: 1.2rem;
    }

    .chart-container {
        height: 300px;
        position: relative;
    }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        margin-bottom: 30px;
        overflow-x: auto;
    }

    [data-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .reports-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1000px;
    }

        .reports-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-theme="dark"] .reports-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .reports-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .reports-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .reports-table tbody tr:hover {
        background: #f8fafc;
    }

    [data-theme="dark"] .reports-table tbody tr:hover {
        background: #0f172a;
    }

    .badge-success {
        background: #d1fae5;
        color: #10b981;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-warning {
        background: #fef3c7;
        color: #f59e0b;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-danger {
        background: #fee2e2;
        color: #ef4444;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .summary-section {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        margin-top: 30px;
    }

    .summary-box {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        border-radius: 24px;
        padding: 24px;
        color: white;
    }

        .summary-box .label {
            font-size: 0.9rem;
            opacity: 0.8;
            margin-bottom: 8px;
        }

        .summary-box .value {
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 4px;
        }

        .summary-box .trend {
            font-size: 0.85rem;
            opacity: 0.9;
        }

    .trend-up {
        color: #10b981;
    }

    .trend-down {
        color: #ef4444;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .charts-grid {
            grid-template-columns: 1fr;
        }

        .summary-section {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .date-filter {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="page-header">
    <h2><i class="bi bi-graph-up-arrow me-2"></i>របាយការណ៍ និងស្ថិតិ</h2>
    <p class="text-muted">មើលរបាយការណ៍ និងវិភាគទិន្នន័យសិស្ស</p>
</div>

<!-- Date Filter -->
<div class="date-filter">
    <div class="date-range">
        <div class="date-input">
            <label>ចាប់ពីថ្ងៃទី:</label>
            <input type="date" id="startDate" value="@DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd")">
        </div>
        <div class="date-input">
            <label>ដល់ថ្ងៃទី:</label>
            <input type="date" id="endDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
        </div>
        <button class="btn-generate" onclick="generateReports()">
            <i class="bi bi-arrow-repeat"></i>
            ដំណើរការ
        </button>
    </div>
    <button class="btn-export" onclick="exportReports()">
        <i class="bi bi-file-earmark-excel"></i>
        នាំចេញ Excel
    </button>
</div>

<!-- Summary Stats -->
<div class="stats-grid" id="statsGrid">
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-cash-stack stat-icon"></i>
        <div class="stat-value" id="totalPayments">$0</div>
        <div class="stat-label">បង់ប្រាក់សរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-calendar-check stat-icon"></i>
        <div class="stat-value" id="avgAttendance">0%</div>
        <div class="stat-label">វត្តមានមធ្យម</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-bar-chart stat-icon"></i>
        <div class="stat-value" id="avgGrade">0.0</div>
        <div class="stat-label">ពិន្ទុមធ្យម</div>
    </div>
</div>

<!-- Charts -->
<div class="charts-grid">
    <!-- Student Distribution by Major -->
    <div class="chart-card">
        <div class="chart-header">
            <h5><i class="bi bi-pie-chart-fill"></i> សិស្សតាមជំនាញ</h5>
        </div>
        <div class="chart-container">
            <canvas id="majorChart"></canvas>
        </div>
    </div>

    <!-- Student Distribution by Year -->
    <div class="chart-card">
        <div class="chart-header">
            <h5><i class="bi bi-bar-chart-fill"></i> សិស្សតាមឆ្នាំសិក្សា</h5>
        </div>
        <div class="chart-container">
            <canvas id="yearChart"></canvas>
        </div>
    </div>
</div>

<!-- Attendance Trends -->
<div class="chart-card" style="margin-bottom: 30px;">
    <div class="chart-header">
        <h5><i class="bi bi-graph-up"></i> វត្តមានប្រចាំខែ</h5>
    </div>
    <div class="chart-container">
        <canvas id="attendanceChart"></canvas>
    </div>
</div>

<!-- Detailed Report Table -->
<div class="table-container">
    <h5 class="fw-bold mb-4"><i class="bi bi-table me-2"></i>របាយការណ៍លម្អិត</h5>
    <table class="reports-table">
        <thead>
            <tr>
                <th>ថ្ងៃខែឆ្នាំ</th>
                <th>ប្រភេទ</th>
                <th>ចំនួនសិស្ស</th>
                <th>វត្តមាន</th>
                <th>អវត្តមាន</th>
                <th>ការបង់ប្រាក់</th>
                <th>ពិន្ទុមធ្យម</th>
            </tr>
        </thead>
        <tbody id="reportTableBody">
            <!-- Data will be loaded here -->
        </tbody>
    </table>
</div>

<!-- Summary Boxes -->
<div class="summary-section" id="summaryBoxes">
    <div class="summary-box">
        <div class="label">សិស្សពូកែ (GPA > 3.5)</div>
        <div class="value" id="topStudents">0</div>
        <div class="trend trend-up">+5% ពីខែមុន</div>
    </div>
    <div class="summary-box" style="background: linear-gradient(135deg, #10b981, #059669);">
        <div class="label">សិស្សដែលត្រូវការជំនួយ</div>
        <div class="value" id="helpNeeded">0</div>
        <div class="trend">ត្រូវការការយកចិត្តទុកដាក់</div>
    </div>
    <div class="summary-box" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
        <div class="label">ប្រាក់ចំណូលប្រចាំខែ</div>
        <div class="value" id="monthlyRevenue">$0</div>
        <div class="trend trend-up">+12% ពីខែមុន</div>
    </div>
</div>

<script>
    let students = [];
    let payments = [];
    let attendances = [];
    let grades = [];

    // Chart instances
    let majorChart, yearChart, attendanceChart;

    $(document).ready(function() {
        loadAllData();
    });

    function loadAllData() {
        Promise.all([
            loadStudents(),
            loadPayments(),
            loadAttendances(),
            loadGrades()
        ]).then(() => {
            generateReports();
        });
    }

    function loadStudents() {
        return $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            success: function(data) {
                students = data;
            }
        });
    }

    function loadPayments() {
        return $.ajax({
            url: '/Student/GetPayments',
            type: 'GET',
            success: function(data) {
                payments = data;
            }
        });
    }

    function loadAttendances() {
        return $.ajax({
            url: '/Student/GetAttendance',
            type: 'GET',
            success: function(data) {
                attendances = data;
            }
        });
    }

    function loadGrades() {
        return $.ajax({
            url: '/Student/GetGrades',
            type: 'GET',
            success: function(data) {
                grades = data;
            }
        });
    }

    function generateReports() {
        updateStats();
        updateCharts();
        updateReportTable();
        updateSummaryBoxes();
    }

    function updateStats() {
        var startDate = new Date($('#startDate').val());
        var endDate = new Date($('#endDate').val());

        // Filter data by date range
        var filteredPayments = payments.filter(p => {
            var date = new Date(p.paymentDate);
            return date >= startDate && date <= endDate;
        });

        var filteredAttendances = attendances.filter(a => {
            var date = new Date(a.date);
            return date >= startDate && date <= endDate;
        });

        // Calculate stats
        var totalStudents = students.length;
        var totalPayments = filteredPayments.reduce((sum, p) => sum + (p.amount || 0), 0);

        var attendanceRate = 0;
        if (filteredAttendances.length > 0) {
            var present = filteredAttendances.filter(a => a.status === 'P').length;
            attendanceRate = (present / filteredAttendances.length * 100).toFixed(1);
        }

        var avgGrade = 0;
        if (grades.length > 0) {
            avgGrade = (grades.reduce((sum, g) => sum + (g.total || 0), 0) / grades.length).toFixed(1);
        }

        $('#totalStudents').text(totalStudents);
        $('#totalPayments').text('$' + totalPayments.toFixed(2));
        $('#avgAttendance').text(attendanceRate + '%');
        $('#avgGrade').text(avgGrade);
    }

    function updateCharts() {
        // Destroy existing charts
        if (majorChart) majorChart.destroy();
        if (yearChart) yearChart.destroy();
        if (attendanceChart) attendanceChart.destroy();

        // Major Distribution Chart
        var majorCounts = {};
        students.forEach(s => {
            var major = s.major || 'មិនមាន';
            majorCounts[major] = (majorCounts[major] || 0) + 1;
        });

        var majorCtx = document.getElementById('majorChart').getContext('2d');
        majorChart = new Chart(majorCtx, {
            type: 'pie',
            data: {
                labels: Object.keys(majorCounts),
                datasets: [{
                    data: Object.values(majorCounts),
                    backgroundColor: [
                        '#8b5cf6', '#10b981', '#f59e0b', '#ef4444', '#3b82f6',
                        '#ec4899', '#14b8a6', '#f97316', '#6366f1', '#84cc16'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // Year Distribution Chart
        var yearCounts = { 'ឆ្នាំទី១': 0, 'ឆ្នាំទី២': 0, 'ឆ្នាំទី៣': 0, 'ឆ្នាំទី៤': 0 };
        students.forEach(s => {
            var year = s.year || '1';
            yearCounts[`ឆ្នាំទី${year}`] = (yearCounts[`ឆ្នាំទី${year}`] || 0) + 1;
        });

        var yearCtx = document.getElementById('yearChart').getContext('2d');
        yearChart = new Chart(yearCtx, {
            type: 'bar',
            data: {
                labels: Object.keys(yearCounts),
                datasets: [{
                    label: 'ចំនួនសិស្ស',
                    data: Object.values(yearCounts),
                    backgroundColor: '#8b5cf6',
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });

        // Attendance Trend Chart
        var months = ['មករា', 'កុម្ភៈ', 'មីនា', 'មេសា', 'ឧសភា', 'មិថុនា',
                      'កក្កដា', 'សីហា', 'កញ្ញា', 'តុលា', 'វិច្ឆិកា', 'ធ្នូ'];

        var monthlyAttendance = {};
        attendances.forEach(a => {
            var date = new Date(a.date);
            var monthKey = `${date.getFullYear()}-${date.getMonth() + 1}`;
            var monthName = months[date.getMonth()];

            if (!monthlyAttendance[monthKey]) {
                monthlyAttendance[monthKey] = {
                    month: monthName,
                    present: 0,
                    total: 0
                };
            }
            monthlyAttendance[monthKey].total++;
            if (a.status === 'P') monthlyAttendance[monthKey].present++;
        });

        var sortedMonths = Object.keys(monthlyAttendance).sort().slice(-6);
        var attendanceData = sortedMonths.map(key => {
            var m = monthlyAttendance[key];
            return ((m.present / m.total) * 100).toFixed(1);
        });
        var monthLabels = sortedMonths.map(key => monthlyAttendance[key].month);

        var attendanceCtx = document.getElementById('attendanceChart').getContext('2d');
        attendanceChart = new Chart(attendanceCtx, {
            type: 'line',
            data: {
                labels: monthLabels,
                datasets: [{
                    label: 'វត្តមាន (%)',
                    data: attendanceData,
                    borderColor: '#8b5cf6',
                    backgroundColor: 'rgba(139,92,246,0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, max: 100 }
                }
            }
        });
    }

    function updateReportTable() {
        var tbody = $('#reportTableBody');
        tbody.empty();

        var startDate = new Date($('#startDate').val());
        var endDate = new Date($('#endDate').val());

        // Group by date
        var reports = {};

        attendances.forEach(a => {
            var date = new Date(a.date);
            if (date >= startDate && date <= endDate) {
                var dateKey = a.date;
                if (!reports[dateKey]) {
                    reports[dateKey] = {
                        date: dateKey,
                        present: 0,
                        absent: 0,
                        late: 0,
                        total: 0
                    };
                }
                reports[dateKey].total++;
                if (a.status === 'P') reports[dateKey].present++;
                else if (a.status === 'A') reports[dateKey].absent++;
                else if (a.status === 'L') reports[dateKey].late++;
            }
        });

        payments.forEach(p => {
            var date = new Date(p.paymentDate);
            if (date >= startDate && date <= endDate) {
                var dateKey = p.paymentDate.split('T')[0];
                if (!reports[dateKey]) {
                    reports[dateKey] = {
                        date: dateKey,
                        payments: 0,
                        present: 0,
                        absent: 0,
                        late: 0,
                        total: 0
                    };
                }
                reports[dateKey].payments = (reports[dateKey].payments || 0) + p.amount;
            }
        });

        var sortedDates = Object.keys(reports).sort().reverse();

        sortedDates.forEach(dateKey => {
            var r = reports[dateKey];
            var attendanceRate = r.total > 0 ? ((r.present / r.total) * 100).toFixed(1) : 0;

            var row = `
                <tr>
                    <td>${new Date(dateKey).toLocaleDateString('km-KH')}</td>
                    <td>ប្រចាំថ្ងៃ</td>
                    <td>${r.total || 0}</td>
                    <td><span class="badge-success">${r.present || 0} (${attendanceRate}%)</span></td>
                    <td><span class="badge-danger">${r.absent || 0}</span></td>
                    <td>$${(r.payments || 0).toFixed(2)}</td>
                    <td>-</td>
                </tr>
            `;
            tbody.append(row);
        });

        if (sortedDates.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="7" class="text-center py-5">
                        <i class="bi bi-file-text" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនមានទិន្នន័យសម្រាប់រយៈពេលនេះទេ</h5>
                    </td>
                </tr>
            `);
        }
    }

    function updateSummaryBoxes() {
        // Calculate top students (GPA > 3.5)
        var topStudents = grades.filter(g => (g.total || 0) >= 85).length;
        $('#topStudents').text(topStudents);

        // Calculate students needing help (GPA < 50 or attendance < 60%)
        var helpNeeded = 0;
        students.forEach(s => {
            var studentGrades = grades.filter(g => g.studentId === s.id);
            var avgGrade = studentGrades.reduce((sum, g) => sum + (g.total || 0), 0) / (studentGrades.length || 1);

            var studentAttendances = attendances.filter(a => a.studentId === s.id);
            var attendanceRate = studentAttendances.length > 0
                ? (studentAttendances.filter(a => a.status === 'P').length / studentAttendances.length * 100)
                : 100;

            if (avgGrade < 50 || attendanceRate < 60) {
                helpNeeded++;
            }
        });
        $('#helpNeeded').text(helpNeeded);

        // Calculate monthly revenue
        var currentMonth = new Date().getMonth();
        var monthlyRevenue = payments.filter(p => {
            var date = new Date(p.paymentDate);
            return date.getMonth() === currentMonth;
        }).reduce((sum, p) => sum + (p.amount || 0), 0);
        $('#monthlyRevenue').text('$' + monthlyRevenue.toFixed(2));
    }

    function exportReports() {
        var wb = XLSX.utils.book_new();

        // Summary sheet
        var summaryData = [
            ['របាយការណ៍សង្ខេប'],
            ['ចាប់ពីថ្ងៃទី', $('#startDate').val()],
            ['ដល់ថ្ងៃទី', $('#endDate').val()],
            [],
            ['ប្រភេទ', 'ចំនួន'],
            ['សិស្សសរុប', $('#totalStudents').text()],
            ['បង់ប្រាក់សរុប', $('#totalPayments').text()],
            ['វត្តមានមធ្យម', $('#avgAttendance').text()],
            ['ពិន្ទុមធ្យម', $('#avgGrade').text()]
        ];

        var ws1 = XLSX.utils.aoa_to_sheet(summaryData);
        XLSX.utils.book_append_sheet(wb, ws1, 'សង្ខេប');

        // Students sheet
        var studentsData = [['ID', 'ឈ្មោះ', 'ភេទ', 'ជំនាញ', 'ឆ្នាំ', 'វេន', 'បន្ទប់', 'អាហារូបករណ៍']];
        students.forEach(s => {
            studentsData.push([
                s.id,
                s.name,
                s.gender,
                s.major,
                'ឆ្នាំទី' + (s.year || '?'),
                s.shift,
                s.room,
                s.scholarship || '0%'
            ]);
        });

        var ws2 = XLSX.utils.aoa_to_sheet(studentsData);
        XLSX.utils.book_append_sheet(wb, ws2, 'សិស្ស');

        // Generate Excel file
        XLSX.writeFile(wb, 'HRU_Report.xlsx');
    }
</script>