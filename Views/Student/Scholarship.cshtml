@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "អាហារូបករណ៍";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #f97316;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #f97316, #ea580c);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #f97316;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .filter-section {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
        }

    [data-theme="dark"] .filter-item label {
        color: #cbd5e1;
    }

    .filter-item select,
    .filter-item input {
        padding: 10px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .filter-item select,
    [data-theme="dark"] .filter-item input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-filter {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(249,115,22,0.3);
        }

    .scholarship-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 24px;
        margin-top: 30px;
    }

    .scholarship-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .scholarship-card {
        background: #1e293b;
        border-color: #334155;
    }

    .scholarship-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(249,115,22,0.1);
        border-color: #f97316;
    }

    .scholarship-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #f97316, #ea580c);
    }

    .card-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 20px;
    }

    .student-avatar-large {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #f97316, #ea580c);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 800;
        font-size: 1.5rem;
        overflow: hidden;
    }

        .student-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .student-info h4 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .student-info h4 {
        color: white;
    }

    .student-info p {
        color: #64748b;
        margin: 0;
        font-size: 0.9rem;
    }

    .scholarship-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 40px;
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 15px;
    }

    .badge-100 {
        background: #fef3c7;
        color: #f97316;
    }

    .badge-75 {
        background: #ffedd5;
        color: #ea580c;
    }

    .badge-50 {
        background: #dbeafe;
        color: #2563eb;
    }

    .badge-25 {
        background: #dcfce7;
        color: #16a34a;
    }

    .badge-0 {
        background: #f1f5f9;
        color: #64748b;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .info-row {
        border-bottom-color: #334155;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: #64748b;
        font-weight: 500;
    }

    .info-value {
        font-weight: 700;
        color: #1e293b;
    }

    [data-theme="dark"] .info-value {
        color: white;
    }

    .amount-due {
        color: #ef4444;
        font-weight: 700;
    }

    .amount-paid {
        color: #10b981;
        font-weight: 700;
    }

    .progress-section {
        margin: 20px 0;
    }

    .progress-label {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .progress-bar {
        height: 8px;
        background: #e2e8f0;
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, #f97316, #ea580c);
        border-radius: 4px;
        transition: width 0.3s ease;
    }

    .card-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn-action {
        flex: 1;
        padding: 10px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #475569;
        font-weight: 600;
        transition: all 0.3s ease;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    [data-theme="dark"] .btn-action {
        background: #0f172a;
        border-color: #334155;
        color: #cbd5e1;
    }

    .btn-action:hover {
        background: linear-gradient(135deg, #f97316, #ea580c);
        border-color: transparent;
        color: white;
        transform: translateY(-2px);
    }

    .summary-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-top: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .summary-section {
        background: #1e293b;
        border-color: #334155;
    }

    .summary-title {
        font-weight: 700;
        margin-bottom: 20px;
        color: #1e293b;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    [data-theme="dark"] .summary-title {
        color: white;
    }

    .summary-title i {
        color: #f97316;
        font-size: 1.5rem;
    }

    .summary-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
    }

    .summary-item {
        text-align: center;
        padding: 15px;
        background: #f8fafc;
        border-radius: 16px;
    }

    [data-theme="dark"] .summary-item {
        background: #0f172a;
    }

    .summary-item .value {
        font-size: 1.8rem;
        font-weight: 800;
        color: #f97316;
        margin-bottom: 5px;
    }

    .summary-item .label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .edit-modal .modal-content {
        border-radius: 24px;
    }

    .scholarship-options {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin: 20px 0;
    }

    .scholarship-option {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .scholarship-option:hover {
            border-color: #f97316;
            background: #fff7ed;
        }

    [data-theme="dark"] .scholarship-option:hover {
        background: #1e293b;
    }

    .scholarship-option.selected {
        border-color: #f97316;
        background: #fff7ed;
    }

    [data-theme="dark"] .scholarship-option.selected {
        background: #1e293b;
    }

    .scholarship-option .percentage {
        font-size: 2rem;
        font-weight: 800;
        color: #f97316;
        margin-bottom: 8px;
    }

    .scholarship-option .label {
        color: #64748b;
        font-size: 0.9rem;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .summary-stats {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .summary-stats {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- AntiForgeryToken Form -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-gift-fill me-2"></i>អាហារូបករណ៍</h2>
    <p class="text-muted">គ្រប់គ្រងអាហារូបករណ៍របស់សិស្ស</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-gift-fill stat-icon"></i>
        <div class="stat-value" id="totalScholarship">0</div>
        <div class="stat-label">មានអាហារូបករណ៍</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-star-fill stat-icon"></i>
        <div class="stat-value" id="avgScholarship">0%</div>
        <div class="stat-label">អាហារូបករណ៍មធ្យម</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-cash-stack stat-icon"></i>
        <div class="stat-value" id="totalAmount">$0</div>
        <div class="stat-label">ទឹកប្រាក់សរុប</div>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-grid">
        <div class="filter-item">
            <label>ជំនាញ</label>
            <select id="filterMajor" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ឆ្នាំសិក្សា</label>
            <select id="filterYear" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="1">ឆ្នាំទី១</option>
                <option value="2">ឆ្នាំទី២</option>
                <option value="3">ឆ្នាំទី៣</option>
                <option value="4">ឆ្នាំទី៤</option>
            </select>
        </div>

        <div class="filter-item">
            <label>កម្រិតអាហារូបករណ៍</label>
            <select id="filterLevel" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="100%">100%</option>
                <option value="75%">75%</option>
                <option value="50%">50%</option>
                <option value="25%">25%</option>
                <option value="0%">0% (គ្មាន)</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ស្វែងរក</label>
            <input type="text" id="searchInput" placeholder="ឈ្មោះ ឬលេខសម្គាល់...">
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn-filter" onclick="applyFilter()">
            <i class="bi bi-search"></i>
            ស្វែងរក
        </button>
        <button class="btn-filter" onclick="resetFilter()" style="background: #64748b;">
            <i class="bi bi-arrow-counterclockwise"></i>
            កំណត់ឡើងវិញ
        </button>
    </div>
</div>

<!-- Scholarship Cards Grid -->
<div class="scholarship-grid" id="scholarshipGrid">
    <!-- Cards will be loaded here -->
</div>

<!-- Summary Section -->
<div class="summary-section">
    <div class="summary-title">
        <i class="bi bi-pie-chart-fill"></i>
        <span>សង្ខេបតាមកម្រិតអាហារូបករណ៍</span>
    </div>

    <div class="summary-stats" id="scholarshipSummary">
        <!-- Summary stats will be loaded here -->
    </div>
</div>

<!-- Edit Scholarship Modal -->
<div class="modal fade edit-modal" id="scholarshipModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: linear-gradient(135deg, #f97316, #ea580c);">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square me-2"></i>
                    កែប្រែអាហារូបករណ៍
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="scholarshipForm">
                    <input type="hidden" id="studentId">

                    <div class="text-center mb-4">
                        <div class="student-avatar-large" style="width: 100px; height: 100px; font-size: 2.5rem; margin: 0 auto;" id="studentInitials">?</div>
                        <h5 class="mt-3" id="studentName"></h5>
                        <p class="text-muted" id="studentInfo"></p>
                    </div>

                    <div class="form-group">
                        <label class="form-label fw-bold">ជ្រើសរើសកម្រិតអាហារូបករណ៍</label>
                        <div class="scholarship-options" id="scholarshipOptions">
                            <div class="scholarship-option" onclick="selectScholarship('100%', this)">
                                <div class="percentage">100%</div>
                                <div class="label">ពេញ</div>
                            </div>
                            <div class="scholarship-option" onclick="selectScholarship('75%', this)">
                                <div class="percentage">75%</div>
                                <div class="label">ច្រើន</div>
                            </div>
                            <div class="scholarship-option" onclick="selectScholarship('50%', this)">
                                <div class="percentage">50%</div>
                                <div class="label">ពាក់កណ្តាល</div>
                            </div>
                            <div class="scholarship-option" onclick="selectScholarship('25%', this)">
                                <div class="percentage">25%</div>
                                <div class="label">តិច</div>
                            </div>
                            <div class="scholarship-option" onclick="selectScholarship('0%', this)">
                                <div class="percentage">0%</div>
                                <div class="label">គ្មាន</div>
                            </div>
                        </div>
                        <input type="hidden" id="scholarshipValue">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">បោះបង់</button>
                <button type="button" class="btn-save" onclick="saveScholarship()">រក្សាទុក</button>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/sweetalert2@11"></script>
<script>
    let allStudents = [];
    let filteredStudents = [];

    $(document).ready(function() {
        loadStudents();
    });

    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            cache: false,
            success: function(response) {
                console.log("Students response:", response);

                if (response && response.success) {
                    allStudents = response.data || [];
                } else if (Array.isArray(response)) {
                    allStudents = response;
                } else {
                    allStudents = [];
                }

                filteredStudents = [...allStudents];
                displayScholarshipCards();
                updateStats();
                generateSummary();
            },
            error: function(xhr, status, error) {
                console.error('Error loading students:', error);
                showError('មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ');
            }
        });
    }

    function displayScholarshipCards() {
        var grid = $('#scholarshipGrid');
        grid.empty();

        if (!Array.isArray(filteredStudents) || filteredStudents.length === 0) {
            grid.html(`
                <div class="text-center py-5" style="grid-column: 1 / -1;">
                    <i class="bi bi-gift" style="font-size: 4rem; color: #cbd5e1;"></i>
                    <h5 class="mt-3 text-muted">មិនមានទិន្នន័យសិស្សនៅឡើយទេ</h5>
                </div>
            `);
            return;
        }

        filteredStudents.forEach(s => {
            var scholarshipPercent = parseInt(s.scholarship) || 0;
            var badgeClass = scholarshipPercent >= 100 ? 'badge-100' :
                            scholarshipPercent >= 75 ? 'badge-75' :
                            scholarshipPercent >= 50 ? 'badge-50' :
                            scholarshipPercent >= 25 ? 'badge-25' : 'badge-0';

            var totalDue = s.amountDue || 0;
            var scholarshipAmount = (totalDue * scholarshipPercent / 100);
            var finalAmount = totalDue - scholarshipAmount;

            var avatarHtml = s.photo ?
                `<img src="${s.photo}" alt="${s.name}" style="width: 100%; height: 100%; object-fit: cover;">` :
                (s.name ? s.name.charAt(0).toUpperCase() : '?');

            var card = `
                <div class="scholarship-card">
                    <div class="card-header">
                        <div class="student-avatar-large">
                            ${avatarHtml}
                        </div>
                        <div class="student-info">
                            <h4>${s.name || 'មិនមានឈ្មោះ'}</h4>
                            <p><i class="bi bi-upc-scan"></i> ${s.id}</p>
                            <p><i class="bi bi-star"></i> ${s.major || 'N/A'} | ឆ្នាំទី${s.year || '?'}</p>
                        </div>
                    </div>

                    <div class="text-center">
                        <span class="scholarship-badge ${badgeClass}">${s.scholarship || '0%'}</span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">ថ្លៃសិក្សាសរុប:</span>
                        <span class="info-value">$${totalDue.toFixed(2)}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">អាហារូបករណ៍ទទួលបាន:</span>
                        <span class="info-value amount-paid">-$${scholarshipAmount.toFixed(2)}</span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">ទឹកប្រាក់ត្រូវបង់:</span>
                        <span class="info-value amount-due">$${finalAmount.toFixed(2)}</span>
                    </div>

                    <div class="progress-section">
                        <div class="progress-label">
                            <span>ភាគរយអាហារូបករណ៍</span>
                            <span>${s.scholarship || '0%'}</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${scholarshipPercent}%;"></div>
                        </div>
                    </div>

                    <div class="card-actions">
                        <button class="btn-action" onclick="editScholarship('${s.id}')">
                            <i class="bi bi-pencil-square"></i>
                            កែប្រែ
                        </button>
                    </div>
                </div>
            `;
            grid.append(card);
        });
    }

    function updateStats() {
        if (!Array.isArray(allStudents)) return;

        var total = allStudents.length;
        var withScholarship = allStudents.filter(s => {
            var percent = parseInt(s.scholarship) || 0;
            return percent > 0;
        }).length;

        var avgScholarship = withScholarship > 0
            ? allStudents.filter(s => parseInt(s.scholarship) > 0)
                .reduce((sum, s) => sum + (parseInt(s.scholarship) || 0), 0) / withScholarship
            : 0;

        var totalAmount = allStudents.reduce((sum, s) => {
            var percent = parseInt(s.scholarship) || 0;
            var amount = (s.amountDue || 0) * percent / 100;
            return sum + amount;
        }, 0);

        $('#totalStudents').text(total);
        $('#totalScholarship').text(withScholarship);
        $('#avgScholarship').text(avgScholarship.toFixed(0) + '%');
        $('#totalAmount').text('$' + totalAmount.toFixed(2));
    }

    function generateSummary() {
        if (!Array.isArray(allStudents)) return;

        var levels = {
            '100%': { count: 0, total: 0 },
            '75%': { count: 0, total: 0 },
            '50%': { count: 0, total: 0 },
            '25%': { count: 0, total: 0 },
            '0%': { count: 0, total: 0 }
        };

        allStudents.forEach(s => {
            var percent = s.scholarship || '0%';
            if (levels[percent]) {
                levels[percent].count++;
                levels[percent].total += (s.amountDue || 0) * (parseInt(percent) / 100);
            }
        });

        var html = '';
        for (var level in levels) {
            var color = level === '100%' ? '#f97316' :
                       level === '75%' ? '#ea580c' :
                       level === '50%' ? '#2563eb' :
                       level === '25%' ? '#16a34a' : '#64748b';

            html += `
                <div class="summary-item">
                    <div class="value" style="color: ${color};">${levels[level].count}</div>
                    <div class="label">${level}</div>
                    <small class="text-muted">$${levels[level].total.toFixed(2)}</small>
                </div>
            `;
        }
        $('#scholarshipSummary').html(html);
    }

    function editScholarship(studentId) {
        var student = allStudents.find(s => s.id === studentId);
        if (!student) return;

        $('#studentId').val(student.id);
        $('#studentName').text(student.name || 'មិនមានឈ្មោះ');
        $('#studentInfo').text(`${student.major || 'N/A'} | ឆ្នាំទី${student.year || '?'}`);

        var initial = student.name ? student.name.charAt(0).toUpperCase() : '?';
        if (student.photo) {
            $('#studentInitials').html(`<img src="${student.photo}" style="width:100%; height:100%; object-fit:cover;">`);
        } else {
            $('#studentInitials').text(initial);
        }

        // Select current scholarship
        $('.scholarship-option').removeClass('selected');
        $(`.scholarship-option:contains('${student.scholarship || '0%'}')`).addClass('selected');
        $('#scholarshipValue').val(student.scholarship || '0%');

        $('#scholarshipModal').modal('show');
    }

    function selectScholarship(value, element) {
        $('.scholarship-option').removeClass('selected');
        $(element).addClass('selected');
        $('#scholarshipValue').val(value);
    }

    function saveScholarship() {
        var studentId = $('#studentId').val();
        var scholarship = $('#scholarshipValue').val();
        var token = $('input[name="__RequestVerificationToken"]').val();

        $('#scholarshipModal').modal('hide');

        // Show loading
        $('body').append('<div id="loading" style="position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; display:flex; align-items:center; justify-content:center;"><div style="background:white; padding:20px; border-radius:10px;"><div class="spinner-border text-primary" role="status"></div><p class="mt-2">កំពុងរក្សាទុក...</p></div></div>');

        $.ajax({
            url: '/Student/UpdateScholarship',
            type: 'POST',
            data: { id: studentId, scholarship: scholarship },
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                $('#loading').remove();

                if (response && response.success) {
                    alert('កែប្រែអាហារូបករណ៍ដោយជោគជ័យ!');
                    loadStudents(); // Reload data
                } else {
                    alert(response.message || 'មានបញ្ហាក្នុងការរក្សាទុក');
                }
            },
            error: function(xhr, status, error) {
                $('#loading').remove();
                alert('មានបញ្ហាបច្ចេកទេស: ' + error);
            }
        });
    }

    function applyFilter() {
        var major = $('#filterMajor').val();
        var year = $('#filterYear').val();
        var level = $('#filterLevel').val();
        var search = $('#searchInput').val().toLowerCase();

        filteredStudents = allStudents.filter(s => {
            var matchMajor = !major || s.major === major;
            var matchYear = !year || s.year === year;
            var matchLevel = !level || s.scholarship === level;
            var matchSearch = !search ||
                (s.name && s.name.toLowerCase().includes(search)) ||
                (s.id && s.id.toLowerCase().includes(search));

            return matchMajor && matchYear && matchLevel && matchSearch;
        });

        displayScholarshipCards();
    }

    function resetFilter() {
        $('#filterMajor').val('');
        $('#filterYear').val('');
        $('#filterLevel').val('');
        $('#searchInput').val('');
        filteredStudents = [...allStudents];
        displayScholarshipCards();
    }

    function showError(message) {
        $('#scholarshipGrid').html(`
            <div class="text-center py-5" style="grid-column: 1 / -1;">
                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                <h5 class="mt-3 text-danger">${message}</h5>
                <button class="btn btn-primary mt-3" onclick="loadStudents()">
                    <i class="bi bi-arrow-clockwise me-2"></i>ព្យាយាមម្តងទៀត
                </button>
            </div>
        `);
    }
</script>