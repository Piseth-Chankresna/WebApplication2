@model IEnumerable<YourProject.Controllers.StudentController.StudentModel>
@{
    Layout = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest" ? null : "_Layout";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

<style>
    :root {
        --khmer-font: 'Kantumruy Pro', sans-serif;
        --hru-blue: #2563eb;
        --blue-gradient: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        --success-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
        --warning-gradient: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        --danger-gradient: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        /* Color Mapping for Modes */
        --bg-page: #f8fafc;
        --bg-card: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --border-color: #edf2f7;
        --table-head-bg: #f8fafc;
        --input-bg: #f1f5f9;
        --item-hover: #f1f5f9;
    }

    /* Dark Mode Variables */
    [data-bs-theme="dark"] {
        --bg-page: #0f172a;
        --bg-card: #1e293b;
        --text-main: #f1f5f9;
        --text-muted: #94a3b8;
        --border-color: #334155;
        --table-head-bg: #0f172a;
        --input-bg: #0f172a;
        --item-hover: #334155;
    }

    body {
        font-family: var(--khmer-font);
        background-color: var(--bg-page);
        color: var(--text-main);
        transition: background-color 0.3s ease;
    }

    .attendance-list-container {
        padding: 2rem;
    }

    /* Summary Banner (Gradient stays the same for look) */
    .summary-banner {
        background: var(--blue-gradient);
        border-radius: 24px;
        padding: 35px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(37, 99, 235, 0.2);
    }

    .stat-mini-card {
        border-radius: 20px;
        padding: 22px;
        color: white;
        position: relative;
        overflow: hidden;
        transition: transform 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

        .stat-mini-card:hover {
            transform: translateY(-5px);
        }

    .bg-p {
        background: var(--success-gradient);
    }

    .bg-l {
        background: var(--warning-gradient);
    }

    .bg-a {
        background: var(--danger-gradient);
    }

    .card-icon-bg {
        position: absolute;
        right: -10px;
        bottom: -10px;
        font-size: 4rem;
        opacity: 0.2;
        transform: rotate(-15deg);
    }

    /* Filters */
    .filter-section {
        background: var(--bg-card);
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        margin-top: 25px;
        margin-bottom: 25px;
        border: 1px solid var(--border-color);
    }

    .form-label-kh {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        background-color: var(--input-bg) !important;
        color: var(--text-main) !important;
        border: 1px solid var(--border-color) !important;
    }

    /* Table Styling */
    .data-card {
        background: var(--bg-card);
        border-radius: 25px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        overflow: hidden;
        border: 1px solid var(--border-color);
    }

    .custom-table thead th {
        background-color: var(--table-head-bg);
        color: var(--text-muted);
        font-weight: 700;
        font-size: 0.75rem;
        padding: 20px;
    }

    .custom-table td {
        padding: 18px 20px;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-main);
    }

    .room-badge {
        background: rgba(37, 99, 235, 0.1);
        color: var(--hru-blue);
        padding: 6px 14px;
        border-radius: 10px;
        font-weight: 700;
    }

    /* Student Item Item in Modal */
    .student-item {
        display: flex;
        align-items: center;
        padding: 15px;
        background: var(--bg-card);
        border-radius: 18px;
        margin-bottom: 12px;
        border: 1px solid var(--border-color);
        transition: 0.2s;
    }

        .student-item:hover {
            border-color: var(--hru-blue);
            background-color: var(--item-hover);
        }

    .student-icon-avatar {
        background: rgba(37, 99, 235, 0.1);
        color: var(--hru-blue);
    }

    .modal-content {
        background-color: var(--bg-card);
        color: var(--text-main);
    }

    .text-dark {
        color: var(--text-main) !important;
    }

    .text-muted {
        color: var(--text-muted) !important;
    }
</style>

<div class="attendance-list-container animate__animated animate__fadeIn">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">ប្រវត្តិវត្តមានសិស្ស</h2>
            <p class="text-muted small">ពិនិត្យ និងគ្រប់គ្រងកំណត់ត្រាវត្តមានក្នុងប្រព័ន្ធ</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-danger border-0 fw-bold" onclick="clearAllAttendance()">
                <i class="bi bi-trash3 me-1"></i> សម្អាតទាំងអស់
            </button>
            <button class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm" onclick="exportToExcel()">
                <i class="bi bi-file-earmark-spreadsheet me-1"></i> Export Excel
            </button>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="summary-banner h-100">
                <div class="small opacity-75">ចំនួនកំណត់ត្រាសរុប</div>
                <div class="d-flex align-items-center">
                    <span class="summary-count h1 fw-bold mb-0" id="totalLogs">0</span>
                    <span class="ms-3 badge bg-white bg-opacity-25 rounded-pill px-3 py-2">កំណត់ត្រា</span>
                </div>
                <div class="mt-4 small">
                    <i class="bi bi-clock-history me-1"></i> បច្ចុប្បន្នភាព៖ @DateTime.Now.ToString("dd/MM/yyyy")
                </div>
                <i class="bi bi-journal-check card-icon-bg"></i>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-mini-card bg-p">
                <div class="small">វត្តមាន (P)</div>
                <div class="h2 fw-bold mb-0" id="grandP">0</div>
                <i class="bi bi-person-check-fill card-icon-bg"></i>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-mini-card bg-l">
                <div class="small">ច្បាប់ (L)</div>
                <div class="h2 fw-bold mb-0" id="grandL">0</div>
                <i class="bi bi-person-exclamation card-icon-bg"></i>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-mini-card bg-a">
                <div class="small">អវត្តមាន (A)</div>
                <div class="h2 fw-bold mb-0" id="grandA">0</div>
                <i class="bi bi-person-x-fill card-icon-bg"></i>
            </div>
        </div>
    </div>

    <div class="filter-section">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label-kh">ស្វែងរកបន្ទប់</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" id="searchAtt" class="form-control" placeholder="ឈ្មោះបន្ទប់..." onkeyup="filterAttendance()">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label-kh">ជំនាញ (Major)</label>
                <select id="majorFilter" class="form-select fw-bold" onchange="filterAttendance()">
                    <option value="">-- គ្រប់ជំនាញ --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label-kh">បន្ទប់/ថ្នាក់</label>
                <select id="roomFilter" class="form-select fw-bold" onchange="filterAttendance()">
                    <option value="">-- គ្រប់បន្ទប់ --</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label-kh">កាលបរិច្ឆេទ</label>
                <select id="dateSelectFilter" class="form-select fw-bold" onchange="filterAttendance()">
                    <option value="">-- គ្រប់កាលបរិច្ឆេទ --</option>
                </select>
            </div>
        </div>
    </div>

    <div class="data-card">
        <div class="table-responsive">
            <table class="custom-table w-100">
                <thead>
                    <tr>
                        <th>កាលបរិច្ឆេទ & ម៉ោង</th>
                        <th>បន្ទប់សិក្សា</th>
                        <th class="text-center">វត្តមាន (P)</th>
                        <th class="text-center">ច្បាប់ (L)</th>
                        <th class="text-center">អវត្តមាន (A)</th>
                        <th class="text-center">សកម្មភាព</th>
                    </tr>
                </thead>
                <tbody id="attendanceListBody"></tbody>
            </table>
        </div>
        <div id="noAttData" class="text-center py-5 d-none">
            <i class="bi bi-inbox display-1 text-muted opacity-25"></i>
            <h5 class="text-muted mt-3">មិនទាន់មានទិន្នន័យឡើយ</h5>
        </div>
    </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 30px;">
            <div class="modal-header border-0 p-4 pb-0">
                <h4 class="fw-bold mb-0 text-dark" id="modalTitle">បញ្ជីឈ្មោះសិស្ស</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div id="studentDetailList" style="max-height: 480px; overflow-y: auto; padding-right: 8px;"></div>
            </div>
        </div>
    </div>
</div>

<script>
    function displayAttendanceHistory() {
        const history = JSON.parse(localStorage.getItem('attendanceRecords')) || [];
        const tbody = document.getElementById('attendanceListBody');
        const noData = document.getElementById('noAttData');

        const search = document.getElementById('searchAtt').value.toLowerCase();
        const majorF = document.getElementById('majorFilter').value;
        const roomF = document.getElementById('roomFilter').value;
        const dateF = document.getElementById('dateSelectFilter').value;

        updateFilterOptions(history);

        let filtered = history.filter(item => {
            const matchSearch = (item.room || '').toLowerCase().includes(search);
            const matchDate = dateF ? item.date === dateF : true;
            const matchRoom = roomF ? item.room === roomF : true;
            let matchMajor = true;
            if (majorF && item.students) {
                matchMajor = item.students.some(s => s.major === majorF);
            }
            return matchSearch && matchDate && matchRoom && matchMajor;
        });

        document.getElementById('totalLogs').innerText = filtered.length;
        updateGrandStats(filtered);

        if (filtered.length === 0) {
            tbody.innerHTML = '';
            noData.classList.remove('d-none');
            return;
        }

        noData.classList.add('d-none');
        tbody.innerHTML = filtered.reverse().map(record => `
            <tr class="animate__animated animate__fadeIn">
                <td>
                    <div class="fw-bold text-dark">${record.date}</div>
                    <div class="text-muted small" style="font-size: 0.7rem;">${record.timestamp || '-'}</div>
                </td>
                <td><span class="room-badge">${record.room || 'ទូទៅ'}</span></td>
                <td class="text-center fw-bold text-success fs-5">${record.present}</td>
                <td class="text-center fw-bold text-warning fs-5">${record.leave}</td>
                <td class="text-center fw-bold text-danger fs-5">${record.absent}</td>
                <td class="text-center">
                    <button class="action-btn btn-view me-1 border-0 rounded-3 p-2" onclick="viewDetails('${record.id}')">
                        <i class="bi bi-eye-fill"></i>
                    </button>
                    <button class="action-btn btn-del border-0 rounded-3 p-2" onclick="deleteRecord('${record.id}')">
                        <i class="bi bi-trash-fill"></i>
                    </button>
                </td>
            </tr>
        `).join('');
    }

    function updateFilterOptions(history) {
        const majorSelect = document.getElementById('majorFilter');
        const roomSelect = document.getElementById('roomFilter');
        const dateSelect = document.getElementById('dateSelectFilter');

        if (dateSelect.options.length > 1) return;

        const dates = [...new Set(history.map(h => h.date))].sort().reverse();
        const rooms = [...new Set(history.map(h => h.room))].filter(r => r).sort();

        let allMajors = [];
        history.forEach(record => {
            if(record.students) {
                record.students.forEach(s => { if(s.major) allMajors.push(s.major); });
            }
        });
        const majors = [...new Set(allMajors)].sort();

        dates.forEach(d => dateSelect.add(new Option(d, d)));
        rooms.forEach(r => roomSelect.add(new Option(r, r)));
        majors.forEach(m => majorSelect.add(new Option(m, m)));
    }

    function updateGrandStats(data) {
        let p=0, l=0, a=0;
        data.forEach(r => {
            p += parseInt(r.present) || 0;
            l += parseInt(r.leave) || 0;
            a += parseInt(r.absent) || 0;
        });
        document.getElementById('grandP').innerText = p;
        document.getElementById('grandL').innerText = l;
        document.getElementById('grandA').innerText = a;
    }

    function viewDetails(id) {
        const history = JSON.parse(localStorage.getItem('attendanceRecords')) || [];
        const record = history.find(r => r.id === id);
        if (!record) return;

        document.getElementById('modalTitle').innerHTML = `
            <div class="d-flex align-items-center">
                <div class="p-3 bg-primary bg-opacity-10 rounded-4 me-3 text-primary">
                    <i class="bi bi-door-open-fill fs-4"></i>
                </div>
                <div>
                    <div class="h5 mb-0 fw-bold">បន្ទប់សិក្សា៖ ${record.room}</div>
                    <div class="small text-muted">${record.date} | ${record.timestamp}</div>
                </div>
            </div>`;

        const listContainer = document.getElementById('studentDetailList');
        listContainer.innerHTML = record.students.map(s => `
            <div class="student-item animate__animated animate__fadeInUp animate__faster">
                <div class="student-icon-avatar p-3 rounded-4 me-3">
                    <i class="bi bi-person-circle fs-4"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="fw-bold text-dark">${s.name} <span class="badge bg-light text-muted border fw-normal ms-1" style="font-size: 0.6rem;">ID: ${s.id}</span></div>
                    <div class="text-muted small" style="font-size: 0.75rem;">
                        <i class="bi bi-mortarboard-fill me-1"></i>${s.major || 'ព័ត៌មានវិទ្យា'}
                    </div>
                </div>
                <div>
                    <span class="status-badge px-3 py-1 rounded-pill ${getStatusBadge(s.status)}">
                        ${getStatusText(s.status)}
                    </span>
                </div>
            </div>
        `).join('');

        new bootstrap.Modal(document.getElementById('detailModal')).show();
    }

    function getStatusBadge(s) {
        if (s === 'P') return 'bg-success text-white';
        if (s === 'L') return 'bg-warning text-dark';
        return 'bg-danger text-white';
    }

    function getStatusText(s) {
        if (s === 'P') return 'វត្តមាន';
        if (s === 'L') return 'ច្បាប់';
        return 'អវត្តមាន';
    }

    function deleteRecord(id) {
        Swal.fire({
            title: 'លុបកំណត់ត្រានេះ?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'បាទ, លុប!',
            cancelButtonText: 'បោះបង់'
        }).then((result) => {
            if (result.isConfirmed) {
                let history = JSON.parse(localStorage.getItem('attendanceRecords')) || [];
                history = history.filter(item => item.id !== id);
                localStorage.setItem('attendanceRecords', JSON.stringify(history));
                displayAttendanceHistory();
            }
        });
    }

    function clearAllAttendance() {
        Swal.fire({
            title: 'សម្អាតទិន្នន័យទាំងអស់?',
            icon: 'error',
            showCancelButton: true,
            confirmButtonText: 'សម្អាតទាំងអស់',
            confirmButtonColor: '#ef4444'
        }).then((result) => {
            if (result.isConfirmed) {
                localStorage.removeItem('attendanceRecords');
                displayAttendanceHistory();
            }
        });
    }

    function filterAttendance() { displayAttendanceHistory(); }

    $(document).ready(function() {
        displayAttendanceHistory();
    });
</script>