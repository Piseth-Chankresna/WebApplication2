@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "បញ្ជីវត្តមាន";
    var startDate = ViewBag.StartDate ?? DateTime.Now.AddMonths(-1).ToString("yyyy-MM-dd");
    var endDate = ViewBag.EndDate ?? DateTime.Now.ToString("yyyy-MM-dd");
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #06b6d4;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #06b6d4, #0891b2);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .filter-section {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        margin-bottom: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
        }

    [data-theme="dark"] .filter-item label {
        color: #cbd5e1;
    }

    .filter-item select,
    .filter-item input {
        padding: 10px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .filter-item select,
    [data-theme="dark"] .filter-item input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-filter {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(6,182,212,0.3);
        }

    .btn-excel {
        background: #10b981;
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-excel:hover {
            background: #059669;
            transform: translateY(-2px);
        }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        overflow-x: auto;
    }

    [data-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .attendance-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1200px;
    }

        .attendance-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-theme="dark"] .attendance-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .attendance-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .attendance-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .attendance-table tbody tr:hover {
        background: #f8fafc;
        cursor: pointer;
    }

    [data-theme="dark"] .attendance-table tbody tr:hover {
        background: #0f172a;
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        overflow: hidden;
        flex-shrink: 0;
    }

        .student-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .status-badge {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-present {
        background: #d1fae5;
        color: #10b981;
    }

    .status-late {
        background: #fef3c7;
        color: #f59e0b;
    }

    .status-absent {
        background: #fee2e2;
        color: #ef4444;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
    }

    [data-theme="dark"] .btn-icon {
        background: #0f172a;
        border-color: #334155;
        color: #cbd5e1;
    }

    .btn-icon:hover {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        transform: translateY(-2px);
    }

    .summary-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .summary-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    [data-theme="dark"] .summary-card {
        background: #1e293b;
        border-color: #334155;
    }

    .summary-icon {
        width: 50px;
        height: 50px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: white;
    }

    .icon-present {
        background: #10b981;
    }

    .icon-late {
        background: #f59e0b;
    }

    .icon-absent {
        background: #ef4444;
    }

    .summary-info h4 {
        font-weight: 700;
        margin-bottom: 5px;
    }

    .summary-info p {
        color: #64748b;
        margin: 0;
        font-size: 0.85rem;
    }

    .pagination {
        margin-top: 20px;
        display: flex;
        justify-content: center;
        gap: 5px;
    }

        .pagination .btn-page {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            color: #1e293b;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

    [data-theme="dark"] .pagination .btn-page {
        background: #1e293b;
        color: white;
        border-color: #334155;
    }

    .pagination .btn-page.active {
        background: #06b6d4;
        color: white;
        border-color: #06b6d4;
    }

    .pagination .btn-page:hover:not(.active) {
        background: #f1f5f9;
    }

    .items-per-page {
        width: 80px;
        padding: 8px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        background: white;
        color: #1e293b;
    }

    /* Modal Styles */
    .modal-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
    }

    [data-theme="dark"] .modal-content {
        background: #1e293b;
        color: white;
    }

    .modal-header {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 20px 24px;
        border: none;
    }

        .modal-header .btn-close {
            filter: brightness(0) invert(1);
        }

    .modal-body {
        padding: 24px;
    }

    .modal-footer {
        padding: 20px 24px;
        border-top: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .modal-footer {
        border-top-color: #334155;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-control, .form-select {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .form-control,
    [data-theme="dark"] .form-select {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .form-control:focus,
    .form-select:focus {
        outline: none;
        border-color: #06b6d4;
        box-shadow: 0 0 0 4px rgba(6,182,212,0.1);
    }

    .btn-save {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 12px 32px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(6,182,212,0.3);
        }

    .btn-cancel {
        background: #f1f5f9;
        color: #475569;
        padding: 12px 32px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .btn-cancel {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
    }

    .btn-delete {
        background: #ef4444;
        color: white;
        padding: 12px 32px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-delete:hover {
            background: #dc2626;
            transform: translateY(-2px);
        }

    @@media (max-width: 1024px) {
        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .summary-cards {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .filter-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- AntiForgeryToken Form (Hidden) -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-clock-history me-2"></i>៣.២. បញ្ជីវត្តមាន</h2>
    <p class="text-muted">មើលប្រវត្តិវត្តមានរបស់សិស្ស</p>
</div>

<!-- Summary Cards -->
<div class="summary-cards" id="summaryCards">
    <div class="summary-card">
        <div class="summary-icon icon-present">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <div class="summary-info">
            <h4 id="totalPresent">0</h4>
            <p>វត្តមានសរុប</p>
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-icon icon-late">
            <i class="bi bi-clock-fill"></i>
        </div>
        <div class="summary-info">
            <h4 id="totalLate">0</h4>
            <p>មកយឺតសរុប</p>
        </div>
    </div>
    <div class="summary-card">
        <div class="summary-icon icon-absent">
            <i class="bi bi-x-circle-fill"></i>
        </div>
        <div class="summary-info">
            <h4 id="totalAbsent">0</h4>
            <p>អវត្តមានសរុប</p>
        </div>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-grid">
        <div class="filter-item">
            <label>ចាប់ពីថ្ងៃទី</label>
            <input type="date" id="startDate" value="@startDate">
        </div>
        <div class="filter-item">
            <label>ដល់ថ្ងៃទី</label>
            <input type="date" id="endDate" value="@endDate">
        </div>
        <div class="filter-item">
            <label>ជំនាញ</label>
            <select id="filterMajor" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>
        <div class="filter-item">
            <label>ស្វែងរក</label>
            <input type="text" id="searchInput" placeholder="ឈ្មោះ ឬលេខសម្គាល់...">
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn-filter" onclick="loadAttendanceRecords()">
            <i class="bi bi-search"></i>
            ស្វែងរក
        </button>
        <button class="btn-excel" onclick="exportAttendance()">
            <i class="bi bi-file-earmark-excel"></i>
            នាំចេញ Excel
        </button>
    </div>
</div>

<!-- Items per page -->
<div class="d-flex justify-content-end mb-3">
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted">បង្ហាញ:</span>
        <select id="itemsPerPage" class="items-per-page" onchange="loadAttendanceRecords()">
            <option value="10">10</option>
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
        <span class="text-muted">កំណត់ត្រា</span>
    </div>
</div>

<!-- Attendance Table -->
<div class="table-container">
    <table class="attendance-table">
        <thead>
            <tr>
                <th>កាលបរិច្ឆេទ</th>
                <th>សិស្ស</th>
                <th>ជំនាញ</th>
                <th>ឆ្នាំ</th>
                <th>ស្ថានភាព</th>
                <th>កំណត់ចំណាំ</th>
                <th class="text-center">សកម្មភាព</th>
            </tr>
        </thead>
        <tbody id="attendanceTableBody">
            <tr>
                <td colspan="7" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Pagination -->
<div class="pagination" id="pagination"></div>

<!-- Edit Attendance Modal -->
<div class="modal fade" id="editAttendanceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square me-2"></i>
                    កែប្រែវត្តមាន
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editAttendanceForm">
                    <input type="hidden" id="editAttendanceId" value="0">

                    <div class="form-group">
                        <label class="form-label">ឈ្មោះសិស្ស</label>
                        <input type="text" id="editStudentName" class="form-control" readonly>
                    </div>

                    <div class="form-group">
                        <label class="form-label">កាលបរិច្ឆេទ</label>
                        <input type="date" id="editDate" class="form-control" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">ស្ថានភាពវត្តមាន</label>
                        <select id="editStatus" class="form-select" required>
                            <option value="P">វត្តមាន</option>
                            <option value="L">មកយឺត</option>
                            <option value="A">អវត្តមាន</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-label">កំណត់ចំណាំ</label>
                        <input type="text" id="editNote" class="form-control" placeholder="បញ្ចូលកំណត់ចំណាំ...">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">បោះបង់</button>
                <button type="button" class="btn-save" onclick="updateAttendance()">រក្សាទុកការកែប្រែ</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteAttendanceModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: #ef4444;">
                <h5 class="modal-title">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    បញ្ជាក់ការលុប
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <i class="bi bi-trash3-fill text-danger" style="font-size: 4rem;"></i>
                <h5 class="mt-3">តើអ្នកពិតជាចង់លុបកំណត់ត្រាវត្តមាននេះមែនទេ?</h5>
                <p class="text-muted" id="deleteInfo">កំណត់ត្រាដែលលុបហើយមិនអាចត្រឡប់វិញបានទេ</p>
                <input type="hidden" id="deleteAttendanceId" value="0">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">បោះបង់</button>
                <button type="button" class="btn-delete" onclick="confirmDelete()">បាទ/ចាស លុប</button>
            </div>
        </div>
    </div>
</div>

<script src="https://unpkg.com/sweetalert2@11"></script>
<script>
    let allRecords = [];
    let currentPage = 1;
    let itemsPerPage = 25;

    $(document).ready(function() {
        loadAttendanceRecords();
    });

    function loadAttendanceRecords() {
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        itemsPerPage = parseInt($('#itemsPerPage').val());

        $('#attendanceTableBody').html(`
            <tr>
                <td colspan="7" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        `);

        $.ajax({
            url: `/Student/GetAttendanceRecords?startDate=${startDate}&endDate=${endDate}`,
            type: 'GET',
            cache: false,
            success: function(response) {
                console.log("Attendance response:", response);

                if (response && response.success) {
                    allRecords = response.data || [];
                } else if (Array.isArray(response)) {
                    allRecords = response;
                } else {
                    console.error("Unexpected response format:", response);
                    allRecords = [];
                }

                displayRecords();
                updateSummary();
            },
            error: function(xhr, status, error) {
                console.error('Error loading attendance:', error);
                console.error('Response:', xhr.responseText);

                $('#attendanceTableBody').html(`
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                            <h5 class="mt-3 text-danger">មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ</h5>
                            <p class="text-muted">${xhr.status} - ${error}</p>
                            <button class="btn btn-primary mt-3" onclick="loadAttendanceRecords()">
                                <i class="bi bi-arrow-clockwise me-2"></i>ព្យាយាមម្តងទៀត
                            </button>
                        </td>
                    </tr>
                `);
            }
        });
    }

    function displayRecords() {
        var tbody = $('#attendanceTableBody');
        tbody.empty();

        if (!Array.isArray(allRecords) || allRecords.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="7" class="text-center py-5">
                        <i class="bi bi-clock-history" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានកំណត់ត្រាវត្តមាននៅឡើយទេ</h5>
                    </td>
                </tr>
            `);
            $('#pagination').empty();
            return;
        }

        var major = $('#filterMajor').val();
        var search = $('#searchInput').val().toLowerCase();

        var filtered = allRecords.filter(record => {
            var matchMajor = !major || (record.studentMajor && record.studentMajor === major);
            var matchSearch = !search ||
                (record.studentName && record.studentName.toLowerCase().includes(search)) ||
                (record.studentId && record.studentId.toLowerCase().includes(search));

            return matchMajor && matchSearch;
        });

        // Pagination
        var totalPages = Math.ceil(filtered.length / itemsPerPage);
        var start = (currentPage - 1) * itemsPerPage;
        var end = start + itemsPerPage;
        var pageData = filtered.slice(start, end);

        pageData.forEach(record => {
            var date = new Date(record.date);
            var formattedDate = date.toLocaleDateString('km-KH', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit'
            });

            var avatarHtml = record.studentPhoto ?
                `<img src="${record.studentPhoto}" alt="${record.studentName || ''}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(record.studentName || 'User')}&background=06b6d4&color=fff'">` :
                `<span>${record.studentName ? record.studentName.charAt(0).toUpperCase() : '?'}</span>`;

            var statusText = record.status === 'P' ? 'វត្តមាន' : record.status === 'L' ? 'មកយឺត' : 'អវត្តមាន';
            var statusClass = record.status === 'P' ? 'status-present' : record.status === 'L' ? 'status-late' : 'status-absent';

            var row = `
                <tr>
                    <td>${formattedDate}</td>
                    <td>
                        <div class="student-info">
                            <div class="student-avatar">
                                ${avatarHtml}
                            </div>
                            <div>
                                <div class="fw-bold">${record.studentName || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">${record.studentId || ''}</small>
                            </div>
                        </div>
                    </td>
                    <td>${record.studentMajor || 'N/A'}</td>
                    <td>ឆ្នាំទី${record.studentYear || '?'}</td>
                    <td>
                        <span class="status-badge ${statusClass}">${statusText}</span>
                    </td>
                    <td>${record.note || '-'}</td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center">
                            <button class="btn-icon" onclick="editAttendance(${record.id})" title="កែប្រែ">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn-icon" onclick="deleteAttendance(${record.id}, '${record.studentName || ''}')" title="លុប">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });

        // Update pagination
        updatePagination(totalPages);
    }

    function updatePagination(totalPages) {
        var pagination = $('#pagination');
        pagination.empty();

        if (totalPages <= 1) return;

        // Previous button
        pagination.append(`
            <button class="btn-page" onclick="changePage(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>
                <i class="bi bi-chevron-left"></i>
            </button>
        `);

        // Page numbers
        for (var i = 1; i <= totalPages; i++) {
            if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) {
                pagination.append(`
                    <button class="btn-page ${i === currentPage ? 'active' : ''}" onclick="changePage(${i})">
                        ${i}
                    </button>
                `);
            } else if (i === currentPage - 3 || i === currentPage + 3) {
                pagination.append(`<span class="btn-page" disabled>...</span>`);
            }
        }

        // Next button
        pagination.append(`
            <button class="btn-page" onclick="changePage(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>
                <i class="bi bi-chevron-right"></i>
            </button>
        `);
    }

    function changePage(page) {
        currentPage = page;
        displayRecords();
    }

    function updateSummary() {
        if (!Array.isArray(allRecords) || allRecords.length === 0) {
            $('#totalPresent').text('0');
            $('#totalLate').text('0');
            $('#totalAbsent').text('0');
            return;
        }

        var present = allRecords.filter(r => r.status === 'P').length;
        var late = allRecords.filter(r => r.status === 'L').length;
        var absent = allRecords.filter(r => r.status === 'A').length;

        $('#totalPresent').text(present);
        $('#totalLate').text(late);
        $('#totalAbsent').text(absent);
    }

    function exportAttendance() {
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        window.location.href = `/Student/ExportAttendance?startDate=${startDate}&endDate=${endDate}`;
    }

    // Edit Attendance Function
    function editAttendance(id) {
        console.log("Editing attendance ID:", id);

        var record = allRecords.find(r => r.id === id);
        if (!record) {
            console.error("Record not found for ID:", id);
            Swal.fire({
                icon: 'error',
                title: 'កំហុស',
                text: 'រកមិនឃើញកំណត់ត្រា'
            });
            return;
        }

        console.log("Record found:", record);

        $('#editAttendanceId').val(record.id);
        $('#editStudentName').val(record.studentName || '');

        // Format date for input (YYYY-MM-DD)
        var date = new Date(record.date);
        var year = date.getFullYear();
        var month = (date.getMonth() + 1).toString().padStart(2, '0');
        var day = date.getDate().toString().padStart(2, '0');
        var formattedDate = `${year}-${month}-${day}`;

        $('#editDate').val(formattedDate);
        $('#editStatus').val(record.status || 'P');
        $('#editNote').val(record.note || '');

        $('#editAttendanceModal').modal('show');
    }

    // Update Attendance Function
    function updateAttendance() {
        var id = $('#editAttendanceId').val();
        var date = $('#editDate').val();
        var status = $('#editStatus').val();
        var note = $('#editNote').val();

        console.log("Updating attendance:", { id, date, status, note });

        if (!id || id === '0') {
            Swal.fire({
                icon: 'error',
                title: 'កំហុស',
                text: 'លេខសម្គាល់កំណត់ត្រាមិនត្រឹមត្រូវ'
            });
            return;
        }

        if (!date) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលកាលបរិច្ឆេទ',
                text: 'កាលបរិច្ឆេទមិនអាចទទេបានទេ'
            });
            return;
        }

        var token = $('input[name="__RequestVerificationToken"]').val();
        if (!token) {
            console.error("AntiForgeryToken not found!");
            Swal.fire({
                icon: 'error',
                title: 'កំហុស',
                text: 'មិនអាចរកឃើញ Token សុវត្ថិភាព'
            });
            return;
        }

        // Show loading
        Swal.fire({
            title: 'កំពុងរក្សាទុក...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Student/UpdateAttendance',
            type: 'POST',
            data: {
                id: id,
                date: date,
                status: status,
                note: note
            },
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                console.log("Update response:", response);

                if (response && response.success) {
                    $('#editAttendanceModal').modal('hide');
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message || 'កែប្រែវត្តមានដោយជោគជ័យ',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadAttendanceRecords(); // Reload data
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message || 'មានបញ្ហាក្នុងការកែប្រែ'
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error("AJAX Error:", error);
                console.error("Status:", xhr.status);
                console.error("Response:", xhr.responseText);

                let errorMessage = 'មានបញ្ហាបច្ចេកទេស';
                try {
                    const response = JSON.parse(xhr.responseText);
                    if (response.message) {
                        errorMessage = response.message;
                    }
                } catch(e) {
                    if (xhr.responseText) {
                        errorMessage = xhr.responseText;
                    }
                }

                Swal.fire({
                    icon: 'error',
                    title: `កំហុស (${xhr.status})`,
                    text: errorMessage
                });
            }
        });
    }

    // Delete Attendance Function
    function deleteAttendance(id, name) {
        $('#deleteAttendanceId').val(id);
        $('#deleteInfo').text(`លុបកំណត់ត្រាវត្តមានរបស់ ${name || 'សិស្ស'}`);
        $('#deleteAttendanceModal').modal('show');
    }

    // Confirm Delete Function
    function confirmDelete() {
        var id = $('#deleteAttendanceId').val();
        var token = $('input[name="__RequestVerificationToken"]').val();

        $('#deleteAttendanceModal').modal('hide');

        Swal.fire({
            title: 'កំពុងដំណើរការ...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Student/DeleteAttendance',
            type: 'POST',
            data: { id: id },
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message || 'លុបកំណត់ត្រាវត្តមានដោយជោគជ័យ',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadAttendanceRecords();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message || 'មានបញ្ហាក្នុងការលុប'
                    });
                }
            },
            error: function(xhr, status, error) {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាបច្ចេកទេស: ' + error
                });
            }
        });
    }
</script>