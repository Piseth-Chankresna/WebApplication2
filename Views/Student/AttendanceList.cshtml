@model IEnumerable<WebApplication2.Models.Student>
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "វត្តមាន";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #06b6d4, #0891b2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #06b6d4;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .date-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

    [data-theme="dark"] .date-section {
        background: #1e293b;
        border-color: #334155;
    }

    .date-picker {
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .date-picker label {
            font-weight: 600;
            color: #475569;
        }

    [data-theme="dark"] .date-picker label {
        color: #cbd5e1;
    }

    .date-picker input {
        padding: 10px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .date-picker input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .summary-cards {
        display: flex;
        gap: 20px;
    }

    .summary-badge {
        padding: 8px 20px;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .badge-present {
        background: #d1fae5;
        color: #10b981;
    }

    .badge-late {
        background: #fef3c7;
        color: #f59e0b;
    }

    .badge-absent {
        background: #fee2e2;
        color: #ef4444;
    }

    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .filter-section {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
        }

    [data-theme="dark"] .filter-item label {
        color: #cbd5e1;
    }

    .filter-item select,
    .filter-item input {
        padding: 10px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .filter-item select,
    [data-theme="dark"] .filter-item input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-filter {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(6,182,212,0.3);
        }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 12px 32px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        overflow-x: auto;
    }

    [data-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .attendance-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1000px;
    }

        .attendance-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-theme="dark"] .attendance-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .attendance-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .attendance-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .attendance-table tbody tr:hover {
        background: #f8fafc;
    }

    [data-theme="dark"] .attendance-table tbody tr:hover {
        background: #0f172a;
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
    }

    .attendance-radio-group {
        display: flex;
        gap: 10px;
    }

    .radio-option {
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
    }

        .radio-option input[type="radio"] {
            display: none;
        }

    .radio-label {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .radio-option input[type="radio"]:checked + .radio-label {
        color: white;
    }

        .radio-option input[type="radio"]:checked + .radio-label.present {
            background: #10b981;
        }

        .radio-option input[type="radio"]:checked + .radio-label.late {
            background: #f59e0b;
        }

        .radio-option input[type="radio"]:checked + .radio-label.absent {
            background: #ef4444;
        }

    .radio-label.present {
        background: #d1fae5;
        color: #10b981;
    }

    .radio-label.late {
        background: #fef3c7;
        color: #f59e0b;
    }

    .radio-label.absent {
        background: #fee2e2;
        color: #ef4444;
    }

    .note-input {
        width: 150px;
        padding: 6px 10px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .note-input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .history-section {
        margin-top: 40px;
    }

    .history-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        font-weight: 700;
        color: #1e293b;
    }

    [data-theme="dark"] .history-title {
        color: white;
    }

    .history-title i {
        color: #06b6d4;
        font-size: 1.5rem;
    }

    .history-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    .history-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .history-card {
        background: #1e293b;
        border-color: #334155;
    }

    .history-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(6,182,212,0.1);
        border-color: #06b6d4;
    }

    .history-date {
        font-size: 1.1rem;
        font-weight: 700;
        color: #06b6d4;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .history-stats {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
    }

    .history-stat {
        text-align: center;
        flex: 1;
    }

        .history-stat .count {
            font-size: 1.2rem;
            font-weight: 700;
        }

        .history-stat .label {
            font-size: 0.8rem;
            color: #64748b;
        }

    .btn-view {
        width: 100%;
        padding: 8px;
        background: #f1f5f9;
        border: none;
        border-radius: 12px;
        color: #475569;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .btn-view {
        background: #0f172a;
        color: #cbd5e1;
    }

    .btn-view:hover {
        background: #06b6d4;
        color: white;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .date-section {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-calendar-check-fill me-2"></i>វត្តមានប្រចាំថ្ងៃ</h2>
    <p class="text-muted">បំពេញ និងគ្រប់គ្រងវត្តមានសិស្ស</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-check-circle-fill stat-icon"></i>
        <div class="stat-value" id="presentCount">0</div>
        <div class="stat-label">វត្តមាន</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-clock-fill stat-icon"></i>
        <div class="stat-value" id="lateCount">0</div>
        <div class="stat-label">មកយឺត</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-x-circle-fill stat-icon"></i>
        <div class="stat-value" id="absentCount">0</div>
        <div class="stat-label">អវត្តមាន</div>
    </div>
</div>

<!-- Date Selection -->
<div class="date-section">
    <div class="date-picker">
        <label><i class="bi bi-calendar3 me-2"></i>ជ្រើសរើសកាលបរិច្ឆេទ:</label>
        <input type="date" id="attendanceDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
    </div>
    <div class="summary-cards">
        <span class="summary-badge badge-present" id="summaryPresent">វត្តមាន: 0</span>
        <span class="summary-badge badge-late" id="summaryLate">មកយឺត: 0</span>
        <span class="summary-badge badge-absent" id="summaryAbsent">អវត្តមាន: 0</span>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-grid">
        <div class="filter-item">
            <label>ជំនាញ</label>
            <select id="filterMajor">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ឆ្នាំសិក្សា</label>
            <select id="filterYear">
                <option value="">ទាំងអស់</option>
                <option value="1">ឆ្នាំទី១</option>
                <option value="2">ឆ្នាំទី២</option>
                <option value="3">ឆ្នាំទី៣</option>
                <option value="4">ឆ្នាំទី៤</option>
            </select>
        </div>

        <div class="filter-item">
            <label>វេនសិក្សា</label>
            <select id="filterShift">
                <option value="">ទាំងអស់</option>
                <option value="ព្រឹក">ព្រឹក</option>
                <option value="រសៀល">រសៀល</option>
                <option value="យប់">យប់</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ស្វែងរក</label>
            <input type="text" id="searchInput" placeholder="ឈ្មោះ ឬលេខសម្គាល់...">
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn-filter" onclick="applyFilter()">
            <i class="bi bi-search"></i>
            អនុវត្តតម្រង
        </button>
        <button class="btn-filter" onclick="resetFilter()" style="background: #64748b;">
            <i class="bi bi-arrow-counterclockwise"></i>
            កំណត់ឡើងវិញ
        </button>
    </div>
</div>

<!-- Action Buttons -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <button class="btn-save" onclick="saveAttendance()">
            <i class="bi bi-save"></i>
            រក្សាទុកវត្តមាន
        </button>
        <button class="btn-save ms-2" onclick="markAllPresent()" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-check-all"></i>
            វត្តមានទាំងអស់
        </button>
    </div>
</div>

<!-- Attendance Table -->
<div class="table-container">
    <table class="attendance-table">
        <thead>
            <tr>
                <th>សិស្ស</th>
                <th>ជំនាញ</th>
                <th>ឆ្នាំ</th>
                <th>វេន</th>
                <th>ស្ថានភាពវត្តមាន</th>
                <th>កំណត់ចំណាំ</th>
            </tr>
        </thead>
        <tbody id="attendanceTableBody">
            <!-- Data will be loaded by JavaScript -->
        </tbody>
    </table>
</div>

<!-- Attendance History -->
<div class="history-section">
    <div class="history-title">
        <i class="bi bi-clock-history"></i>
        <span>ប្រវត្តិវត្តមានថ្មីៗ</span>
    </div>

    <div class="history-grid" id="historyGrid">
        <!-- History will be loaded by JavaScript -->
    </div>
</div>

<script>
    let students = [];
    let attendanceRecords = [];
    let currentAttendance = {};

    $(document).ready(function() {
        loadStudents();
        loadAttendanceHistory();
        $('#attendanceDate').val(new Date().toISOString().split('T')[0]);
    });

    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            success: function(data) {
                students = data;
                displayAttendance();
            }
        });
    }

    function loadAttendanceHistory() {
        $.ajax({
            url: '/Student/GetAttendance',
            type: 'GET',
            success: function(data) {
                attendanceRecords = data;
                displayHistory();
            }
        });
    }

    function displayAttendance() {
        var tbody = $('#attendanceTableBody');
        tbody.empty();

        if (students.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="bi bi-people" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានទិន្នន័យសិស្សនៅឡើយទេ</h5>
                    </td>
                </tr>
            `);
            return;
        }

        var major = $('#filterMajor').val();
        var year = $('#filterYear').val();
        var shift = $('#filterShift').val();
        var search = $('#searchInput').val().toLowerCase();

        var filteredStudents = students.filter(s => {
            var matchMajor = !major || s.major === major;
            var matchYear = !year || s.year === year;
            var matchShift = !shift || s.shift === shift;
            var matchSearch = !search ||
                (s.name && s.name.toLowerCase().includes(search)) ||
                (s.id && s.id.toLowerCase().includes(search));

            return matchMajor && matchYear && matchShift && matchSearch;
        });

        $('#totalStudents').text(filteredStudents.length);

        filteredStudents.forEach(s => {
            var status = currentAttendance[s.id] || 'P';

            var row = `
                <tr>
                    <td>
                        <div class="student-info">
                            <div class="student-avatar">
                                ${s.name ? s.name.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div>
                                <div class="fw-bold">${s.name || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">${s.id}</small>
                            </div>
                        </div>
                    </td>
                    <td>${s.major || 'N/A'}</td>
                    <td>ឆ្នាំទី${s.year || '?'}</td>
                    <td>${s.shift || 'N/A'}</td>
                    <td>
                        <div class="attendance-radio-group">
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="P" ${status === 'P' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label present">វត្តមាន</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="L" ${status === 'L' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label late">មកយឺត</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="A" ${status === 'A' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label absent">អវត្តមាន</span>
                            </label>
                        </div>
                    </td>
                    <td>
                        <input type="text" class="note-input" id="note_${s.id}" placeholder="កំណត់ចំណាំ..." value="${currentAttendance[`note_${s.id}`] || ''}">
                    </td>
                </tr>
            `;
            tbody.append(row);
        });

        updateCounts();
    }

    function updateAttendance(studentId, status) {
        currentAttendance[studentId] = status;
        updateCounts();
    }

    function updateCounts() {
        var present = 0, late = 0, absent = 0;

        $('input[type="radio"]:checked').each(function() {
            var value = $(this).val();
            if (value === 'P') present++;
            else if (value === 'L') late++;
            else if (value === 'A') absent++;
        });

        $('#presentCount').text(present);
        $('#lateCount').text(late);
        $('#absentCount').text(absent);

        $('#summaryPresent').text(`វត្តមាន: ${present}`);
        $('#summaryLate').text(`មកយឺត: ${late}`);
        $('#summaryAbsent').text(`អវត្តមាន: ${absent}`);
    }

    function saveAttendance() {
        var date = $('#attendanceDate').val();
        var attendanceData = [];

        $('input[type="radio"]:checked').each(function() {
            var name = $(this).attr('name');
            var studentId = name.replace('att_', '');
            var status = $(this).val();
            var note = $(`#note_${studentId}`).val();

            attendanceData.push({
                studentId: studentId,
                studentName: $(this).closest('tr').find('.fw-bold').text(),
                date: date,
                status: status,
                note: note
            });
        });

        $.ajax({
            url: '/Student/SaveAttendance',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(attendanceData),
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadAttendanceHistory();
                    currentAttendance = {};
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាបច្ចេកទេស'
                });
            }
        });
    }

    function markAllPresent() {
        $('input[type="radio"][value="P"]').prop('checked', true);
        updateCounts();
    }

    function displayHistory() {
        var grid = $('#historyGrid');
        grid.empty();

        var grouped = {};
        attendanceRecords.forEach(record => {
            if (!grouped[record.date]) {
                grouped[record.date] = {
                    date: record.date,
                    present: 0,
                    late: 0,
                    absent: 0,
                    total: 0
                };
            }
            grouped[record.date][record.status === 'P' ? 'present' : record.status === 'L' ? 'late' : 'absent']++;
            grouped[record.date].total++;
        });

        var sorted = Object.values(grouped).sort((a, b) => new Date(b.date) - new Date(a.date)).slice(0, 6);

        sorted.forEach(day => {
            var card = `
                <div class="history-card">
                    <div class="history-date">
                        <span><i class="bi bi-calendar3 me-2"></i>${day.date}</span>
                        <span class="badge bg-secondary">${day.total} នាក់</span>
                    </div>
                    <div class="history-stats">
                        <div class="history-stat">
                            <div class="count text-success">${day.present}</div>
                            <div class="label">វត្តមាន</div>
                        </div>
                        <div class="history-stat">
                            <div class="count text-warning">${day.late}</div>
                            <div class="label">មកយឺត</div>
                        </div>
                        <div class="history-stat">
                            <div class="count text-danger">${day.absent}</div>
                            <div class="label">អវត្តមាន</div>
                        </div>
                    </div>
                    <button class="btn-view" onclick="viewHistory('${day.date}')">
                        <i class="bi bi-eye me-2"></i>មើលលម្អិត
                    </button>
                </div>
            `;
            grid.append(card);
        });
    }

    function viewHistory(date) {
        var dayRecords = attendanceRecords.filter(r => r.date === date);

        var html = '<div style="max-height: 400px; overflow-y: auto;">';
        dayRecords.forEach(r => {
            var statusColor = r.status === 'P' ? 'success' : r.status === 'L' ? 'warning' : 'danger';
            var statusText = r.status === 'P' ? 'វត្តមាន' : r.status === 'L' ? 'មកយឺត' : 'អវត្តមាន';

            html += `
                <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                    <div>
                        <strong>${r.studentName}</strong>
                        <div class="small text-muted">${r.note || 'គ្មានកំណត់ចំណាំ'}</div>
                    </div>
                    <span class="badge bg-${statusColor}">${statusText}</span>
                </div>
            `;
        });
        html += '</div>';

        Swal.fire({
            title: `វត្តមានប្រចាំថ្ងៃទី ${date}`,
            html: html,
            width: 600,
            confirmButtonColor: '#06b6d4'
        });
    }

    function applyFilter() {
        displayAttendance();
    }

    function resetFilter() {
        $('#filterMajor').val('');
        $('#filterYear').val('');
        $('#filterShift').val('');
        $('#searchInput').val('');
        displayAttendance();
    }
</script>