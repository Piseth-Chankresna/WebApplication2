@model WebApplication2.Models.Student
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "ព័ត៌មានលម្អិតសិស្ស";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #3b82f6;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #3b82f6, #2563eb);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .profile-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .profile-card {
        background: white;
        border-radius: 30px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .profile-card {
        background: #1e293b;
        border-color: #334155;
    }

    .profile-header {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        padding: 40px;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .profile-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .profile-header::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

    .profile-header-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 40px;
        flex-wrap: wrap;
    }

    .profile-avatar-large {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 5px solid rgba(255,255,255,0.3);
        object-fit: cover;
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        background: white;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
        font-size: 4rem;
        font-weight: 700;
        overflow: hidden;
    }

        .profile-avatar-large img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .profile-title h3 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .profile-title .badge {
        background: rgba(255,255,255,0.2);
        padding: 8px 20px;
        border-radius: 40px;
        font-size: 0.9rem;
        backdrop-filter: blur(5px);
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .profile-stats {
        display: flex;
        gap: 30px;
        margin-top: 20px;
    }

    .stat-item {
        text-align: center;
    }

    .stat-value {
        font-size: 1.5rem;
        font-weight: 700;
    }

    .stat-label {
        font-size: 0.85rem;
        opacity: 0.8;
    }

    .profile-body {
        padding: 40px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
        margin-bottom: 40px;
    }

    .info-card {
        background: #f8fafc;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
    }

    [data-bs-theme="dark"] .info-card {
        background: #0f172a;
        border-color: #334155;
    }

    .info-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(59,130,246,0.1);
        border-color: #3b82f6;
    }

    .info-card .icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        margin-bottom: 15px;
    }

    .info-card .label {
        color: #64748b;
        font-size: 0.85rem;
        margin-bottom: 5px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .info-card .value {
        font-weight: 700;
        color: #1e293b;
        font-size: 1.1rem;
    }

    [data-bs-theme="dark"] .info-card .value {
        color: white;
    }

    .section-title {
        font-weight: 700;
        color: #1e293b;
        margin: 40px 0 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    [data-bs-theme="dark"] .section-title {
        color: white;
        border-bottom-color: #334155;
    }

    .section-title i {
        color: #3b82f6;
        font-size: 1.5rem;
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        margin-top: 30px;
    }

    .action-btn {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .action-btn {
        background: #1e293b;
        border-color: #334155;
        color: white;
    }

    .action-btn:hover {
        transform: translateY(-5px);
        border-color: #3b82f6;
        box-shadow: 0 15px 30px rgba(59,130,246,0.15);
    }

    .action-btn i {
        font-size: 2rem;
        color: #3b82f6;
        margin-bottom: 10px;
        display: block;
    }

    .action-btn span {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 40px;
        color: #475569;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        margin-bottom: 20px;
    }

    [data-bs-theme="dark"] .btn-back {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-back:hover {
        background: #e2e8f0;
    }

    @@media (max-width: 768px) {
        .profile-header-content {
            flex-direction: column;
            text-align: center;
        }

        .info-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .quick-actions {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 480px) {
        .info-grid {
            grid-template-columns: 1fr;
        }

        .quick-actions {
            grid-template-columns: 1fr;
        }
    }
</style>

<!-- AntiForgeryToken -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-eye-fill me-2"></i>ព័ត៌មានលម្អិតសិស្ស</h2>
    <p class="text-muted">មើលព័ត៌មានលម្អិតរបស់សិស្ស</p>
</div>

<a href="/Student/Index" class="btn-back ajax-link" data-url="/Student/Index">
    <i class="bi bi-arrow-left"></i> ត្រឡប់ទៅបញ្ជីសិស្ស
</a>

<div class="profile-container">
    <div class="profile-card">
        <!-- Profile Header -->
        <div class="profile-header">
            <div class="profile-header-content">
                <div class="profile-avatar-large">
                    @if (!string.IsNullOrEmpty(Model.Photo))
                    {
                        <img src="@Model.Photo" alt="@Model.Name" onerror="this.src='https://ui-avatars.com/api/?name=@(Model.Name ?? "User")&background=3b82f6&color=fff&size=150'">
                    }
                    else
                    {
                        <span>@(Model.Name?.Length > 0 ? Model.Name.Substring(0, 1).ToUpper() : "?")</span>
                    }
                </div>
                <div class="profile-title">
                    <h3>@Model.Name</h3>
                    <div class="badge">
                        <i class="bi bi-upc-scan"></i> លេខសម្គាល់: @Model.Id
                    </div>
                    <div class="profile-stats">
                        <div class="stat-item">
                            <div class="stat-value">@Model.Year</div>
                            <div class="stat-label">ឆ្នាំសិក្សា</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value">@(Model.Status ?? "កំពុងសិក្សា")</div>
                            <div class="stat-label">ស្ថានភាព</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-value">$@Model.AmountDue</div>
                            <div class="stat-label">ថ្លៃត្រូវបង់</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Profile Body -->
        <div class="profile-body">
            <!-- Personal Information -->
            <div class="section-title">
                <i class="bi bi-person"></i> ព័ត៌មានផ្ទាល់ខ្លួន
            </div>

            <div class="info-grid">
                <div class="info-card">
                    <div class="icon"><i class="bi bi-gender-ambiguous"></i></div>
                    <div class="label">ភេទ</div>
                    <div class="value">@Model.Gender</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-calendar"></i></div>
                    <div class="label">ថ្ងៃខែឆ្នាំកំណើត</div>
                    <div class="value">@(Model.Dob ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-geo-alt"></i></div>
                    <div class="label">ទីកន្លែងកំណើត</div>
                    <div class="value">@(Model.Pob ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-phone"></i></div>
                    <div class="label">លេខទូរស័ព្ទ</div>
                    <div class="value">@(Model.Phone ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-tag"></i></div>
                    <div class="label">លេខសម្គាល់/ក្រុម</div>
                    <div class="value">@(Model.Batch ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-calendar-week"></i></div>
                    <div class="label">ឆ្នាំសិក្សា</div>
                    <div class="value">@(Model.AcademicYear ?? "មិនមាន")</div>
                </div>
            </div>

            <!-- Academic Information -->
            <div class="section-title">
                <i class="bi bi-mortarboard"></i> ព័ត៌មានសិក្សា
            </div>

            <div class="info-grid">
                <div class="info-card">
                    <div class="icon"><i class="bi bi-book"></i></div>
                    <div class="label">កម្រិតសិក្សា</div>
                    <div class="value">@(Model.Degree ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-star"></i></div>
                    <div class="label">ជំនាញ</div>
                    <div class="value">@(Model.Major ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-calendar3"></i></div>
                    <div class="label">ឆ្នាំសិក្សា</div>
                    <div class="value">ឆ្នាំទី @(Model.Year ?? "?")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-door-open"></i></div>
                    <div class="label">បន្ទប់</div>
                    <div class="value">@(Model.Room ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-clock"></i></div>
                    <div class="label">វេនសិក្សា</div>
                    <div class="value">@(Model.Shift ?? "មិនមាន")</div>
                </div>
                <div class="info-card">
                    <div class="icon"><i class="bi bi-gift"></i></div>
                    <div class="label">អាហារូបករណ៍</div>
                    <div class="value">@(Model.Scholarship ?? "0%")</div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="section-title">
                <i class="bi bi-lightning"></i> សកម្មភាពរហ័ស
            </div>

            <div class="quick-actions">
                <a href="/Student/Edit/@Model.Id" class="action-btn ajax-link" data-url="/Student/Edit/@Model.Id">
                    <i class="bi bi-pencil-square"></i> <span>កែប្រែព័ត៌មាន</span>
                </a>
                <a href="/Student/CheckAttendance?studentId=@Model.Id" class="action-btn ajax-link" data-url="/Student/CheckAttendance?studentId=@Model.Id">
                    <i class="bi bi-calendar-check"></i> <span>វត្តមាន</span>
                </a>
                <a href="/Student/Grades?studentId=@Model.Id" class="action-btn ajax-link" data-url="/Student/Grades?studentId=@Model.Id">
                    <i class="bi bi-bar-chart"></i> <span>ពិន្ទុ</span>
                </a>
                <a href="/Student/Payment?studentId=@Model.Id" class="action-btn ajax-link" data-url="/Student/Payment?studentId=@Model.Id">
                    <i class="bi bi-credit-card"></i> <span>ការបង់ប្រាក់</span>
                </a>
            </div>
        </div>
    </div>
</div>