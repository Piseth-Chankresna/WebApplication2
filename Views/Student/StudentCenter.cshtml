@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Student Center";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

    .welcome-banner {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 30px;
        padding: 40px;
        margin-bottom: 40px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(59,130,246,0.2);
    }

        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

        .welcome-banner::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
        }

    .welcome-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .welcome-icon {
        width: 100px;
        height: 100px;
        background: rgba(255,255,255,0.2);
        border-radius: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .welcome-text h3 {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .welcome-text p {
        font-size: 1.1rem;
        opacity: 0.9;
        margin: 0;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 24px;
        margin-bottom: 40px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(59,130,246,0.1);
        border-color: #3b82f6;
    }

    .stat-card .stat-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
        margin-bottom: 15px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .quick-actions-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .action-card {
        background: white;
        border-radius: 24px;
        padding: 30px 20px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .action-card {
        background: #1e293b;
        border-color: #334155;
    }

    .action-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, #3b82f6, #2563eb);
        transform: scaleX(0);
        transition: transform 0.3s ease;
    }

    .action-card:hover::before {
        transform: scaleX(1);
    }

    .action-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(59,130,246,0.1);
    }

    .action-icon {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2rem;
        margin: 0 auto 20px;
        transition: all 0.3s ease;
    }

    .action-card:hover .action-icon {
        transform: scale(1.1) rotate(5deg);
    }

    .action-card h4 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .action-card h4 {
        color: white;
    }

    .action-card p {
        color: #64748b;
        margin: 0;
        font-size: 0.9rem;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
        font-weight: 700;
        color: #1e293b;
    }

    [data-theme="dark"] .section-title {
        color: white;
    }

    .section-title i {
        color: #3b82f6;
        font-size: 1.5rem;
    }

    .recent-activities {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 40px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .recent-activities {
        background: #1e293b;
        border-color: #334155;
    }

    .activity-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .activity-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px 0;
        border-bottom: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .activity-item {
        border-bottom-color: #334155;
    }

    .activity-item:last-child {
        border-bottom: none;
    }

    .activity-icon {
        width: 40px;
        height: 40px;
        background: #dbeafe;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
    }

    .activity-content {
        flex: 1;
    }

    .activity-title {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .activity-title {
        color: white;
    }

    .activity-time {
        font-size: 0.85rem;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .deadline-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 40px;
    }

    .deadline-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    [data-theme="dark"] .deadline-card {
        background: #1e293b;
        border-color: #334155;
    }

    .deadline-date {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: white;
        line-height: 1.2;
    }

        .deadline-date .day {
            font-size: 1.5rem;
            font-weight: 800;
        }

        .deadline-date .month {
            font-size: 0.8rem;
            opacity: 0.9;
        }

    .deadline-info h5 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .deadline-info h5 {
        color: white;
    }

    .deadline-info p {
        color: #64748b;
        margin: 0;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .deadline-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-urgent {
        background: #fee2e2;
        color: #ef4444;
    }

    .badge-warning {
        background: #fef3c7;
        color: #f59e0b;
    }

    .badge-normal {
        background: #dbeafe;
        color: #3b82f6;
    }

    .announcement-card {
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    [data-theme="dark"] .announcement-card {
        background: #0f172a;
        border-color: #334155;
    }

    .announcement-icon {
        width: 50px;
        height: 50px;
        background: #3b82f6;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .announcement-content {
        flex: 1;
    }

        .announcement-content h5 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 4px;
        }

    [data-theme="dark"] .announcement-content h5 {
        color: white;
    }

    .announcement-content p {
        color: #64748b;
        margin: 0;
        font-size: 0.9rem;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .quick-actions-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .deadline-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .quick-actions-grid {
            grid-template-columns: 1fr;
        }

        .welcome-content {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-layout-text-window me-2"></i>Student Center</h2>
    <p class="text-muted">មជ្ឈមណ្ឌលរួមសម្រាប់គ្រប់គ្រងព័ត៌មានសិស្ស</p>
</div>

<!-- Welcome Banner -->
<div class="welcome-banner">
    <div class="welcome-content">
        <div class="welcome-icon">
            <i class="bi bi-mortarboard-fill"></i>
        </div>
        <div class="welcome-text">
            <h3>សូមស្វាគមន៍មកកាន់ Student Center</h3>
            <p>គ្រប់គ្រងព័ត៌មានសិស្ស ថ្នាក់ វត្តមាន ពិន្ទុ និងការបង់ប្រាក់ក្នុងកន្លែងតែមួយ</p>
        </div>
    </div>
</div>

<!-- Statistics Cards -->
<div class="stats-grid" id="statsGrid">
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-door-open-fill"></i></div>
        <div class="stat-value" id="totalClasses">0</div>
        <div class="stat-label">ថ្នាក់សរុប</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
        <div class="stat-value" id="totalPayments">$0</div>
        <div class="stat-label">បង់ប្រាក់សរុប</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon"><i class="bi bi-bar-chart-fill"></i></div>
        <div class="stat-value" id="avgGrade">0.0</div>
        <div class="stat-label">ពិន្ទុមធ្យម</div>
    </div>
</div>

<!-- Quick Actions -->
<div class="section-title">
    <i class="bi bi-lightning-charge-fill"></i>
    <span>សកម្មភាពរហ័ស</span>
</div>

<div class="quick-actions-grid">
    <a href="/Student/Create" class="action-card ajax-link" data-url="/Student/Create">
        <div class="action-icon"><i class="bi bi-person-plus-fill"></i></div>
        <h4>បន្ថែមសិស្សថ្មី</h4>
        <p>ចុះឈ្មោះសិស្សថ្មីក្នុងប្រព័ន្ធ</p>
    </a>

    <a href="/Student/Index" class="action-card ajax-link" data-url="/Student/Index">
        <div class="action-icon"><i class="bi bi-people-fill"></i></div>
        <h4>បញ្ជីសិស្ស</h4>
        <p>មើល និងគ្រប់គ្រងបញ្ជីសិស្ស</p>
    </a>

    <a href="/Student/Classes" class="action-card ajax-link" data-url="/Student/Classes">
        <div class="action-icon"><i class="bi bi-door-open-fill"></i></div>
        <h4>គ្រប់គ្រងថ្នាក់</h4>
        <p>បន្ថែម និងកែប្រែថ្នាក់រៀន</p>
    </a>

    <a href="/Student/Attendance" class="action-card ajax-link" data-url="/Student/Attendance">
        <div class="action-icon"><i class="bi bi-calendar-check-fill"></i></div>
        <h4>វត្តមាន</h4>
        <p>បំពេញ និងពិនិត្យវត្តមាន</p>
    </a>

    <a href="/Student/Grades" class="action-card ajax-link" data-url="/Student/Grades">
        <div class="action-icon"><i class="bi bi-bar-chart-fill"></i></div>
        <h4>គ្រប់គ្រងពិន្ទុ</h4>
        <p>បញ្ចូល និងកែប្រែពិន្ទុសិស្ស</p>
    </a>

    <a href="/Student/Payment" class="action-card ajax-link" data-url="/Student/Payment">
        <div class="action-icon"><i class="bi bi-credit-card-fill"></i></div>
        <h4>ការបង់ប្រាក់</h4>
        <p>គ្រប់គ្រងការបង់ប្រាក់របស់សិស្ស</p>
    </a>

    <a href="/Student/Scholarship" class="action-card ajax-link" data-url="/Student/Scholarship">
        <div class="action-icon"><i class="bi bi-gift-fill"></i></div>
        <h4>អាហារូបករណ៍</h4>
        <p>គ្រប់គ្រងអាហារូបករណ៍សិស្ស</p>
    </a>

    <a href="/Student/Reports" class="action-card ajax-link" data-url="/Student/Reports">
        <div class="action-icon"><i class="bi bi-graph-up-arrow"></i></div>
        <h4>របាយការណ៍</h4>
        <p>មើលរបាយការណ៍ និងស្ថិតិ</p>
    </a>
</div>

<!-- Recent Activities and Deadlines -->
<div class="row g-4">
    <div class="col-md-6">
        <div class="recent-activities">
            <div class="section-title mb-3">
                <i class="bi bi-clock-history"></i>
                <span>សកម្មភាពថ្មីៗ</span>
            </div>

            <ul class="activity-list" id="activityList">
                <li class="activity-item">
                    <div class="activity-icon"><i class="bi bi-person-plus"></i></div>
                    <div class="activity-content">
                        <div class="activity-title">បានបន្ថែមសិស្សថ្មី: សុខ សុភ័ក្រ</div>
                        <div class="activity-time"><i class="bi bi-clock"></i> 5 នាទីមុន</div>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon"><i class="bi bi-cash"></i></div>
                    <div class="activity-content">
                        <div class="activity-title">ការបង់ប្រាក់ថ្មី: $500.00</div>
                        <div class="activity-time"><i class="bi bi-clock"></i> 30 នាទីមុន</div>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon"><i class="bi bi-calendar-check"></i></div>
                    <div class="activity-content">
                        <div class="activity-title">បានកត់ត្រាវត្តមាន 25 នាក់</div>
                        <div class="activity-time"><i class="bi bi-clock"></i> 1 ម៉ោងមុន</div>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon"><i class="bi bi-bar-chart"></i></div>
                    <div class="activity-content">
                        <div class="activity-title">បានបញ្ចូលពិន្ទុ 15 នាក់</div>
                        <div class="activity-time"><i class="bi bi-clock"></i> 2 ម៉ោងមុន</div>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon"><i class="bi bi-door-open"></i></div>
                    <div class="activity-content">
                        <div class="activity-title">បានបន្ថែមថ្នាក់ថ្មី: គណិតវិទ្យា</div>
                        <div class="activity-time"><i class="bi bi-clock"></i> 3 ម៉ោងមុន</div>
                    </div>
                </li>
            </ul>
        </div>
    </div>

    <div class="col-md-6">
        <div class="recent-activities">
            <div class="section-title mb-3">
                <i class="bi bi-calendar-event"></i>
                <span>កាលបរិច្ឆេទសំខាន់ៗ</span>
            </div>

            <div class="deadline-grid">
                <div class="deadline-card">
                    <div class="deadline-date">
                        <span class="day">15</span>
                        <span class="month">មីនា</span>
                    </div>
                    <div class="deadline-info">
                        <h5>ថ្ងៃផុតកំណត់បង់ប្រាក់</h5>
                        <p><i class="bi bi-clock"></i> នៅសល់ 3 ថ្ងៃ</p>
                        <span class="deadline-badge badge-urgent">បន្ទាន់</span>
                    </div>
                </div>

                <div class="deadline-card">
                    <div class="deadline-date">
                        <span class="day">20</span>
                        <span class="month">មីនា</span>
                    </div>
                    <div class="deadline-info">
                        <h5>ប្រឡងពាក់កណ្តាលឆ្នាំ</h5>
                        <p><i class="bi bi-clock"></i> នៅសល់ 8 ថ្ងៃ</p>
                        <span class="deadline-badge badge-warning">ជិតដល់</span>
                    </div>
                </div>

                <div class="deadline-card">
                    <div class="deadline-date">
                        <span class="day">25</span>
                        <span class="month">មីនា</span>
                    </div>
                    <div class="deadline-info">
                        <h5>ប្រកាសពិន្ទុ</h5>
                        <p><i class="bi bi-clock"></i> នៅសល់ 13 ថ្ងៃ</p>
                        <span class="deadline-badge badge-normal">ធម្មតា</span>
                    </div>
                </div>

                <div class="deadline-card">
                    <div class="deadline-date">
                        <span class="day">30</span>
                        <span class="month">មីនា</span>
                    </div>
                    <div class="deadline-info">
                        <h5>បិទការចុះឈ្មោះ</h5>
                        <p><i class="bi bi-clock"></i> នៅសល់ 18 ថ្ងៃ</p>
                        <span class="deadline-badge badge-normal">ធម្មតា</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Announcement -->
        <div class="announcement-card mt-4">
            <div class="announcement-icon">
                <i class="bi bi-megaphone-fill"></i>
            </div>
            <div class="announcement-content">
                <h5>ប្រកាសព័ត៌មាន</h5>
                <p>ការប្រឡងពាក់កណ្តាលឆ្នាំនឹងប្រព្រឹត្តទៅនៅថ្ងៃទី 20 ខែ មីនា សូមសិស្សានុសិស្សត្រៀមខ្លួនអោយបានល្អ។</p>
            </div>
        </div>
    </div>
</div>

<script>
    let students = [];
    let classes = [];
    let payments = [];
    let grades = [];

    $(document).ready(function() {
        loadData();
    });

    function loadData() {
        Promise.all([
            loadStudents(),
            loadClasses(),
            loadPayments(),
            loadGrades()
        ]).then(() => {
            updateStats();
        });
    }

    function loadStudents() {
        return $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            success: function(data) {
                students = data;
            }
        });
    }

    function loadClasses() {
        return $.ajax({
            url: '/Student/GetClasses',
            type: 'GET',
            success: function(data) {
                classes = data;
            }
        });
    }

    function loadPayments() {
        return $.ajax({
            url: '/Student/GetPayments',
            type: 'GET',
            success: function(data) {
                payments = data;
            }
        });
    }

    function loadGrades() {
        return $.ajax({
            url: '/Student/GetGrades',
            type: 'GET',
            success: function(data) {
                grades = data;
            }
        });
    }

    function updateStats() {
        var totalStudents = students.length;
        var totalClasses = classes.length;
        var totalPayments = payments.reduce((sum, p) => sum + (p.amount || 0), 0);

        var avgGrade = 0;
        if (grades.length > 0) {
            avgGrade = (grades.reduce((sum, g) => sum + (g.total || 0), 0) / grades.length).toFixed(1);
        }

        $('#totalStudents').text(totalStudents);
        $('#totalClasses').text(totalClasses);
        $('#totalPayments').text('$' + totalPayments.toFixed(2));
        $('#avgGrade').text(avgGrade);
    }
</script>