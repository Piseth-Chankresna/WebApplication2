@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Student Center";
}

<style>
    /* ====== VARIABLES ====== */
    :root {
        --primary-50: #eef2ff;
        --primary-100: #e0e7ff;
        --primary-200: #c7d2fe;
        --primary-300: #a5b4fc;
        --primary-400: #818cf8;
        --primary-500: #6366f1;
        --primary-600: #4f46e5;
        --primary-700: #4338ca;
        --secondary-500: #0ea5e9;
        --success-500: #22c55e;
        --warning-500: #f59e0b;
        --danger-500: #ef4444;
        --info-500: #3b82f6;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --bg-primary: #ffffff;
        --bg-secondary: #f8fafc;
        --text-primary: #1e293b;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.03);
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
        --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
        --radius-sm: 12px;
        --radius-md: 16px;
        --radius-lg: 24px;
        --radius-xl: 32px;
    }

    [data-bs-theme="dark"] {
        --bg-primary: #0f172a;
        --bg-secondary: #1e293b;
        --text-primary: #f1f5f9;
        --text-secondary: #cbd5e1;
        --text-muted: #94a3b8;
        --gray-50: #18181b;
        --gray-100: #27272a;
        --gray-200: #3f3f46;
        --gray-300: #52525b;
        --gray-400: #71717a;
        --gray-500: #a1a1aa;
        --gray-600: #d4d4d8;
        --gray-700: #e4e4e7;
        --gray-800: #f4f4f5;
        --gray-900: #fafafa;
    }

    /* ====== BASE STYLES ====== */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: var(--bg-secondary);
        color: var(--text-primary);
        font-family: 'Inter', 'Kantumruy Pro', sans-serif;
    }

    .student-center-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 20px;
    }

    /* ====== HEADER SECTION ====== */
    .welcome-header {
        background: linear-gradient(135deg, var(--primary-600), var(--secondary-500));
        border-radius: var(--radius-xl);
        padding: 40px;
        margin-bottom: 30px;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
    }

        .welcome-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -10%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

        .welcome-header::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -5%;
            width: 200px;
            height: 200px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

    .welcome-content {
        position: relative;
        z-index: 2;
        display: flex;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    .welcome-icon {
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 30px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        box-shadow: var(--shadow-lg);
    }

    .welcome-text h1 {
        font-size: 2.2rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .welcome-text p {
        font-size: 1rem;
        opacity: 0.9;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .date-badge {
        background: rgba(255, 255, 255, 0.2);
        padding: 6px 15px;
        border-radius: 40px;
        font-size: 0.9rem;
        backdrop-filter: blur(5px);
    }

    /* ====== STATS CARDS ====== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: var(--bg-primary);
        border-radius: var(--radius-lg);
        padding: 24px;
        box-shadow: var(--shadow);
        border: 1px solid var(--gray-200);
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.5s ease;
        animation-fill-mode: both;
    }

        .stat-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .stat-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .stat-card:nth-child(4) {
            animation-delay: 0.4s;
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
        border-color: var(--primary-300);
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: var(--primary-500);
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .stat-label {
        color: var(--text-secondary);
        font-size: 0.9rem;
    }

    /* ====== QUICK ACTIONS ====== */
    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        font-weight: 700;
        color: var(--text-primary);
    }

        .section-title i {
            color: var(--primary-500);
            font-size: 1.5rem;
        }

    .actions-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .action-card {
        background: var(--bg-primary);
        border-radius: var(--radius-lg);
        padding: 25px 20px;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        border: 1px solid var(--gray-200);
        box-shadow: var(--shadow);
        position: relative;
        overflow: hidden;
        cursor: pointer;
        animation: fadeIn 0.6s ease;
        animation-fill-mode: both;
    }

        .action-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .action-card:nth-child(2) {
            animation-delay: 0.15s;
        }

        .action-card:nth-child(3) {
            animation-delay: 0.2s;
        }

        .action-card:nth-child(4) {
            animation-delay: 0.25s;
        }

        .action-card:nth-child(5) {
            animation-delay: 0.3s;
        }

        .action-card:nth-child(6) {
            animation-delay: 0.35s;
        }

        .action-card:nth-child(7) {
            animation-delay: 0.4s;
        }

        .action-card:nth-child(8) {
            animation-delay: 0.45s;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .action-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--primary-500), var(--secondary-500));
        transform: scaleX(0);
        transition: transform 0.3s ease;
    }

    .action-card:hover::before {
        transform: scaleX(1);
    }

    .action-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
    }

    .action-icon {
        width: 70px;
        height: 70px;
        background: var(--primary-50);
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-600);
        font-size: 2rem;
        margin: 0 auto 15px;
        transition: all 0.3s ease;
    }

    .action-card:hover .action-icon {
        transform: scale(1.1) rotate(5deg);
        background: var(--primary-100);
    }

    .action-card h4 {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 5px;
        font-size: 1.1rem;
    }

    .action-card p {
        color: var(--text-secondary);
        margin: 0;
        font-size: 0.85rem;
    }

    /* ====== QUICK STATS ====== */
    .quick-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .quick-stat-item {
        background: var(--bg-primary);
        border-radius: var(--radius-md);
        padding: 15px;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid var(--gray-200);
        transition: all 0.2s ease;
    }

        .quick-stat-item:hover {
            background: var(--primary-50);
            border-color: var(--primary-300);
        }

    .quick-stat-icon {
        width: 45px;
        height: 45px;
        background: var(--primary-100);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-600);
        font-size: 1.3rem;
    }

    .quick-stat-info h5 {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 2px;
    }

    .quick-stat-info p {
        color: var(--text-secondary);
        margin: 0;
        font-size: 0.8rem;
    }

    /* ====== RECENT ACTIVITIES ====== */
    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 25px;
        margin-bottom: 30px;
    }

    .recent-card {
        background: var(--bg-primary);
        border-radius: var(--radius-xl);
        padding: 25px;
        box-shadow: var(--shadow);
        border: 1px solid var(--gray-200);
    }

    .card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

        .card-header h3 {
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .card-header h3 i {
                color: var(--primary-500);
            }

    .view-all-link {
        color: var(--primary-600);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 5px;
        transition: all 0.2s ease;
    }

        .view-all-link:hover {
            color: var(--primary-700);
            gap: 8px;
        }

    .activity-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .activity-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px 0;
        border-bottom: 1px solid var(--gray-200);
        transition: all 0.2s ease;
    }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-item:hover {
            background: var(--gray-50);
            padding-left: 10px;
            border-radius: 12px;
        }

    .activity-icon {
        width: 40px;
        height: 40px;
        background: var(--primary-50);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary-600);
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .activity-content {
        flex: 1;
    }

    .activity-title {
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 2px;
    }

    .activity-time {
        font-size: 0.8rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* ====== UPCOMING EVENTS ====== */
    .event-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .event-item {
        background: var(--gray-50);
        border-radius: 16px;
        padding: 16px;
        border-left: 4px solid;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .event-item:hover {
            transform: translateX(5px);
            box-shadow: var(--shadow-md);
        }

    .event-warning {
        border-left-color: var(--warning-500);
    }

    .event-important {
        border-left-color: var(--danger-500);
    }

    .event-info {
        border-left-color: var(--info-500);
    }

    .event-success {
        border-left-color: var(--success-500);
    }

    .event-date {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .event-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .event-title {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .event-description {
        font-size: 0.85rem;
        color: var(--text-secondary);
    }

    /* ====== NOTICE BOARD ====== */
    .notice-card {
        background: linear-gradient(135deg, var(--primary-50), var(--primary-100));
        border-radius: 20px;
        padding: 20px;
        margin-top: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
        border: 1px solid var(--primary-200);
        transition: all 0.3s ease;
    }

        .notice-card:hover {
            transform: scale(1.02);
            box-shadow: var(--shadow-lg);
        }

    .notice-icon {
        width: 50px;
        height: 50px;
        background: var(--primary-600);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.5rem;
    }

    .notice-content {
        flex: 1;
    }

        .notice-content h5 {
            font-weight: 700;
            color: var(--primary-700);
            margin-bottom: 4px;
        }

        .notice-content p {
            color: var(--text-secondary);
            margin: 0;
            font-size: 0.9rem;
        }

    /* ====== LOADING ====== */
    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid var(--gray-200);
        border-top-color: var(--primary-500);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 20px auto;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ====== RESPONSIVE ====== */
    @@media (max-width: 1024px) {
        .stats-grid,
        .actions-grid,
        .quick-stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .content-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .stats-grid,
        .actions-grid,
        .quick-stats-grid {
            grid-template-columns: 1fr;
        }

        .welcome-content {
            flex-direction: column;
            text-align: center;
        }

        .welcome-text h1 {
            font-size: 1.8rem;
        }
    }
</style>

<!-- AntiForgeryToken -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="student-center-container">
    <!-- Welcome Header -->
    <div class="welcome-header">
        <div class="welcome-content">
            <div class="welcome-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </div>
            <div class="welcome-text">
                <h1>សូមស្វាគមន៍មកកាន់ Student Center</h1>
                <p>
                    <span><i class="bi bi-person-circle"></i> អ្នកគ្រប់គ្រង</span>
                    <span class="date-badge" id="currentDateTime"></span>
                </p>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid" id="statsGrid">
        <div class="stat-card">
            <i class="bi bi-people-fill stat-icon"></i>
            <div class="stat-value" id="totalStudents">0</div>
            <div class="stat-label">សិស្សសរុប</div>
        </div>
        <div class="stat-card">
            <i class="bi bi-door-open-fill stat-icon"></i>
            <div class="stat-value" id="totalClasses">0</div>
            <div class="stat-label">ថ្នាក់សរុប</div>
        </div>
        <div class="stat-card">
            <i class="bi bi-cash-stack stat-icon"></i>
            <div class="stat-value" id="totalPayments">$0</div>
            <div class="stat-label">បង់ប្រាក់សរុប</div>
        </div>
        <div class="stat-card">
            <i class="bi bi-bar-chart-fill stat-icon"></i>
            <div class="stat-value" id="avgGrade">0.0</div>
            <div class="stat-label">ពិន្ទុមធ្យម</div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="quick-stats-grid" id="quickStats">
        <div class="quick-stat-item">
            <div class="quick-stat-icon"><i class="bi bi-gender-male"></i></div>
            <div class="quick-stat-info">
                <h5 id="maleStudents">0</h5>
                <p>សិស្សប្រុស</p>
            </div>
        </div>
        <div class="quick-stat-item">
            <div class="quick-stat-icon"><i class="bi bi-gender-female"></i></div>
            <div class="quick-stat-info">
                <h5 id="femaleStudents">0</h5>
                <p>សិស្សស្រី</p>
            </div>
        </div>
        <div class="quick-stat-item">
            <div class="quick-stat-icon"><i class="bi bi-check-circle"></i></div>
            <div class="quick-stat-info">
                <h5 id="activeStudents">0</h5>
                <p>កំពុងសិក្សា</p>
            </div>
        </div>
        <div class="quick-stat-item">
            <div class="quick-stat-icon"><i class="bi bi-trophy"></i></div>
            <div class="quick-stat-info">
                <h5 id="scholarshipCount">0</h5>
                <p>មានអាហារូបករណ៍</p>
            </div>
        </div>
    </div>

    <!-- Section Title -->
    <div class="section-title">
        <i class="bi bi-lightning-charge-fill"></i>
        <h3>សកម្មភាពរហ័ស</h3>
    </div>

    <!-- Quick Actions Grid -->
    <div class="actions-grid">
        <div class="action-card" onclick="window.location.href='/Student/Create'">
            <div class="action-icon"><i class="bi bi-person-plus-fill"></i></div>
            <h4>បន្ថែមសិស្សថ្មី</h4>
            <p>ចុះឈ្មោះសិស្សថ្មីក្នុងប្រព័ន្ធ</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Student/Index'">
            <div class="action-icon"><i class="bi bi-people-fill"></i></div>
            <h4>បញ្ជីសិស្ស</h4>
            <p>មើល និងគ្រប់គ្រងបញ្ជីសិស្ស</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Student/Classes'">
            <div class="action-icon"><i class="bi bi-door-open-fill"></i></div>
            <h4>គ្រប់គ្រងថ្នាក់</h4>
            <p>បន្ថែម និងកែប្រែថ្នាក់រៀន</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Student/CheckAttendance'">
            <div class="action-icon"><i class="bi bi-calendar-check-fill"></i></div>
            <h4>វត្តមាន</h4>
            <p>បំពេញ និងពិនិត្យវត្តមាន</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Student/Grades'">
            <div class="action-icon"><i class="bi bi-bar-chart-fill"></i></div>
            <h4>គ្រប់គ្រងពិន្ទុ</h4>
            <p>បញ្ចូល និងកែប្រែពិន្ទុសិស្ស</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Student/Payment'">
            <div class="action-icon"><i class="bi bi-credit-card-fill"></i></div>
            <h4>ការបង់ប្រាក់</h4>
            <p>គ្រប់គ្រងការបង់ប្រាក់របស់សិស្ស</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Student/Scholarship'">
            <div class="action-icon"><i class="bi bi-gift-fill"></i></div>
            <h4>អាហារូបករណ៍</h4>
            <p>គ្រប់គ្រងអាហារូបករណ៍សិស្ស</p>
        </div>

        <div class="action-card" onclick="window.location.href='/Report/Index'">
            <div class="action-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
            <h4>របាយការណ៍</h4>
            <p>មើលរបាយការណ៍ និងស្ថិតិ</p>
        </div>
    </div>

    <!-- Content Grid -->
    <div class="content-grid">
        <!-- Recent Activities -->
        <div class="recent-card">
            <div class="card-header">
                <h3><i class="bi bi-clock-history"></i> សកម្មភាពថ្មីៗ</h3>
                <a href="/SystemSettings/ActivityLogs" class="view-all-link">
                    មើលទាំងអស់ <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div id="recentActivities">
                <div class="text-center py-4">
                    <div class="loading-spinner"></div>
                </div>
            </div>
        </div>

        <!-- Upcoming Events -->
        <div class="recent-card">
            <div class="card-header">
                <h3><i class="bi bi-calendar-event"></i> ព្រឹត្តិការណ៍ខាងមុខ</h3>
                <span class="badge-count" id="eventCount">5 ព្រឹត្តិការណ៍</span>
            </div>

            <div class="event-list" id="upcomingEvents">
                <!-- Events will be loaded here -->
            </div>

            <!-- Notice Board -->
            <div class="notice-card">
                <div class="notice-icon">
                    <i class="bi bi-megaphone-fill"></i>
                </div>
                <div class="notice-content">
                    <h5>ប្រកាសព័ត៌មាន</h5>
                    <p id="dailyNotice">កំពុងផ្ទុក...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
<script>
    // ==================== GLOBAL VARIABLES ====================
    let refreshInterval;
    let students = [];
    let classes = [];
    let payments = [];
    let grades = [];

    // ==================== DOCUMENT READY ====================
    $(document).ready(function() {
        updateDateTime();
        loadAllData();
        startAutoRefresh();

        // Update datetime every second
        setInterval(updateDateTime, 1000);
    });

    function updateDateTime() {
        let now = new Date();
        let options = {
            weekday: 'long',
            year: 'numeric',
            month: 'long',
            day: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        };
        $('#currentDateTime').text(now.toLocaleDateString('km-KH', options));
    }

    function startAutoRefresh() {
        refreshInterval = setInterval(() => {
            refreshData();
        }, 30000); // Refresh every 30 seconds
    }

    function refreshData() {
        loadAllData();
    }

    function loadAllData() {
        loadStudents();
        loadClasses();
        loadPayments();
        loadGrades();
        loadRecentActivities();
        loadUpcomingEvents();
    }

    // ==================== LOAD DATA ====================
    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            cache: false,
            success: function(response) {
                if (response && response.success) {
                    students = response.data || [];
                } else if (Array.isArray(response)) {
                    students = response;
                } else {
                    students = [];
                }
                updateStats();
            },
            error: function(xhr, status, error) {
                console.error('Error loading students:', error);
            }
        });
    }

    function loadClasses() {
        $.ajax({
            url: '/Student/GetClasses',
            type: 'GET',
            cache: false,
            success: function(response) {
                if (response && response.success) {
                    classes = response.data || [];
                } else if (Array.isArray(response)) {
                    classes = response;
                } else {
                    classes = [];
                }
                updateStats();
            },
            error: function(xhr, status, error) {
                console.error('Error loading classes:', error);
            }
        });
    }

    function loadPayments() {
        $.ajax({
            url: '/Student/GetPayments',
            type: 'GET',
            cache: false,
            success: function(response) {
                if (response && response.success) {
                    payments = response.data || [];
                } else if (Array.isArray(response)) {
                    payments = response;
                } else {
                    payments = [];
                }
                updateStats();
            },
            error: function(xhr, status, error) {
                console.error('Error loading payments:', error);
            }
        });
    }

    function loadGrades() {
        $.ajax({
            url: '/Student/GetGrades',
            type: 'GET',
            cache: false,
            success: function(response) {
                if (response && response.success) {
                    grades = response.data || [];
                } else if (Array.isArray(response)) {
                    grades = response;
                } else {
                    grades = [];
                }
                updateStats();
            },
            error: function(xhr, status, error) {
                console.error('Error loading grades:', error);
            }
        });
    }

    // ==================== UPDATE STATISTICS ====================
    function updateStats() {
        // Student stats
        let totalStudents = students.length;
        let maleStudents = students.filter(s => s.gender === 'ប្រុស' || s.gender === 'Male').length;
        let femaleStudents = students.filter(s => s.gender === 'ស្រី' || s.gender === 'Female').length;
        let activeStudents = students.filter(s => s.status === 'កំពុងសិក្សា').length;
        let scholarshipCount = students.filter(s => s.scholarship && s.scholarship !== '0%').length;

        $('#totalStudents').text(totalStudents);
        $('#maleStudents').text(maleStudents);
        $('#femaleStudents').text(femaleStudents);
        $('#activeStudents').text(activeStudents);
        $('#scholarshipCount').text(scholarshipCount);

        // Class stats
        $('#totalClasses').text(classes.length);

        // Payment stats
        let totalPayments = payments.reduce((sum, p) => sum + (p.amount || 0), 0);
        $('#totalPayments').text('$' + totalPayments.toFixed(2));

        // Grade stats
        let avgGrade = 0;
        if (grades.length > 0) {
            avgGrade = grades.reduce((sum, g) => sum + (g.total || 0), 0) / grades.length;
        }
        $('#avgGrade').text(avgGrade.toFixed(1));
    }

    // ==================== RECENT ACTIVITIES ====================
    function loadRecentActivities() {
        $.ajax({
            url: '/SystemSettings/GetRecentActivities',
            type: 'GET',
            cache: false,
            success: function(response) {
                if (response && response.success) {
                    renderRecentActivities(response.data);
                } else {
                    renderRecentActivities([]);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error loading activities:', error);
                renderRecentActivities([]);
            }
        });
    }

    function renderRecentActivities(activities) {
        let container = $('#recentActivities');
        container.empty();

        if (!activities || activities.length === 0) {
            container.html('<div class="text-center py-4 text-muted">មិនទាន់មានសកម្មភាព</div>');
            return;
        }

        let html = '<ul class="activity-list">';
        activities.slice(0, 5).forEach(activity => {
            let icon = activity.icon || 'bi-circle-fill';
            let timeAgo = activity.timeAgo || 'ទើបតែប៉ុន្មាននាទីមុន';

            html += `
                <li class="activity-item">
                    <div class="activity-icon"><i class="bi ${icon}"></i></div>
                    <div class="activity-content">
                        <div class="activity-title">${activity.action}</div>
                        <div class="activity-time"><i class="bi bi-clock"></i> ${timeAgo}</div>
                    </div>
                </li>
            `;
        });
        html += '</ul>';
        container.html(html);
    }

    // ==================== UPCOMING EVENTS ====================
    function loadUpcomingEvents() {
        let today = new Date();
        let events = [
            {
                date: new Date(today.getFullYear(), today.getMonth(), today.getDate() + 3),
                title: 'ថ្ងៃផុតកំណត់បង់ប្រាក់',
                type: 'warning',
                description: 'សិស្សដែលមិនទាន់បង់ប្រាក់ត្រូវបង់មុនថ្ងៃនេះ'
            },
            {
                date: new Date(today.getFullYear(), today.getMonth(), today.getDate() + 7),
                title: 'ប្រឡងពាក់កណ្តាលឆ្នាំ',
                type: 'important',
                description: 'ប្រឡងឆមាសទី១ ឆ្នាំសិក្សា 2025-2026'
            },
            {
                date: new Date(today.getFullYear(), today.getMonth(), today.getDate() + 14),
                title: 'កិច្ចប្រជុំគណៈគ្រប់គ្រង',
                type: 'info',
                description: 'ប្រជុំពិភាក្សាពីការអភិវឌ្ឍន៍កម្មវិធីសិក្សា'
            },
            {
                date: new Date(today.getFullYear(), today.getMonth(), today.getDate() + 21),
                title: 'ទិវាជាតិ',
                type: 'success',
                description: 'ច្បាប់ឈប់សម្រាក'
            }
        ];

        renderUpcomingEvents(events);
        updateDailyNotice();
    }

    function renderUpcomingEvents(events) {
        let container = $('#upcomingEvents');
        container.empty();

        events.sort((a, b) => a.date - b.date).slice(0, 3).forEach(event => {
            let daysLeft = Math.ceil((event.date - new Date()) / (1000 * 60 * 60 * 24));
            let daysText = daysLeft === 0 ? 'ថ្ងៃនេះ' : daysLeft === 1 ? '១ ថ្ងៃទៀត' : `${daysLeft} ថ្ងៃទៀត`;

            let badgeClass = event.type === 'warning' ? 'bg-warning' :
                            event.type === 'important' ? 'bg-danger' :
                            event.type === 'info' ? 'bg-info' : 'bg-success';

            let badgeText = event.type === 'warning' ? 'ជិតដល់' :
                           event.type === 'important' ? 'សំខាន់' :
                           event.type === 'info' ? 'ព័ត៌មាន' : 'រីករាយ';

            container.append(`
                <div class="event-item event-${event.type}">
                    <div class="event-date">
                        <span><i class="bi bi-calendar3"></i> ${moment(event.date).format('DD MMM YYYY')}</span>
                        <span class="event-badge ${badgeClass} text-white">${badgeText}</span>
                    </div>
                    <div class="event-title">${event.title}</div>
                    <div class="event-description">${event.description}</div>
                    <div class="mt-2 small text-muted"><i class="bi bi-hourglass"></i> នៅសល់ ${daysText}</div>
                </div>
            `);
        });

        $('#eventCount').text(events.length + ' ព្រឹត្តិការណ៍');
    }

    function updateDailyNotice() {
        let notices = [
            'ការប្រឡងពាក់កណ្តាលឆ្នាំនឹងប្រព្រឹត្តទៅនៅថ្ងៃទី ២០ ខែ មីនា',
            'សូមសិស្សានុសិស្សទាំងអស់មកកាន់សាលាមុនម៉ោង ៧:០០ ព្រឹក',
            'ការបង់ប្រាក់ឆមាសទី២ អាចធ្វើតាមរយៈ ABA Pay ឬ Wing',
            'កិច្ចប្រជុំគណៈគ្រប់គ្រងនឹងប្រព្រឹត្តទៅនៅថ្ងៃសុក្រនេះ'
        ];
        let randomNotice = notices[Math.floor(Math.random() * notices.length)];
        $('#dailyNotice').text(randomNotice);
    }

    // Clean up interval on page unload
    window.addEventListener('beforeunload', function() {
        if (refreshInterval) {
            clearInterval(refreshInterval);
        }
    });
</script>