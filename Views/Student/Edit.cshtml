@model WebApplication2.Models.Student
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "កែប្រែព័ត៌មានសិស្ស";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #f59e0b;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #f59e0b, #d97706);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .form-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .form-card {
        background: #1e293b;
        border-color: #334155;
    }

    .student-id-badge {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        padding: 12px 24px;
        border-radius: 60px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 30px;
        font-weight: 600;
        box-shadow: 0 10px 15px -3px rgba(245,158,11,0.2);
    }

        .student-id-badge i {
            font-size: 1.2rem;
        }

    .form-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .form-header i {
            font-size: 3.5rem;
            color: #f59e0b;
            margin-bottom: 16px;
        }

        .form-header h3 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 8px;
        }

    [data-theme="dark"] .form-header h3 {
        color: white;
    }

    .form-header p {
        color: #64748b;
        margin: 0;
    }

    .section-title {
        font-weight: 700;
        color: #1e293b;
        margin: 30px 0 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    [data-theme="dark"] .section-title {
        color: white;
        border-bottom-color: #334155;
    }

    .section-title i {
        color: #f59e0b;
        font-size: 1.5rem;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-label i {
        margin-right: 8px;
        color: #f59e0b;
    }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
        }

        .input-wrapper input,
        .input-wrapper select,
        .input-wrapper textarea {
            width: 100%;
            padding: 14px 16px 14px 48px;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            background: white;
            color: #1e293b;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

    [data-theme="dark"] .input-wrapper input,
    [data-theme="dark"] .input-wrapper select,
    [data-theme="dark"] .input-wrapper textarea {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .input-wrapper input:focus,
    .input-wrapper select:focus,
    .input-wrapper textarea:focus {
        outline: none;
        border-color: #f59e0b;
        box-shadow: 0 0 0 4px rgba(245,158,11,0.1);
    }

    .input-wrapper select {
        appearance: none;
        cursor: pointer;
    }

    .input-wrapper .select-arrow {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .photo-section {
        display: flex;
        align-items: center;
        gap: 30px;
        margin-bottom: 30px;
        padding: 25px;
        background: #f8fafc;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .photo-section {
        background: #0f172a;
        border-color: #334155;
    }

    .current-photo {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        background: linear-gradient(135deg, #f59e0b, #d97706);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 3rem;
        font-weight: 700;
        overflow: hidden;
    }

        .current-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .photo-upload {
        flex: 1;
        border: 2px dashed #e2e8f0;
        border-radius: 16px;
        padding: 25px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .photo-upload:hover {
            border-color: #f59e0b;
            background: #fef3c7;
        }

    [data-theme="dark"] .photo-upload:hover {
        background: #422006;
    }

    .photo-upload i {
        font-size: 2.5rem;
        color: #94a3b8;
        margin-bottom: 10px;
    }

    .photo-upload p {
        color: #64748b;
        margin: 0;
        font-size: 0.95rem;
    }

    .photo-upload small {
        color: #94a3b8;
        font-size: 0.8rem;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 2px solid #e2e8f0;
    }

    [data-theme="dark"] .form-actions {
        border-top-color: #334155;
    }

    .btn {
        flex: 1;
        padding: 16px;
        border: none;
        border-radius: 16px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(245,158,11,0.3);
        }

    .btn-secondary {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .btn-secondary {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
    }

    .alert {
        padding: 16px;
        border-radius: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #ef4444;
        border: 1px solid #fecaca;
    }

    .alert-success {
        background: #d1fae5;
        color: #10b981;
        border: 1px solid #a7f3d0;
    }

    .row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    @@media (max-width: 768px) {
        .row {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }

        .photo-section {
            flex-direction: column;
            text-align: center;
        }

        .current-photo {
            width: 150px;
            height: 150px;
        }
    }
</style>

<!-- AntiForgeryToken -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-pencil-square me-2"></i>កែប្រែព័ត៌មានសិស្ស</h2>
    <p class="text-muted">កែប្រែព័ត៌មានសិស្សក្នុងប្រព័ន្ធ</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
    </div>
}

<div class="form-container">
    <div class="form-card">
        <!-- Student ID Badge -->
        <div class="student-id-badge">
            <i class="bi bi-upc-scan"></i>
            <span>លេខសម្គាល់សិស្ស: @Model.Id</span>
        </div>

        <div class="form-header">
            <i class="bi bi-pencil-square"></i>
            <h3>កែប្រែព័ត៌មាន</h3>
            <p>សូមកែប្រែព័ត៌មានខាងក្រោម</p>
        </div>

        <form asp-action="Update" asp-controller="Student" method="post" id="editForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" id="existingPhoto" name="ExistingPhoto" value="@Model.Photo" />

            <!-- Photo Section -->
            <div class="photo-section">
                <div class="current-photo" id="photoPreviewContainer">
                    @if (!string.IsNullOrEmpty(Model.Photo))
                    {
                        <img src="@Model.Photo" alt="@Model.Name" id="previewImg" style="width:100%; height:100%; object-fit:cover;" onerror="this.src='https://ui-avatars.com/api/?name=@(Model.Name ?? "User")&background=f59e0b&color=fff&size=120'">
                    }
                    else
                    {
                        <span id="previewInitial">@(Model.Name?.Length > 0 ? Model.Name.Substring(0, 1).ToUpper() : "?")</span>
                        <img src="" alt="" id="previewImg" style="display: none;">
                    }
                </div>
                <div class="photo-upload" onclick="$('#photoInput').click()">
                    <i class="bi bi-camera"></i>
                    <p>ចុចដើម្បីផ្លាស់ប្តូររូបថត</p>
                    <small>គាំទ្រ JPG, PNG</small>
                </div>
                <input type="file" id="photoInput" name="NewPhoto" accept="image/*" style="display: none;">
            </div>

            <!-- Personal Information -->
            <div class="section-title">
                <i class="bi bi-person"></i>
                <span>ព័ត៌មានផ្ទាល់ខ្លួន</span>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-person"></i> ឈ្មោះពេញ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-person"></i>
                        <input asp-for="Name" class="form-control" placeholder="ឧ. សុខ សុភ័ក្រ" required>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-gender-ambiguous"></i> ភេទ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-gender-ambiguous"></i>
                        <select asp-for="Gender" class="form-control" required>
                            <option value="">ជ្រើសរើសភេទ</option>
                            <option value="ប្រុស">ប្រុស</option>
                            <option value="ស្រី">ស្រី</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-calendar"></i> ថ្ងៃខែឆ្នាំកំណើត</label>
                    <div class="input-wrapper">
                        <i class="bi bi-calendar"></i>
                        <input asp-for="Dob" type="date" class="form-control" required>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-geo-alt"></i> ទីកន្លែងកំណើត</label>
                    <div class="input-wrapper">
                        <i class="bi bi-geo-alt"></i>
                        <input asp-for="Pob" class="form-control" placeholder="ឧ. ភ្នំពេញ" required>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="bi bi-phone"></i> លេខទូរស័ព្ទ</label>
                <div class="input-wrapper">
                    <i class="bi bi-phone"></i>
                    <input asp-for="Phone" class="form-control" placeholder="ឧ. 012 345 678" required>
                </div>
            </div>

            <!-- Academic Information -->
            <div class="section-title">
                <i class="bi bi-mortarboard"></i>
                <span>ព័ត៌មានសិក្សា</span>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-book"></i> កម្រិតសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-book"></i>
                        <select asp-for="Degree" class="form-control" required>
                            <option value="">ជ្រើសរើសកម្រិត</option>
                            <option value="បរិញ្ញាបត្ររង">បរិញ្ញាបត្ររង</option>
                            <option value="បរិញ្ញាបត្រ">បរិញ្ញាបត្រ</option>
                            <option value="បរិញ្ញាបត្រជាន់ខ្ពស់">បរិញ្ញាបត្រជាន់ខ្ពស់</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-star"></i> ជំនាញ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-star"></i>
                        <select asp-for="Major" class="form-control" required>
                            <option value="">ជ្រើសរើសជំនាញ</option>
                            <option value="Information Technology">Information Technology</option>
                            <option value="Business Administration">Business Administration</option>
                            <option value="English Literature">English Literature</option>
                            <option value="Law">Law</option>
                            <option value="Accounting">Accounting</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-calendar3"></i> ឆ្នាំសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-calendar3"></i>
                        <select asp-for="Year" class="form-control" required>
                            <option value="">ជ្រើសរើសឆ្នាំ</option>
                            <option value="1">ឆ្នាំទី១</option>
                            <option value="2">ឆ្នាំទី២</option>
                            <option value="3">ឆ្នាំទី៣</option>
                            <option value="4">ឆ្នាំទី៤</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-door-open"></i> បន្ទប់</label>
                    <div class="input-wrapper">
                        <i class="bi bi-door-open"></i>
                        <input asp-for="Room" class="form-control" placeholder="ឧ. A101" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-clock"></i> វេនសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-clock"></i>
                        <select asp-for="Shift" class="form-control" required>
                            <option value="">ជ្រើសរើសវេន</option>
                            <option value="ព្រឹក">ព្រឹក (៧:០០-១១:០០)</option>
                            <option value="រសៀល">រសៀល (១:០០-៥:០០)</option>
                            <option value="យប់">យប់ (៥:៣០-៨:៣០)</option>
                            <option value="សៅរ៍-អាទិត្យ">សៅរ៍-អាទិត្យ</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-gift"></i> អាហារូបករណ៍</label>
                    <div class="input-wrapper">
                        <i class="bi bi-gift"></i>
                        <select asp-for="Scholarship" class="form-control">
                            <option value="0%">0% (បង់ថ្លៃពេញ)</option>
                            <option value="25%">25%</option>
                            <option value="50%">50%</option>
                            <option value="75%">75%</option>
                            <option value="100%">100%</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="section-title">
                <i class="bi bi-info-circle"></i>
                <span>ព័ត៌មានបន្ថែម</span>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-tag"></i> លេខសម្គាល់ (បើមាន)</label>
                    <div class="input-wrapper">
                        <i class="bi bi-tag"></i>
                        <input asp-for="Batch" class="form-control" placeholder="ឧ. BATCH-2025">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-calendar-week"></i> ឆ្នាំសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-calendar-week"></i>
                        <input asp-for="AcademicYear" class="form-control" placeholder="ឧ. 2025-2026">
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label class="form-label"><i class="bi bi-currency-dollar"></i> ថ្លៃសិក្សាត្រូវបង់ ($)</label>
                    <div class="input-wrapper">
                        <i class="bi bi-currency-dollar"></i>
                        <input asp-for="AmountDue" class="form-control" step="0.01">
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label"><i class="bi bi-flag"></i> ស្ថានភាព</label>
                    <div class="input-wrapper">
                        <i class="bi bi-flag"></i>
                        <select asp-for="Status" class="form-control">
                            <option value="កំពុងសិក្សា">កំពុងសិក្សា</option>
                            <option value="ឈប់សម្រាក">ឈប់សម្រាក</option>
                            <option value="បញ្ចប់ការសិក្សា">បញ្ចប់ការសិក្សា</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a href="/Student/Index" class="btn btn-secondary ajax-link" data-url="/Student/Index">
                    <i class="bi bi-x-lg"></i> បោះបង់
                </a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="bi bi-check-lg"></i> រក្សាទុកការកែប្រែ
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function() {
        // Preview photo before upload
        $('#photoInput').change(function(e) {
            var file = e.target.files[0];
            if (file) {
                var reader = new FileReader();
                reader.onload = function(e) {
                    $('#previewImg').attr('src', e.target.result).show();
                    $('#previewInitial').hide();
                };
                reader.readAsDataURL(file);
            }
        });

        // Form submit
        $('#editForm').submit(function(e) {
            e.preventDefault();

            var token = $('input[name="__RequestVerificationToken"]').val();

            // Validate required fields
            if (!$('#Name').val()) {
                Swal.fire('កំហុស', 'សូមបញ្ចូលឈ្មោះសិស្ស', 'error');
                return;
            }

            var formData = new FormData(this);

            // Show loading
            Swal.fire({
                title: 'កំពុងរក្សាទុក...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/Student/Update',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: {
                    'RequestVerificationToken': token
                },
                success: function(response) {
                    if (response && response.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'ជោគជ័យ!',
                            text: response.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = '/Student/Index';
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'កំហុស',
                            text: response.message || 'មានបញ្ហាក្នុងការរក្សាទុក'
                        });
                    }
                },
                error: function(xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: 'មានបញ្ហាបច្ចេកទេស: ' + error
                    });
                }
            });
        });
    });
</script>