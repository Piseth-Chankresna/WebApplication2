@model IEnumerable<WebApplication2.Models.Payment>
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "ការបង់ប្រាក់";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #10b981, #059669);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #10b981;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .filter-section {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
        }

    [data-theme="dark"] .filter-item label {
        color: #cbd5e1;
    }

    .filter-item select,
    .filter-item input {
        padding: 10px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .filter-item select,
    [data-theme="dark"] .filter-item input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-filter {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .btn-add {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        padding: 12px 28px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(245,158,11,0.3);
        }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        overflow-x: auto;
    }

    [data-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .payment-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1200px;
    }

        .payment-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-theme="dark"] .payment-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .payment-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .payment-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .payment-table tbody tr:hover {
        background: #f8fafc;
    }

    [data-theme="dark"] .payment-table tbody tr:hover {
        background: #0f172a;
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
    }

    .receipt-badge {
        background: #e0e7ff;
        color: #4f46e5;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
    }

    .amount-paid {
        color: #10b981;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .amount-due {
        color: #ef4444;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-paid {
        background: #d1fae5;
        color: #10b981;
    }

    .status-pending {
        background: #fef3c7;
        color: #f59e0b;
    }

    .status-overdue {
        background: #fee2e2;
        color: #ef4444;
    }

    .btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
    }

    [data-theme="dark"] .btn-icon {
        background: #0f172a;
        border-color: #334155;
        color: #cbd5e1;
    }

    .btn-icon:hover {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        transform: translateY(-2px);
    }

    /* Modal Styles */
    .modal-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
    }

    [data-theme="dark"] .modal-content {
        background: #1e293b;
        color: white;
    }

    .modal-header {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 20px 24px;
        border: none;
    }

    .modal-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .form-control {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .form-control:focus {
        outline: none;
        border-color: #10b981;
        box-shadow: 0 0 0 4px rgba(16,185,129,0.1);
    }

    .student-select {
        max-height: 300px;
        overflow-y: auto;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px;
    }

    .student-option {
        padding: 10px;
        border-bottom: 1px solid #e2e8f0;
        cursor: pointer;
        transition: all 0.2s ease;
        border-radius: 8px;
    }

        .student-option:hover {
            background: #f1f5f9;
        }

    [data-theme="dark"] .student-option:hover {
        background: #0f172a;
    }

    .student-option.selected {
        background: #d1fae5;
        border: 2px solid #10b981;
    }

    [data-theme="dark"] .student-option.selected {
        background: #1e293b;
        border-color: #10b981;
    }

    .payment-methods {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 20px;
    }

    .payment-method {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 15px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .payment-method:hover {
            border-color: #10b981;
        }

        .payment-method.selected {
            border-color: #10b981;
            background: #d1fae5;
        }

    [data-theme="dark"] .payment-method.selected {
        background: #1e293b;
    }

    .payment-method i {
        font-size: 2rem;
        color: #10b981;
        margin-bottom: 8px;
        display: block;
    }

    .summary-section {
        background: #f8fafc;
        border-radius: 16px;
        padding: 20px;
        margin-top: 30px;
    }

    [data-theme="dark"] .summary-section {
        background: #0f172a;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #e2e8f0;
    }

        .summary-row:last-child {
            border-bottom: none;
            font-weight: 700;
            font-size: 1.2rem;
            color: #10b981;
        }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 12px 32px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    /* Receipt Modal */
    .receipt {
        background: white;
        padding: 30px;
        border-radius: 16px;
        max-width: 500px;
        margin: 0 auto;
    }

    [data-theme="dark"] .receipt {
        background: #1e293b;
        color: white;
    }

    .receipt-header {
        text-align: center;
        margin-bottom: 30px;
        padding-bottom: 20px;
        border-bottom: 2px dashed #e2e8f0;
    }

        .receipt-header h3 {
            font-weight: 800;
            color: #10b981;
            margin-bottom: 10px;
        }

    .receipt-info {
        margin-bottom: 20px;
    }

    .receipt-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid #e2e8f0;
    }

        .receipt-row.total {
            font-weight: 800;
            font-size: 1.2rem;
            color: #10b981;
            border-bottom: none;
            margin-top: 20px;
        }

    .receipt-footer {
        text-align: center;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 2px dashed #e2e8f0;
        color: #64748b;
        font-size: 0.9rem;
    }

    .btn-print {
        background: #10b981;
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        margin-top: 20px;
        width: 100%;
        transition: all 0.3s ease;
    }

        .btn-print:hover {
            background: #059669;
            transform: translateY(-2px);
        }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-credit-card-fill me-2"></i>ការបង់ប្រាក់</h2>
    <p class="text-muted">គ្រប់គ្រងការបង់ប្រាក់របស់សិស្ស</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-cash-stack stat-icon"></i>
        <div class="stat-value" id="totalCollected">$0</div>
        <div class="stat-label">បង់ប្រាក់សរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-clock-history stat-icon"></i>
        <div class="stat-value" id="totalPending">$0</div>
        <div class="stat-label">នៅរង់ចាំបង់</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-check-circle-fill stat-icon"></i>
        <div class="stat-value" id="totalPaid">0</div>
        <div class="stat-label">បង់រួច</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-grid">
        <div class="filter-item">
            <label>ជំនាញ</label>
            <select id="filterMajor">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ឆ្នាំសិក្សា</label>
            <select id="filterYear">
                <option value="">ទាំងអស់</option>
                <option value="1">ឆ្នាំទី១</option>
                <option value="2">ឆ្នាំទី២</option>
                <option value="3">ឆ្នាំទី៣</option>
                <option value="4">ឆ្នាំទី៤</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ស្ថានភាព</label>
            <select id="filterStatus">
                <option value="">ទាំងអស់</option>
                <option value="paid">បង់រួច</option>
                <option value="pending">មិនទាន់បង់</option>
                <option value="overdue">ហួសកំណត់</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ស្វែងរក</label>
            <input type="text" id="searchInput" placeholder="ឈ្មោះ ឬលេខសម្គាល់...">
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn-filter" onclick="applyFilter()">
            <i class="bi bi-search"></i>
            អនុវត្តតម្រង
        </button>
        <button class="btn-filter" onclick="resetFilter()" style="background: #64748b;">
            <i class="bi bi-arrow-counterclockwise"></i>
            កំណត់ឡើងវិញ
        </button>
    </div>
</div>

<!-- Add Payment Button -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn-add" onclick="openAddPaymentModal()">
        <i class="bi bi-plus-circle"></i>
        កត់ត្រាការបង់ប្រាក់ថ្មី
    </button>
</div>

<!-- Payments Table -->
<div class="table-container">
    <table class="payment-table">
        <thead>
            <tr>
                <th>លេខវិក្កយបត្រ</th>
                <th>សិស្ស</th>
                <th>ជំនាញ</th>
                <th>កាលបរិច្ឆេទ</th>
                <th>វិធីបង់ប្រាក់</th>
                <th>ទឹកប្រាក់</th>
                <th>ស្ថានភាព</th>
                <th class="text-center">សកម្មភាព</th>
            </tr>
        </thead>
        <tbody id="paymentTableBody">
            <!-- Data will be loaded by JavaScript -->
        </tbody>
    </table>
</div>

<!-- Summary Section -->
<div class="summary-section">
    <h5 class="fw-bold mb-3">សង្ខេបការបង់ប្រាក់ប្រចាំខែ</h5>
    <div id="monthlySummary">
        <!-- Monthly summary will be loaded here -->
    </div>
</div>

<!-- Add Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>
                    កត់ត្រាការបង់ប្រាក់ថ្មី
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="paymentForm">
                    <div class="form-group">
                        <label class="form-label">ជ្រើសរើសសិស្ស</label>
                        <div class="student-select" id="studentSelect">
                            <!-- Students will be loaded here -->
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">ចំនួនទឹកប្រាក់ ($)</label>
                                <input type="number" id="amount" class="form-control" placeholder="0.00" step="0.01" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">កាលបរិច្ឆេទបង់ប្រាក់</label>
                                <input type="date" id="paymentDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">វិធីបង់ប្រាក់</label>
                        <div class="payment-methods" id="paymentMethods">
                            <div class="payment-method selected" onclick="selectPaymentMethod('cash', this)">
                                <i class="bi bi-cash"></i>
                                <span>សាច់ប្រាក់</span>
                            </div>
                            <div class="payment-method" onclick="selectPaymentMethod('aba', this)">
                                <i class="bi bi-phone"></i>
                                <span>ABA Pay</span>
                            </div>
                            <div class="payment-method" onclick="selectPaymentMethod('wing', this)">
                                <i class="bi bi-bank"></i>
                                <span>Wing</span>
                            </div>
                        </div>
                        <input type="hidden" id="paymentMethod" value="cash">
                    </div>

                    <div class="form-group">
                        <label class="form-label">កំណត់ចំណាំ</label>
                        <input type="text" id="note" class="form-control" placeholder="បញ្ចូលកំណត់ចំណាំ (បើមាន)...">
                    </div>

                    <div class="summary-section">
                        <div class="summary-row">
                            <span>ចំនួនទឹកប្រាក់ត្រូវបង់:</span>
                            <span id="summaryAmount">$0.00</span>
                        </div>
                        <div class="summary-row">
                            <span>សមប្រភេទ:</span>
                            <span id="summarySemester">ឆមាសទី ១</span>
                        </div>
                        <div class="summary-row">
                            <span>សរុបដែលត្រូវបង់:</span>
                            <span id="summaryTotal">$0.00</span>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">បោះបង់</button>
                <button type="button" class="btn btn-save" onclick="savePayment()">រក្សាទុកការបង់ប្រាក់</button>
            </div>
        </div>
    </div>
</div>

<!-- Receipt Modal -->
<div class="modal fade" id="receiptModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-receipt me-2"></i>
                    វិក្កយបត្របង់ប្រាក់
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="receiptContent">
                <!-- Receipt content will be loaded here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">បិទ</button>
                <button type="button" class="btn btn-print" onclick="printReceipt()">
                    <i class="bi bi-printer me-2"></i>បោះពុម្ព
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    let students = [];
    let payments = [];
    let selectedStudent = null;
    let currentPaymentMethod = 'cash';
    let currentReceipt = null;

    $(document).ready(function() {
        loadStudents();
        loadPayments();
    });

    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            success: function(data) {
                students = data;
                populateStudentSelect();
                updateStats();
            }
        });
    }

    function loadPayments() {
        $.ajax({
            url: '/Student/GetPayments',
            type: 'GET',
            success: function(data) {
                payments = data;
                displayPayments();
                updateStats();
                generateMonthlySummary();
            }
        });
    }

    function populateStudentSelect() {
        var select = $('#studentSelect');
        select.empty();

        students.forEach(s => {
            var option = `
                <div class="student-option" onclick="selectStudent('${s.id}')" id="student_${s.id}">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong>${s.name || 'មិនមានឈ្មោះ'}</strong>
                            <div class="small text-muted">${s.id} | ${s.major || 'N/A'} | ឆ្នាំទី${s.year || '?'}</div>
                        </div>
                        <div class="text-end">
                            <span class="fw-bold text-danger">$<span id="due_${s.id}">${s.amountDue || 0}</span></span>
                        </div>
                    </div>
                </div>
            `;
            select.append(option);
        });
    }

    function selectStudent(studentId) {
        $('.student-option').removeClass('selected');
        $(`#student_${studentId}`).addClass('selected');
        selectedStudent = students.find(s => s.id === studentId);

        if (selectedStudent) {
            $('#summaryAmount').text(`$${selectedStudent.amountDue || 0}`);
            $('#summaryTotal').text(`$${selectedStudent.amountDue || 0}`);
        }
    }

    function selectPaymentMethod(method, element) {
        $('.payment-method').removeClass('selected');
        $(element).addClass('selected');
        currentPaymentMethod = method;
        $('#paymentMethod').val(method);
    }

    function displayPayments() {
        var tbody = $('#paymentTableBody');
        tbody.empty();

        if (payments.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="8" class="text-center py-5">
                        <i class="bi bi-credit-card" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានកំណត់ត្រាការបង់ប្រាក់នៅឡើយទេ</h5>
                    </td>
                </tr>
            `);
            return;
        }

        var major = $('#filterMajor').val();
        var year = $('#filterYear').val();
        var status = $('#filterStatus').val();
        var search = $('#searchInput').val().toLowerCase();

        var filtered = payments.filter(p => {
            var student = students.find(s => s.id === p.studentId);
            if (!student) return false;

            var matchMajor = !major || student.major === major;
            var matchYear = !year || student.year === year;
            var matchStatus = !status ||
                (status === 'paid' && p.status === 'បង់រួច') ||
                (status === 'pending' && p.status === 'មិនទាន់បង់') ||
                (status === 'overdue' && p.status === 'ហួសកំណត់');
            var matchSearch = !search ||
                (student.name && student.name.toLowerCase().includes(search)) ||
                (p.receiptNumber && p.receiptNumber.toLowerCase().includes(search));

            return matchMajor && matchYear && matchStatus && matchSearch;
        });

        filtered.forEach(p => {
            var student = students.find(s => s.id === p.studentId) || {};
            var statusClass = p.status === 'បង់រួច' ? 'status-paid' :
                             p.status === 'មិនទាន់បង់' ? 'status-pending' : 'status-overdue';

            var row = `
                <tr>
                    <td>
                        <span class="receipt-badge">
                            <i class="bi bi-upc-scan me-1"></i>${p.receiptNumber || 'N/A'}
                        </span>
                    </td>
                    <td>
                        <div class="student-info">
                            <div class="student-avatar">
                                ${student.name ? student.name.charAt(0).toUpperCase() : '?'}
                            </div>
                            <div>
                                <div class="fw-bold">${student.name || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">${p.studentId}</small>
                            </div>
                        </div>
                    </td>
                    <td>${student.major || 'N/A'}</td>
                    <td>${new Date(p.paymentDate).toLocaleDateString('km-KH')}</td>
                    <td>
                        <i class="bi ${p.paymentMethod === 'cash' ? 'bi-cash' : p.paymentMethod === 'aba' ? 'bi-phone' : 'bi-bank'} me-1"></i>
                        ${p.paymentMethod === 'cash' ? 'សាច់ប្រាក់' : p.paymentMethod === 'aba' ? 'ABA Pay' : 'Wing'}
                    </td>
                    <td class="amount-paid">$${p.amount?.toFixed(2) || '0.00'}</td>
                    <td>
                        <span class="status-badge ${statusClass}">${p.status || 'បង់រួច'}</span>
                    </td>
                    <td class="text-center">
                        <button class="btn-icon" onclick="viewReceipt('${p.receiptNumber}')" title="មើលវិក្កយបត្រ">
                            <i class="bi bi-eye"></i>
                        </button>
                        <button class="btn-icon" onclick="printReceiptDirect('${p.receiptNumber}')" title="បោះពុម្ព">
                            <i class="bi bi-printer"></i>
                        </button>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });
    }

    function updateStats() {
        var totalCollected = payments.reduce((sum, p) => sum + (p.amount || 0), 0);
        var totalPaid = payments.length;
        var totalPending = students.reduce((sum, s) => sum + (s.amountDue || 0), 0) - totalCollected;

        $('#totalCollected').text(`$${totalCollected.toFixed(2)}`);
        $('#totalPending').text(`$${totalPending.toFixed(2)}`);
        $('#totalPaid').text(totalPaid);
        $('#totalStudents').text(students.length);
    }

    function generateMonthlySummary() {
        var summary = {};
        var months = ['មករា', 'កុម្ភៈ', 'មីនា', 'មេសា', 'ឧសភា', 'មិថុនា',
                      'កក្កដា', 'សីហា', 'កញ្ញា', 'តុលា', 'វិច្ឆិកា', 'ធ្នូ'];

        payments.forEach(p => {
            var date = new Date(p.paymentDate);
            var monthKey = `${date.getFullYear()}-${date.getMonth() + 1}`;
            var monthName = months[date.getMonth()];

            if (!summary[monthKey]) {
                summary[monthKey] = {
                    month: monthName,
                    year: date.getFullYear(),
                    total: 0,
                    count: 0
                };
            }
            summary[monthKey].total += p.amount || 0;
            summary[monthKey].count++;
        });

        var html = '<div class="row">';
        Object.values(summary).sort((a, b) => b.year - a.year || months.indexOf(b.month) - months.indexOf(a.month))
            .slice(0, 3).forEach(s => {
                html += `
                    <div class="col-md-4">
                        <div class="card border-0 bg-light p-3 rounded-3">
                            <h6 class="fw-bold mb-2">${s.month} ${s.year}</h6>
                            <div class="d-flex justify-content-between">
                                <span>សរុប:</span>
                                <span class="fw-bold text-success">$${s.total.toFixed(2)}</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>ចំនួនដង:</span>
                                <span class="fw-bold">${s.count}</span>
                            </div>
                        </div>
                    </div>
                `;
            });
        html += '</div>';
        $('#monthlySummary').html(html);
    }

    function openAddPaymentModal() {
        selectedStudent = null;
        $('.student-option').removeClass('selected');
        $('#amount').val('');
        $('#paymentDate').val(new Date().toISOString().split('T')[0]);
        $('#note').val('');
        $('#summaryAmount').text('$0.00');
        $('#summaryTotal').text('$0.00');
        $('#paymentModal').modal('show');
    }

    function savePayment() {
        if (!selectedStudent) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមជ្រើសរើសសិស្ស',
                confirmButtonColor: '#10b981'
            });
            return;
        }

        var amount = parseFloat($('#amount').val());
        if (!amount || amount <= 0) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលចំនួនទឹកប្រាក់',
                confirmButtonColor: '#10b981'
            });
            return;
        }

        var paymentData = {
            studentId: selectedStudent.id,
            amount: amount,
            paymentDate: $('#paymentDate').val(),
            paymentMethod: currentPaymentMethod,
            note: $('#note').val(),
            status: 'បង់រួច'
        };

        $.ajax({
            url: '/Student/SavePayment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(paymentData),
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
                if (response.success) {
                    $('#paymentModal').modal('hide');
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadPayments();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message
                    });
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាបច្ចេកទេស'
                });
            }
        });
    }

    function viewReceipt(receiptNumber) {
        var payment = payments.find(p => p.receiptNumber === receiptNumber);
        var student = students.find(s => s.id === payment.studentId);

        currentReceipt = { payment, student };

        var receiptHtml = `
            <div class="receipt">
                <div class="receipt-header">
                    <h3>HR UNIVERSITY</h3>
                    <p>វិក្កយបត្របង់ប្រាក់</p>
                </div>

                <div class="receipt-info">
                    <div class="receipt-row">
                        <span>លេខវិក្កយបត្រ:</span>
                        <span class="fw-bold">${payment.receiptNumber}</span>
                    </div>
                    <div class="receipt-row">
                        <span>ថ្ងៃ-ខែ-ឆ្នាំ:</span>
                        <span>${new Date(payment.paymentDate).toLocaleDateString('km-KH')}</span>
                    </div>
                    <div class="receipt-row">
                        <span>ឈ្មោះសិស្ស:</span>
                        <span>${student?.name || 'N/A'}</span>
                    </div>
                    <div class="receipt-row">
                        <span>លេខសម្គាល់:</span>
                        <span>${payment.studentId}</span>
                    </div>
                    <div class="receipt-row">
                        <span>ជំនាញ:</span>
                        <span>${student?.major || 'N/A'}</span>
                    </div>
                    <div class="receipt-row">
                        <span>វិធីបង់ប្រាក់:</span>
                        <span>${payment.paymentMethod === 'cash' ? 'សាច់ប្រាក់' : payment.paymentMethod === 'aba' ? 'ABA Pay' : 'Wing'}</span>
                    </div>
                    <div class="receipt-row">
                        <span>កំណត់ចំណាំ:</span>
                        <span>${payment.note || 'គ្មាន'}</span>
                    </div>
                    <div class="receipt-row total">
                        <span>ចំនួនទឹកប្រាក់:</span>
                        <span>$${payment.amount?.toFixed(2)}</span>
                    </div>
                </div>

                <div class="receipt-footer">
                    <p>សូមអរគុណសម្រាប់ការបង់ប្រាក់</p>
                    <small>វិក្កយបត្រនេះត្រូវបានបង្កើតដោយប្រព័ន្ធ</small>
                </div>
            </div>
        `;

        $('#receiptContent').html(receiptHtml);
        $('#receiptModal').modal('show');
    }

    function printReceipt() {
        var printWindow = window.open('', '_blank');
        printWindow.document.write(`
            <html>
                <head>
                    <title>វិក្កយបត្របង់ប្រាក់</title>
                    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
                    <style>
                        body { padding: 40px; font-family: 'Khmer OS', 'Kantumruy Pro', sans-serif; }
                        .receipt { max-width: 500px; margin: 0 auto; }
                        .receipt-header { text-align: center; margin-bottom: 30px; }
                        .receipt-header h3 { color: #10b981; font-weight: 800; }
                        .receipt-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #ddd; }
                        .receipt-row.total { font-weight: 800; font-size: 1.2rem; color: #10b981; }
                        .receipt-footer { text-align: center; margin-top: 30px; color: #666; }
                        @@media print {
                            .no-print { display: none; }
                        }
                    </style>
                </head>
                <body>
                    ${$('#receiptContent').html()}
                    <div class="text-center mt-4 no-print">
                        <button class="btn btn-primary" onclick="window.print()">បោះពុម្ព</button>
                        <button class="btn btn-secondary" onclick="window.close()">បិទ</button>
                    </div>
                </body>
            </html>
        `);
        printWindow.document.close();
    }

    function printReceiptDirect(receiptNumber) {
        viewReceipt(receiptNumber);
        setTimeout(() => {
            printReceipt();
        }, 500);
    }

    function applyFilter() {
        displayPayments();
    }

    function resetFilter() {
        $('#filterMajor').val('');
        $('#filterYear').val('');
        $('#filterStatus').val('');
        $('#searchInput').val('');
        displayPayments();
    }
</script>