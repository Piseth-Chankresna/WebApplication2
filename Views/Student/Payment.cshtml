@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "ការបង់ប្រាក់";
}

<style>
    /* ====== VARIABLES ====== */
    :root {
        --primary: #10b981;
        --primary-dark: #059669;
        --primary-light: #d1fae5;
        --secondary: #f59e0b;
        --danger: #ef4444;
        --dark: #1e293b;
        --light: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --gray-900: #0f172a;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        --shadow-md: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        --shadow-lg: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        --shadow-xl: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        --shadow-colored: 0 10px 20px -5px rgba(16, 185, 129, 0.3);
    }

    [data-theme="dark"] {
        --primary: #34d399;
        --primary-dark: #10b981;
        --primary-light: #1e293b;
        --secondary: #fbbf24;
        --danger: #f87171;
        --dark: #f8fafc;
        --light: #0f172a;
        --gray-100: #1e293b;
        --gray-200: #334155;
        --gray-300: #475569;
        --gray-400: #64748b;
        --gray-500: #94a3b8;
        --gray-600: #cbd5e1;
        --gray-700: #e2e8f0;
        --gray-800: #f1f5f9;
        --gray-900: #f8fafc;
    }

    /* ====== BASE STYLES ====== */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', 'Kantumruy Pro', sans-serif;
        background-color: var(--light);
        color: var(--gray-900);
        transition: background-color 0.3s ease;
    }

    /* ====== PAGE HEADER ====== */
    .page-header {
        margin-bottom: 30px;
        animation: slideDown 0.5s ease;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header h2 {
        font-weight: 800;
        color: var(--primary);
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .page-header h2 i {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 2.2rem;
        }

    .page-header p {
        color: var(--gray-500);
        font-size: 1rem;
    }

    /* ====== STATS CARDS ====== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: var(--shadow);
        border: 1px solid var(--gray-200);
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
        animation: fadeInUp 0.5s ease;
        animation-fill-mode: both;
    }

        .stat-card:nth-child(1) {
            animation-delay: 0.1s;
        }

        .stat-card:nth-child(2) {
            animation-delay: 0.2s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.3s;
        }

        .stat-card:nth-child(4) {
            animation-delay: 0.4s;
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    [data-theme="dark"] .stat-card {
        background: var(--gray-100);
        border-color: var(--gray-200);
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-lg);
        border-color: var(--primary);
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: var(--primary);
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--gray-900);
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: var(--gray-500);
        font-size: 0.9rem;
    }

    /* ====== FILTER SECTION ====== */
    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid var(--gray-200);
        box-shadow: var(--shadow);
        animation: fadeIn 0.6s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    [data-theme="dark"] .filter-section {
        background: var(--gray-100);
        border-color: var(--gray-200);
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: var(--gray-600);
            font-size: 0.9rem;
        }

    [data-theme="dark"] .filter-item label {
        color: var(--gray-400);
    }

    .filter-item select,
    .filter-item input {
        padding: 12px 16px;
        border: 2px solid var(--gray-200);
        border-radius: 12px;
        background: white;
        color: var(--gray-900);
        transition: all 0.2s ease;
    }

    [data-theme="dark"] .filter-item select,
    [data-theme="dark"] .filter-item input {
        background: var(--gray-200);
        border-color: var(--gray-300);
        color: white;
    }

    .filter-item select:focus,
    .filter-item input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
    }

    .btn-filter {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 12px 28px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-colored);
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px -5px rgba(16, 185, 129, 0.4);
        }

        .btn-filter:active {
            transform: translateY(0);
        }

    .btn-export {
        background: white;
        color: var(--primary);
        padding: 12px 28px;
        border: 2px solid var(--primary);
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .btn-export {
        background: var(--gray-200);
        color: var(--primary);
        border-color: var(--primary);
    }

    .btn-export:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-2px);
        box-shadow: var(--shadow-colored);
    }

    /* ====== ACTION BUTTONS ====== */
    .action-bar {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .btn-add {
        background: linear-gradient(135deg, var(--secondary), #d97706);
        color: white;
        padding: 14px 32px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px -5px rgba(245, 158, 11, 0.3);
        font-size: 1rem;
    }

        .btn-add:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 30px -5px rgba(245, 158, 11, 0.4);
        }

        .btn-add i {
            font-size: 1.2rem;
        }

    /* ====== TABLE STYLES ====== */
    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--gray-200);
        overflow-x: auto;
        animation: slideUp 0.7s ease;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    [data-theme="dark"] .table-container {
        background: var(--gray-100);
        border-color: var(--gray-200);
    }

    .payment-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1200px;
    }

        .payment-table th {
            padding: 16px;
            text-align: left;
            color: var(--gray-500);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border-bottom: 2px solid var(--gray-200);
            background: var(--gray-100);
        }

    [data-theme="dark"] .payment-table th {
        background: var(--gray-200);
        color: var(--gray-400);
        border-bottom-color: var(--gray-300);
    }

    .payment-table td {
        padding: 16px;
        border-bottom: 1px solid var(--gray-200);
        color: var(--gray-900);
    }

    [data-theme="dark"] .payment-table td {
        color: white;
        border-bottom-color: var(--gray-300);
    }

    .payment-table tbody tr {
        transition: all 0.2s ease;
    }

        .payment-table tbody tr:hover {
            background: var(--gray-100);
            transform: scale(1.01);
            box-shadow: var(--shadow);
        }

    [data-theme="dark"] .payment-table tbody tr:hover {
        background: var(--gray-200);
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-avatar {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        overflow: hidden;
        flex-shrink: 0;
        box-shadow: var(--shadow);
    }

        .student-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .receipt-badge {
        background: var(--primary-light);
        color: var(--primary);
        padding: 6px 12px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
        border: 1px solid var(--primary);
    }

    [data-theme="dark"] .receipt-badge {
        background: var(--gray-200);
        color: var(--primary);
    }

    .amount-paid {
        color: var(--primary);
        font-weight: 700;
        font-size: 1.1rem;
    }

    .amount-due {
        color: var(--danger);
        font-weight: 700;
        font-size: 1.1rem;
    }

    .status-badge {
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .status-paid {
        background: var(--primary-light);
        color: var(--primary);
        border: 1px solid var(--primary);
    }

    [data-theme="dark"] .status-paid {
        background: var(--gray-200);
    }

    .btn-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: 1px solid var(--gray-200);
        background: white;
        color: var(--gray-600);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        cursor: pointer;
        text-decoration: none;
    }

    [data-theme="dark"] .btn-icon {
        background: var(--gray-200);
        border-color: var(--gray-300);
        color: var(--gray-400);
    }

    .btn-icon:hover {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        transform: translateY(-3px) rotate(5deg);
        box-shadow: var(--shadow-colored);
    }

    /* ====== MODAL STYLES ====== */
    .modal-content {
        border-radius: 28px;
        border: none;
        overflow: hidden;
        box-shadow: var(--shadow-xl);
    }

    [data-theme="dark"] .modal-content {
        background: var(--gray-100);
        color: white;
    }

    .modal-header {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 25px 30px;
        border: none;
    }

        .modal-header .modal-title {
            font-weight: 700;
            font-size: 1.3rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-header .btn-close {
            filter: brightness(0) invert(1);
            opacity: 0.8;
        }

            .modal-header .btn-close:hover {
                opacity: 1;
                transform: rotate(90deg);
            }

    .modal-body {
        padding: 30px;
    }

    .modal-footer {
        padding: 20px 30px;
        border-top: 2px solid var(--gray-200);
    }

    [data-theme="dark"] .modal-footer {
        border-top-color: var(--gray-300);
    }

    /* ====== FORM STYLES ====== */
    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--gray-700);
        margin-bottom: 10px;
        font-size: 0.95rem;
    }

    [data-theme="dark"] .form-label {
        color: var(--gray-400);
    }

    .form-label i {
        margin-right: 8px;
        color: var(--primary);
    }

    .form-control, .form-select {
        width: 100%;
        padding: 14px 18px;
        border: 2px solid var(--gray-200);
        border-radius: 16px;
        background: white;
        color: var(--gray-900);
        font-size: 1rem;
        transition: all 0.2s ease;
    }

    [data-theme="dark"] .form-control,
    [data-theme="dark"] .form-select {
        background: var(--gray-200);
        border-color: var(--gray-300);
        color: white;
    }

    .form-control:focus,
    .form-select:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
    }

    /* ====== STUDENT SELECTION ====== */
    .student-search {
        position: relative;
        margin-bottom: 15px;
    }

        .student-search i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-400);
            font-size: 1.2rem;
        }

        .student-search input {
            width: 100%;
            padding: 14px 18px 14px 50px;
            border: 2px solid var(--gray-200);
            border-radius: 16px;
            background: white;
            color: var(--gray-900);
            font-size: 1rem;
            transition: all 0.2s ease;
        }

    [data-theme="dark"] .student-search input {
        background: var(--gray-200);
        border-color: var(--gray-300);
        color: white;
    }

    .student-search input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
    }

    .student-list {
        max-height: 280px;
        overflow-y: auto;
        border: 2px solid var(--gray-200);
        border-radius: 16px;
        padding: 8px;
        margin-bottom: 15px;
    }

    [data-theme="dark"] .student-list {
        border-color: var(--gray-300);
    }

    .student-list::-webkit-scrollbar {
        width: 8px;
    }

    .student-list::-webkit-scrollbar-thumb {
        background: var(--gray-300);
        border-radius: 4px;
    }

    [data-theme="dark"] .student-list::-webkit-scrollbar-thumb {
        background: var(--gray-400);
    }

    .student-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 15px;
        border-radius: 14px;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 2px solid transparent;
        margin-bottom: 5px;
    }

        .student-item:hover {
            background: var(--gray-100);
            transform: translateX(5px);
        }

    [data-theme="dark"] .student-item:hover {
        background: var(--gray-200);
    }

    .student-item.selected {
        background: var(--primary-light);
        border-color: var(--primary);
    }

    [data-theme="dark"] .student-item.selected {
        background: var(--gray-200);
    }

    .student-avatar-sm {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        overflow: hidden;
        flex-shrink: 0;
    }

        .student-avatar-sm img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .student-info h5 {
        font-weight: 700;
        margin-bottom: 5px;
        color: var(--gray-900);
    }

    [data-theme="dark"] .student-info h5 {
        color: white;
    }

    .student-info p {
        color: var(--gray-500);
        font-size: 0.85rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .student-amount {
        margin-left: auto;
        text-align: right;
    }

        .student-amount .label {
            font-size: 0.8rem;
            color: var(--gray-500);
        }

        .student-amount .value {
            font-weight: 700;
            color: var(--danger);
            font-size: 1.1rem;
        }

    .selected-student-card {
        background: var(--primary-light);
        border-radius: 20px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 20px;
        border: 2px solid var(--primary);
        animation: pulse 0.5s ease;
    }

    @@keyframes pulse {
        0% {
            transform: scale(0.95);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    [data-theme="dark"] .selected-student-card {
        background: var(--gray-200);
    }

    .selected-avatar {
        width: 70px;
        height: 70px;
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 2rem;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

        .selected-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .selected-details h4 {
        font-weight: 800;
        margin-bottom: 5px;
        color: var(--gray-900);
    }

    [data-theme="dark"] .selected-details h4 {
        color: white;
    }

    .selected-details p {
        color: var(--gray-600);
        margin-bottom: 8px;
    }

    .selected-details .badge {
        background: var(--primary);
        color: white;
        padding: 5px 15px;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    /* ====== AMOUNT INPUT STYLES ====== */
    .amount-display {
        background: linear-gradient(135deg, var(--primary-light), white);
        border-radius: 24px;
        padding: 25px;
        text-align: center;
        margin-bottom: 25px;
        border: 2px dashed var(--primary);
    }

    [data-theme="dark"] .amount-display {
        background: var(--gray-200);
    }

    .amount-display .label {
        color: var(--gray-600);
        font-size: 1rem;
        margin-bottom: 10px;
    }

    .amount-display .value {
        font-size: 3.5rem;
        font-weight: 800;
        color: var(--primary);
        line-height: 1.2;
        text-shadow: 0 2px 10px rgba(16, 185, 129, 0.2);
    }

    .amount-display .currency {
        font-size: 1.5rem;
        color: var(--gray-400);
    }

    .quick-amounts {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 20px;
    }

    .quick-amount-btn {
        background: white;
        border: 2px solid var(--primary);
        color: var(--primary);
        padding: 15px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

    [data-theme="dark"] .quick-amount-btn {
        background: var(--gray-200);
    }

    .quick-amount-btn:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-3px);
        box-shadow: var(--shadow-colored);
    }

    .quick-amount-btn i {
        font-size: 1.2rem;
    }

    .number-pad {
        background: var(--gray-100);
        border-radius: 24px;
        padding: 20px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-bottom: 20px;
    }

    [data-theme="dark"] .number-pad {
        background: var(--gray-200);
    }

    .num-btn {
        background: white;
        border: none;
        padding: 18px;
        border-radius: 16px;
        font-weight: 700;
        font-size: 1.3rem;
        color: var(--gray-900);
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: var(--shadow);
    }

    [data-theme="dark"] .num-btn {
        background: var(--gray-300);
        color: white;
    }

    .num-btn:hover {
        background: var(--primary);
        color: white;
        transform: scale(0.95);
    }

    .num-btn.wide {
        grid-column: span 2;
    }

    .num-btn.danger {
        background: var(--danger);
        color: white;
    }

        .num-btn.danger:hover {
            background: #dc2626;
        }

    /* ====== PAYMENT METHODS ====== */
    .payment-methods {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin: 20px 0;
    }

    .payment-method-card {
        background: white;
        border: 2px solid var(--gray-200);
        border-radius: 20px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .payment-method-card {
        background: var(--gray-200);
        border-color: var(--gray-300);
    }

    .payment-method-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary);
        box-shadow: var(--shadow-colored);
    }

    .payment-method-card.selected {
        border-color: var(--primary);
        background: var(--primary-light);
    }

    [data-theme="dark"] .payment-method-card.selected {
        background: var(--gray-300);
    }

    .payment-method-card i {
        font-size: 2.5rem;
        color: var(--primary);
        margin-bottom: 10px;
    }

    .payment-method-card span {
        font-weight: 600;
        color: var(--gray-900);
    }

    [data-theme="dark"] .payment-method-card span {
        color: white;
    }

    /* ====== ACTION BUTTONS ====== */
    .btn-save {
        background: linear-gradient(135deg, var(--primary), var(--primary-dark));
        color: white;
        padding: 16px 32px;
        border: none;
        border-radius: 40px;
        font-weight: 700;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        box-shadow: var(--shadow-colored);
    }

        .btn-save:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 30px -5px rgba(16, 185, 129, 0.4);
        }

        .btn-save:active {
            transform: translateY(0);
        }

        .btn-save i {
            font-size: 1.2rem;
        }

    .btn-cancel {
        background: white;
        color: var(--gray-700);
        padding: 16px 32px;
        border: 2px solid var(--gray-200);
        border-radius: 40px;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    [data-theme="dark"] .btn-cancel {
        background: var(--gray-200);
        color: white;
        border-color: var(--gray-300);
    }

    .btn-cancel:hover {
        background: var(--gray-200);
        transform: translateY(-2px);
    }

    /* ====== EMPTY STATE ====== */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }

        .empty-state i {
            font-size: 5rem;
            color: var(--gray-300);
            margin-bottom: 20px;
        }

        .empty-state h3 {
            font-weight: 700;
            color: var(--gray-900);
            margin-bottom: 10px;
        }

    [data-theme="dark"] .empty-state h3 {
        color: white;
    }

    .empty-state p {
        color: var(--gray-500);
        margin-bottom: 25px;
    }

    /* ====== LOADING ====== */
    .loading-spinner {
        display: inline-block;
        width: 40px;
        height: 40px;
        border: 3px solid var(--gray-200);
        border-top-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ====== RESPONSIVE ====== */
    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .payment-methods {
            grid-template-columns: 1fr;
        }

        .quick-amounts {
            grid-template-columns: repeat(2, 1fr);
        }

        .number-pad {
            grid-template-columns: repeat(3, 1fr);
        }

        .amount-display .value {
            font-size: 2.5rem;
        }
    }
    /* Amount Input Styling */
    .input-group {
        box-shadow: var(--shadow-sm);
        transition: all 0.3s ease;
    }

        .input-group:focus-within {
            box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.15);
        }

    .input-group-text {
        background: white;
        border: 2px solid var(--gray-200);
        border-right: none;
        border-radius: 16px 0 0 16px !important;
        padding-left: 20px;
        padding-right: 15px;
    }

    [data-theme="dark"] .input-group-text {
        background: var(--gray-200);
        border-color: var(--gray-300);
        color: white;
    }

    #amountInput {
        border: 2px solid var(--gray-200);
        border-left: none;
        border-radius: 0 16px 16px 0 !important;
        height: 60px;
        font-size: 1.5rem !important;
        font-weight: 600 !important;
        padding-right: 20px;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] #amountInput {
        background: var(--gray-200);
        border-color: var(--gray-300);
        color: white;
    }

    #amountInput:focus {
        outline: none;
        box-shadow: none;
        border-color: var(--primary);
    }

    .quick-amounts {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
        margin-top: 15px;
    }

    .quick-amount-btn {
        background: white;
        border: 2px solid var(--primary);
        color: var(--primary);
        padding: 12px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

    [data-theme="dark"] .quick-amount-btn {
        background: var(--gray-200);
        color: var(--primary);
    }

    .quick-amount-btn:hover {
        background: var(--primary);
        color: white;
        transform: translateY(-2px);
        box-shadow: var(--shadow-colored);
    }

    .alert {
        border-radius: 16px;
        padding: 15px 20px;
        border: none;
    }

    .alert-info {
        background: #e0f2fe;
        color: #0369a1;
        border-left: 4px solid #0284c7;
    }

    .alert-warning {
        background: #fef3c7;
        color: #92400e;
        border-left: 4px solid #f59e0b;
    }

    [data-theme="dark"] .alert-info {
