<script src="https://unpkg.com/sweetalert2@11"></script>
<script>
    // ==================== GLOBAL VARIABLES ====================
    let students = [];
    let payments = [];
    let selectedStudent = null;
    let currentPaymentMethod = 'cash';
    let isSaving = false;

    // ==================== DOCUMENT READY ====================
    $(document).ready(function() {
        console.log("Payment page loaded");
        loadStudents();
        loadPayments();

        // Initialize amount input
        initializeAmountInput();

        // Student search
        $('#studentSearch').on('keyup', function() {
            filterStudentList();
        });

        // Quick amount buttons
        $('.quick-amount-btn').click(function() {
            let amount = $(this).data('amount');
            let currentAmount = parseFloat($('#amountInput').val()) || 0;
            let newAmount = currentAmount + amount;

            // Check if exceeds due amount
            if (selectedStudent && newAmount > selectedStudent.amountDue) {
                Swal.fire({
                    icon: 'warning',
                    title: 'ប្រយ័ត្ន!',
                    text: `ចំនួនទឹកប្រាក់សរុប ($${newAmount.toFixed(2)}) លើសពីចំនួនដែលត្រូវបង់ ($${selectedStudent.amountDue.toFixed(2)})`,
                    confirmButtonColor: '#10b981'
                });
                return;
            }

            $('#amountInput').val(newAmount.toFixed(2));
            updateAmountDisplay(newAmount);
        });

        // Reset modal when closed
        $('#paymentModal').on('hidden.bs.modal', function() {
            resetPaymentForm();
        });

        // Filter change events
        $('#filterMajor, #filterYear, #filterMethod, #searchInput').on('change keyup', function() {
            renderPaymentsTable();
        });
    });

    // ==================== AMOUNT FUNCTIONS ====================
    function initializeAmountInput() {
        let amountInput = document.getElementById('amountInput');
        if (!amountInput) return;

        // Format number on input
        amountInput.addEventListener('input', function(e) {
            let value = this.value;

            // Remove any non-numeric characters except dot
            value = value.replace(/[^\d.]/g, '');

            // Ensure only one decimal point
            let parts = value.split('.');
            if (parts.length > 2) {
                value = parts[0] + '.' + parts.slice(1).join('');
            }

            // Limit decimal places to 2
            if (parts.length === 2 && parts[1].length > 2) {
                value = parts[0] + '.' + parts[1].substring(0, 2);
            }

            this.value = value;

            // Update amount value
            let numValue = parseFloat(value) || 0;
            updateAmountDisplay(numValue);
        });

        // Handle blur event
        amountInput.addEventListener('blur', function(e) {
            let value = this.value;
            if (value === '' || value === '.') {
                this.value = '0.00';
                updateAmountDisplay(0);
            } else {
                // Format to 2 decimal places
                let num = parseFloat(value) || 0;
                this.value = num.toFixed(2);
                updateAmountDisplay(num);
            }
        });

        // Handle focus - select all text
        amountInput.addEventListener('focus', function(e) {
            this.select();
        });
    }

    function updateAmountDisplay(amount) {
        $('#amountValue').text(amount.toFixed(2));

        // Show due reminder if student selected
        if (selectedStudent) {
            let dueAmount = selectedStudent.amountDue || 0;
            if (amount > dueAmount) {
                $('#dueMessage').html(`<strong>ប្រយ័ត្ន!</strong> ចំនួនទឹកប្រាក់ ($${amount.toFixed(2)}) លើសពីចំនួនដែលត្រូវបង់ ($${dueAmount.toFixed(2)})`);
                $('#dueReminder').removeClass('alert-info').addClass('alert-warning').show();
            } else if (amount > 0) {
                $('#dueMessage').html(`<strong>នៅសល់ត្រូវបង់:</strong> $${(dueAmount - amount).toFixed(2)}`);
                $('#dueReminder').removeClass('alert-warning').addClass('alert-info').show();
            } else {
                $('#dueReminder').hide();
            }
        }
    }

    // ==================== STUDENT FUNCTIONS ====================
    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            cache: false,
            success: function(response) {
                console.log("Students loaded:", response);

                if (response && response.success) {
                    students = response.data || [];
                } else if (Array.isArray(response)) {
                    students = response;
                } else {
                    students = [];
                }

                renderStudentList();
                updateStats();
            },
            error: function(xhr, status, error) {
                console.error('Error loading students:', error);
                showError('មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យសិស្ស');
            }
        });
    }

    function renderStudentList() {
        let container = $('#studentList');
        container.empty();

        if (!students || students.length === 0) {
            container.html(`
                <div class="text-center p-4 text-muted">
                    <i class="bi bi-people fs-1"></i>
                    <p class="mt-2">មិនទាន់មានទិន្នន័យសិស្ស</p>
                </div>
            `);
            return;
        }

        students.forEach(s => {
            let avatarHtml = s.photo ?
                `<img src="${s.photo}" alt="${s.name}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(s.name || 'User')}&background=10b981&color=fff'">` :
                (s.name ? s.name.charAt(0).toUpperCase() : '?');

            let item = `
                <div class="student-item" onclick="selectStudent('${s.id}')" id="student_${s.id}">
                    <div class="student-avatar-sm">
                        ${avatarHtml}
                    </div>
                    <div class="student-info flex-grow-1">
                        <h5>${s.name || 'មិនមានឈ្មោះ'}</h5>
                        <p>
                            <i class="bi bi-upc-scan"></i> ${s.id} |
                            <i class="bi bi-star"></i> ${s.major || 'N/A'} |
                            <i class="bi bi-calendar3"></i> ឆ្នាំទី${s.year || '?'}
                        </p>
                    </div>
                    <div class="student-amount">
                        <div class="label">ជំពាក់</div>
                        <div class="value">$${(s.amountDue || 0).toFixed(2)}</div>
                    </div>
                </div>
            `;
            container.append(item);
        });
    }

    function filterStudentList() {
        let searchText = $('#studentSearch').val().toLowerCase();

        $('.student-item').each(function() {
            let text = $(this).text().toLowerCase();
            if (text.includes(searchText) || searchText === '') {
                $(this).show();
            } else {
                $(this).hide();
            }
        });
    }

    function selectStudent(studentId) {
        let student = students.find(s => s.id === studentId);
        if (!student) return;

        selectedStudent = student;

        // Update UI
        $('.student-item').removeClass('selected');
        $(`#student_${studentId}`).addClass('selected');

        // Show selected card
        let avatarHtml = student.photo ?
            `<img src="${student.photo}" alt="${student.name}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(student.name || 'User')}&background=10b981&color=fff'">` :
            (student.name ? student.name.charAt(0).toUpperCase() : '?');

        $('#selectedAvatar').html(avatarHtml);
        $('#selectedName').text(student.name || 'មិនមានឈ្មោះ');
        $('#selectedInfo').text(`${student.major || 'N/A'} | ឆ្នាំទី${student.year || '?'} | ${student.id}`);
        $('#selectedAmount').text(`ជំពាក់: $${(student.amountDue || 0).toFixed(2)}`);

        $('#selectedStudentCard').fadeIn(300);

        // Update due reminder with current amount
        let currentAmount = parseFloat($('#amountInput').val()) || 0;
        if (currentAmount > 0) {
            if (currentAmount > student.amountDue) {
                $('#dueMessage').html(`<strong>ប្រយ័ត្ន!</strong> ចំនួនទឹកប្រាក់ ($${currentAmount.toFixed(2)}) លើសពីចំនួនដែលត្រូវបង់ ($${student.amountDue.toFixed(2)})`);
                $('#dueReminder').removeClass('alert-info').addClass('alert-warning').show();
            } else {
                $('#dueMessage').html(`<strong>នៅសល់ត្រូវបង់:</strong> $${(student.amountDue - currentAmount).toFixed(2)}`);
                $('#dueReminder').removeClass('alert-warning').addClass('alert-info').show();
            }
        }

        // Scroll to selected student
        $(`#student_${studentId}`)[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    // ==================== PAYMENT FUNCTIONS ====================
    function loadPayments() {
        $('#paymentTableBody').html(`
            <tr>
                <td colspan="9" class="text-center py-5">
                    <div class="loading-spinner"></div>
                    <p class="mt-3 text-muted">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        `);

        $.ajax({
            url: '/Student/GetPayments',
            type: 'GET',
            cache: false,
            success: function(response) {
                console.log("Payments loaded:", response);

                if (response && response.success) {
                    payments = response.data || [];
                } else if (Array.isArray(response)) {
                    payments = response;
                } else {
                    payments = [];
                }

                renderPaymentsTable();
                updateStats();
            },
            error: function(xhr, status, error) {
                console.error('Error loading payments:', error);
                showTableError('មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ');
            }
        });
    }

    function renderPaymentsTable() {
        let tbody = $('#paymentTableBody');
        tbody.empty();

        if (!payments || payments.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="9" class="text-center py-5">
                        <div class="empty-state">
                            <i class="bi bi-credit-card"></i>
                            <h3>មិនទាន់មានកំណត់ត្រាការបង់ប្រាក់</h3>
                            <p>ចាប់ផ្តើមកត់ត្រាការបង់ប្រាក់ដំបូង</p>
                            <button class="btn-add" onclick="openAddPaymentModal()">
                                <i class="bi bi-plus-circle"></i>
                                កត់ត្រាឥឡូវនេះ
                            </button>
                        </div>
                    </td>
                </tr>
            `);
            return;
        }

        let major = $('#filterMajor').val();
        let year = $('#filterYear').val();
        let method = $('#filterMethod').val();
        let search = $('#searchInput').val().toLowerCase();

        let filtered = payments.filter(p => {
            let student = students.find(s => s.id === p.studentId);
            if (!student) return false;

            let matchMajor = !major || student.major === major;
            let matchYear = !year || student.year === year;
            let matchMethod = !method || p.paymentMethod === method;
            let matchSearch = !search ||
                (student.name && student.name.toLowerCase().includes(search)) ||
                (p.receiptNumber && p.receiptNumber.toLowerCase().includes(search));

            return matchMajor && matchYear && matchMethod && matchSearch;
        });

        if (filtered.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="9" class="text-center py-5">
                        <i class="bi bi-search fs-1 text-muted"></i>
                        <p class="mt-2">មិនមានកំណត់ត្រាដែលត្រូវនឹងតម្រង</p>
                    </td>
                </tr>
            `);
            return;
        }

        filtered.forEach(p => {
            let student = students.find(s => s.id === p.studentId) || {};
            let avatarHtml = student.photo ?
                `<img src="${student.photo}" alt="${student.name}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(student.name || 'User')}&background=10b981&color=fff'">` :
                (student.name ? student.name.charAt(0).toUpperCase() : '?');

            let date = p.paymentDate ? new Date(p.paymentDate) : new Date();
            let formattedDate = date.toLocaleDateString('km-KH');

            let row = `
                <tr>
                    <td>
                        <span class="receipt-badge">
                            <i class="bi bi-upc-scan"></i> ${p.receiptNumber || 'N/A'}
                        </span>
                    </td>
                    <td>
                        <div class="student-info">
                            <div class="student-avatar">
                                ${avatarHtml}
                            </div>
                            <div>
                                <div class="fw-bold">${student.name || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">${p.studentId}</small>
                            </div>
                        </div>
                    </td>
                    <td>${student.major || 'N/A'}</td>
                    <td>${formattedDate}</td>
                    <td>
                        <i class="bi ${p.paymentMethod === 'cash' ? 'bi-cash' : p.paymentMethod === 'aba' ? 'bi-phone' : 'bi-bank'} me-1"></i>
                        ${p.paymentMethod === 'cash' ? 'សាច់ប្រាក់' : p.paymentMethod === 'aba' ? 'ABA Pay' : 'Wing'}
                    </td>
                    <td>${p.semester || 'ឆមាសទី១'}</td>
                    <td class="amount-paid">$${(p.amount || 0).toFixed(2)}</td>
                    <td>
                        <span class="status-badge status-paid">បង់រួច</span>
                    </td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center">
                            <button class="btn-icon" onclick="deletePayment(${p.id})" title="លុប">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });
    }

    function updateStats() {
        if (!students || !payments) return;

        let totalCollected = payments.reduce((sum, p) => sum + (p.amount || 0), 0);
        let totalPaid = payments.length;
        let totalPending = students.reduce((sum, s) => sum + (s.amountDue || 0), 0) - totalCollected;

        $('#totalCollected').text('$' + totalCollected.toFixed(2));
        $('#totalPending').text('$' + Math.max(0, totalPending).toFixed(2));
        $('#totalPaid').text(totalPaid);
        $('#totalStudents').text(students.length);
    }

    // ==================== MODAL FUNCTIONS ====================
    function openAddPaymentModal() {
        if (!students || students.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'គ្មានទិន្នន័យសិស្ស',
                text: 'សូមបន្ថែមសិស្សជាមុនសិន',
                confirmButtonColor: '#10b981'
            });
            return;
        }

        resetPaymentForm();
        $('#paymentModal').modal('show');

        // Focus on search input
        setTimeout(function() {
            $('#studentSearch').focus();
        }, 500);
    }

    function resetPaymentForm() {
        selectedStudent = null;
        currentPaymentMethod = 'cash';

        $('#amountInput').val('0.00');
        $('#amountValue').text('0.00');
        $('.student-item').removeClass('selected');
        $('#selectedStudentCard').hide();
        $('#dueReminder').hide();
        $('#studentSearch').val('');
        $('.student-item').show();
        $('#note').val('');
        $('#paymentDate').val(new Date().toISOString().split('T')[0]);
        $('#semester').val('ឆមាសទី១');

        $('.payment-method-card').removeClass('selected');
        $('.payment-method-card:first').addClass('selected');
        $('#paymentMethod').val('cash');
    }

    function selectPaymentMethod(method, element) {
        $('.payment-method-card').removeClass('selected');
        $(element).addClass('selected');
        currentPaymentMethod = method;
        $('#paymentMethod').val(method);
    }

    // ==================== SAVE PAYMENT ====================
    function savePayment() {
        if (isSaving) return;

        if (!selectedStudent) {
            Swal.fire({
                icon: 'warning',
                title: 'ជ្រើសរើសសិស្ស',
                text: 'សូមជ្រើសរើសសិស្សមុនពេលរក្សាទុក',
                confirmButtonColor: '#10b981'
            });
            return;
        }

        let amount = parseFloat($('#amountInput').val()) || 0;

        if (amount <= 0) {
            Swal.fire({
                icon: 'warning',
                title: 'បញ្ចូលចំនួនទឹកប្រាក់',
                text: 'សូមបញ្ចូលចំនួនទឹកប្រាក់ត្រឹមត្រូវ',
                confirmButtonColor: '#10b981'
            });
            return;
        }

        if (amount > (selectedStudent.amountDue || 0)) {
            Swal.fire({
                icon: 'warning',
                title: 'ចំនួនទឹកប្រាក់លើស',
                text: `សិស្សនេះជំពាក់តែ $${(selectedStudent.amountDue || 0).toFixed(2)} ប៉ុណ្ណោះ`,
                confirmButtonColor: '#10b981'
            });
            return;
        }

        let token = $('input[name="__RequestVerificationToken"]').val();
        if (!token) {
            Swal.fire({
                icon: 'error',
                title: 'កំហុស',
                text: 'មិនអាចរកឃើញ Token សុវត្ថិភាព'
            });
            return;
        }

        let paymentData = {
            studentId: selectedStudent.id,
            studentName: selectedStudent.name,
            amount: amount,
            paymentDate: $('#paymentDate').val(),
            paymentMethod: currentPaymentMethod,
            semester: $('#semester').val(),
            academicYear: '2025-2026',
            note: $('#note').val() || ''
        };

        console.log("Saving payment:", paymentData);

        isSaving = true;
        $('#paymentModal').modal('hide');

        Swal.fire({
            title: 'កំពុងរក្សាទុក...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Student/SavePayment',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(paymentData),
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                isSaving = false;
                console.log("Save response:", response);

                if (response && response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message || 'កត់ត្រាការបង់ប្រាក់ដោយជោគជ័យ',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadPayments();
                    loadStudents();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message || 'មានបញ្ហាក្នុងការរក្សាទុក'
                    });
                }
            },
            error: function(xhr, status, error) {
                isSaving = false;
                console.error("Save error:", error);
                console.error("Response:", xhr.responseText);

                let errorMsg = 'មានបញ្ហាបច្ចេកទេស';
                try {
                    let res = JSON.parse(xhr.responseText);
                    errorMsg = res.message || errorMsg;
                } catch(e) {
                    errorMsg = xhr.responseText || errorMsg;
                }

                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: errorMsg
                });
            }
        });
    }

    // ==================== DELETE PAYMENT ====================
    function deletePayment(id) {
        Swal.fire({
            title: 'លុបកំណត់ត្រា?',
            text: 'តើអ្នកពិតជាចង់លុបកំណត់ត្រានេះមែនទេ?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'បាទ, លុប',
            cancelButtonText: 'បោះបង់',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                let token = $('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'កំពុងដំណើរការ...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '/Student/DeletePayment',
                    type: 'POST',
                    data: { id: id },
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        if (response && response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'ជោគជ័យ!',
                                text: response.message || 'លុបកំណត់ត្រាដោយជោគជ័យ',
                                timer: 2000,
                                showConfirmButton: false
                            });
                            loadPayments();
                            loadStudents();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'កំហុស',
                                text: response.message || 'មានបញ្ហាក្នុងការលុប'
                            });
                        }
                    },
                    error: function(xhr, status, error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'កំហុស',
                            text: 'មានបញ្ហាបច្ចេកទេស: ' + error
                        });
                    }
                });
            }
        });
    }

    // ==================== UTILITY FUNCTIONS ====================
    function exportPayments() {
        window.location.href = '/Student/ExportPayments';
    }

    function showError(message) {
        $('#studentList').html(`
            <div class="text-center p-4 text-danger">
                <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                <p class="mt-2">${message}</p>
                <button class="btn btn-sm btn-primary mt-2" onclick="loadStudents()">
                    <i class="bi bi-arrow-clockwise"></i> ព្យាយាមម្តងទៀត
                </button>
            </div>
        `);
    }

    function showTableError(message) {
        $('#paymentTableBody').html(`
            <tr>
                <td colspan="9" class="text-center py-5">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-danger">${message}</h5>
                    <button class="btn-filter mt-3" onclick="loadPayments()">
                        <i class="bi bi-arrow-clockwise"></i>
                        ព្យាយាមម្តងទៀត
                    </button>
                </td>
            </tr>
        `);
    }
</script>