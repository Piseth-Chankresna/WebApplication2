@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "កត់ត្រាវត្តមាន";
    var selectedDate = ViewBag.SelectedDate ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #06b6d4;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #06b6d4, #0891b2);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #06b6d4;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .date-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

    [data-theme="dark"] .date-section {
        background: #1e293b;
        border-color: #334155;
    }

    .date-picker {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

        .date-picker label {
            font-weight: 600;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    [data-theme="dark"] .date-picker label {
        color: #cbd5e1;
    }

    .date-picker input {
        padding: 10px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .date-picker input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .summary-cards {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .summary-badge {
        padding: 8px 20px;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .badge-present {
        background: #d1fae5;
        color: #10b981;
    }

    .badge-late {
        background: #fef3c7;
        color: #f59e0b;
    }

    .badge-absent {
        background: #fee2e2;
        color: #ef4444;
    }

    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .filter-section {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
        }

    [data-theme="dark"] .filter-item label {
        color: #cbd5e1;
    }

    .filter-item select,
    .filter-item input {
        padding: 10px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-theme="dark"] .filter-item select,
    [data-theme="dark"] .filter-item input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-filter {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(6,182,212,0.3);
        }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 12px 32px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .btn-reset {
        background: #64748b;
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-reset:hover {
            background: #475569;
            transform: translateY(-2px);
        }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        overflow-x: auto;
    }

    [data-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .attendance-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1000px;
    }

        .attendance-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-theme="dark"] .attendance-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .attendance-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .attendance-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .attendance-table tbody tr:hover {
        background: #f8fafc;
    }

    [data-theme="dark"] .attendance-table tbody tr:hover {
        background: #0f172a;
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
        overflow: hidden;
        flex-shrink: 0;
    }

        .student-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .attendance-radio-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .radio-option {
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
    }

        .radio-option input[type="radio"] {
            display: none;
        }

    .radio-label {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .radio-option input[type="radio"]:checked + .radio-label.present {
        background: #10b981;
        color: white;
    }

    .radio-option input[type="radio"]:checked + .radio-label.late {
        background: #f59e0b;
        color: white;
    }

    .radio-option input[type="radio"]:checked + .radio-label.absent {
        background: #ef4444;
        color: white;
    }

    .radio-label.present {
        background: #d1fae5;
        color: #10b981;
        border: 1px solid #10b981;
    }

    .radio-label.late {
        background: #fef3c7;
        color: #f59e0b;
        border: 1px solid #f59e0b;
    }

    .radio-label.absent {
        background: #fee2e2;
        color: #ef4444;
        border: 1px solid #ef4444;
    }

    .note-input {
        width: 150px;
        padding: 8px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        background: white;
        color: #1e293b;
        font-size: 0.85rem;
    }

    [data-theme="dark"] .note-input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .note-input:focus {
        outline: none;
        border-color: #06b6d4;
        box-shadow: 0 0 0 3px rgba(6,182,212,0.1);
    }

    .btn-mark {
        background: #3b82f6;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-mark:hover {
            background: #2563eb;
            transform: translateY(-2px);
        }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .date-section {
            flex-direction: column;
            align-items: flex-start;
        }

        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-save, .btn-mark {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<!-- AntiForgeryToken Form (Hidden) -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-calendar-check-fill me-2"></i>៣.១. កត់ត្រាវត្តមានប្រចាំថ្ងៃ</h2>
    <p class="text-muted">បំពេញវត្តមានសិស្សប្រចាំថ្ងៃ</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-check-circle-fill stat-icon"></i>
        <div class="stat-value" id="presentCount">0</div>
        <div class="stat-label">វត្តមាន</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-clock-fill stat-icon"></i>
        <div class="stat-value" id="lateCount">0</div>
        <div class="stat-label">មកយឺត</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-x-circle-fill stat-icon"></i>
        <div class="stat-value" id="absentCount">0</div>
        <div class="stat-label">អវត្តមាន</div>
    </div>
</div>

<!-- Date Selection -->
<div class="date-section">
    <div class="date-picker">
        <label>
            <i class="bi bi-calendar3"></i>
            ជ្រើសរើសកាលបរិច្ឆេទ:
        </label>
        <input type="date" id="attendanceDate" value="@selectedDate">
    </div>
    <div class="summary-cards">
        <span class="summary-badge badge-present" id="summaryPresent">
            <i class="bi bi-check-circle-fill"></i>
            វត្តមាន: 0
        </span>
        <span class="summary-badge badge-late" id="summaryLate">
            <i class="bi bi-clock-fill"></i>
            មកយឺត: 0
        </span>
        <span class="summary-badge badge-absent" id="summaryAbsent">
            <i class="bi bi-x-circle-fill"></i>
            អវត្តមាន: 0
        </span>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-grid">
        <div class="filter-item">
            <label>ជំនាញ</label>
            <select id="filterMajor" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ឆ្នាំសិក្សា</label>
            <select id="filterYear" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="1">ឆ្នាំទី១</option>
                <option value="2">ឆ្នាំទី២</option>
                <option value="3">ឆ្នាំទី៣</option>
                <option value="4">ឆ្នាំទី៤</option>
            </select>
        </div>

        <div class="filter-item">
            <label>វេនសិក្សា</label>
            <select id="filterShift" class="form-select">
                <option value="">ទាំងអស់</option>
                <option value="ព្រឹក">ព្រឹក</option>
                <option value="រសៀល">រសៀល</option>
                <option value="យប់">យប់</option>
                <option value="សៅរ៍-អាទិត្យ">សៅរ៍-អាទិត្យ</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ស្វែងរក</label>
            <input type="text" id="searchInput" placeholder="ឈ្មោះ ឬលេខសម្គាល់...">
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button class="btn-filter" onclick="applyFilter()">
            <i class="bi bi-search"></i>
            អនុវត្តតម្រង
        </button>
        <button class="btn-reset" onclick="resetFilter()">
            <i class="bi bi-arrow-counterclockwise"></i>
            កំណត់ឡើងវិញ
        </button>
    </div>
</div>

<!-- Action Buttons -->
<div class="action-bar">
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn-save" onclick="saveAttendance()">
            <i class="bi bi-save"></i>
            រក្សាទុកវត្តមាន
        </button>
        <button class="btn-mark" onclick="markAllPresent()">
            <i class="bi bi-check-all"></i>
            វត្តមានទាំងអស់
        </button>
        <button class="btn-mark" style="background: #f59e0b;" onclick="markAllLate()">
            <i class="bi bi-clock"></i>
            មកយឺតទាំងអស់
        </button>
        <button class="btn-mark" style="background: #ef4444;" onclick="markAllAbsent()">
            <i class="bi bi-x-circle"></i>
            អវត្តមានទាំងអស់
        </button>
    </div>
</div>

<!-- Attendance Table -->
<div class="table-container">
    <table class="attendance-table">
        <thead>
            <tr>
                <th>សិស្ស</th>
                <th>ជំនាញ</th>
                <th>ឆ្នាំ</th>
                <th>វេន</th>
                <th>ស្ថានភាពវត្តមាន</th>
                <th>កំណត់ចំណាំ</th>
            </tr>
        </thead>
        <tbody id="attendanceTableBody">
            <tr>
                <td colspan="6" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<script src="https://unpkg.com/sweetalert2@11"></script>
<script>
    let studentList = [];
    let currentAttendance = {};
    let isSaving = false;

    $(document).ready(function() {
        loadStudents();
        loadStats();

        $('#attendanceDate').on('change', function() {
            loadStats();
        });
    });

    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            cache: false,
            success: function(response) {
                console.log("Students response:", response);

                if (response && response.success) {
                    studentList = response.data || [];
                } else if (Array.isArray(response)) {
                    studentList = response;
                } else {
                    console.error("Unexpected response format:", response);
                    studentList = [];
                }

                displayAttendance();
            },
            error: function(xhr, status, error) {
                console.error('Error loading students:', error);
                showError('មានបញ្ហាក្នុងការតភ្ជាប់ទៅកាន់ម៉ាស៊ីនបម្រើ');
            }
        });
    }

    function loadStats() {
        var date = $('#attendanceDate').val();

        $.ajax({
            url: '/Student/GetAttendanceStats?date=' + date,
            type: 'GET',
            cache: false,
            success: function(response) {
                console.log("Stats response:", response);

                if (response && response.success) {
                    $('#presentCount').text(response.present || 0);
                    $('#lateCount').text(response.late || 0);
                    $('#absentCount').text(response.absent || 0);

                    $('#summaryPresent').html(`<i class="bi bi-check-circle-fill"></i> វត្តមាន: ${response.present || 0}`);
                    $('#summaryLate').html(`<i class="bi bi-clock-fill"></i> មកយឺត: ${response.late || 0}`);
                    $('#summaryAbsent').html(`<i class="bi bi-x-circle-fill"></i> អវត្តមាន: ${response.absent || 0}`);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error loading stats:', error);
            }
        });
    }

    function displayAttendance() {
        var tbody = $('#attendanceTableBody');
        tbody.empty();

        if (!Array.isArray(studentList) || studentList.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="bi bi-people" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានទិន្នន័យសិស្សនៅឡើយទេ</h5>
                    </td>
                </tr>
            `);
            return;
        }

        var major = $('#filterMajor').val();
        var year = $('#filterYear').val();
        var shift = $('#filterShift').val();
        var search = $('#searchInput').val().toLowerCase();

        var filteredStudents = studentList.filter(s => {
            var matchMajor = !major || s.major === major;
            var matchYear = !year || s.year === year;
            var matchShift = !shift || s.shift === shift;
            var matchSearch = !search ||
                (s.name && s.name.toLowerCase().includes(search)) ||
                (s.id && s.id.toLowerCase().includes(search));

            return matchMajor && matchYear && matchShift && matchSearch;
        });

        $('#totalStudents').text(filteredStudents.length);

        filteredStudents.forEach(s => {
            var status = currentAttendance[s.id] || 'P';

            // Create avatar HTML
            var avatarHtml = '';
            if (s.photo) {
                avatarHtml = `<img src="${s.photo}" alt="${s.name || ''}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(s.name || 'User')}&background=06b6d4&color=fff'">`;
            } else {
                avatarHtml = s.name ? s.name.charAt(0).toUpperCase() : '?';
            }

            var row = `
                <tr>
                    <td>
                        <div class="student-info">
                            <div class="student-avatar">
                                ${avatarHtml}
                            </div>
                            <div>
                                <div class="fw-bold">${s.name || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">${s.id}</small>
                            </div>
                        </div>
                    </td>
                    <td>${s.major || 'N/A'}</td>
                    <td>ឆ្នាំទី${s.year || '?'}</td>
                    <td>${s.shift || 'N/A'}</td>
                    <td>
                        <div class="attendance-radio-group">
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="P" ${status === 'P' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label present">វត្តមាន</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="L" ${status === 'L' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label late">មកយឺត</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="A" ${status === 'A' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label absent">អវត្តមាន</span>
                            </label>
                        </div>
                    </td>
                    <td>
                        <input type="text" class="note-input" id="note_${s.id}" placeholder="កំណត់ចំណាំ..." value="${currentAttendance[`note_${s.id}`] || ''}">
                    </td>
                </tr>
            `;
            tbody.append(row);
        });

        updateCounts();
    }

    function updateAttendance(studentId, status) {
        currentAttendance[studentId] = status;
        updateCounts();
    }

    function updateCounts() {
        var present = 0, late = 0, absent = 0;

        $('input[type="radio"]:checked').each(function() {
            var value = $(this).val();
            if (value === 'P') present++;
            else if (value === 'L') late++;
            else if (value === 'A') absent++;
        });

        $('#presentCount').text(present);
        $('#lateCount').text(late);
        $('#absentCount').text(absent);

        $('#summaryPresent').html(`<i class="bi bi-check-circle-fill"></i> វត្តមាន: ${present}`);
        $('#summaryLate').html(`<i class="bi bi-clock-fill"></i> មកយឺត: ${late}`);
        $('#summaryAbsent').html(`<i class="bi bi-x-circle-fill"></i> អវត្តមាន: ${absent}`);
    }

    function markAllPresent() {
        $('input[type="radio"][value="P"]').prop('checked', true);
        updateCounts();
    }

    function markAllLate() {
        $('input[type="radio"][value="L"]').prop('checked', true);
        updateCounts();
    }

    function markAllAbsent() {
        $('input[type="radio"][value="A"]').prop('checked', true);
        updateCounts();
    }

    function saveAttendance() {
        // Prevent multiple clicks
        if (isSaving) {
            Swal.fire({
                icon: 'info',
                title: 'កំពុងដំណើរការ',
                text: 'សូមរង់ចាំ...'
            });
            return;
        }

        // Get AntiForgeryToken
        var token = $('input[name="__RequestVerificationToken"]').val();
        console.log("AntiForgeryToken:", token);

        if (!token) {
            console.error("AntiForgeryToken not found!");
            Swal.fire({
                icon: 'error',
                title: 'កំហុស',
                text: 'មិនអាចរកឃើញ Token សុវត្ថិភាព'
            });
            return;
        }

        var date = $('#attendanceDate').val();
        var attendanceData = [];

        $('input[type="radio"]:checked').each(function() {
            var name = $(this).attr('name');
            var studentId = name.replace('att_', '');
            var status = $(this).val();
            var note = $(`#note_${studentId}`).val();

            attendanceData.push({
                studentId: studentId,
                studentName: $(this).closest('tr').find('.fw-bold').text(),
                date: date,
                status: status,
                note: note
            });
        });

        console.log("Attendance data to save:", attendanceData);

        // Check if there is data
        if (attendanceData.length === 0) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមជ្រើសរើសស្ថានភាពវត្តមាន',
                text: 'មិនទាន់មានទិន្នន័យវត្តមានត្រូវបានជ្រើសរើសទេ'
            });
            return;
        }

        // Show loading
        isSaving = true;
        Swal.fire({
            title: 'កំពុងរក្សាទុក...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Student/SaveAttendance',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(attendanceData),
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                console.log("Save response:", response);
                isSaving = false;

                if (response && response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message || 'រក្សាទុកវត្តមានដោយជោគជ័យ!',
                        timer: 2000,
                        showConfirmButton: false
                    });
                    currentAttendance = {};
                    loadStats();
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message || 'មានបញ្ហាក្នុងការរក្សាទុក'
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error("AJAX Error:", error);
                console.error("Status:", xhr.status);
                console.error("Response:", xhr.responseText);
                isSaving = false;

                let errorMessage = 'មានបញ្ហាបច្ចេកទេស';
                try {
                    const response = JSON.parse(xhr.responseText);
                    if (response.message) {
                        errorMessage = response.message;
                    } else if (response.title) {
                        errorMessage = response.title;
                    }
                } catch(e) {
                    if (xhr.responseText) {
                        errorMessage = xhr.responseText;
                    }
                }

                Swal.fire({
                    icon: 'error',
                    title: `កំហុស (${xhr.status})`,
                    text: errorMessage
                });
            },
            complete: function() {
                isSaving = false;
            }
        });
    }

    function applyFilter() {
        displayAttendance();
    }

    function resetFilter() {
        $('#filterMajor').val('');
        $('#filterYear').val('');
        $('#filterShift').val('');
        $('#searchInput').val('');
        displayAttendance();
    }

    function showError(message) {
        $('#attendanceTableBody').html(`
            <tr>
                <td colspan="6" class="text-center py-5">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                    <h5 class="mt-3 text-danger">${message}</h5>
                    <button class="btn btn-primary mt-3" onclick="loadStudents()">
                        <i class="bi bi-arrow-clockwise me-2"></i>ព្យាយាមម្តងទៀត
                    </button>
                </td>
            </tr>
        `);
    }
</script>