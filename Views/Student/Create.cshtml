@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "បន្ថែមសិស្សថ្មី";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            color: #10b981;
            margin-bottom: 8px;
        }

            .page-header h2 i {
                background: linear-gradient(135deg, #10b981, #059669);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                background-clip: text;
            }

    .form-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .form-card {
        background: #1e293b;
        border-color: #334155;
    }

    .form-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .form-header i {
            font-size: 3.5rem;
            color: #10b981;
            margin-bottom: 16px;
        }

        .form-header h3 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 8px;
        }

    [data-bs-theme="dark"] .form-header h3 {
        color: white;
    }

    .form-header p {
        color: #64748b;
        margin: 0;
    }

    .section-title {
        font-weight: 700;
        color: #1e293b;
        margin: 30px 0 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    [data-bs-theme="dark"] .section-title {
        color: white;
        border-bottom-color: #334155;
    }

    .section-title i {
        color: #10b981;
        font-size: 1.5rem;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-bs-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-label i {
        margin-right: 8px;
        color: #10b981;
    }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
        }

        .input-wrapper input,
        .input-wrapper select,
        .input-wrapper textarea {
            width: 100%;
            padding: 14px 16px 14px 48px;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            background: white;
            color: #1e293b;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

    [data-bs-theme="dark"] .input-wrapper input,
    [data-bs-theme="dark"] .input-wrapper select,
    [data-bs-theme="dark"] .input-wrapper textarea {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .input-wrapper input:focus,
    .input-wrapper select:focus,
    .input-wrapper textarea:focus {
        outline: none;
        border-color: #10b981;
        box-shadow: 0 0 0 4px rgba(16,185,129,0.1);
    }

    .input-wrapper select {
        appearance: none;
        cursor: pointer;
    }

    .input-wrapper .select-arrow {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .photo-upload {
        border: 2px dashed #e2e8f0;
        border-radius: 20px;
        padding: 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        background: #f8fafc;
    }

    [data-bs-theme="dark"] .photo-upload {
        background: #0f172a;
        border-color: #334155;
    }

    .photo-upload:hover {
        border-color: #10b981;
        background: #f0fdf4;
    }

    [data-bs-theme="dark"] .photo-upload:hover {
        background: #1a2e2a;
    }

    .photo-upload i {
        font-size: 3rem;
        color: #94a3b8;
        margin-bottom: 10px;
    }

    .photo-upload p {
        color: #64748b;
        margin: 0;
    }

    .photo-preview {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        margin: 0 auto 15px;
        border: 4px solid white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: none;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 40px;
        padding-top: 30px;
        border-top: 2px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .form-actions {
        border-top-color: #334155;
    }

    .btn {
        flex: 1;
        padding: 16px;
        border: none;
        border-radius: 16px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .btn-secondary {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .btn-secondary {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
    }

    .alert {
        padding: 16px;
        border-radius: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #ef4444;
        border: 1px solid #fecaca;
    }

    .alert-success {
        background: #d1fae5;
        color: #10b981;
        border: 1px solid #a7f3d0;
    }

    .row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    @@media (max-width: 768px) {
        .row {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }

        .form-card {
            padding: 30px 20px;
        }
    }
</style>

<!-- AntiForgeryToken -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-person-plus-fill me-2"></i>បន្ថែមសិស្សថ្មី</h2>
    <p class="text-muted">បំពេញព័ត៌មានខាងក្រោមដើម្បីបង្កើតសិស្សថ្មី</p>
</div>

<div class="form-container">
    <div class="form-card">
        <div class="form-header">
            <i class="bi bi-person-plus-fill"></i>
            <h3>ព័ត៌មានសិស្ស</h3>
            <p>សូមបំពេញព័ត៌មានអោយបានត្រឹមត្រូវ</p>
        </div>

        <form id="createForm" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <!-- Photo Upload -->
            <div class="photo-upload" onclick="$('#photoInput').click()">
                <img id="photoPreview" class="photo-preview" src="#" alt="Preview">
                <i class="bi bi-camera"></i>
                <p>ចុចដើម្បីបញ្ចូលរូបថត</p>
                <small class="text-muted">គាំទ្រ JPG, PNG (រូបថត 3x4)</small>
            </div>
            <input type="file" id="photoInput" name="Photo" accept="image/*" style="display: none;">

            <!-- Personal Information -->
            <div class="section-title">
                <i class="bi bi-person"></i>
                <span>ព័ត៌មានផ្ទាល់ខ្លួន</span>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentName" class="form-label"><i class="bi bi-person"></i> ឈ្មោះពេញ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-person"></i>
                        <input type="text" name="FullName" id="studentName" class="form-control" placeholder="ឧ. សុខ សុភ័ក្រ" autocomplete="name" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentEmail" class="form-label"><i class="bi bi-envelope"></i> អ៊ីមែល</label>
                    <div class="input-wrapper">
                        <i class="bi bi-envelope"></i>
                        <input type="email" name="Email" id="studentEmail" class="form-control" placeholder="ឧ. student@example.com" autocomplete="email" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentGender" class="form-label"><i class="bi bi-gender-ambiguous"></i> ភេទ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-gender-ambiguous"></i>
                        <select name="Gender" id="studentGender" class="form-control" autocomplete="sex" required>
                            <option value="">ជ្រើសរើសភេទ</option>
                            <option value="ប្រុស">ប្រុស</option>
                            <option value="ស្រី">ស្រី</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentDob" class="form-label"><i class="bi bi-calendar"></i> ថ្ងៃខែឆ្នាំកំណើត</label>
                    <div class="input-wrapper">
                        <i class="bi bi-calendar"></i>
                        <input type="date" name="DateOfBirth" id="studentDob" class="form-control" autocomplete="bday" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentPob" class="form-label"><i class="bi bi-geo-alt"></i> ទីកន្លែងកំណើត</label>
                    <div class="input-wrapper">
                        <i class="bi bi-geo-alt"></i>
                        <input type="text" name="PlaceOfBirth" id="studentPob" class="form-control" placeholder="ឧ. ភ្នំពេញ" autocomplete="home" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentPhone" class="form-label"><i class="bi bi-phone"></i> លេខទូរស័ព្ទ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-phone"></i>
                        <input type="tel" name="Phone" id="studentPhone" class="form-control" placeholder="ឧ. 012 345 678" autocomplete="tel" required>
                    </div>
                </div>
            </div>

            <!-- Academic Information -->
            <div class="section-title">
                <i class="bi bi-mortarboard"></i>
                <span>ព័ត៌មានសិក្សា</span>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentDegree" class="form-label"><i class="bi bi-book"></i> កម្រិតសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-book"></i>
                        <select name="Degree" id="studentDegree" class="form-control" autocomplete="education" required>
                            <option value="">ជ្រើសរើសកម្រិត</option>
                            <option value="បរិញ្ញាបត្ររង">បរិញ្ញាបត្ររង</option>
                            <option value="បរិញ្ញាបត្រ">បរិញ្ញាបត្រ</option>
                            <option value="បរិញ្ញាបត្រជាន់ខ្ពស់">បរិញ្ញាបត្រជាន់ខ្ពស់</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentMajor" class="form-label"><i class="bi bi-star"></i> ជំនាញ</label>
                    <div class="input-wrapper">
                        <i class="bi bi-star"></i>
                        <select name="Major" id="studentMajor" class="form-control" autocomplete="organization" required>
                            <option value="">ជ្រើសរើសជំនាញ</option>
                            <option value="Information Technology">Information Technology</option>
                            <option value="Business Administration">Business Administration</option>
                            <option value="English Literature">English Literature</option>
                            <option value="Law">Law</option>
                            <option value="Accounting">Accounting</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentYear" class="form-label"><i class="bi bi-calendar3"></i> ឆ្នាំសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-calendar3"></i>
                        <select name="Year" id="studentYear" class="form-control" autocomplete="organization-title" required>
                            <option value="">ជ្រើសរើសឆ្នាំ</option>
                            <option value="1">ឆ្នាំទី១</option>
                            <option value="2">ឆ្នាំទី២</option>
                            <option value="3">ឆ្នាំទី៣</option>
                            <option value="4">ឆ្នាំទី៤</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentRoom" class="form-label"><i class="bi bi-door-open"></i> បន្ទប់</label>
                    <div class="input-wrapper">
                        <i class="bi bi-door-open"></i>
                        <input type="text" name="Room" id="studentRoom" class="form-control" placeholder="ឧ. A101" autocomplete="address-line1" required>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentShift" class="form-label"><i class="bi bi-clock"></i> វេនសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-clock"></i>
                        <select name="Shift" id="studentShift" class="form-control" autocomplete="off" required>
                            <option value="">ជ្រើសរើសវេន</option>
                            <option value="ព្រឹក">ព្រឹក (៧:០០-១១:០០)</option>
                            <option value="រសៀល">រសៀល (១:០០-៥:០០)</option>
                            <option value="យប់">យប់ (៥:៣០-៨:៣០)</option>
                            <option value="សៅរ៍-អាទិត្យ">សៅរ៍-អាទិត្យ</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentScholarship" class="form-label"><i class="bi bi-gift"></i> អាហារូបករណ៍</label>
                    <div class="input-wrapper">
                        <i class="bi bi-gift"></i>
                        <select name="Scholarship" id="studentScholarship" class="form-control" autocomplete="off">
                            <option value="0%">0% (បង់ថ្លៃពេញ)</option>
                            <option value="25%">25%</option>
                            <option value="50%">50%</option>
                            <option value="75%">75%</option>
                            <option value="100%">100%</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="section-title">
                <i class="bi bi-info-circle"></i>
                <span>ព័ត៌មានបន្ថែម</span>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentBatch" class="form-label"><i class="bi bi-tag"></i> លេខសម្គាល់ (បើមាន)</label>
                    <div class="input-wrapper">
                        <i class="bi bi-tag"></i>
                        <input type="text" name="Batch" id="studentBatch" class="form-control" placeholder="ឧ. BATCH-2025" autocomplete="off">
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentAcademicYear" class="form-label"><i class="bi bi-calendar-week"></i> ឆ្នាំសិក្សា</label>
                    <div class="input-wrapper">
                        <i class="bi bi-calendar-week"></i>
                        <input type="text" name="AcademicYear" id="studentAcademicYear" class="form-control" value="2025-2026" autocomplete="off">
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="form-group">
                    <label for="studentAmountDue" class="form-label"><i class="bi bi-currency-dollar"></i> ថ្លៃសិក្សាត្រូវបង់ ($)</label>
                    <div class="input-wrapper">
                        <i class="bi bi-currency-dollar"></i>
                        <input type="number" name="TuitionFee" id="studentAmountDue" class="form-control" value="1000" step="0.01" autocomplete="transaction-amount">
                    </div>
                </div>

                <div class="form-group">
                    <label for="studentPaidAmount" class="form-label"><i class="bi bi-cash-check"></i> ប្រាក់បង់រួច ($)</label>
                    <div class="input-wrapper">
                        <i class="bi bi-cash-check"></i>
                        <input type="number" name="PaidAmount" id="studentPaidAmount" class="form-control" value="0" step="0.01" autocomplete="transaction-amount">
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="studentNotes" class="form-label"><i class="bi bi-journal-text"></i> ចំណាំ</label>
                <div class="input-wrapper">
                    <i class="bi bi-journal-text"></i>
                    <textarea name="Notes" id="studentNotes" class="form-control" rows="3" placeholder="ចំណាំអំពីសិស្ស..." autocomplete="off"></textarea>
                </div>
            </div>

            <div class="form-actions">
                <a href="/Student/Index" class="btn btn-secondary ajax-link" data-url="/Student/Index">
                    <i class="bi bi-x-lg"></i> បោះបង់
                </a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="bi bi-check-lg"></i> រក្សាទុក
                </button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Preview photo before upload
    $('#photoInput').change(function(e) {
        var file = e.target.files[0];
        if (file) {
            var reader = new FileReader();
            reader.onload = function(e) {
                $('#photoPreview').attr('src', e.target.result).show();
                $('.photo-upload i, .photo-upload p, .photo-upload small').hide();
            };
            reader.readAsDataURL(file);
        }
    });

    // Form submit
    $('#createForm').submit(function(e) {
        e.preventDefault();

        var token = $('input[name="__RequestVerificationToken"]').val();

        // Validate required fields
        if (!$('#studentName').val()) {
            Swal.fire('កំហុស', 'សូមបញ្ចូលឈ្មោះសិស្ស', 'error');
            return;
        }

        var formData = new FormData(this);

        // Show loading
        Swal.fire({
            title: 'កំពុងរក្សាទុក...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Student/Create',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                if (response && response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/Student/Index';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message || 'មានបញ្ហាក្នុងការរក្សាទុក'
                    });
                }
            },
            error: function(xhr, status, error) {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាបច្ចេកទេស: ' + error
                });
            }
        });
    });
</script>