<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --hru-blue: #2563eb;
        --hru-bg: #f1f5f9;
        --hru-card-bg: #ffffff;
        --hru-text: #1e293b;
        --hru-text-muted: #64748b;
        --hru-input-bg: #f8fafc;
        --hru-border: #e2e8f0;
        --section-title: #475569;
    }

    /* Dark Mode variables */
    [data-bs-theme="dark"] {
        --hru-bg: #0f172a;
        --hru-card-bg: #1e293b;
        --hru-text: #f1f5f9;
        --hru-text-muted: #94a3b8;
        --hru-input-bg: #0f172a;
        --hru-border: #334155;
        --section-title: #cbd5e1;
    }

    #studentRegistrationPage {
        background-color: var(--hru-bg);
        color: var(--hru-text);
        min-height: 100vh;
        transition: all 0.3s ease;
    }

    .hru-banner-custom {
        background: var(--hru-blue);
        color: white;
        border-radius: 15px;
        padding: 25px 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 25px;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2);
    }

    .hru-banner-icon {
        background: rgba(255, 255, 255, 0.2);
        width: 60px;
        height: 60px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        margin-right: 20px;
    }

    .section-divider {
        border-left: 4px solid var(--hru-blue);
        padding-left: 10px;
        margin: 25px 0 15px 0;
        font-weight: bold;
        color: var(--section-title);
        font-size: 1.1rem;
    }

    .card {
        background-color: var(--hru-card-bg) !important;
        border: 1px solid var(--hru-border) !important;
    }

    .form-control, .form-select {
        border-radius: 8px;
        padding: 10px 15px;
        border: 1px solid var(--hru-border);
        background-color: var(--hru-input-bg);
        color: var(--hru-text);
        transition: 0.2s;
    }

        .form-control:focus, .form-select:focus {
            background-color: var(--hru-card-bg);
            border-color: var(--hru-blue);
            color: var(--hru-text);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
        }

    .profile-section-container {
        background: var(--hru-input-bg);
        border: 2px dashed var(--hru-border);
        border-radius: 20px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .profile-upload-wrapper {
        position: relative;
        margin-bottom: 15px;
    }

    .profile-preview {
        width: 130px;
        height: 130px;
        object-fit: cover;
        border-radius: 12px;
        border: 4px solid var(--hru-card-bg);
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .upload-btn-badge {
        position: absolute;
        bottom: -5px;
        right: -5px;
        background: var(--hru-blue);
        color: white;
        width: 35px;
        height: 35px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        border: 2px solid var(--hru-card-bg);
    }

    .btn-save {
        background: var(--hru-blue);
        padding: 12px 40px;
        border-radius: 10px;
        font-weight: 600;
        transition: 0.3s;
        border: none;
        color: white;
    }

        .btn-save:hover:not(:disabled) {
            background: #1d4ed8;
            transform: translateY(-2px);
        }

    .btn-cancel {
        padding: 12px 30px;
        border-radius: 10px;
        font-weight: 600;
        border: 1px solid var(--hru-border);
        background: var(--hru-card-bg);
        color: var(--hru-text);
    }

    .text-muted {
        color: var(--hru-text-muted) !important;
    }

    /* Modal Dark Mode Fix */
    .swal2-popup {
        background-color: var(--hru-card-bg) !important;
        color: var(--hru-text) !important;
    }
</style>

<div id="studentRegistrationPage" class="container-fluid p-2 animate__animated animate__fadeIn">
    <div class="row mb-4">
        <div class="col-12">
            <div class="hru-banner-custom animate__animated animate__fadeInDown">
                <div class="d-flex align-items-center">
                    <div class="hru-banner-icon">
                        <i class="bi bi-person-plus-fill"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold m-0">ចុះឈ្មោះសិស្សថ្មី (New Student)</h4>
                        <p class="mb-0 opacity-75 small">ប្រព័ន្ធគ្រប់គ្រងទិន្នន័យសិស្ស និងអាហារូបករណ៍</p>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4">
                    <form id="studentForm">
                        <div class="row">
                            <div class="col-lg-3 text-center mb-4">
                                <div class="profile-section-container h-100 justify-content-center">
                                    <div class="profile-upload-wrapper">
                                        <img id="imagePreview" src="https://ui-avatars.com/api/?name=User&background=cbd5e1&color=fff&size=128" class="profile-preview" alt="Profile Preview">
                                        <label for="profileInput" class="upload-btn-badge shadow-sm">
                                            <i class="bi bi-camera-fill"></i>
                                        </label>
                                        <input type="file" id="profileInput" name="ProfileImage" class="d-none" accept="image/*" onchange="previewImage(event)">
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-1">រូបថតអ្នកប្រើប្រាស់</h6>
                                        <p class="text-muted small mb-0">សូមជ្រើសរើសរូបថត (JPG, PNG)</p>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-9">
                                <div class="section-divider">ព័ត៌មានផ្ទាល់ខ្លួន</div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">ឈ្មោះពេញ (Full Name)</label>
                                        <input type="text" id="studentName" class="form-control" placeholder="ឧ. សុខ ហេង" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small fw-bold">ភេទ (Gender)</label>
                                        <select id="studentGender" class="form-select">
                                            <option value="ប្រុស">ប្រុស (Male)</option>
                                            <option value="ស្រី">ស្រី (Female)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label small fw-bold">ថ្ងៃខែឆ្នាំកំណើត (DOB)</label>
                                        <input type="date" id="studentDOB" class="form-control" onclick="this.showPicker()" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">ទីកន្លែងកំណើត (Place of Birth)</label>
                                        <input type="text" id="studentPOB" class="form-control" placeholder="ខេត្ត/ក្រុង..." required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold">លេខទូរស័ព្ទ (Phone Number)</label>
                                        <input type="tel" id="studentPhone" class="form-control" placeholder="097 347 466" required>
                                    </div>
                                </div>

                                <div class="section-divider">ព័ត៌មានការសិក្សា</div>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">កម្រិតសិក្សា (Degree)</label>
                                        <select id="studentDegree" class="form-select">
                                            <option value="បរិញ្ញាបត្រ">បរិញ្ញាបត្រ (Bachelor)</option>
                                            <option value="បរិញ្ញាបត្ររង">បរិញ្ញាបត្ររង (Associate)</option>
                                            <option value="បរិញ្ញាបត្រជាន់ខ្ពស់">បរិញ្ញាបត្រជាន់ខ្ពស់ (Master)</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">ជំនាញ (Major)</label>
                                        <select id="studentMajor" class="form-select">
                                            <option>Information Technology</option>
                                            <option>Business Administration</option>
                                            <option>English Literature</option>
                                            <option>Law</option>
                                            <option>Accounting</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">ឆ្នាំសិក្សា (Year)</label>
                                        <select id="studentYear" class="form-select">
                                            <option value="1">Year 1</option>
                                            <option value="2">Year 2</option>
                                            <option value="3">Year 3</option>
                                            <option value="4">Year 4</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">អាហារូបករណ៍ (Scholarship %)</label>
                                        <select id="studentScholarship" class="form-select">
                                            <option value="0">0% (បង់ពេញ)</option>
                                            <option value="10">10% Scholarship</option>
                                            <option value="25">25% Scholarship</option>
                                            <option value="50">50% Scholarship</option>
                                            <option value="100">100% Scholarship</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">បន្ទប់សិក្សា (Room)</label>
                                        <input type="text" id="studentRoom" class="form-control" placeholder="ឧ. R1-06" required>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold">វេនសិក្សា (Study Shift)</label>
                                        <select id="studentShift" class="form-select">
                                            <option value="ព្រឹក">ព្រឹក (Morning)</option>
                                            <option value="រសៀល">រសៀល (Afternoon)</option>
                                            <option value="វេនយប់">វេនយប់ (Evening)</option>
                                            <option value="សៅរ៍/អាទិត្យ">សៅរ៍/អាទិត្យ (Weekend)</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4 opacity-25">

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-cancel" onclick="forceReset()">បោះបង់</button>
                            <button type="submit" id="saveBtn" class="btn btn-save text-white shadow-sm">
                                <i class="bi bi-sd-card-fill me-2"></i>រក្សាទុកព័ត៌មាន
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function previewImage(event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                document.getElementById('imagePreview').src = e.target.result;
            };
            reader.readAsDataURL(file);
        }
    }

    function forceReset() {
        document.getElementById('studentForm').reset();
        document.getElementById('imagePreview').src = "https://ui-avatars.com/api/?name=User&background=cbd5e1&color=fff&size=128";
    }

    document.getElementById('studentForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const saveBtn = document.getElementById('saveBtn');
        saveBtn.disabled = true;
        saveBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span> កំពុងរក្សាទុក...`;

        setTimeout(() => {
            try {
                const scholarshipVal = parseInt(document.getElementById('studentScholarship').value) || 0;
                const newStudent = {
                    id: "HRU-" + Math.floor(10000 + Math.random() * 90000),
                    name: document.getElementById('studentName').value,
                    gender: document.getElementById('studentGender').value,
                    dob: document.getElementById('studentDOB').value,
                    pob: document.getElementById('studentPOB').value,
                    phone: document.getElementById('studentPhone').value,
                    degree: document.getElementById('studentDegree').value,
                    major: document.getElementById('studentMajor').value,
                    year: document.getElementById('studentYear').value,
                    scholarship: scholarshipVal,
                    scholarship_type: scholarshipVal > 0 ? 'អាហារូបករណ៍' : 'ទូទៅ',
                    room: document.getElementById('studentRoom').value,
                    shift: document.getElementById('studentShift').value,
                    photo: document.getElementById('imagePreview').src,
                    regDate: new Date().toLocaleDateString('km-KH')
                };

                let students = JSON.parse(localStorage.getItem('students')) || [];
                students.unshift(newStudent);
                localStorage.setItem('students', JSON.stringify(students));

                Swal.fire({
                    icon: 'success',
                    title: 'រក្សាទុកជោគជ័យ!',
                    text: 'ទិន្នន័យសិស្សត្រូវបានបញ្ចូលទៅក្នុងប្រព័ន្ធ',
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    forceReset();
                    saveBtn.disabled = false;
                    saveBtn.innerHTML = `<i class="bi bi-sd-card-fill me-2"></i>រក្សាទុកព័ត៌មាន`;
                });
            } catch (error) {
                saveBtn.disabled = false;
                saveBtn.innerHTML = `<i class="bi bi-sd-card-fill me-2"></i>រក្សាទុកព័ត៌មាន`;
                Swal.fire('Error', 'Something went wrong!', 'error');
            }
        }, 800);
    });
</script>