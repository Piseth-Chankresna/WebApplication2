@model IEnumerable<WebApplication2.Models.StudentClass>
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "គ្រប់គ្រងថ្នាក់";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #8b5cf6, #7c3aed);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #8b5cf6;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .action-bar {
        background: white;
        border-radius: 60px;
        padding: 6px 6px 6px 24px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .action-bar {
        background: #1e293b;
        border-color: #334155;
    }

    .search-wrapper {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .search-wrapper i {
            color: #94a3b8;
        }

        .search-wrapper input {
            border: none;
            background: transparent;
            padding: 12px 0;
            width: 100%;
            outline: none;
            color: #1e293b;
        }

    [data-theme="dark"] .search-wrapper input {
        color: white;
    }

    .btn-create {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        padding: 12px 28px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        border: none;
    }

        .btn-create:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(139,92,246,0.3);
        }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .class-table {
        width: 100%;
        border-collapse: collapse;
    }

        .class-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
        }

    [data-theme="dark"] .class-table th {
        border-bottom-color: #334155;
    }

    .class-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-theme="dark"] .class-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .class-table tbody tr:hover {
        background: #f8fafc;
        cursor: pointer;
    }

    [data-theme="dark"] .class-table tbody tr:hover {
        background: #0f172a;
    }

    .teacher-avatar {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
    }

    .room-badge {
        background: #e0e7ff;
        color: #8b5cf6;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        display: inline-block;
    }

    .time-badge {
        background: #f1f5f9;
        color: #64748b;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        display: inline-block;
    }

    [data-theme="dark"] .time-badge {
        background: #0f172a;
        color: #cbd5e1;
    }

    .action-group {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        cursor: pointer;
        text-decoration: none;
    }

    [data-theme="dark"] .btn-icon {
        background: #0f172a;
        border-color: #334155;
        color: #cbd5e1;
    }

    .btn-icon:hover {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        transform: translateY(-2px);
    }

    /* Modal Styles */
    .modal-content {
        border-radius: 24px;
        border: none;
        overflow: hidden;
    }

    [data-theme="dark"] .modal-content {
        background: #1e293b;
        color: white;
    }

    .modal-header {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        padding: 20px 24px;
        border: none;
    }

        .modal-header .btn-close {
            filter: brightness(0) invert(1);
        }

    .modal-body {
        padding: 24px;
    }

    .modal-footer {
        padding: 20px 24px;
        border-top: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .modal-footer {
        border-top-color: #334155;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .form-control {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .form-control:focus {
        outline: none;
        border-color: #8b5cf6;
        box-shadow: 0 0 0 4px rgba(139,92,246,0.1);
    }

    .btn-modal {
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-modal-primary {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        border: none;
    }

        .btn-modal-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(139,92,246,0.3);
        }

    .btn-modal-secondary {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .btn-modal-secondary {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .action-bar {
            flex-direction: column;
            border-radius: 20px;
            padding: 16px;
        }

        .search-wrapper {
            width: 100%;
        }

        .btn-create {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-door-open-fill me-2"></i>គ្រប់គ្រងថ្នាក់</h2>
    <p class="text-muted">គ្រប់គ្រងថ្នាក់រៀន គ្រូបង្រៀន និងម៉ោងសិក្សា</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-door-open-fill stat-icon"></i>
        <div class="stat-value" id="totalClasses">0</div>
        <div class="stat-label">ថ្នាក់សរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-person-badge stat-icon"></i>
        <div class="stat-value" id="totalTeachers">0</div>
        <div class="stat-label">គ្រូបង្រៀន</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-people stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-building stat-icon"></i>
        <div class="stat-value" id="totalRooms">0</div>
        <div class="stat-label">បន្ទប់</div>
    </div>
</div>

<!-- Action Bar -->
<div class="action-bar">
    <div class="search-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" placeholder="ស្វែងរកតាមឈ្មោះថ្នាក់ លេខកូដ ឬគ្រូ...">
    </div>
    <button class="btn-create" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i>
        <span>បន្ថែមថ្នាក់ថ្មី</span>
    </button>
</div>

<!-- Classes Table -->
<div class="table-container">
    <div class="table-responsive">
        <table class="class-table">
            <thead>
                <tr>
                    <th>លេខកូដ</th>
                    <th>ឈ្មោះថ្នាក់</th>
                    <th>គ្រូបង្រៀន</th>
                    <th>បន្ទប់</th>
                    <th>ម៉ោងសិក្សា</th>
                    <th>សិស្ស</th>
                    <th class="text-end">សកម្មភាព</th>
                </tr>
            </thead>
            <tbody id="classTableBody">
                <!-- Data will be loaded by JavaScript -->
            </tbody>
        </table>
    </div>
</div>

<!-- Create/Edit Modal -->
<div class="modal fade" id="classModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">
                    <i class="bi bi-plus-circle me-2"></i>
                    <span id="modalTitleText">បន្ថែមថ្នាក់ថ្មី</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="classForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="classId" value="0">

                    <div class="form-group">
                        <label class="form-label">លេខកូដថ្នាក់ <span class="text-danger">*</span></label>
                        <input type="text" id="classCode" class="form-control" placeholder="ឧ. IT-101" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">ឈ្មោះថ្នាក់ <span class="text-danger">*</span></label>
                        <input type="text" id="className" class="form-control" placeholder="ឧ. កម្មវិធីកុំព្យូទ័រ" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">ឈ្មោះគ្រូបង្រៀន <span class="text-danger">*</span></label>
                        <input type="text" id="teacherName" class="form-control" placeholder="ឧ. លោក សុខ សុភ័ក្រ" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">បន្ទប់ <span class="text-danger">*</span></label>
                                <input type="text" id="room" class="form-control" placeholder="ឧ. A101" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">ម៉ោងសិក្សា <span class="text-danger">*</span></label>
                                <input type="text" id="time" class="form-control" placeholder="ឧ. ៧:០០-៩:០០" required>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-modal-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-2"></i>បោះបង់
                </button>
                <button type="button" class="btn btn-modal-primary" onclick="saveClass()">
                    <i class="bi bi-check-lg me-2"></i>រក្សាទុក
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let classes = [];
    let token = '';

    // Load classes on page load
    $(document).ready(function() {
        // Get anti-forgery token
        token = $('input[name="__RequestVerificationToken"]').val();
        console.log('AntiForgeryToken loaded:', token ? 'Yes' : 'No');

        loadClasses();
    });

    function loadClasses() {
        $('#classTableBody').html(`
            <tr>
                <td colspan="7" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        `);

        $.ajax({
            url: '/Student/GetClasses',
            type: 'GET',
            cache: false,
            success: function(data) {
                classes = data;
                displayClasses(data);
                updateStats(data);
            },
            error: function(xhr, status, error) {
                console.error('Error loading classes:', error);
                $('#classTableBody').html(`
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                            <h5 class="mt-3 text-danger">មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ</h5>
                            <button class="btn btn-primary mt-3" onclick="loadClasses()">
                                <i class="bi bi-arrow-clockwise me-2"></i>ព្យាយាមម្តងទៀត
                            </button>
                        </td>
                    </tr>
                `);
            }
        });
    }

    function displayClasses(data) {
        var tbody = $('#classTableBody');
        tbody.empty();

        if (data.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="7" class="text-center py-5">
                        <i class="bi bi-door-open" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានទិន្នន័យថ្នាក់នៅឡើយទេ</h5>
                        <button class="btn btn-primary mt-3" onclick="openCreateModal()">
                            <i class="bi bi-plus-lg me-2"></i>បន្ថែមថ្នាក់ដំបូង
                        </button>
                    </td>
                </tr>
            `);
            return;
        }

        data.forEach(c => {
            var row = `
                <tr>
                    <td><span class="fw-bold text-primary">${c.classCode || 'N/A'}</span></td>
                    <td>${c.className || 'N/A'}</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="teacher-avatar">
                                ${c.teacherName ? c.teacherName.charAt(0).toUpperCase() : '?'}
                            </div>
                            <span>${c.teacherName || 'មិនមាន'}</span>
                        </div>
                    </td>
                    <td><span class="room-badge"><i class="bi bi-door-open me-1"></i>${c.room || 'N/A'}</span></td>
                    <td><span class="time-badge"><i class="bi bi-clock me-1"></i>${c.time || 'N/A'}</span></td>
                    <td><span class="badge bg-secondary">${c.studentCount || 0} នាក់</span></td>
                    <td class="text-end">
                        <div class="action-group">
                            <button class="btn-icon" onclick="openEditModal(${c.id})" title="កែប្រែ">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn-icon" onclick="deleteClass(${c.id}, '${c.className}')" title="លុប">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            `;
            tbody.append(row);
        });
    }

    function updateStats(data) {
        $('#totalClasses').text(data.length);

        var teachers = [...new Set(data.map(c => c.teacherName))].filter(t => t).length;
        $('#totalTeachers').text(teachers);

        var rooms = [...new Set(data.map(c => c.room))].filter(r => r).length;
        $('#totalRooms').text(rooms);

        var totalStudents = data.reduce((sum, c) => sum + (c.studentCount || 0), 0);
        $('#totalStudents').text(totalStudents);
    }

    // Search functionality
    $('#searchInput').on('keyup', function() {
        var searchText = $(this).val().toLowerCase();
        var filtered = classes.filter(c =>
            (c.className && c.className.toLowerCase().includes(searchText)) ||
            (c.classCode && c.classCode.toLowerCase().includes(searchText)) ||
            (c.teacherName && c.teacherName.toLowerCase().includes(searchText)) ||
            (c.room && c.room.toLowerCase().includes(searchText))
        );
        displayClasses(filtered);
    });

    // Modal functions
    function openCreateModal() {
        $('#modalTitleText').text('បន្ថែមថ្នាក់ថ្មី');
        $('#classId').val('0');
        $('#classCode').val('');
        $('#className').val('');
        $('#teacherName').val('');
        $('#room').val('');
        $('#time').val('');

        // Remove modal backdrop manually if any
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open');

        $('#classModal').modal('show');
    }

    function openEditModal(id) {
        var classObj = classes.find(c => c.id === id);
        if (classObj) {
            $('#modalTitleText').text('កែប្រែព័ត៌មានថ្នាក់');
            $('#classId').val(classObj.id);
            $('#classCode').val(classObj.classCode);
            $('#className').val(classObj.className);
            $('#teacherName').val(classObj.teacherName);
            $('#room').val(classObj.room);
            $('#time').val(classObj.time);

            // Remove modal backdrop manually if any
            $('.modal-backdrop').remove();
            $('body').removeClass('modal-open');

            $('#classModal').modal('show');
        }
    }

    function saveClass() {
        var id = $('#classId').val();
        var classData = {
            id: id == '0' ? 0 : parseInt(id),
            classCode: $('#classCode').val(),
            className: $('#className').val(),
            teacherName: $('#teacherName').val(),
            room: $('#room').val(),
            time: $('#time').val(),
            studentCount: 0
        };

        // Validate
        if (!classData.classCode) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលលេខកូដថ្នាក់',
                confirmButtonColor: '#8b5cf6'
            });
            return;
        }
        if (!classData.className) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលឈ្មោះថ្នាក់',
                confirmButtonColor: '#8b5cf6'
            });
            return;
        }
        if (!classData.teacherName) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលឈ្មោះគ្រូ',
                confirmButtonColor: '#8b5cf6'
            });
            return;
        }
        if (!classData.room) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលបន្ទប់',
                confirmButtonColor: '#8b5cf6'
            });
            return;
        }
        if (!classData.time) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមបញ្ចូលម៉ោងសិក្សា',
                confirmButtonColor: '#8b5cf6'
            });
            return;
        }

        // Check if token exists
        if (!token) {
            token = $('input[name="__RequestVerificationToken"]').val();
            if (!token) {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មិនអាចរកឃើញ AntiForgeryToken',
                    confirmButtonColor: '#8b5cf6'
                });
                return;
            }
        }

        // Show loading
        Swal.fire({
            title: 'កំពុងរក្សាទុក...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        var url = id == '0' ? '/Student/CreateClass' : '/Student/UpdateClass';

        $.ajax({
            url: url,
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(classData),
            headers: {
                'RequestVerificationToken': token
            },
            success: function(response) {
                if (response.success) {
                    // Close modal first
                    $('#classModal').modal('hide');

                    // Remove modal backdrop
                    $('.modal-backdrop').remove();
                    $('body').removeClass('modal-open');

                    // Show success message after modal is closed
                    setTimeout(function() {
                        Swal.fire({
                            icon: 'success',
                            title: 'ជោគជ័យ!',
                            text: response.message,
                            timer: 2000,
                            showConfirmButton: false
                        });
                    }, 300);

                    // Reload data
                    setTimeout(function() {
                        loadClasses();
                    }, 500);
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message,
                        confirmButtonColor: '#8b5cf6'
                    });
                }
            },
            error: function(xhr, status, error) {
                console.error('AJAX Error:', error);
                console.error('Status:', xhr.status);
                console.error('Response:', xhr.responseText);

                let errorMsg = 'មានបញ្ហាបច្ចេកទេស';
                try {
                    const response = JSON.parse(xhr.responseText);
                    if (response.message) {
                        errorMsg = response.message;
                    } else if (response.title) {
                        errorMsg = response.title;
                    }
                } catch(e) {
                    if (xhr.responseText) {
                        errorMsg = xhr.responseText;
                    }
                }

                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស (Status: ' + xhr.status + ')',
                    text: errorMsg,
                    confirmButtonColor: '#8b5cf6'
                });
            }
        });
    }

    function deleteClass(id, name) {
        Swal.fire({
            title: 'លុបថ្នាក់?',
            text: `តើអ្នកពិតជាចង់លុបថ្នាក់ "${name}" មែនទេ?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#64748b',
            confirmButtonText: 'បាទ/ចាស លុប',
            cancelButtonText: 'បោះបង់'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    url: '/Student/DeleteClass',
                    type: 'POST',
                    data: { id: id },
                    headers: {
                        'RequestVerificationToken': token
                    },
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'ជោគជ័យ!',
                                text: response.message,
                                timer: 2000,
                                showConfirmButton: false
                            });
                            loadClasses();
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'កំហុស',
                                text: response.message
                            });
                        }
                    },
                    error: function(xhr, status, error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'កំហុស',
                            text: 'មានបញ្ហាបច្ចេកទេស'
                        });
                    }
                });
            }
        });
    }

    // Clean up modal when hidden
    $('#classModal').on('hidden.bs.modal', function () {
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open');
    });
</script>