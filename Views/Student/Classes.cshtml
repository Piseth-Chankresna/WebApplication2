@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "គ្រប់គ្រងថ្នាក់";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

    .page-header h2 {
        font-weight: 800;
        color: #f97316;
        margin-bottom: 8px;
    }

    .page-header h2 i {
        background: linear-gradient(135deg, #f97316, #ea580c);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-bs-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #f97316, #ea580c);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 20px;
    }

    .stat-card .stat-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 8px;
    }

    [data-bs-theme="dark"] .stat-card .stat-value {
        color: white;
    }

    .stat-card .stat-label {
        font-size: 0.875rem;
        color: #64748b;
        font-weight: 500;
    }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .action-bar {
        background: #1e293b;
        border-color: #334155;
    }

    .search-wrapper {
        position: relative;
        flex: 1;
        max-width: 400px;
    }

    .search-wrapper i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
    }

    .search-wrapper input {
        padding-left: 45px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        height: 48px;
        width: 100%;
        transition: all 0.3s ease;
    }

    .search-wrapper input:focus {
        outline: none;
        border-color: #f97316;
        box-shadow: 0 0 0 4px rgba(249,115,22,0.1);
    }

    .btn-create {
        background: linear-gradient(135deg, #f97316, #ea580c);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(249,115,22,0.3);
    }

    .table-container {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .class-table {
        width: 100%;
        border-collapse: collapse;
    }

    .class-table th {
        background: #f8fafc;
        padding: 16px;
        text-align: left;
        font-weight: 600;
        color: #475569;
        border-bottom: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .class-table th {
        background: #334155;
        color: #e2e8f0;
        border-color: #475569;
    }

    .class-table td {
        padding: 16px;
        border-bottom: 1px solid #f1f5f9;
    }

    [data-bs-theme="dark"] .class-table td {
        border-color: #334155;
    }

    .class-table tr:hover {
        background: #f8fafc;
    }

    [data-bs-theme="dark"] .class-table tr:hover {
        background: #334155;
    }

    .teacher-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #f97316, #ea580c);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 14px;
    }

    .room-badge, .time-badge {
        background: #f1f5f9;
        color: #0ea5e9;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    [data-bs-theme="dark"] .room-badge, [data-bs-theme="dark"] .time-badge {
        background: #1e293b;
        color: #0ea5e9;
    }

    .action-group {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .btn-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-icon:hover {
        background: #f97316;
        color: white;
        border-color: #f97316;
    }

    [data-bs-theme="dark"] .btn-icon {
        background: #1e293b;
        border-color: #334155;
        color: #e2e8f0;
    }

    .form-control {
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        padding: 12px 16px;
        width: 100%;
        transition: all 0.3s ease;
        background: white;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .form-control {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .form-control:focus {
        outline: none;
        border-color: #8b5cf6;
        box-shadow: 0 0 0 4px rgba(139,92,246,0.1);
    }

    .btn-modal-primary {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-modal-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(139,92,246,0.3);
    }

    .btn-modal-secondary {
        background: #f1f5f9;
        color: #475569;
        padding: 12px 24px;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    [data-bs-theme="dark"] .btn-modal-secondary {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .action-bar {
            flex-direction: column;
            border-radius: 20px;
            padding: 16px;
        }

        .search-wrapper {
            width: 100%;
        }

        .btn-create {
            width: 100%;
        }
    }
</style>

<!-- AntiForgeryToken -->
<form id="antiForgeryForm" style="display: none;">
    @Html.AntiForgeryToken()
</form>

<div class="page-header">
    <h2><i class="bi bi-door-open-fill me-2"></i>គ្រប់គ្រងថ្នាក់</h2>
    <p class="text-muted">គ្រប់គ្រងថ្នាក់រៀន គ្រូបង្រៀន និងម៉ោងសិក្សា</p>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-door-open-fill stat-icon"></i>
        <div class="stat-value" id="totalClasses">0</div>
        <div class="stat-label">ថ្នាក់សរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-person-badge stat-icon"></i>
        <div class="stat-value" id="totalTeachers">0</div>
        <div class="stat-label">គ្រូបង្រៀន</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-people stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-building stat-icon"></i>
        <div class="stat-value" id="totalRooms">0</div>
        <div class="stat-label">បន្ទប់</div>
    </div>
</div>

<!-- Action Bar -->
<div class="action-bar">
    <div class="search-wrapper">
        <i class="bi bi-search"></i>
        <input type="text" id="searchInput" name="searchInput" placeholder="ស្វែងរកតាមឈ្មោះថ្នាក់ លេខកូដ ឬគ្រូ..." aria-label="ស្វែងរកថ្នាក់">
    </div>
    <button class="btn-create" onclick="openCreateModal()">
        <i class="bi bi-plus-lg"></i>
        <span>បន្ថែមថ្នាក់ថ្មី</span>
    </button>
</div>

<!-- Classes Table -->
<div class="table-container">
    <div class="table-responsive">
        <table class="class-table">
            <thead>
                <tr>
                    <th>លេខកូដ</th>
                    <th>ឈ្មោះថ្នាក់</th>
                    <th>គ្រូបង្រៀន</th>
                    <th>បន្ទប់</th>
                    <th>ម៉ោងសិក្សា</th>
                    <th>សិស្ស</th>
                    <th class="text-end">សកម្មភាព</th>
                </tr>
            </thead>
            <tbody id="classTableBody">
                <tr>
                    <td colspan="7" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Create/Edit Modal -->
<div class="modal fade" id="classModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">
                    <i class="bi bi-plus-circle me-2"></i>
                    <span id="modalTitleText">បន្ថែមថ្នាក់ថ្មី</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="this.blur()"></button>
            </div>
            <div class="modal-body">
                <form id="classForm">
                    <input type="hidden" id="classId" name="classId" value="0">

                    <div class="mb-3">
                        <label class="form-label" for="classCode">លេខកូដថ្នាក់ <span class="text-danger">*</span></label>
                        <input type="text" id="classCode" name="classCode" class="form-control" placeholder="ឧ. IT-101" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="className">ឈ្មោះថ្នាក់ <span class="text-danger">*</span></label>
                        <input type="text" id="className" name="className" class="form-control" placeholder="ឧ. កម្មវិធីកុំព្យូទ័រ" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="teacherName">ឈ្មោះគ្រូបង្រៀន <span class="text-danger">*</span></label>
                        <input type="text" id="teacherName" name="teacherName" class="form-control" placeholder="ឧ. លោក សុខ សុភ័ក្រ" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="room">បន្ទប់ <span class="text-danger">*</span></label>
                                <input type="text" id="room" name="room" class="form-control" placeholder="ឧ. A101" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" for="time">ម៉ោងសិក្សា <span class="text-danger">*</span></label>
                                <input type="text" id="time" name="time" class="form-control" placeholder="ឧ. ៧:០០-៩:០០" required>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-modal-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-2"></i>បោះបង់
                </button>
                <button type="button" class="btn-modal-primary" onclick="saveClass()">
                    <i class="bi bi-check-lg me-2"></i>រក្សាទុក
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // Use IIFE to avoid global scope pollution
    (function() {
        // Check if already initialized to prevent re-execution
        if (window.classesPageInitialized) {
            return;
        }
        window.classesPageInitialized = true;
        
        let classesData = [];
        let token = '';

        function initClassesPage() {
            token = $('input[name="__RequestVerificationToken"]').val();
            loadClasses();
        }

        function loadClasses() {
            $('#classTableBody').html(`
                <tr>
                    <td colspan="7" class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                    </td>
                </tr>
            `);

            $.ajax({
                url: '/Student/GetClasses',
                type: 'GET',
                cache: false,
                success: function(response) {
                    if (response && response.success) {
                        classesData = response.data || [];
                    } else if (Array.isArray(response)) {
                        classesData = response;
                    } else {
                        classesData = [];
                    }
                    displayClasses(classesData);
                    updateStats(classesData);
                },
                error: function(xhr, status, error) {
                    console.error('Error loading classes:', error);
                    $('#classTableBody').html(`
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 3rem;"></i>
                                <h5 class="mt-3 text-danger">មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ</h5>
                                <button class="btn btn-primary mt-3" onclick="loadClasses()">
                                    <i class="bi bi-arrow-clockwise me-2"></i>ព្យាយាម្តងទៀត
                                </button>
                            </td>
                        </tr>
                    `);
                }
            });
        }

        function displayClasses(data) {
            var tbody = $('#classTableBody');
            tbody.empty();

            if (!Array.isArray(data) || data.length === 0) {
                tbody.html(`
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <i class="bi bi-door-open" style="font-size: 4rem; color: #cbd5e1;"></i>
                            <h5 class="mt-3 text-muted">មិនទាន់មានទិន្នន័យថ្នាក់នៅឡើយទេ</h5>
                            <button class="btn btn-primary mt-3" onclick="openCreateModal()">
                                <i class="bi bi-plus-lg me-2"></i>បន្ថែមថ្នាក់ដំបូង
                            </button>
                        </td>
                    </tr>
                `);
                return;
            }

            data.forEach(cls => {
                var row = `
                    <tr>
                        <td><span class="fw-bold text-primary">${cls.classCode || 'N/A'}</span></td>
                        <td>${cls.className || 'N/A'}</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="teacher-avatar">
                                    ${cls.teacherName ? cls.teacherName.charAt(0).toUpperCase() : '?'}
                                </div>
                                <span>${cls.teacherName || 'មិនមាន'}</span>
                            </div>
                        </td>
                        <td><span class="room-badge"><i class="bi bi-door-open me-1"></i>${cls.room || 'N/A'}</span></td>
                        <td><span class="time-badge"><i class="bi bi-clock me-1"></i>${cls.time || 'N/A'}</span></td>
                        <td><span class="badge bg-secondary">${cls.studentCount || 0} នាក់</span></td>
                        <td class="text-end">
                            <div class="action-group">
                                <button class="btn-icon" onclick="openEditModal(${cls.id})" title="កែប្រែ">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn-icon" onclick="deleteClass(${cls.id}, '${cls.className}')" title="លុប">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
                tbody.append(row);
            });
        }

        function updateStats(data) {
            if (!Array.isArray(data)) data = [];

            $('#totalClasses').text(data.length);

            var teachers = [...new Set(data.map(c => c.teacherName))].filter(t => t).length;
            $('#totalTeachers').text(teachers);

            var rooms = [...new Set(data.map(c => c.room))].filter(r => r).length;
            $('#totalRooms').text(rooms);

            var totalStudents = data.reduce((sum, c) => sum + (c.studentCount || 0), 0);
            $('#totalStudents').text(totalStudents);
        }

        // Search functionality
        $('#searchInput').on('keyup', function() {
            var searchText = $(this).val().toLowerCase();

            if (!Array.isArray(classesData)) classesData = [];

            var filtered = classesData.filter(c =>
                (c.className && c.className.toLowerCase().includes(searchText)) ||
                (c.classCode && c.classCode.toLowerCase().includes(searchText)) ||
                (c.teacherName && c.teacherName.toLowerCase().includes(searchText)) ||
                (c.room && c.room.toLowerCase().includes(searchText))
            );
            displayClasses(filtered);
        });

        function openCreateModal() {
            $('#modalTitleText').text('បន្ថែមថ្នាក់ថ្មី');
            $('#classId').val('0');
            $('#classCode').val('');
            $('#className').val('');
            $('#teacherName').val('');
            $('#room').val('');
            $('#time').val('');
            $('#classModal').modal('show');
        }

        function openEditModal(id) {
            var classObj = classesData.find(c => c.id === id);
            if (classObj) {
                $('#modalTitleText').text('កែប្រែព័ត៌មានថ្នាក់');
                $('#classId').val(classObj.id);
                $('#classCode').val(classObj.classCode);
                $('#className').val(classObj.className);
                $('#teacherName').val(classObj.teacherName);
                $('#room').val(classObj.room);
                $('#time').val(classObj.time);
                $('#classModal').modal('show');
            }
        }

        function saveClass() {
            var id = $('#classId').val();
            var classData = {
                id: id == '0' ? 0 : parseInt(id),
                classCode: $('#classCode').val(),
                className: $('#className').val(),
                teacherName: $('#teacherName').val(),
                room: $('#room').val(),
                time: $('#time').val(),
                academicYear: '2025-2026', // Add required AcademicYear
                studentCount: 0
            };

            // Validate
            if (!classData.classCode) {
                Swal.fire({ icon: 'warning', title: 'សូមបញ្ចូលលេខកូដថ្នាក់' }); return;
            }
            if (!classData.className) {
                Swal.fire({ icon: 'warning', title: 'សូមបញ្ចូលឈ្មោះថ្នាក់' }); return;
            }
            if (!classData.teacherName) {
                Swal.fire({ icon: 'warning', title: 'សូមបញ្ចូលឈ្មោះគ្រូ' }); return;
            }
            if (!classData.room) {
                Swal.fire({ icon: 'warning', title: 'សូមបញ្ចូលបន្ទប់' }); return;
            }
            if (!classData.time) {
                Swal.fire({ icon: 'warning', title: 'សូមបញ្ចូលម៉ោងសិក្សា' }); return;
            }

            var url = id == '0' ? '/Student/CreateClass' : '/Student/UpdateClass';

            Swal.fire({ title: 'កំពុងរក្សាទុក...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

            $.ajax({
                url: url,
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(classData),
                success: function(response) {
                    if (response && response.success) {
                        $('#classModal').modal('hide');
                        Swal.fire({ icon: 'success', title: 'ជោគជ័យ!', text: response.message, timer: 2000, showConfirmButton: false });
                        loadClasses();
                    } else {
                        Swal.fire({ icon: 'error', title: 'កំហុស', text: response.message });
                    }
                },
                error: function(xhr, status, error) {
                    Swal.fire({ icon: 'error', title: 'កំហុស', text: 'មានបញ្ហាបច្ចេកទេស: ' + error });
                }
            });
        }

        function deleteClass(id, name) {
            Swal.fire({
                title: 'លុបថ្នាក់?',
                text: `តើអ្នកពិតជាចង់លុបថ្នាក់ "${name}" មែនទេ?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'បាទ/ចាស លុប',
                cancelButtonText: 'បោះបង់'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Student/DeleteClass',
                        type: 'POST',
                        data: { id: id },
                        headers: { 'RequestVerificationToken': token },
                        success: function(response) {
                            if (response && response.success) {
                                Swal.fire({ icon: 'success', title: 'ជោគជ័យ!', text: response.message, timer: 2000, showConfirmButton: false });
                                loadClasses();
                            } else {
                                Swal.fire({ icon: 'error', title: 'កំហុស', text: response.message });
                            }
                        },
                        error: function(xhr, status, error) {
                            Swal.fire({ icon: 'error', title: 'កំហុស', text: 'មានបញ្ហាបច្ចេកទេស' });
                        }
                    });
                }
            });
        }

        // Expose functions globally for onclick handlers
        window.openCreateModal = openCreateModal;
        window.openEditModal = openEditModal;
        window.saveClass = saveClass;
        window.deleteClass = deleteClass;

        // Initialize when document is ready
        $(document).ready(initClassesPage);
    })();
</script>