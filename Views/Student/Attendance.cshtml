@model IEnumerable<WebApplication2.Models.Attendance>
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "វត្តមាន";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #06b6d4, #0891b2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 8px;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        position: relative;
        overflow: hidden;
    }

    [data-bs-theme="dark"] .stat-card {
        background: #1e293b;
        border-color: #334155;
    }

    .stat-card .stat-icon {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 3rem;
        opacity: 0.1;
        color: #06b6d4;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 4px;
    }

    [data-bs-theme="dark"] .stat-value {
        color: white;
    }

    .stat-label {
        color: #64748b;
        font-size: 0.9rem;
    }

    .date-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 20px;
    }

    [data-bs-theme="dark"] .date-section {
        background: #1e293b;
        border-color: #334155;
    }

    .date-picker {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

        .date-picker label {
            font-weight: 600;
            color: #475569;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    [data-bs-theme="dark"] .date-picker label {
        color: #cbd5e1;
    }

    .date-picker input {
        padding: 10px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .date-picker input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .summary-cards {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .summary-badge {
        padding: 8px 20px;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .badge-present {
        background: #d1fae5;
        color: #10b981;
    }

    .badge-late {
        background: #fef3c7;
        color: #f59e0b;
    }

    .badge-absent {
        background: #fee2e2;
        color: #ef4444;
    }

    .filter-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .filter-section {
        background: #1e293b;
        border-color: #334155;
    }

    .filter-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .filter-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .filter-item label {
            font-weight: 600;
            color: #475569;
            font-size: 0.9rem;
        }

    [data-bs-theme="dark"] .filter-item label {
        color: #cbd5e1;
    }

    .filter-item select,
    .filter-item input {
        padding: 10px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        background: white;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .filter-item select,
    [data-bs-theme="dark"] .filter-item input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .btn-filter {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-filter:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(6,182,212,0.3);
        }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        padding: 12px 32px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        font-size: 1rem;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .btn-reset {
        background: #64748b;
        color: white;
        padding: 10px 24px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
    }

        .btn-reset:hover {
            background: #475569;
            transform: translateY(-2px);
        }

    .btn-excel {
        background: #10b981;
        color: white;
        padding: 12px 28px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-excel:hover {
            background: #059669;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .table-container {
        background: white;
        border-radius: 24px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
        overflow-x: auto;
    }

    [data-bs-theme="dark"] .table-container {
        background: #1e293b;
        border-color: #334155;
    }

    .attendance-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 1000px;
    }

        .attendance-table th {
            padding: 16px;
            text-align: left;
            color: #64748b;
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid #e2e8f0;
            background: #f8fafc;
        }

    [data-bs-theme="dark"] .attendance-table th {
        background: #0f172a;
        color: #cbd5e1;
        border-bottom-color: #334155;
    }

    .attendance-table td {
        padding: 16px;
        border-bottom: 1px solid #e2e8f0;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .attendance-table td {
        color: white;
        border-bottom-color: #334155;
    }

    .attendance-table tbody tr:hover {
        background: #f8fafc;
    }

    [data-bs-theme="dark"] .attendance-table tbody tr:hover {
        background: #0f172a;
    }

    .student-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .student-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1rem;
        overflow: hidden;
    }

        .student-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .attendance-radio-group {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .radio-option {
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
    }

        .radio-option input[type="radio"] {
            display: none;
        }

    .radio-label {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .radio-option input[type="radio"]:checked + .radio-label.present {
        background: #10b981;
        color: white;
    }

    .radio-option input[type="radio"]:checked + .radio-label.late {
        background: #f59e0b;
        color: white;
    }

    .radio-option input[type="radio"]:checked + .radio-label.absent {
        background: #ef4444;
        color: white;
    }

    .radio-label.present {
        background: #d1fae5;
        color: #10b981;
        border: 1px solid #10b981;
    }

    .radio-label.late {
        background: #fef3c7;
        color: #f59e0b;
        border: 1px solid #f59e0b;
    }

    .radio-label.absent {
        background: #fee2e2;
        color: #ef4444;
        border: 1px solid #ef4444;
    }

    .note-input {
        width: 150px;
        padding: 8px 12px;
        border: 2px solid #e2e8f0;
        border-radius: 8px;
        background: white;
        color: #1e293b;
        font-size: 0.85rem;
    }

    [data-bs-theme="dark"] .note-input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .note-input:focus {
        outline: none;
        border-color: #06b6d4;
        box-shadow: 0 0 0 3px rgba(6,182,212,0.1);
    }

    .history-section {
        margin-top: 40px;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
        font-weight: 700;
        color: #1e293b;
    }

    [data-bs-theme="dark"] .section-title {
        color: white;
    }

    .section-title i {
        color: #06b6d4;
        font-size: 1.5rem;
    }

    .history-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    .history-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        border: 1px solid #e2e8f0;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    [data-bs-theme="dark"] .history-card {
        background: #1e293b;
        border-color: #334155;
    }

    .history-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(6,182,212,0.1);
        border-color: #06b6d4;
    }

    .history-date {
        font-size: 1.1rem;
        font-weight: 700;
        color: #06b6d4;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .history-stats {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
    }

    .history-stat {
        text-align: center;
        flex: 1;
    }

        .history-stat .count {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .history-stat .label {
            font-size: 0.8rem;
            color: #64748b;
        }

    .btn-view {
        width: 100%;
        padding: 10px;
        background: #f1f5f9;
        border: none;
        border-radius: 12px;
        color: #475569;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    [data-bs-theme="dark"] .btn-view {
        background: #0f172a;
        color: #cbd5e1;
    }

    .btn-view:hover {
        background: #06b6d4;
        color: white;
    }

    /* Loading animation */
    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .spinner-border {
        display: inline-block;
        width: 2rem;
        height: 2rem;
        border: 0.25em solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spin 0.75s linear infinite;
    }

    .qr-section {
        background: white;
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 30px;
        border: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        gap: 30px;
        flex-wrap: wrap;
    }

    [data-bs-theme="dark"] .qr-section {
        background: #1e293b;
        border-color: #334155;
    }

    .qr-code {
        width: 150px;
        height: 150px;
        background: #f1f5f9;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .qr-code img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .qr-info h4 {
        font-weight: 700;
        margin-bottom: 10px;
    }

    .qr-info p {
        color: #64748b;
        margin-bottom: 15px;
    }

    @@media (max-width: 1024px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .filter-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .filter-grid {
            grid-template-columns: 1fr;
        }

        .date-section {
            flex-direction: column;
            align-items: flex-start;
        }

        .action-bar {
            flex-direction: column;
            align-items: stretch;
        }

        .btn-save {
            width: 100%;
            justify-content: center;
        }

        .qr-section {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-calendar-check-fill me-2"></i>វត្តមានប្រចាំថ្ងៃ</h2>
    <p class="text-muted">បំពេញ និងគ្រប់គ្រងវត្តមានសិស្ស</p>
</div>

<!-- QR Code Section for Quick Check-in -->
<div class="qr-section">
    <div class="qr-code">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=Attendance-@DateTime.Now.ToString("yyyyMMdd")" alt="QR Code">
    </div>
    <div class="qr-info">
        <h4>ស្កេន QR Code ដើម្បី Check-in រហ័ស</h4>
        <p>សិស្សអាចស្កេន QR Code នេះដើម្បីកត់ត្រាវត្តមានដោយខ្លួនឯង</p>
        <button class="btn btn-sm btn-outline-primary" onclick="generateNewQR()">
            <i class="bi bi-arrow-clockwise me-2"></i>បង្កើត QR Code ថ្មី
        </button>
    </div>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <i class="bi bi-people-fill stat-icon"></i>
        <div class="stat-value" id="totalStudents">0</div>
        <div class="stat-label">សិស្សសរុប</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-check-circle-fill stat-icon"></i>
        <div class="stat-value" id="presentCount">0</div>
        <div class="stat-label">វត្តមាន</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-clock-fill stat-icon"></i>
        <div class="stat-value" id="lateCount">0</div>
        <div class="stat-label">មកយឺត</div>
    </div>
    <div class="stat-card">
        <i class="bi bi-x-circle-fill stat-icon"></i>
        <div class="stat-value" id="absentCount">0</div>
        <div class="stat-label">អវត្តមាន</div>
    </div>
</div>

<!-- Date Selection -->
<div class="date-section">
    <div class="date-picker">
        <label>
            <i class="bi bi-calendar3"></i>
            ជ្រើសរើសកាលបរិច្ឆេទ:
        </label>
        <input type="date" id="attendanceDate" value="@DateTime.Now.ToString("yyyy-MM-dd")">
    </div>
    <div class="summary-cards">
        <span class="summary-badge badge-present" id="summaryPresent">
            <i class="bi bi-check-circle-fill"></i>
            វត្តមាន: 0
        </span>
        <span class="summary-badge badge-late" id="summaryLate">
            <i class="bi bi-clock-fill"></i>
            មកយឺត: 0
        </span>
        <span class="summary-badge badge-absent" id="summaryAbsent">
            <i class="bi bi-x-circle-fill"></i>
            អវត្តមាន: 0
        </span>
    </div>
</div>

<!-- Filter Section -->
<div class="filter-section">
    <div class="filter-grid">
        <div class="filter-item">
            <label>ជំនាញ</label>
            <select id="filterMajor">
                <option value="">ទាំងអស់</option>
                <option value="Information Technology">Information Technology</option>
                <option value="Business Administration">Business Administration</option>
                <option value="English Literature">English Literature</option>
                <option value="Law">Law</option>
                <option value="Accounting">Accounting</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ឆ្នាំសិក្សា</label>
            <select id="filterYear">
                <option value="">ទាំងអស់</option>
                <option value="1">ឆ្នាំទី១</option>
                <option value="2">ឆ្នាំទី២</option>
                <option value="3">ឆ្នាំទី៣</option>
                <option value="4">ឆ្នាំទី៤</option>
            </select>
        </div>

        <div class="filter-item">
            <label>វេនសិក្សា</label>
            <select id="filterShift">
                <option value="">ទាំងអស់</option>
                <option value="ព្រឹក">ព្រឹក</option>
                <option value="រសៀល">រសៀល</option>
                <option value="យប់">យប់</option>
            </select>
        </div>

        <div class="filter-item">
            <label>ស្វែងរក</label>
            <input type="text" id="searchInput" placeholder="ឈ្មោះ ឬលេខសម្គាល់...">
        </div>
    </div>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        <button class="btn-filter" onclick="applyFilter()">
            <i class="bi bi-search"></i>
            អនុវត្តតម្រង
        </button>
        <button class="btn-reset" onclick="resetFilter()">
            <i class="bi bi-arrow-counterclockwise"></i>
            កំណត់ឡើងវិញ
        </button>
    </div>
</div>

<!-- Action Buttons -->
<div class="action-bar">
    <div class="d-flex gap-2 flex-wrap">
        <button class="btn-save" onclick="saveAttendance()">
            <i class="bi bi-save"></i>
            រក្សាទុកវត្តមាន
        </button>
        <button class="btn-save" onclick="markAllPresent()" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-check-all"></i>
            វត្តមានទាំងអស់
        </button>
        <button class="btn-excel" onclick="exportAttendance()">
            <i class="bi bi-file-earmark-excel"></i>
            នាំចេញ Excel
        </button>
    </div>
</div>

<!-- Attendance Table -->
<div class="table-container">
    <table class="attendance-table">
        <thead>
            <tr>
                <th>សិស្ស</th>
                <th>ជំនាញ</th>
                <th>ឆ្នាំ</th>
                <th>វេន</th>
                <th>ស្ថានភាពវត្តមាន</th>
                <th>កំណត់ចំណាំ</th>
            </tr>
        </thead>
        <tbody id="attendanceTableBody">
            <tr>
                <td colspan="6" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="mt-2">កំពុងផ្ទុកទិន្នន័យ...</p>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<!-- Monthly Attendance Chart -->
<div class="chart-card mt-4">
    <h5 class="mb-3"><i class="bi bi-bar-chart-line me-2"></i>ស្ថិតិវត្តមានប្រចាំខែ</h5>
    <canvas id="monthlyChart" style="height: 300px;"></canvas>
</div>

<!-- Attendance History -->
<div class="history-section">
    <div class="section-title">
        <i class="bi bi-clock-history"></i>
        <span>ប្រវត្តិវត្តមានថ្មីៗ</span>
    </div>

    <div class="history-grid" id="historyGrid">
        <!-- History will be loaded by JavaScript -->
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    let attendanceStudentsData = [];
    let attendanceRecords = [];
    let currentAttendance = {};
    let monthlyChart = null;

    $(document).ready(function() {
        loadStudents();
        loadAttendanceHistory();
        loadMonthlyStats();
        $('#attendanceDate').val(new Date().toISOString().split('T')[0]);
    });

    function loadStudents() {
        $.ajax({
            url: '/Student/GetStudents',
            type: 'GET',
            cache: true,
            success: function(data) {
                attendanceStudentsData = data;
                displayAttendance();
            },
            error: function(xhr, status, error) {
                console.error("Error loading students:", error);
                showError("មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យសិស្ស");
            }
        });
    }

    function loadAttendanceHistory() {
        $.ajax({
            url: '/Student/GetAttendance',
            type: 'GET',
            cache: true,
            success: function(data) {
                attendanceRecords = data;
                displayHistory();
            },
            error: function(xhr, status, error) {
                console.error("Error loading attendance history:", error);
            }
        });
    }

    function loadMonthlyStats() {
        $.ajax({
            url: '/Student/GetAttendanceStats',
            type: 'GET',
            success: function(data) {
                updateMonthlyChart(data);
            }
        });
    }

    function displayAttendance() {
        var tbody = $('#attendanceTableBody');
        tbody.empty();

        if (attendanceStudentsData.length === 0) {
            tbody.html(`
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="bi bi-people" style="font-size: 4rem; color: #cbd5e1;"></i>
                        <h5 class="mt-3 text-muted">មិនទាន់មានទិន្នន័យសិស្សនៅឡើយទេ</h5>
                    </td>
                </tr>
            `);
            return;
        }

        var major = $('#filterMajor').val();
        var year = $('#filterYear').val();
        var shift = $('#filterShift').val();
        var search = $('#searchInput').val().toLowerCase();

        var filteredStudents = attendanceStudentsData.filter(s => {
            var matchMajor = !major || s.major === major;
            var matchYear = !year || s.year === year;
            var matchShift = !shift || s.shift === shift;
            var matchSearch = !search ||
                (s.name && s.name.toLowerCase().includes(search)) ||
                (s.id && s.id.toLowerCase().includes(search));

            return matchMajor && matchYear && matchShift && matchSearch;
        });

        $('#totalStudents').text(filteredStudents.length);

        filteredStudents.forEach(s => {
            var status = currentAttendance[s.id] || 'P';

            // Create avatar HTML
            var avatarHtml = '';
            if (s.photo) {
                avatarHtml = `<img src="${s.photo}" alt="${s.name}">`;
            } else {
                avatarHtml = s.name ? s.name.charAt(0).toUpperCase() : '?';
            }

            var row = `
                <tr>
                    <td>
                        <div class="student-info">
                            <div class="student-avatar">
                                ${avatarHtml}
                            </div>
                            <div>
                                <div class="fw-bold">${s.name || 'មិនមានឈ្មោះ'}</div>
                                <small class="text-muted">${s.id}</small>
                            </div>
                        </div>
                    </td>
                    <td>${s.major || 'N/A'}</td>
                    <td>ឆ្នាំទី${s.year || '?'}</td>
                    <td>${s.shift || 'N/A'}</td>
                    <td>
                        <div class="attendance-radio-group">
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="P" ${status === 'P' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label present">វត្តមាន</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="L" ${status === 'L' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label late">មកយឺត</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="att_${s.id}" value="A" ${status === 'A' ? 'checked' : ''} onchange="updateAttendance('${s.id}', this.value)">
                                <span class="radio-label absent">អវត្តមាន</span>
                            </label>
                        </div>
                    </td>
                    <td>
                        <input type="text" class="note-input" id="note_${s.id}" placeholder="កំណត់ចំណាំ..." value="${currentAttendance[`note_${s.id}`] || ''}">
                    </td>
                </tr>
            `;
            tbody.append(row);
        });

        updateCounts();
    }

    function updateAttendance(studentId, status) {
        currentAttendance[studentId] = status;
        updateCounts();
    }

    function updateCounts() {
        var present = 0, late = 0, absent = 0;

        $('input[type="radio"]:checked').each(function() {
            var value = $(this).val();
            if (value === 'P') present++;
            else if (value === 'L') late++;
            else if (value === 'A') absent++;
        });

        $('#presentCount').text(present);
        $('#lateCount').text(late);
        $('#absentCount').text(absent);

        $('#summaryPresent').html(`<i class="bi bi-check-circle-fill"></i> វត្តមាន: ${present}`);
        $('#summaryLate').html(`<i class="bi bi-clock-fill"></i> មកយឺត: ${late}`);
        $('#summaryAbsent').html(`<i class="bi bi-x-circle-fill"></i> អវត្តមាន: ${absent}`);
    }

    function saveAttendance() {
        var date = $('#attendanceDate').val();
        var attendanceData = [];

        $('input[type="radio"]:checked').each(function() {
            var name = $(this).attr('name');
            var studentId = name.replace('att_', '');
            var status = $(this).val();
            var note = $(`#note_${studentId}`).val();

            attendanceData.push({
                studentId: studentId,
                studentName: $(this).closest('tr').find('.fw-bold').text(),
                date: date,
                status: status,
                note: note
            });
        });

        // Show loading
        Swal.fire({
            title: 'កំពុងរក្សាទុក...',
            allowOutsideClick: false,
            didOpen: () => {
                Swal.showLoading();
            }
        });

        $.ajax({
            url: '/Student/SaveAttendance',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(attendanceData),
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    });
                    loadAttendanceHistory();
                    loadMonthlyStats();
                    currentAttendance = {};
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message
                    });
                }
            },
            error: function(xhr, status, error) {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាបច្ចេកទេស: ' + error
                });
            }
        });
    }

    function markAllPresent() {
        $('input[type="radio"][value="P"]').prop('checked', true);
        updateCounts();
    }

    function displayHistory() {
        var grid = $('#historyGrid');
        grid.empty();

        // Group attendance by date
        var grouped = {};
        attendanceRecords.forEach(record => {
            if (!grouped[record.date]) {
                grouped[record.date] = {
                    date: record.date,
                    present: 0,
                    late: 0,
                    absent: 0,
                    total: 0
                };
            }
            if (record.status === 'P') grouped[record.date].present++;
            else if (record.status === 'L') grouped[record.date].late++;
            else if (record.status === 'A') grouped[record.date].absent++;
            grouped[record.date].total++;
        });

        // Sort by date (newest first)
        var sorted = Object.values(grouped).sort((a, b) => new Date(b.date) - new Date(a.date)).slice(0, 6);

        if (sorted.length === 0) {
            grid.html(`
                <div class="text-center py-4" style="grid-column: 1/-1;">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <p class="mt-2 text-muted">មិនទាន់មានប្រវត្តិវត្តមាននៅឡើយទេ</p>
                </div>
            `);
            return;
        }

        sorted.forEach(day => {
            var formattedDate = new Date(day.date).toLocaleDateString('km-KH', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });

            var card = `
                <div class="history-card" onclick="viewHistoryDetails('${day.date}')">
                    <div class="history-date">
                        <span><i class="bi bi-calendar3 me-2"></i>${formattedDate}</span>
                        <span class="badge bg-secondary">${day.total} នាក់</span>
                    </div>
                    <div class="history-stats">
                        <div class="history-stat">
                            <div class="count text-success">${day.present}</div>
                            <div class="label">វត្តមាន</div>
                        </div>
                        <div class="history-stat">
                            <div class="count text-warning">${day.late}</div>
                            <div class="label">មកយឺត</div>
                        </div>
                        <div class="history-stat">
                            <div class="count text-danger">${day.absent}</div>
                            <div class="label">អវត្តមាន</div>
                        </div>
                    </div>
                    <button class="btn-view">
                        <i class="bi bi-eye me-2"></i>មើលលម្អិត
                    </button>
                </div>
            `;
            grid.append(card);
        });
    }

    function viewHistoryDetails(date) {
        var dayRecords = attendanceRecords.filter(r => r.date === date);

        var html = '<div style="max-height: 400px; overflow-y: auto;">';
        dayRecords.forEach(r => {
            var statusColor = r.status === 'P' ? 'success' : r.status === 'L' ? 'warning' : 'danger';
            var statusText = r.status === 'P' ? 'វត្តមាន' : r.status === 'L' ? 'មកយឺត' : 'អវត្តមាន';
            var statusIcon = r.status === 'P' ? 'bi-check-circle-fill' : r.status === 'L' ? 'bi-clock-fill' : 'bi-x-circle-fill';

            html += `
                <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
                    <div>
                        <strong>${r.studentName}</strong>
                        <div class="small text-muted">
                            <i class="bi bi-chat-dots me-1"></i>${r.note || 'គ្មានកំណត់ចំណាំ'}
                        </div>
                    </div>
                    <span class="badge bg-${statusColor} p-2">
                        <i class="bi ${statusIcon} me-1"></i>${statusText}
                    </span>
                </div>
            `;
        });
        html += '</div>';

        var formattedDate = new Date(date).toLocaleDateString('km-KH', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
        });

        Swal.fire({
            title: `វត្តមានប្រចាំថ្ងៃទី ${formattedDate}`,
            html: html,
            width: 600,
            confirmButtonColor: '#06b6d4',
            confirmButtonText: 'បិទ'
        });
    }

    function updateMonthlyChart(data) {
        var ctx = document.getElementById('monthlyChart').getContext('2d');

        if (monthlyChart) {
            monthlyChart.destroy();
        }

        monthlyChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: data.map(d => {
                    var date = new Date(d.date);
                    return date.toLocaleDateString('km-KH', { day: 'numeric', month: 'short' });
                }),
                datasets: [{
                    label: 'វត្តមាន',
                    data: data.map(d => d.present),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16,185,129,0.1)',
                    tension: 0.4,
                    fill: true
                }, {
                    label: 'មកយឺត',
                    data: data.map(d => d.late),
                    borderColor: '#f59e0b',
                    backgroundColor: 'rgba(245,158,11,0.1)',
                    tension: 0.4,
                    fill: true
                }, {
                    label: 'អវត្តមាន',
                    data: data.map(d => d.absent),
                    borderColor: '#ef4444',
                    backgroundColor: 'rgba(239,68,68,0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });
    }

    function generateNewQR() {
        var newDate = new Date().toISOString().split('T')[0];
        var qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=Attendance-${newDate}`;
        $('.qr-code img').attr('src', qrUrl);

        Swal.fire({
            icon: 'success',
            title: 'បង្កើត QR Code ថ្មីរួចរាល់',
            text: `QR Code សម្រាប់ថ្ងៃទី ${newDate}`,
            timer: 2000
        });
    }

    function exportAttendance() {
        var startDate = $('#attendanceDate').val();
        var endDate = startDate;

        window.location.href = `/Student/ExportAttendance?startDate=${startDate}&endDate=${endDate}`;
    }

    function applyFilter() {
        displayAttendance();
    }

    function resetFilter() {
        $('#filterMajor').val('');
        $('#filterYear').val('');
        $('#filterShift').val('');
        $('#searchInput').val('');
        displayAttendance();
    }

    function showError(message) {
        Swal.fire({
            icon: 'error',
            title: 'កំហុស',
            text: message
        });
    }
</script>