@model WebApplication2.Models.UserAccount
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "ប្រវត្តិរូប";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .profile-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .profile-card {
        background: #1e293b;
        border-color: #334155;
    }

    .profile-avatar {
        width: 150px;
        height: 150px;
        margin: 0 auto 30px;
        position: relative;
    }

        .profile-avatar img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid white;
            box-shadow: 0 10px 30px rgba(67,97,238,0.3);
        }

    .avatar-upload {
        position: absolute;
        bottom: 10px;
        right: 10px;
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        cursor: pointer;
        border: 3px solid white;
        transition: all 0.3s ease;
    }

        .avatar-upload:hover {
            transform: scale(1.1);
        }

    .profile-info {
        text-align: center;
        margin-bottom: 30px;
    }

        .profile-info h3 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 5px;
        }

    [data-bs-theme="dark"] .profile-info h3 {
        color: white;
    }

    .profile-info .badge {
        background: #e0e7ff;
        color: #4361ee;
        padding: 8px 20px;
        border-radius: 30px;
        font-weight: 600;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-top: 30px;
    }

    .info-item {
        background: #f8fafc;
        padding: 20px;
        border-radius: 20px;
        border: 1px solid #e2e8f0;
    }

    [data-bs-theme="dark"] .info-item {
        background: #0f172a;
        border-color: #334155;
    }

    .info-item .label {
        color: #64748b;
        font-size: 0.85rem;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .info-item .value {
        font-weight: 700;
        color: #1e293b;
        font-size: 1.1rem;
    }

    [data-bs-theme="dark"] .info-item .value {
        color: white;
    }

    .edit-form {
        margin-top: 40px;
        padding-top: 40px;
        border-top: 2px dashed #e2e8f0;
    }

    [data-bs-theme="dark"] .edit-form {
        border-top-color: #334155;
    }

    .edit-form h5 {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 20px;
    }

    [data-bs-theme="dark"] .edit-form h5 {
        color: white;
    }

    .form-label {
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-bs-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        background: white;
        color: #1e293b;
        transition: all 0.3s ease;
    }

    [data-bs-theme="dark"] .form-control {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .form-control:focus {
        outline: none;
        border-color: #4361ee;
        box-shadow: 0 0 0 4px #e0e7ff;
    }

    .btn-save {
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
        color: white;
        padding: 12px 40px;
        border: none;
        border-radius: 40px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(67,97,238,0.3);
        }

    .btn-cancel {
        background: #f1f5f9;
        color: #475569;
        padding: 12px 40px;
        border: 1px solid #e2e8f0;
        border-radius: 40px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
    }

    [data-bs-theme="dark"] .btn-cancel {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-cancel:hover {
        background: #e2e8f0;
    }
</style>

<div class="profile-container">
    <div class="profile-card">
        <!-- Profile Avatar -->
        <div class="profile-avatar">
            <img src="@(Model.ProfileImage ?? $"https://ui-avatars.com/api/?name={Model.FullName}&background=4361ee&color=fff&size=150")"
                 alt="Profile" id="profileImage">
            <label for="avatarInput" class="avatar-upload">
                <i class="bi bi-camera-fill"></i>
            </label>
            <input type="file" id="avatarInput" accept="image/*" style="display: none;">
        </div>

        <!-- Profile Info -->
        <div class="profile-info">
            <h3>@Model.FullName</h3>
            <span class="badge"><i class="bi bi-shield me-1"></i>@Model.Role</span>
        </div>

        <!-- Info Grid -->
        <div class="info-grid">
            <div class="info-item">
                <div class="label"><i class="bi bi-envelope"></i> អ៊ីមែល</div>
                <div class="value">@Model.Email</div>
            </div>
            <div class="info-item">
                <div class="label"><i class="bi bi-calendar"></i> ថ្ងៃចូលរួម</div>
                <div class="value">@Model.CreatedAt.ToString("dd MMMM yyyy")</div>
            </div>
            <div class="info-item">
                <div class="label"><i class="bi bi-shield-check"></i> ស្ថានភាព</div>
                <div class="value">
                    @if (Model.IsActive)
                    {
                        <span class="text-success">សកម្ម</span>
                    }
                    else
                    {
                        <span class="text-danger">អសកម្ម</span>
                    }
                </div>
            </div>
            <div class="info-item">
                <div class="label"><i class="bi bi-key"></i> លេខសម្ងាត់</div>
                <div class="value">
                    <button class="btn btn-sm btn-outline-primary" onclick="changePassword()">
                        <i class="bi bi-pencil"></i> ប្តូរលេខសម្ងាត់
                    </button>
                </div>
            </div>
        </div>

        <!-- Edit Form -->
        <div class="edit-form">
            <h5><i class="bi bi-pencil-square me-2"></i>កែប្រែព័ត៌មាន</h5>

            <form id="profileForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">ឈ្មោះពេញ</label>
                        <input type="text" name="FullName" class="form-control" value="@Model.FullName" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">អ៊ីមែល</label>
                        <input type="email" name="Email" class="form-control" value="@Model.Email" required>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-3">
                    <a href="/User/Index" class="btn-cancel">បោះបង់</a>
                    <button type="submit" class="btn-save">
                        <i class="bi bi-check-lg me-2"></i>រក្សាទុក
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Upload Avatar
    $('#avatarInput').change(function(e) {
        var file = e.target.files[0];
        if (file) {
            var reader = new FileReader();
            reader.onload = function(e) {
                $('#profileImage').attr('src', e.target.result);

                // Upload to server
                var formData = new FormData();
                formData.append('Id', '@Model.Id');
                formData.append('ProfileImage', file);

                $.ajax({
                    url: '/User/UpdateCurrentUserProfile',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'ជោគជ័យ!',
                                text: response.message,
                                timer: 2000,
                                showConfirmButton: false
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'កំហុស',
                                text: response.message
                            });
                        }
                    }
                });
            };
            reader.readAsDataURL(file);
        }
    });

    // Update Profile
    $('#profileForm').submit(function(e) {
        e.preventDefault();

        var formData = $(this).serialize();
        console.log('Form data being sent:', formData);

        $.ajax({
            url: '/User/UpdateCurrentUserProfile',
            type: 'POST',
            data: formData,
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
                console.log('Server response:', response);
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        location.reload();
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message
                    });
                }
            },
            error: function(xhr, status, error) {
                console.log('AJAX Error:', xhr.responseText);
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាក្នុងការទំនាក់ទំនង: ' + error
                });
            }
        });
    });

    function changePassword() {
        window.location.href = '/User/ResetPassword';
    }
</script>