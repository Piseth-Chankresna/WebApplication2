@model IEnumerable<WebApplication2.Models.UserAccount>
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "User Management";
}

<style>
    /* Your original working styles */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    .stat-card {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        padding: 25px;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
    }

    .search-bar {
        background: var(--card-bg);
        border-radius: 50px;
        padding: 8px 20px;
        margin-bottom: 25px;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
    }

        .search-bar input {
            border: none;
            background: transparent;
            padding: 12px;
            width: 100%;
            outline: none;
            color: var(--text-main);
        }

    .user-table {
        width: 100%;
        border-collapse: collapse;
    }

        .user-table th {
            text-align: left;
            padding: 15px;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.85rem;
            border-bottom: 2px solid var(--border-color);
        }

        .user-table td {
            padding: 15px;
            border-bottom: 1px solid var(--border-color);
        }

    .user-info {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .user-avatar {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
    }

    .role-badge {
        background: rgba(102, 126, 234, 0.1);
        color: #667eea;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .status-active {
        color: #10b981;
        background: rgba(16, 185, 129, 0.1);
        padding: 5px 12px;
        border-radius: 20px;
    }

    .status-inactive {
        color: #ef4444;
        background: rgba(239, 68, 68, 0.1);
        padding: 5px 12px;
        border-radius: 20px;
    }

    .btn-group {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        width: 35px;
        height: 35px;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        background: transparent;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

        .btn-icon:hover {
            background: #667eea;
            border-color: #667eea;
            color: white;
        }

    .btn-create {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        padding: 12px 25px;
        border-radius: 50px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
</style>

<!-- Stats Cards -->
<div class="stats-grid">
    <div class="stat-card">
        <h3 class="fw-bold mb-2">@Model.Count()</h3>
        <p class="mb-0 opacity-75">អ្នកប្រើប្រាស់សរុប</p>
    </div>
    <div class="stat-card" style="background: linear-gradient(135deg, #06b6d4, #0891b2);">
        <h3 class="fw-bold mb-2">@Model.Count(u => u.IsActive)</h3>
        <p class="mb-0 opacity-75">សកម្ម</p>
    </div>
    <div class="stat-card" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
        <h3 class="fw-bold mb-2">@Model.Count(u => !u.IsActive)</h3>
        <p class="mb-0 opacity-75">អសកម្ម</p>
    </div>
</div>

<!-- Search and Create -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="search-bar flex-grow-1 me-3">
        <i class="bi bi-search me-2" style="color: var(--text-muted);"></i>
        <input type="text" id="searchInput" placeholder="ស្វែងរកអ្នកប្រើប្រាស់...">
    </div>
    <a href="/User/Create" class="btn-create ajax-link" data-url="/User/Create">
        <i class="bi bi-plus-circle"></i> បង្កើតថ្មី
    </a>
</div>

<!-- User Table -->
<div class="table-responsive">
    <table class="user-table">
        <thead>
            <tr>
                <th>អ្នកប្រើប្រាស់</th>
                <th>តួនាទី</th>
                <th>ស្ថានភាព</th>
                <th>ថ្ងៃបង្កើត</th>
                <th>សកម្មភាព</th>
            </tr>
        </thead>
        <tbody id="userTableBody">
            @foreach (var user in Model)
            {
                <tr id="row-@user.Id">
                    <td>
                        <div class="user-info">
                            <div class="user-avatar">@(user.FullName?.Substring(0, 1))</div>
                            <div>
                                <div class="fw-bold">@user.FullName</div>
                                <small class="text-muted">@user.Email</small>
                            </div>
                        </div>
                    </td>
                    <td><span class="role-badge">@user.Role</span></td>
                    <td>
                        <span class="@(user.IsActive ? "status-active" : "status-inactive")">
                            @(user.IsActive ? "សកម្ម" : "អសកម្ម")
                        </span>
                    </td>
                    <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="btn-group">
                            <a href="/User/Edit/@user.Id" class="btn-icon ajax-link" data-url="/User/Edit/@user.Id" title="កែប្រែ">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a href="/User/ResetPassword/@user.Id" class="btn-icon ajax-link" data-url="/User/ResetPassword/@user.Id" title="ប្តូរលេខសម្ងាត់">
                                <i class="bi bi-key"></i>
                            </a>
                            <button class="btn-icon" onclick="deleteUser(@user.Id, '@user.FullName')" title="លុប">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    // Search
    $('#searchInput').on('keyup', function() {
        var value = $(this).val().toLowerCase();
        $('#userTableBody tr').filter(function() {
            $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
        });
    });

    // Delete
    function deleteUser(id, name) {
        Swal.fire({
            title: 'លុបអ្នកប្រើប្រាស់?',
            text: `លុប ${name} មែនទេ?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'លុប',
            cancelButtonText: 'បោះបង់'
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('/User/Delete/' + id, function(res) {
                    if (res.success) {
                        $('#row-' + id).remove();
                        Swal.fire('ជោគជ័យ', res.message, 'success');
                    }
                });
            }
        });
    }
</script>