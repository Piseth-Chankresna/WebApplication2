@model WebApplication2.Models.UserAccount
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Edit User";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #4361ee, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }

    .edit-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .edit-card {
        background: white;
        border-radius: 24px;
        padding: 32px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .edit-card {
        background: #1e293b;
        border-color: #334155;
    }

    .user-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: white;
        font-size: 32px;
        font-weight: 700;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-label i {
        margin-right: 8px;
        color: #4361ee;
    }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
        }

        .input-wrapper input,
        .input-wrapper select {
            width: 100%;
            padding: 14px 16px 14px 48px;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            background: white;
            color: #1e293b;
            font-size: 0.95rem;
        }

    [data-theme="dark"] .input-wrapper input,
    [data-theme="dark"] .input-wrapper select {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .input-wrapper input:focus,
    .input-wrapper select:focus {
        outline: none;
        border-color: #4361ee;
        box-shadow: 0 0 0 4px #e0e7ff;
    }

    .switch-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        background: #f1f5f9;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .switch-wrapper {
        background: #0f172a;
        border-color: #334155;
    }

    .switch-wrapper span {
        font-weight: 600;
        color: #475569;
    }

    [data-theme="dark"] .switch-wrapper span {
        color: #cbd5e1;
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 56px;
        height: 28px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #cbd5e1;
        transition: .3s;
        border-radius: 28px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
    }

        input:checked + .slider:before {
            transform: translateX(28px);
        }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 32px;
    }

    .btn {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(67,97,238,0.3);
        }

    .btn-secondary {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .btn-secondary {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
    }

    .alert {
        padding: 16px;
        border-radius: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #ef4444;
        border: 1px solid #fecaca;
    }

    .alert-success {
        background: #d1fae5;
        color: #10b981;
        border: 1px solid #a7f3d0;
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-pencil-square me-2"></i>កែប្រែព័ត៌មានអ្នកប្រើប្រាស់</h2>
    <p class="text-muted">កែប្រែព័ត៌មានរបស់ @Model.FullName</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
    </div>
}

<div class="edit-container">
    <div class="edit-card">
        <div class="user-avatar">
            @(Model.FullName?.Length > 0 ? Model.FullName.Substring(0, 1).ToUpper() : "?")
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Password" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="form-group">
                <label class="form-label"><i class="bi bi-person"></i> ឈ្មោះពេញ</label>
                <div class="input-wrapper">
                    <i class="bi bi-person"></i>
                    <input asp-for="FullName" class="form-control" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="bi bi-envelope"></i> អ៊ីមែល</label>
                <div class="input-wrapper">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" type="email" class="form-control" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="bi bi-shield"></i> តួនាទី</label>
                <div class="input-wrapper">
                    <i class="bi bi-shield"></i>
                    <select asp-for="Role" class="form-control" required>
                        <option value="Admin">Admin</option>
                        <option value="Super Admin">Super Admin</option>
                        <option value="Registrar">Registrar</option>
                        <option value="Accounting">Accounting</option>
                        <option value="User">User</option>
                    </select>
                    <i class="bi bi-chevron-down" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none;"></i>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label"><i class="bi bi-toggle-on"></i> ស្ថានភាព</label>
                <div class="switch-wrapper">
                    <span><i class="bi bi-check-circle me-2"></i>គណនីសកម្ម</span>
                    <label class="switch">
                        <input asp-for="IsActive" type="checkbox" />
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

            <div class="form-actions">
                <a href="/User/Index" class="btn btn-secondary ajax-link" data-url="/User/Index">
                    <i class="bi bi-x-lg"></i> បោះបង់
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> រក្សាទុក
                </button>
            </div>
        </form>
    </div>
</div>