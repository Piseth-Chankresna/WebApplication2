@model WebApplication2.Models.UserAccount
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Create User";
}

<style>
    :root {
        --primary: #4361ee;
        --primary-light: #4895ef;
        --primary-soft: #eef2ff;
        --secondary: #64748b;
        --success: #10b981;
        --success-soft: #e0f2e9;
        --warning: #f59e0b;
        --warning-soft: #fff3e0;
        --danger: #ef4444;
        --danger-soft: #fee9e9;
        --gray-50: #f9fafb;
        --gray-100: #f3f4f6;
        --gray-200: #e5e7eb;
        --gray-300: #d1d5db;
        --gray-400: #9ca3af;
        --gray-500: #6b7280;
        --gray-600: #4b5563;
        --gray-700: #374151;
        --gray-800: #1f2937;
        --gray-900: #111827;
        --bg-light: #f5f7fb;
        --bg-card: #ffffff;
        --text-primary: #1e293b;
        --text-secondary: #475569;
        --text-muted: #64748b;
        --border-light: #f1f5f9;
        --shadow-sm: 0 2px 4px rgba(0,0,0,0.02);
        --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05);
    }

    [data-theme="dark"] {
        --primary: #60a5fa;
        --primary-light: #93c5fd;
        --primary-soft: #1e293b;
        --secondary: #94a3b8;
        --success: #34d399;
        --success-soft: #1a2e2a;
        --warning: #fbbf24;
        --warning-soft: #322a1a;
        --danger: #f87171;
        --danger-soft: #2d1a1a;
        --gray-50: #18181b;
        --gray-100: #27272a;
        --gray-200: #3f3f46;
        --gray-300: #52525b;
        --gray-400: #71717a;
        --gray-500: #a1a1aa;
        --gray-600: #d4d4d8;
        --gray-700: #e4e4e7;
        --gray-800: #f4f4f5;
        --gray-900: #fafafa;
        --bg-light: #0f172a;
        --bg-card: #1e293b;
        --text-primary: #f1f5f9;
        --text-secondary: #cbd5e1;
        --text-muted: #94a3b8;
        --border-light: #334155;
    }

    body {
        background: var(--bg-light);
        color: var(--text-primary);
        font-family: 'Inter', 'Kantumruy Pro', sans-serif;
    }

    .page-header {
        margin-bottom: 30px;
    }

    .page-header h2 {
        font-weight: 800;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 8px;
    }

    .form-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 28px;
        padding: 32px;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-light);
    }

    [data-theme="dark"] .form-card {
        background: var(--gray-800);
        border-color: var(--gray-700);
    }

    .form-header {
        text-align: center;
        margin-bottom: 32px;
    }

    .form-header i {
        font-size: 3rem;
        color: var(--primary);
        margin-bottom: 16px;
    }

    .form-header h3 {
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .form-header p {
        color: var(--text-muted);
        margin: 0;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .form-label i {
        margin-right: 8px;
        color: var(--primary);
    }

    .input-wrapper {
        position: relative;
    }

    .input-wrapper i:not(.toggle-password) {
        position: absolute;
        left: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 1.1rem;
    }

    .input-wrapper input,
    .input-wrapper select {
        width: 100%;
        padding: 14px 16px 14px 48px;
        border: 2px solid var(--border-light);
        border-radius: 16px;
        background: var(--bg-card);
        color: var(--text-primary);
        font-size: 0.95rem;
        transition: all 0.2s ease;
    }

    [data-theme="dark"] .input-wrapper input,
    [data-theme="dark"] .input-wrapper select {
        background: var(--gray-900);
        border-color: var(--gray-700);
        color: white;
    }

    .input-wrapper input:focus,
    .input-wrapper select:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px var(--primary-soft);
    }

    .toggle-password {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        cursor: pointer;
        z-index: 2;
    }

    .toggle-password:hover {
        color: var(--primary);
    }

    .password-strength {
        margin-top: 12px;
        padding: 16px;
        background: var(--gray-50);
        border-radius: 16px;
        border: 1px solid var(--border-light);
    }

    [data-theme="dark"] .password-strength {
        background: var(--gray-800);
    }

    .strength-bar {
        height: 8px;
        background: var(--gray-200);
        border-radius: 4px;
        margin: 8px 0;
        overflow: hidden;
    }

    .strength-progress {
        height: 100%;
        width: 0;
        transition: all 0.3s ease;
        border-radius: 4px;
    }

    .strength-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .match-indicator {
        margin-top: 8px;
        font-size: 0.85rem;
        min-height: 24px;
    }

    .switch-wrapper {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 20px;
        background: var(--gray-50);
        border-radius: 16px;
        border: 1px solid var(--border-light);
    }

    [data-theme="dark"] .switch-wrapper {
        background: var(--gray-800);
    }

    .switch-wrapper span {
        font-weight: 600;
        color: var(--text-secondary);
    }

    .switch {
        position: relative;
        display: inline-block;
        width: 56px;
        height: 28px;
    }

    .switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--gray-300);
        transition: .3s;
        border-radius: 28px;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 22px;
        width: 22px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: .3s;
        border-radius: 50%;
    }

    input:checked + .slider {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
    }

    input:checked + .slider:before {
        transform: translateX(28px);
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 32px;
    }

    .btn {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 16px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        box-shadow: 0 4px 15px var(--primary-soft);
    }

    .btn-primary:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px var(--primary-soft);
    }

    .btn-primary:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-secondary {
        background: var(--gray-100);
        color: var(--text-secondary);
        border: 1px solid var(--border-light);
    }

    [data-theme="dark"] .btn-secondary {
        background: var(--gray-800);
        color: var(--gray-300);
        border-color: var(--gray-700);
    }

    .btn-secondary:hover {
        background: var(--gray-200);
    }

    .alert {
        padding: 16px;
        border-radius: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .alert-danger {
        background: var(--danger-soft);
        color: var(--danger);
        border: 1px solid var(--danger);
    }

    .alert-success {
        background: var(--success-soft);
        color: var(--success);
        border: 1px solid var(--success);
    }

    @@media (max-width: 640px) {
        .form-actions {
            flex-direction: column;
        }
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <h2><i class="bi bi-person-plus-fill me-2"></i>បង្កើតអ្នកប្រើប្រាស់ថ្មី</h2>
    <p class="text-muted">បំពេញព័ត៌មានខាងក្រោមដើម្បីបង្កើតគណនីថ្មី</p>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        <i class="bi bi-check-circle-fill"></i>
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        @TempData["Error"]
    </div>
}

<!-- Form -->
<div class="form-container">
    <div class="form-card">
        <div class="form-header">
            <i class="bi bi-person-plus-fill"></i>
            <h3>ព័ត៌មានអ្នកប្រើប្រាស់</h3>
            <p>បញ្ចូលព័ត៌មានលម្អិត</p>
        </div>

        <form asp-action="Create" method="post" id="createForm">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-person"></i> ឈ្មោះពេញ</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person"></i>
                            <input asp-for="FullName" class="form-control" placeholder="បញ្ចូលឈ្មោះពេញ" required />
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-envelope"></i> អ៊ីមែល</label>
                        <div class="input-wrapper">
                            <i class="bi bi-envelope"></i>
                            <input asp-for="Email" type="email" class="form-control" placeholder="បញ្ចូលអ៊ីមែល" required />
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-shield"></i> តួនាទី</label>
                        <div class="input-wrapper">
                            <i class="bi bi-shield"></i>
                            <select asp-for="Role" class="form-control" required>
                                <option value="">ជ្រើសរើសតួនាទី</option>
                                <option value="Admin">Admin</option>
                                <option value="Super Admin">Super Admin</option>
                                <option value="Registrar">Registrar</option>
                                <option value="Accounting">Accounting</option>
                                <option value="User">User</option>
                            </select>
                            <i class="bi bi-chevron-down" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none;"></i>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-lock"></i> ពាក្យសម្ងាត់</label>
                        <div class="input-wrapper">
                            <i class="bi bi-lock"></i>
                            <input asp-for="Password" type="password" id="password" class="form-control" placeholder="បញ្ចូលពាក្យសម្ងាត់" required />
                            <i class="bi bi-eye-slash toggle-password" onclick="togglePassword('password', this)"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-check-circle"></i> បញ្ជាក់ពាក្យសម្ងាត់</label>
                        <div class="input-wrapper">
                            <i class="bi bi-check-circle"></i>
                            <input type="password" id="confirmPassword" class="form-control" placeholder="បញ្ចូលម្តងទៀត" required />
                            <i class="bi bi-eye-slash toggle-password" onclick="togglePassword('confirmPassword', this)"></i>
                        </div>
                        
                        <!-- កម្រិតសុវត្ថិភាព -->
                        <div class="password-strength" id="passwordStrength" style="display: none;">
                            <div class="strength-bar">
                                <div class="strength-progress" id="strengthBar"></div>
                            </div>
                            <div class="strength-labels">
                                <span>ខ្សោយ</span>
                                <span>មធ្យម</span>
                                <span>រឹងមាំ</span>
                            </div>
                        </div>

                        <div class="match-indicator" id="matchIndicator"></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="form-label"><i class="bi bi-toggle-on"></i> ស្ថានភាពគណនី</label>
                        <div class="switch-wrapper">
                            <span><i class="bi bi-check-circle me-2"></i>សកម្ម</span>
                            <label class="switch">
                                <input asp-for="IsActive" type="checkbox" checked />
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a href="/User/Index" class="btn btn-secondary ajax-link" data-url="/User/Index">
                    <i class="bi bi-x-lg"></i>
                    បោះបង់
                </a>
                <button type="submit" class="btn btn-primary" id="submitBtn">
                    <i class="bi bi-check-lg"></i>
                    បង្កើតអ្នកប្រើប្រាស់
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // បិទ/បើកការមើលពាក្យសម្ងាត់
    function togglePassword(inputId, icon) {
        var input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        } else {
            input.type = "password";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        }
    }

    $(document).ready(function() {
        // ពិនិត្យកម្រិតសុវត្ថិភាពពាក្យសម្ងាត់
        $('#password').on('keyup', function() {
            var password = $(this).val();
            
            if (password.length > 0) {
                $('#passwordStrength').show();
                
                var strength = 0;
                if (password.length >= 8) strength++;
                if (password.match(/[a-z]+/)) strength++;
                if (password.match(/[A-Z]+/)) strength++;
                if (password.match(/[0-9]+/)) strength++;
                if (password.match(/[$@@#&!]+/)) strength++;
                
                var strengthBar = $('#strengthBar');
                var color, width;
                
                if (strength <= 2) {
                    color = '#ef4444';
                    width = '33%';
                } else if (strength <= 4) {
                    color = '#f59e0b';
                    width = '66%';
                } else {
                    color = '#10b981';
                    width = '100%';
                }
                
                strengthBar.css({
                    'width': width,
                    'background': color
                });
            } else {
                $('#passwordStrength').hide();
            }
        });

        // ពិនិត្យពាក្យសម្ងាត់ថាត្រូវគ្នាឬអត់
        function checkPasswordMatch() {
            var password = $('#password').val();
            var confirm = $('#confirmPassword').val();
            var indicator = $('#matchIndicator');
            var submitBtn = $('#submitBtn');
            
            if (confirm.length > 0) {
                if (password === confirm) {
                    indicator.html('<span style="color:#10b981;"><i class="bi bi-check-circle-fill"></i> ពាក្យសម្ងាត់ត្រឹមត្រូវ</span>');
                    submitBtn.prop('disabled', false);
                } else {
                    indicator.html('<span style="color:#ef4444;"><i class="bi bi-exclamation-circle-fill"></i> ពាក្យសម្ងាត់មិនត្រូវគ្នា</span>');
                    submitBtn.prop('disabled', true);
                }
            } else {
                indicator.html('');
                submitBtn.prop('disabled', true);
            }
        }

        $('#password, #confirmPassword').on('keyup', checkPasswordMatch);

        // ពិនិត្យមុនពេល Submit
        $('#createForm').on('submit', function(e) {
            var password = $('#password').val();
            var confirm = $('#confirmPassword').val();
            
            if (password !== confirm) {
                e.preventDefault();
                Swal.fire({
                    icon: 'error',
                    title: 'ពាក្យសម្ងាត់មិនត្រូវគ្នា',
                    text: 'សូមបញ្ចូលពាក្យសម្ងាត់អោយដូចគ្នា',
                    confirmButtonColor: '#4361ee'
                });
                return false;
            }
            
            if (password.length < 6) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'ពាក្យសម្ងាត់ខ្លីពេក',
                    text: 'ពាក្យសម្ងាត់ត្រូវមានយ៉ាងហោចណាស់ ៦ តួអក្សរ',
                    confirmButtonColor: '#4361ee'
                });
                return false;
            }
        });
    });
</script>