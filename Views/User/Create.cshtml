@model WebApplication2.Models.UserAccount
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Create User";
}

<style>
    .create-container {
        max-width: 700px;
        margin: 0 auto;
    }

    .form-card-modern {
        background: var(--glass-bg);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 50px;
        padding: 40px;
        animation: cardFloat 0.8s ease;
    }

    @@keyframes cardFloat {
        from {
            opacity: 0;
            transform: translateY(50px) scale(0.9);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .form-title {
        text-align: center;
        margin-bottom: 35px;
    }

    .form-title i {
        font-size: 3.5rem;
        background: var(--gradient-1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 15px;
    }

    .form-title h2 {
        color: white;
        font-weight: 800;
        font-size: 2rem;
        margin-bottom: 10px;
    }

    .form-title p {
        color: rgba(255,255,255,0.7);
    }

    .input-group-modern {
        margin-bottom: 25px;
        position: relative;
    }

    .input-group-modern label {
        display: block;
        color: white;
        font-weight: 600;
        margin-bottom: 10px;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
    }

    .input-group-modern .input-wrapper {
        position: relative;
    }

    .input-group-modern .input-wrapper i.input-icon {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.6);
        font-size: 1.2rem;
        z-index: 1;
    }

    .input-group-modern input,
    .input-group-modern select {
        width: 100%;
        padding: 16px 20px 16px 50px;
        background: rgba(255,255,255,0.1);
        border: 2px solid rgba(255,255,255,0.2);
        border-radius: 30px;
        color: white;
        font-size: 1rem;
        transition: all 0.3s;
        backdrop-filter: blur(5px);
    }

    .input-group-modern input:focus,
    .input-group-modern select:focus {
        outline: none;
        border-color: var(--neon-blue);
        box-shadow: 0 0 30px rgba(0,255,255,0.3);
        background: rgba(255,255,255,0.15);
    }

    .input-group-modern input::placeholder {
        color: rgba(255,255,255,0.5);
    }

    .input-group-modern select {
        cursor: pointer;
        appearance: none;
    }

    .input-group-modern select option {
        background: #1a1a1a;
        color: white;
    }

    .password-strength {
        margin-top: 15px;
        padding: 15px;
        background: rgba(255,255,255,0.05);
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .strength-bar {
        height: 8px;
        background: rgba(255,255,255,0.1);
        border-radius: 4px;
        margin: 10px 0;
        overflow: hidden;
    }

    .strength-progress {
        height: 100%;
        width: 0;
        transition: all 0.3s;
        border-radius: 4px;
    }

    .strength-text {
        color: rgba(255,255,255,0.7);
        font-size: 0.85rem;
        display: flex;
        justify-content: space-between;
    }

    .password-match-indicator {
        margin-top: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .switch-modern {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: rgba(255,255,255,0.05);
        padding: 15px 20px;
        border-radius: 30px;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .switch-modern span {
        color: white;
        font-weight: 600;
    }

    .switch-modern .switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 30px;
    }

    .switch-modern .switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .switch-modern .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.2);
        transition: .3s;
        border-radius: 30px;
    }

    .switch-modern .slider:before {
        position: absolute;
        content: "";
        height: 24px;
        width: 24px;
        left: 3px;
        bottom: 3px;
        background: white;
        transition: .3s;
        border-radius: 50%;
    }

    .switch-modern input:checked + .slider {
        background: var(--gradient-4);
    }

    .switch-modern input:checked + .slider:before {
        transform: translateX(30px);
    }

    .form-actions-modern {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 15px;
        margin-top: 35px;
    }

    .btn-modern {
        padding: 16px;
        border: none;
        border-radius: 40px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s;
        text-decoration: none;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        position: relative;
        overflow: hidden;
    }

    .btn-modern::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    .btn-modern:hover::before {
        width: 300px;
        height: 300px;
    }

    .btn-primary-modern {
        background: var(--gradient-1);
        color: white;
        box-shadow: 0 10px 20px rgba(65,88,208,0.3);
    }

    .btn-secondary-modern {
        background: rgba(255,255,255,0.1);
        color: white;
        border: 1px solid rgba(255,255,255,0.2);
        backdrop-filter: blur(5px);
    }

    .btn-modern:hover {
        transform: translateY(-3px);
        box-shadow: 0 20px 30px rgba(0,0,0,0.3);
    }

    .error-message {
        color: #ff6b6b;
        font-size: 0.85rem;
        margin-top: 8px;
        display: none;
        align-items: center;
        gap: 5px;
    }

    .error-message.show {
        display: flex;
    }
</style>

<div class="create-container">
    <div class="form-card-modern">
        <div class="form-title">
            <i class="bi bi-person-plus-fill"></i>
            <h2>បង្កើតអ្នកប្រើប្រាស់ថ្មី</h2>
            <p>សូមបំពេញព័ត៌មានខាងក្រោម</p>
        </div>

        <form asp-action="Create" method="post" id="createForm">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-6">
                    <div class="input-group-modern">
                        <label><i class="bi bi-person me-2"></i>ឈ្មោះពេញ</label>
                        <div class="input-wrapper">
                            <i class="bi bi-person input-icon"></i>
                            <input asp-for="FullName" placeholder="សូមបញ្ចូលឈ្មោះពេញ" required>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="input-group-modern">
                        <label><i class="bi bi-envelope me-2"></i>អ៊ីមែល</label>
                        <div class="input-wrapper">
                            <i class="bi bi-envelope input-icon"></i>
                            <input asp-for="Email" type="email" placeholder="សូមបញ្ចូលអ៊ីមែល" required>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="input-group-modern">
                        <label><i class="bi bi-shield me-2"></i>តួនាទី</label>
                        <div class="input-wrapper">
                            <i class="bi bi-shield input-icon"></i>
                            <select asp-for="Role" required>
                                <option value="">-- ជ្រើសរើសតួនាទី --</option>
                                <option value="Admin">Admin</option>
                                <option value="Super Admin">Super Admin</option>
                                <option value="Registrar">Registrar</option>
                                <option value="Accounting">Accounting</option>
                                <option value="User">User</option>
                            </select>
                            <i class="bi bi-chevron-down" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.6);"></i>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="input-group-modern">
                        <label><i class="bi bi-key me-2"></i>លេខសម្ងាត់</label>
                        <div class="input-wrapper">
                            <i class="bi bi-key input-icon"></i>
                            <input asp-for="Password" type="password" id="password" class="password-input" placeholder="បញ្ចូលលេខសម្ងាត់" required>
                            <i class="bi bi-eye-slash" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.6); cursor: pointer;" onclick="togglePassword('password', this)"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="input-group-modern">
                        <label><i class="bi bi-check-circle me-2"></i>បញ្ជាក់លេខសម្ងាត់</label>
                        <div class="input-wrapper">
                            <i class="bi bi-check-circle input-icon"></i>
                            <input type="password" id="confirmPassword" class="password-input" placeholder="បញ្ចូលម្តងទៀត" required>
                            <i class="bi bi-eye-slash" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.6); cursor: pointer;" onclick="togglePassword('confirmPassword', this)"></i>
                        </div>
                        
                        <!-- Password Strength -->
                        <div class="password-strength" id="passwordStrength">
                            <div class="strength-bar">
                                <div class="strength-progress" id="strengthBar"></div>
                            </div>
                            <div class="strength-text">
                                <span>កម្រិតសុវត្ថិភាព</span>
                                <span id="strengthLabel">ខ្សោយ</span>
                            </div>
                        </div>

                        <div class="password-match-indicator" id="matchIndicator">
                            <i class="bi bi-exclamation-circle" style="color: #ff6b6b;"></i>
                            <span style="color: #ff6b6b;">លេខសម្ងាត់មិនត្រូវគ្នា</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="input-group-modern">
                        <label><i class="bi bi-toggle-on me-2"></i>ស្ថានភាព</label>
                        <div class="switch-modern">
                            <span><i class="bi bi-check-circle me-2"></i>សកម្ម</span>
                            <label class="switch">
                                <input asp-for="IsActive" type="checkbox" checked>
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-actions-modern">
                <a href="/User/Index" class="btn-modern btn-secondary-modern ajax-link" data-url="/User/Index">
                    <i class="bi bi-arrow-left"></i>
                    បោះបង់
                </a>
                <button type="submit" class="btn-modern btn-primary-modern" id="submitBtn">
                    <i class="bi bi-save"></i>
                    រក្សាទុក
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Toggle password visibility
    function togglePassword(inputId, icon) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        } else {
            input.type = "password";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        }
    }

    // Password strength checker
    function checkPasswordStrength(password) {
        let strength = 0;
        
        if (password.length >= 8) strength++;
        if (password.match(/[a-z]+/)) strength++;
        if (password.match(/[A-Z]+/)) strength++;
        if (password.match(/[0-9]+/)) strength++;
        if (password.match(/[$#&!]+/)) strength++;
        
        return strength;
    }

    // Update password strength
    $('#password').on('keyup', function() {
        const password = $(this).val();
        const strength = checkPasswordStrength(password);
        const strengthBar = $('#strengthBar');
        const strengthLabel = $('#strengthLabel');
        
        let color, label;
        
        if (strength <= 2) {
            color = '#ff6b6b';
            label = 'ខ្សោយ';
        } else if (strength <= 4) {
            color = '#ffbe0b';
            label = 'មធ្យម';
        } else {
            color = '#00b09b';
            label = 'រឹងមាំ';
        }
        
        strengthBar.css({
            'width': (strength * 20) + '%',
            'background': color
        });
        
        strengthLabel.text(label).css('color', color);
    });

    // Password match checker
    function checkPasswordMatch() {
        const password = $('#password').val();
        const confirm = $('#confirmPassword').val();
        const indicator = $('#matchIndicator');
        const submitBtn = $('#submitBtn');
        
        if (confirm.length > 0) {
            if (password === confirm) {
                indicator.html('<i class="bi bi-check-circle" style="color: #00b09b;"></i><span style="color: #00b09b;">លេខសម្ងាត់ត្រឹមត្រូវ</span>');
                submitBtn.prop('disabled', false);
            } else {
                indicator.html('<i class="bi bi-exclamation-circle" style="color: #ff6b6b;"></i><span style="color: #ff6b6b;">លេខសម្ងាត់មិនត្រូវគ្នា</span>');
                submitBtn.prop('disabled', true);
            }
        }
    }

    $('#password, #confirmPassword').on('keyup', checkPasswordMatch);

    // Form submit animation
    $('#createForm').on('submit', function(e) {
        const submitBtn = $('#submitBtn');
        submitBtn.prop('disabled', true);
        submitBtn.html('<span class="spinner-border spinner-border-sm me-2"></span>កំពុងរក្សាទុក...');
    });

    // Animate form on load
    gsap.from('.form-card-modern', {
        duration: 0.8,
        y: 50,
        opacity: 0,
        scale: 0.9,
        ease: 'power3.out'
    });

    gsap.from('.input-group-modern', {
        duration: 0.5,
        y: 30,
        opacity: 0,
        stagger: 0.1,
        delay: 0.3,
        ease: 'power3.out'
    });
</script>