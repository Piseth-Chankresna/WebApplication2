@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Role & Permissions";
}

<style>
    .roles-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        margin-top: 20px;
    }

    .role-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 25px;
        transition: all 0.3s;
        cursor: pointer;
        border: 1px solid var(--border-color);
    }

        .role-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(102, 126, 234, 0.15);
        }

    .role-icon {
        width: 60px;
        height: 60px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 28px;
        color: white;
    }

        .role-icon.admin {
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        .role-icon.registrar {
            background: linear-gradient(135deg, #06b6d4, #0891b2);
        }

        .role-icon.accounting {
            background: linear-gradient(135deg, #f59e0b, #d97706);
        }
</style>

<h4 class="fw-bold mb-4">គ្រប់គ្រងតួនាទី និងសិទ្ធិ</h4>

<div class="roles-grid">
    <div class="role-card" onclick="viewPermissions('Admin')">
        <div class="role-icon admin"><i class="bi bi-shield-check"></i></div>
        <h5 class="fw-bold">Admin</h5>
        <p class="text-muted small">អ្នកគ្រប់គ្រងប្រព័ន្ធ</p>
    </div>

    <div class="role-card" onclick="viewPermissions('Registrar')">
        <div class="role-icon registrar"><i class="bi bi-person-badge"></i></div>
        <h5 class="fw-bold">Registrar</h5>
        <p class="text-muted small">អ្នកគ្រប់គ្រងការសិក្សា</p>
    </div>

    <div class="role-card" onclick="viewPermissions('Accounting')">
        <div class="role-icon accounting"><i class="bi bi-calculator"></i></div>
        <h5 class="fw-bold">Accounting</h5>
        <p class="text-muted small">គណនេយ្យករ</p>
    </div>
</div>

<script>
    function viewPermissions(role) {
        $.get('/User/GetPermissions', { roleName: role }, function(data) {
            let html = '<div class="text-start">';
            data.forEach(p => {
                html += `<div class="border-bottom p-2">
                    <strong>${p.moduleName}:</strong>
                    ${p.canView ? '👁️ View ' : ''}
                    ${p.canCreate ? '➕ Create ' : ''}
                    ${p.canEdit ? '✏️ Edit ' : ''}
                </div>`;
            });
            html += '</div>';

            Swal.fire({
                title: role + ' Permissions',
                html: html,
                confirmButtonText: 'Close'
            });
        });
    }
</script>