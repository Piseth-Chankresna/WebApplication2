@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Reset Password";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

        .page-header h2 {
            font-weight: 800;
            background: linear-gradient(135deg, #4361ee, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 8px;
        }

    .reset-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .reset-card {
        background: white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .reset-card {
        background: #1e293b;
        border-color: #334155;
    }

    .reset-header {
        text-align: center;
        margin-bottom: 30px;
    }

        .reset-header i {
            font-size: 3rem;
            color: #4361ee;
            margin-bottom: 16px;
        }

        .reset-header h3 {
            font-weight: 700;
            color: #1e293b;
            margin-bottom: 8px;
        }

    [data-theme="dark"] .reset-header h3 {
        color: white;
    }

    .reset-header p {
        color: #64748b;
        margin: 0;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #475569;
        margin-bottom: 8px;
    }

    [data-theme="dark"] .form-label {
        color: #cbd5e1;
    }

    .form-label i {
        margin-right: 8px;
        color: #4361ee;
    }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i:not(.toggle-password) {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
        }

        .input-wrapper select,
        .input-wrapper input {
            width: 100%;
            padding: 14px 16px 14px 48px;
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            background: white;
            color: #1e293b;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

    [data-theme="dark"] .input-wrapper select,
    [data-theme="dark"] .input-wrapper input {
        background: #0f172a;
        border-color: #334155;
        color: white;
    }

    .input-wrapper select:focus,
    .input-wrapper input:focus {
        outline: none;
        border-color: #4361ee;
        box-shadow: 0 0 0 4px #e0e7ff;
    }

    .toggle-password {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        cursor: pointer;
        z-index: 2;
    }

        .toggle-password:hover {
            color: #4361ee;
        }

    .match-indicator {
        margin-top: 8px;
        font-size: 0.85rem;
        min-height: 24px;
    }

    .user-info {
        background: #f8fafc;
        border-radius: 16px;
        padding: 16px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 16px;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .user-info {
        background: #0f172a;
        border-color: #334155;
    }

    .user-avatar-sm {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1.2rem;
    }

    .user-details h4 {
        font-weight: 700;
        margin: 0 0 4px;
    }

    .user-details span {
        color: #64748b;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .form-actions {
        display: flex;
        gap: 16px;
        margin-top: 32px;
    }

    .btn {
        flex: 1;
        padding: 14px;
        border: none;
        border-radius: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4361ee, #8b5cf6);
        color: white;
    }

        .btn-primary:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(67,97,238,0.3);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .btn-secondary {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
    }

    [data-theme="dark"] .btn-secondary {
        background: #0f172a;
        color: #cbd5e1;
        border-color: #334155;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
    }

    [data-theme="dark"] .btn-secondary:hover {
        background: #1e293b;
    }

    .loading-spinner {
        display: inline-block;
        width: 20px;
        height: 20px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>

<div class="page-header">
    <h2><i class="bi bi-key-fill me-2"></i>ប្តូរពាក្យសម្ងាត់</h2>
    <p class="text-muted">ជ្រើសរើសអ្នកប្រើប្រាស់ និងកំណត់ពាក្យសម្ងាត់ថ្មី</p>
</div>

<div class="reset-container">
    <div class="reset-card">
        <div class="reset-header">
            <i class="bi bi-shield-lock"></i>
            <h3>កំណត់ពាក្យសម្ងាត់ថ្មី</h3>
            <p>ជ្រើសរើសគណនី និងបញ្ចូលពាក្យសម្ងាត់ថ្មី</p>
        </div>

        <!-- User Select -->
        <div class="form-group">
            <label class="form-label"><i class="bi bi-person"></i> ជ្រើសរើសអ្នកប្រើប្រាស់</label>
            <div class="input-wrapper">
                <i class="bi bi-person"></i>
                <select id="userSelect" class="form-control" required>
                    <option value="">-- កំពុងផ្ទុកទិន្នន័យ... --</option>
                </select>
                <i class="bi bi-chevron-down" style="position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: #94a3b8; pointer-events: none;"></i>
            </div>
        </div>

        <!-- Selected User Info (will show when user selected) -->
        <div id="selectedUserInfo" style="display: none;" class="user-info">
            <div class="user-avatar-sm" id="selectedUserAvatar">?</div>
            <div class="user-details">
                <h4 id="selectedUserName"></h4>
                <span id="selectedUserEmail"></span>
            </div>
        </div>

        <!-- New Password -->
        <div class="form-group">
            <label class="form-label"><i class="bi bi-lock"></i> ពាក្យសម្ងាត់ថ្មី</label>
            <div class="input-wrapper">
                <i class="bi bi-lock"></i>
                <input type="password" id="newPassword" class="form-control" placeholder="បញ្ចូលពាក្យសម្ងាត់ថ្មី" disabled>
                <i class="bi bi-eye-slash toggle-password" onclick="togglePassword('newPassword', this)"></i>
            </div>
        </div>

        <!-- Confirm Password -->
        <div class="form-group">
            <label class="form-label"><i class="bi bi-check-circle"></i> បញ្ជាក់ពាក្យសម្ងាត់</label>
            <div class="input-wrapper">
                <i class="bi bi-check-circle"></i>
                <input type="password" id="confirmPassword" class="form-control" placeholder="បញ្ចូលម្តងទៀត" disabled>
                <i class="bi bi-eye-slash toggle-password" onclick="togglePassword('confirmPassword', this)"></i>
            </div>
            <div class="match-indicator" id="matchIndicator"></div>
        </div>

        <!-- Actions -->
        <div class="form-actions">
            <a href="/User/Index" class="btn btn-secondary ajax-link" data-url="/User/Index">
                <i class="bi bi-x-lg"></i> បោះបង់
            </a>
            <button type="button" class="btn btn-primary" id="submitBtn" onclick="resetPassword()" disabled>
                <i class="bi bi-check-lg"></i> ប្តូរពាក្យសម្ងាត់
            </button>
        </div>
    </div>
</div>

<script>
    function togglePassword(inputId, icon) {
        var input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");
        } else {
            input.type = "password";
            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");
        }
    }

    $(document).ready(function() {
        // Load users for select
        loadUsers();

        // ពិនិត្យពាក្យសម្ងាត់
        function checkPasswordMatch() {
            var password = $('#newPassword').val();
            var confirm = $('#confirmPassword').val();
            var userId = $('#userSelect').val();

            if (confirm.length > 0 && userId) {
                if (password === confirm) {
                    $('#matchIndicator').html('<span style="color:#10b981;"><i class="bi bi-check-circle-fill"></i> ពាក្យសម្ងាត់ត្រឹមត្រូវ</span>');
                    $('#submitBtn').prop('disabled', false);
                } else {
                    $('#matchIndicator').html('<span style="color:#ef4444;"><i class="bi bi-exclamation-circle-fill"></i> ពាក្យសម្ងាត់មិនត្រូវគ្នា</span>');
                    $('#submitBtn').prop('disabled', true);
                }
            } else {
                $('#matchIndicator').html('');
                $('#submitBtn').prop('disabled', true);
            }
        }

        $('#newPassword, #confirmPassword').on('keyup', checkPasswordMatch);
    });

    function loadUsers() {
        $('#userSelect').html('<option value="">កំពុងផ្ទុកទិន្នន័យ...</option>');

        $.ajax({
            url: '/User/GetUsersForReset',
            type: 'GET',
            success: function(users) {
                var options = '<option value="">-- ជ្រើសរើសអ្នកប្រើប្រាស់ --</option>';
                users.forEach(user => {
                    options += `<option value="${user.id}" data-name="${user.fullName}" data-email="${user.email}">${user.fullName} (${user.email}) - ${user.role}</option>`;
                });
                $('#userSelect').html(options);
            },
            error: function() {
                $('#userSelect').html('<option value="">មានបញ្ហាក្នុងការផ្ទុកទិន្នន័យ</option>');
            }
        });
    }

    // ពេលជ្រើសរើសអ្នកប្រើប្រាស់
    $('#userSelect').on('change', function() {
        var selected = $(this).find('option:selected');
        var userId = $(this).val();
        var userName = selected.data('name');
        var userEmail = selected.data('email');

        if (userId) {
            $('#selectedUserInfo').show();
            $('#selectedUserName').text(userName);
            $('#selectedUserEmail').text(userEmail);
            $('#selectedUserAvatar').text(userName ? userName.substring(0,1).toUpperCase() : '?');
            $('#newPassword, #confirmPassword').prop('disabled', false);
        } else {
            $('#selectedUserInfo').hide();
            $('#newPassword, #confirmPassword').prop('disabled', true).val('');
            $('#matchIndicator').html('');
            $('#submitBtn').prop('disabled', true);
        }
    });

    function resetPassword() {
        var userId = $('#userSelect').val();
        var newPassword = $('#newPassword').val();
        var confirmPassword = $('#confirmPassword').val();

        if (!userId) {
            Swal.fire({
                icon: 'warning',
                title: 'សូមជ្រើសរើសអ្នកប្រើប្រាស់',
                confirmButtonColor: '#4361ee'
            });
            return;
        }

        if (newPassword.length < 6) {
            Swal.fire({
                icon: 'warning',
                title: 'ពាក្យសម្ងាត់ខ្លីពេក',
                text: 'ពាក្យសម្ងាត់ត្រូវមានយ៉ាងហោចណាស់ ៦ តួអក្សរ',
                confirmButtonColor: '#4361ee'
            });
            return;
        }

        if (newPassword !== confirmPassword) {
            Swal.fire({
                icon: 'error',
                title: 'ពាក្យសម្ងាត់មិនត្រូវគ្នា',
                confirmButtonColor: '#4361ee'
            });
            return;
        }

        // Show loading
        var btn = $('#submitBtn');
        btn.prop('disabled', true).html('<span class="loading-spinner me-2"></span>កំពុងដំណើរការ...');

        $.ajax({
            url: '/User/ResetPassword',
            type: 'POST',
            data: {
                userId: userId,
                newPassword: newPassword,
                confirmPassword: confirmPassword
            },
            headers: {
                'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
            },
            success: function(response) {
                if (response.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'ជោគជ័យ!',
                        text: response.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = '/User/Index';
                    });
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'កំហុស',
                        text: response.message,
                        confirmButtonColor: '#4361ee'
                    });
                    btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> ប្តូរពាក្យសម្ងាត់');
                }
            },
            error: function() {
                Swal.fire({
                    icon: 'error',
                    title: 'កំហុស',
                    text: 'មានបញ្ហាបច្ចេកទេស',
                    confirmButtonColor: '#4361ee'
                });
                btn.prop('disabled', false).html('<i class="bi bi-check-lg"></i> ប្តូរពាក្យសម្ងាត់');
            }
        });
    }
</script>