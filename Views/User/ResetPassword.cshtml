@model WebApplication2.Models.UserAccount
@{
    bool isAjax = Context.Request.Headers["X-Requested-With"] == "XMLHttpRequest";
    Layout = isAjax ? null : "_Layout";
    ViewData["Title"] = "Reset Password";
}

<style>
    .reset-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 30px;
        max-width: 500px;
        margin: 0 auto;
        text-align: center;
    }

    .user-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #667eea, #764ba2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        color: white;
        font-size: 32px;
        font-weight: bold;
    }

    .form-group {
        margin-bottom: 20px;
        text-align: left;
    }

    .form-label {
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 8px;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid var(--border-color);
        border-radius: 12px;
        background: var(--card-bg);
        color: var(--text-main);
    }

    .btn-reset {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        padding: 12px 30px;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
    }

    .btn-cancel {
        background: transparent;
        color: var(--text-muted);
        padding: 12px 30px;
        border: 2px solid var(--border-color);
        border-radius: 12px;
        text-decoration: none;
        display: inline-block;
        margin-bottom: 10px;
    }

    .password-hint {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 5px;
    }

    .text-danger {
        color: #ef4444;
        font-size: 0.85rem;
    }
</style>

<div class="reset-card">
    @if (Model != null)
    {
        <div class="user-avatar">
            @(Model.FullName?.Substring(0, 1))
        </div>

        <h4 class="fw-bold mb-1">@Model.FullName</h4>
        <p class="text-muted mb-4">@Model.Email</p>

        <form asp-action="ResetPassword" method="post" id="resetForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="form-group">
                <label class="form-label">លេខសម្ងាត់ថ្មី</label>
                <input type="password" name="newPassword" id="newPassword" class="form-control" required>
            </div>

            <div class="form-group">
                <label class="form-label">បញ្ជាក់លេខសម្ងាត់</label>
                <input type="password" id="confirmPassword" class="form-control" required>
                <div class="password-hint" id="passwordError" style="display: none; color: #ef4444;">
                    <i class="bi bi-exclamation-circle"></i> លេខសម្ងាត់មិនត្រូវគ្នា
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn-reset" id="submitBtn">ប្តូរលេខសម្ងាត់</button>
                <a href="/User/Index" class="btn-cancel ajax-link" data-url="/User/Index">បោះបង់</a>
            </div>
        </form>
    }
    else
    {
        <p>រកមិនឃើញអ្នកប្រើប្រាស់</p>
        <a href="/User/Index" class="btn-cancel ajax-link" data-url="/User/Index">ត្រឡប់ក្រោយ</a>
    }
</div>

<script>
    $('#confirmPassword').on('keyup', function() {
        var pw = $('#newPassword').val();
        var confirm = $(this).val();

        if (pw !== confirm) {
            $('#passwordError').show();
            $('#submitBtn').prop('disabled', true);
        } else {
            $('#passwordError').hide();
            $('#submitBtn').prop('disabled', false);
        }
    });
</script>