@page
@model WebApplication2.Views.User.ResetPasswordModel
@{
}

<style>
    /* --- Variables for Light/Dark Mode --- */
    :root {
        --reset-bg: #ffffff;
        --reset-card-bg: #f8fafc;
        --reset-text: #1e293b;
        --reset-text-muted: #64748b;
        --reset-border: #e2e8f0;
        --reset-input-bg: #f8fafc;
        --reset-header-border: #f1f5f9;
        --reset-badge-bg: #f1f5f9;
        --reset-shadow: rgba(0, 0, 0, 0.05);
    }

    [data-bs-theme="dark"] {
        --reset-bg: #1e293b;
        --reset-card-bg: #0f172a;
        --reset-text: #f1f5f9;
        --reset-text-muted: #94a3b8;
        --reset-border: #334155;
        --reset-input-bg: #1e293b;
        --reset-header-border: #334155;
        --reset-badge-bg: #334155;
        --reset-shadow: rgba(0, 0, 0, 0.3);
    }

    /* --- Main Wrapper --- */
    .reset-page-wrapper {
        max-width: 900px;
        margin: 0 auto;
        padding: 30px;
        background-color: var(--reset-bg);
        border-radius: 24px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px var(--reset-shadow);
    }

    .reset-header-minimal {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 40px;
        padding-bottom: 25px;
        border-bottom: 2px solid var(--reset-header-border);
    }

    .reset-icon-box {
        width: 64px;
        height: 64px;
        background: linear-gradient(135deg, #3b82f6 0%, #1d4ed8 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
        font-size: 28px;
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
    }

    /* --- Choose User Badge Style (Select) --- */
    .user-select-badge-wrapper {
        background: var(--reset-badge-bg);
        padding: 10px 15px;
        border-radius: 18px;
        border: 1.5px solid var(--reset-border);
        display: flex;
        align-items: center;
        gap: 15px;
        transition: 0.3s;
        cursor: pointer;
    }

        .user-select-badge-wrapper:focus-within {
            border-color: #3b82f6;
            background: var(--reset-bg);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

    .avatar-circle-sm {
        width: 45px;
        height: 45px;
        background: #2563eb;
        color: white;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    /* Clean Select without arrow box */
    .select-clean {
        background: transparent !important;
        border: none !important;
        color: var(--reset-text) !important;
        font-weight: 700;
        font-size: 1.05rem;
        padding: 0 !important;
        box-shadow: none !important;
        cursor: pointer;
        width: 100%;
    }

        .select-clean option {
            background-color: var(--reset-bg);
            color: var(--reset-text);
        }

    /* --- Form Elements --- */
    .form-label-reset {
        font-weight: 700;
        color: var(--reset-text);
        font-size: 0.85rem;
        margin-bottom: 10px;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .input-reset-modern {
        background-color: var(--reset-input-bg) !important;
        border: 1.5px solid var(--reset-border) !important;
        padding: 14px 18px !important;
        border-radius: 14px !important;
        font-size: 1rem;
        color: var(--reset-text);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

        .input-reset-modern:focus {
            border-color: #3b82f6 !important;
            background-color: var(--reset-bg) !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1) !important;
        }

    .toggle-icon {
        position: absolute;
        right: 18px;
        top: 50%;
        transform: translateY(-50%);
        cursor: pointer;
        color: var(--reset-text-muted);
        font-size: 1.25rem;
        z-index: 10;
    }

    /* --- Action Bar --- */
    .action-bar-reset {
        background: var(--reset-card-bg);
        border-radius: 20px;
        padding: 25px;
        margin-top: 40px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        border: 1px solid var(--reset-border);
    }

    .text-dark {
        color: var(--reset-text) !important;
    }

    .text-muted {
        color: var(--reset-text-muted) !important;
    }
</style>

<div class="reset-page-wrapper">
    <div class="reset-header-minimal">
        <div class="reset-icon-box">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <div>
            <h3 class="fw-bold text-dark mb-1">ផ្លាស់ប្តូរលេខសម្ងាត់</h3>
            <p class="text-muted mb-0 small">ជ្រើសរើសគណនី និងធ្វើបច្ចុប្បន្នភាពសុវត្ថិភាព</p>
        </div>
    </div>

    <form id="resetPasswordForm">
        <div class="row g-4">
            <div class="col-12">
                <label class="form-label-reset">គណនីដែលត្រូវផ្លាស់ប្តូរ</label>
                <div class="user-select-badge-wrapper">
                    <div class="avatar-circle-sm" id="userAvatar">?</div>
                    <div class="flex-grow-1">
                        <select id="userEmailSelect" class="form-select select-clean" required onchange="updateAvatar(this)">
                            <option value="" disabled selected>ជ្រើសរើស Gmail អ្នកប្រើប្រាស់...</option>
                            <option value="admin@example.com" data-init="A">admin@example.com</option>
                            <option value="registrar@example.com" data-init="R">registrar@example.com</option>
                            <option value="accounting@example.com" data-init="A">accounting@example.com</option>
                            <option value="user123@gmail.com" data-init="U">user123@gmail.com</option>
                        </select>
                        <span class="text-muted small d-block" style="margin-top: -2px;">ចុចដើម្បីផ្លាស់ប្តូរអ្នកប្រើប្រាស់</span>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="form-group-custom">
                    <label class="form-label-reset">លេខសម្ងាត់ចាស់</label>
                    <div class="input-group-modern position-relative">
                        <input type="password" id="oldPassword" class="form-control input-reset-modern" placeholder="បញ្ចូលលេខសម្ងាត់បច្ចុប្បន្ន..." required>
                        <i class="bi bi-eye toggle-icon" onclick="toggleView('oldPassword', this)"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-reset">លេខសម្ងាត់ថ្មី</label>
                    <div class="input-group-modern position-relative">
                        <input type="password" id="newPassword" class="form-control input-reset-modern" placeholder="បញ្ចូលលេខសម្ងាត់ថ្មី..." required>
                        <i class="bi bi-eye toggle-icon" onclick="toggleView('newPassword', this)"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-reset">បញ្ជាក់លេខសម្ងាត់ថ្មី</label>
                    <div class="input-group-modern position-relative">
                        <input type="password" id="confirmPassword" class="form-control input-reset-modern" placeholder="បញ្ជាក់លេខសម្ងាត់ថ្មី..." required>
                        <i class="bi bi-eye toggle-icon" onclick="toggleView('confirmPassword', this)"></i>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="action-bar-reset">
                    <div class="d-none d-md-flex align-items-center text-muted small">
                        <i class="bi bi-info-circle-fill text-primary me-2"></i>
                        <span>លេខសម្ងាត់ត្រូវមានយ៉ាងហោចណាស់ ៨ តួអក្សរ។</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <a href="javascript:void(0)" class="btn-cancel-link" onclick="loadContent('/User/Index', 'User List')">បោះបង់</a>
                        <button type="submit" class="btn btn-save-reset shadow-sm" style="background: #2563eb; color: white; border-radius: 12px; padding: 12px 25px; border: none; font-weight: bold;">
                            <i class="bi bi-check2-circle me-2"></i> រក្សាទុក
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    // Update Avatar Icon based on Selection
    function updateAvatar(select) {
        const option = select.options[select.selectedIndex];
        const initial = option.getAttribute('data-init') || '?';
        document.getElementById('userAvatar').innerText = initial;
    }

    // Toggle Password Visibility
    function toggleView(inputId, icon) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("bi-eye", "bi-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("bi-eye-slash", "bi-eye");
        }
    }

    $(document).ready(function() {
        $("#resetPasswordForm").on("submit", function(e) {
            e.preventDefault();
            const selectedUser = $("#userEmailSelect").val();
            const newPw = $("#newPassword").val();
            const confirmPw = $("#confirmPassword").val();

            if (!selectedUser) {
                Swal.fire({ title: 'សូមជ្រើសរើសគណនី!', icon: 'warning', confirmButtonColor: '#2563eb' });
                return;
            }

            if (newPw.length < 8) {
                Swal.fire({ title: 'ខ្សោយពេក!', text: 'យ៉ាងហោចណាស់ ៨ តួអក្សរ', icon: 'warning', confirmButtonColor: '#2563eb' });
                return;
            }

            if (newPw !== confirmPw) {
                Swal.fire({ title: 'មិនត្រូវគ្នា!', text: 'ការបញ្ជាក់លេខសម្ងាត់មិនត្រឹមត្រូវ', icon: 'error', confirmButtonColor: '#2563eb' });
                return;
            }

            Swal.fire({
                title: 'ជោគជ័យ!',
                text: 'លេខសម្ងាត់សម្រាប់ ' + selectedUser + ' បានប្តូររួចរាល់',
                icon: 'success',
                timer: 2000,
                showConfirmButton: false
            }).then(() => {
                loadContent('/User/Index', 'User List');
            });
        });
    });
</script>