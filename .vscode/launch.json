{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "https://localhost:7123",
            "webRoot": "${workspaceFolder}"
        },          
        {
            "name": "Attach to Chrome",
            "port": 9222,
            "request": "attach",
            "type": "chrome",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Launch Program",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/bin/Debug/net8.0/WebApplication2.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false
        }

    ],
    "compounds": [
        {
            "name": "Launch Web App with Chrome",
            "configurations": ["Launch Program", "Launch Chrome"]
        }
    ]
}